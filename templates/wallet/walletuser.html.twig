{% extends 'base.html.twig' %}

{% block content %}
<div class="clean-dashboard">

    <div class="clean-header">
        <h1>Dashboard</h1>

         <div class="header-actions">
        <a href="{{ path('transactions') }}" class="btn">
            + Transaction
        </a>
         <a href="{{ path('wishlist') }}" class="btn-purple">
            Wishlist
    </a>

        <div class="export-under">
            <a href="{{ path('transactions_pdf') }}" class="btn-outline">PDF</a>
            <a href="{{ path('transactions_excel') }}" class="btn-outline">Excel</a>
        </div>
    </div>
    </div>

    <div class="dash-row">

        <div class="left-side">

            <div class="clean-stats">

    <div>
        <span>Balance</span>
        <h2>{{ balance }} DT</h2>
    </div>

    <div>
        <span>Income</span>
        <h2 class="green">{{ income }} DT</h2>
    </div>

    <div>
        <span>Outcome</span>
        <h2 class="red">{{ outcome }} DT</h2>
    </div>

    <div>
        <span>Transactions</span>
        <h2>{{ transactions|length }}</h2>
    </div>

</div>
<div class="charts-row">

    <div class="chart-box">
        <h3 class="chart-title">Income</h3>
        <canvas id="incomeChart"></canvas>
    </div>

    <div class="chart-box">
        <h3 class="chart-title">Outcome</h3>
        <canvas id="outcomeChart"></canvas>
    </div>

</div>

            

        </div>

       

   <div class="charts-right">
        <div class="chart-box small-chart">
            <h3 class="center-title">RÉPARTITION</h3>
          <canvas id="pieChart" style="max-height:150px;"></canvas> 
        </div>

        <div class="chart-box small-chart">
            <h3 class="center-title">TRANSACTIONS PAR DATE</h3>
            <canvas id="dateChart"></canvas>
        </div>
    </div>

</div>

     

    </div>


    <div class="dash-row">

<div class="chart-box" style="margin-top: 20px; width: 100%;">
  <div style="display:flex; align-items:center; gap:12px; margin-bottom:16px;">
    <h3 style="font-size:15px; font-weight:700; color:var(--text-dark); margin:0;">
      🤖 Analyse IA
    </h3>
    <button id="aiBtn" class="btn-purple" style="margin-left:auto;">Prediction IA</button>
  </div>

  <div id="aiResult">
    <p style="color:var(--text-light); font-size:14px;">
      Click "Prediction IA" to generate your financial analysis.
    </p>
  </div>
</div>

</div>
</div>

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
const transactions = {{ transactions|json_encode|raw }};
</script>

<script>
new Chart(document.getElementById('pieChart'), {
    type: 'doughnut',
    data: {
        labels: ['Income', 'Outcome'],
        datasets: [{
            data: [{{ income }}, {{ outcome }}],
            backgroundColor: ['#2563eb', '#e5e7eb']
        }]
    },
    options: {
        cutout: '70%',  
        radius: '90%',
        plugins: {
            legend: { 
            position: 'bottom' ,
        labels: {
                boxWidth: 15,   // 🔥 أصغر rectangle
                boxHeight: 8,
                padding: 8,

                font: {
                    size: 10   // 🔥 تصغير الكتابة
                },

                color: '#475569' // لون نص خفيف
            }
        }
        }
    }
});

function showIncomeTransactions(label) {

    let filtered = transactions.filter(t => {
        return t.category.nom === label && t.montant > 0;
    });

    updateTable(filtered);
}

function showOutcomeTransactions(label) {

    let filtered = transactions.filter(t => {
        return t.category.nom === label && t.montant < 0;
    });

    updateTable(filtered);
}

function updateTable(data) {

    let table = document.querySelector("table tbody");
    table.innerHTML = "";

    data.forEach(t => {
        table.innerHTML += `
            <tr>
                <td>${t.nomTransaction}</td>
                <td>${t.type}</td>
                <td>${t.montant} DT</td>
                <td>${t.category.nom}</td>
                <td>${t.dateTransaction}</td>
            </tr>
        `;
    });
}
// INCOME
new Chart(document.getElementById('incomeChart'), {
    type: 'line',
    data: {
        labels: {{ incomeChartLabels|json_encode|raw }},
        datasets: [{
            data: {{ incomeChartData|json_encode|raw }},
            borderColor: '#2563eb',
            backgroundColor: 'rgba(37,99,235,0.15)',
            fill: true,
            pointBackgroundColor: '#2563eb',
            borderWidth: 2,
            pointRadius: 2,
            tension: 0.4 
        }]
    },
    
    options: {
        plugins: { legend: { display: false } },
    onClick: function(evt, elements) {
        if (elements.length > 0) {
            let index = elements[0].index;
            let label = this.data.labels[index];

            showIncomeTransactions(label);
        }
    }
}
});


// OUTCOME
new Chart(document.getElementById('outcomeChart'), {
    type: 'line',
    data: {
        labels: {{ outcomeChartLabels|json_encode|raw }},
        datasets: [{
            data: {{ outcomeChartData|json_encode|raw }},
            borderColor: '#7c3aed',
            backgroundColor: 'rgba(124,58,237,0.15)',
            fill: true,
            pointBackgroundColor: '#7c3aed',
            borderWidth: 2,
            pointRadius: 2,
            tension: 0.4
        }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
        legend: { display: false }
    },
    scales: {
        x: {
            grid: { display: false },
            ticks: {
                color: '#999',
                font: { size: 11 }
            }
        },
        y: {
            grid: {
                color: '#eee'
            },
            ticks: {
                color: '#999',
                font: { size: 11 }
            }
        }
    },

    onClick: function(evt, elements) {
        if (elements.length > 0) {
            let index = elements[0].index;
            let label = this.data.labels[index];

            showOutcomeTransactions(label);
        }
    }
}
});

new Chart(document.getElementById('dateChart'), {
    type: 'bar',
    data: {
        labels: {{ chartLabels|json_encode|raw }},
        datasets: [
            {
                label: 'Income',
                data: {{ incomeData|json_encode|raw }},
                backgroundColor: '#2563eb' 
            },
            {
                label: 'Outcome',
                data: {{ outcomeData|json_encode|raw }},
                backgroundColor: '#c7d2fe' 
            }
        ]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,

        plugins: {
            legend: {
                position: 'top'
            }
        },

        scales: {
            x: {
                stacked: true,
                grid: { display: false }
            },
            y: {
                stacked: true,
                grid: { color: '#eee' }
            }
        }
    }
});
document.getElementById("aiBtn").addEventListener("click", function () {
  fetch(`/ai/analyse-data?income={{ income }}&expenses={{ outcome }}`)
    .then(res => res.json())
    .then(data => {
      document.getElementById("aiResult").innerHTML = `
        <div style="
  display: grid;
  grid-template-columns: repeat(4, minmax(0,1fr));
  gap: 12px;
  width: 100%;
">
          <div style="background:#f8faff; border-radius:12px; padding:16px; display:flex; flex-direction:column; gap:6px;">
            <span style="font-size:11px; font-weight:600; color:var(--text-light); text-transform:uppercase; letter-spacing:0.08em;">Balance</span>
            <strong style="font-family:'IBM Plex Mono',monospace; font-size:16px; color:var(--text-dark);">${data.balance} DT</strong>
          </div>

          <div style="background:#f8faff; border-radius:12px; padding:16px; display:flex; flex-direction:column; gap:6px;">
            <span style="font-size:11px; font-weight:600; color:var(--text-light); text-transform:uppercase; letter-spacing:0.08em;">Ratio</span>
            <strong style="font-family:'IBM Plex Mono',monospace; font-size:16px; color:var(--text-dark);">${data.ratio.toFixed(2)}%</strong>
          </div>

          <div style="background:#f8faff; border-radius:12px; padding:16px; display:flex; flex-direction:column; gap:6px;">
            <span style="font-size:11px; font-weight:600; color:var(--text-light); text-transform:uppercase; letter-spacing:0.08em;">Risk</span>
            <strong class="risk ${data.risk.toLowerCase()}" style="font-size:16px;">${data.risk}</strong>
          </div>

          <div style="background:#f8faff; border-radius:12px; padding:16px; display:flex; flex-direction:column; gap:6px;">
            <span style="font-size:11px; font-weight:600; color:var(--text-light); text-transform:uppercase; letter-spacing:0.08em;">Next expenses</span>
            <strong style="font-family:'IBM Plex Mono',monospace; font-size:16px; color:var(--text-dark);">${data.predictedExpenses.toFixed(2)} DT</strong>
          </div>
        </div>

        <div style="
  grid-column: span 4;
  background:#f8faff;
  border-radius:12px;
  padding:16px;
">
          <p style="font-size:13px; font-weight:700; color:var(--text-dark); margin:0 0 10px;">
            💡 Recommendations
          </p>
          <ul style="margin:0; padding-left:18px;">
            ${data.recommendation.map(r => `
              <li style="font-size:13px; color:var(--text-mid); margin-bottom:6px;">${r}</li>
            `).join("")}
          </ul>
        </div>
      `;
    });
});
</script>
{% endblock %}

{% endblock %}