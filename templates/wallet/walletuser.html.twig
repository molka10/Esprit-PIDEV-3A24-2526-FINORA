{% extends 'base.html.twig' %}

{% block stylesheets %}
<style>
    :root {
        --p: #7c3aed;
        --p-light: #ede9fe;
        --success: #22c55e;
        --danger: #ef4444;
        --warning: #f59e0b;
        --text-dark: #1e1b4b;
        --text-muted: #64748b;
        --bg-subtle: #f8fafc;
        --card-shadow: 0 10px 25px -5px rgba(124, 58, 237, 0.1);
    }

    .clean-dashboard {
        padding: 30px;
        background: #fdfaff;
        min-height: 100vh;
        font-family: 'Inter', sans-serif;
    }

    .clean-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .clean-header h1 {
        font-size: 28px;
        font-weight: 800;
        color: var(--text-dark);
        margin: 0;
    }

    .btn-outline {
        padding: 8px 16px;
        border: 1px solid var(--p);
        border-radius: 10px;
        color: var(--p);
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
        background: white;
    }

    .btn-outline:hover {
        background: var(--p);
        color: white;
    }

    /* ── Stats Grid ── */
    .clean-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        padding: 24px;
        border-radius: 20px;
        box-shadow: var(--card-shadow);
        border: 1px solid rgba(124, 58, 237, 0.05);
        display: flex;
        flex-direction: column;
        gap: 8px;
        position: relative;
        overflow: hidden;
    }

    .stat-card::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        background: var(--p);
    }

    .stat-card.green::after { background: var(--success); }
    .stat-card.red::after { background: var(--danger); }
    .stat-card.blue::after { background: #3b82f6; }

    .stat-card span {
        font-size: 13px;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .stat-card h2 {
        font-size: 24px;
        font-weight: 800;
        color: var(--text-dark);
        margin: 0;
    }

    .stat-card.green h2 { color: var(--success); }
    .stat-card.red h2 { color: var(--danger); }

    /* ── Insights Section ── */
    .insights-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .insight-card {
        background: white;
        padding: 20px;
        border-radius: 20px;
        border: 1px solid var(--p-light);
        display: flex;
        align-items: center;
        gap: 15px;
        transition: transform 0.2s;
    }

    .insight-card:hover {
        transform: translateY(-5px);
    }

    .insight-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

    .bg-p { background: var(--p-light); color: var(--p); }
    .bg-g { background: #dcfce7; color: var(--success); }
    .bg-r { background: #fee2e2; color: var(--danger); }
    .bg-o { background: #fef3c7; color: var(--warning); }

    .insight-content h4 {
        margin: 0;
        font-size: 12px;
        color: var(--text-muted);
        font-weight: 600;
        text-transform: uppercase;
    }

    .insight-content p {
        margin: 2px 0 0;
        font-size: 16px;
        font-weight: 700;
        color: var(--text-dark);
    }

    .insight-trend {
        font-size: 11px;
        margin-top: 4px;
    }

    /* ── Charts Layout ── */
    .dashboard-main-row {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 25px;
        margin-bottom: 30px;
    }

    .chart-container-card {
        background: white;
        padding: 25px;
        border-radius: 24px;
        box-shadow: var(--card-shadow);
        border: 1px solid rgba(124, 58, 237, 0.05);
    }

    .chart-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .chart-header h3 {
        font-size: 16px;
        font-weight: 800;
        color: var(--text-dark);
        margin: 0;
    }

    @media (max-width: 1024px) {
        .dashboard-main-row {
            grid-template-columns: 1fr;
        }
    }
</style>
{% endblock %}

{% block content %}
<div class="clean-dashboard">

    <div class="clean-header">
        <h1>Mon Portefeuille</h1>
        <div class="header-actions">
            <div class="d-flex align-items-center" style="gap: 12px;">
                <!-- Notification Dropdown -->
                <div class="dropdown">
                    <a class="btn-outline position-relative" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="bi bi-bell"></i>
                        <span id="notif-badge" class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle d-none"></span>
                    </a>
                    <div class="dropdown-menu dropdown-menu-end shadow-lg border-0 p-0" style="min-width: 320px;">
                        <div class="card bg-transparent border-0">
                            <div class="card-header bg-transparent border-bottom p-3 d-flex justify-content-between align-items-center">
                                <h6 class="m-0 fw-bold">Notifications <span id="notif-count" class="badge bg-danger ms-1">0</span></h6>
                            </div>
                            <div class="card-body p-0">
                                <ul class="list-group list-group-flush" id="notif-list">
                                    <li class="list-group-item p-3 text-center text-muted small">Chargement...</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
                <a href="{{ path('transactions_pdf') }}" class="btn-outline"><i class="bi bi-file-pdf"></i> PDF</a>
                <a href="{{ path('transactions_excel') }}" class="btn-outline"><i class="bi bi-file-excel"></i> Excel</a>
            </div>
        </div>
    </div>

    <!-- Currency Selection -->
    <div style="margin-bottom: 25px; display: flex; gap: 10px;">
        {% for c in ['DT', 'EUR', 'USD'] %}
            <a href="?currency={{ c }}" class="btn-outline" style="border-radius: 12px; font-size: 13px; {{ currencySymbol == c ? 'background:var(--p); color:white;' : '' }}">
                {{ c }}
            </a>
        {% endfor %}
    </div>

    <!-- Key Stats -->
    <div class="clean-stats">
        <div class="stat-card blue">
            <span>Solde Actuel</span>
            <h2>{{ balance }} {{ currencySymbol }}</h2>
        </div>
        <div class="stat-card green">
            <span>Total Revenus</span>
            <h2>+ {{ income }} {{ currencySymbol }}</h2>
        </div>
        <div class="stat-card red">
            <span>Total Dépenses</span>
            <h2>- {{ outcome }} {{ currencySymbol }}</h2>
        </div>
        <div class="stat-card">
            <span>Transactions</span>
            <h2>{{ transactions|length }}</h2>
        </div>
    </div>

    <!-- Métier Insights Section -->
    <div class="insights-grid">
      

        <div class="insight-card">
            <div class="insight-icon bg-r"><i class="bi bi-cart-x"></i></div>
            <div class="insight-content">
                <h4>Top Dépense</h4>
                <p>{{ topSpendingCat }}</p>
                <div class="insight-trend text-muted">
                    {{ topSpendingAmt }} {{ currencySymbol }} cumulés
                </div>
            </div>
        </div>

        

        
    </div>

    <!-- Main Charts Row -->
    <div class="dashboard-main-row">
        <!-- Big Chart: Timeline -->
        <div class="chart-container-card">
            <div class="chart-header">
                <h3>Évolution des Flux</h3>
                <div class="badge bg-light text-dark p-2 border">Quotidien</div>
            </div>
            <div style="height: 350px;">
                <canvas id="mainFlowChart"></canvas>
            </div>
        </div>

        <!-- Right Side: Distribution -->
        <div class="chart-container-card">
            <div class="chart-header">
                <h3>Répartition Globale</h3>
            </div>
            <div style="height: 250px; position: relative;">
                <canvas id="globalDonut"></canvas>
            </div>
            <div class="mt-4 p-3 rounded bg-light border-start border-4 border-primary">
                <span class="small text-muted d-block">Plus grosse transaction</span>
                {% if biggestTx %}
                    <strong class="text-dark">{{ biggestTx.nomTransaction }}</strong>
                    <span class="float-end text-danger fw-bold">-{{ biggestAmt }} {{ currencySymbol }}</span>
                {% else %}
                    <span class="text-muted">–</span>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Secondary Charts Row -->
    <div class="dashboard-main-row" style="grid-template-columns: 1fr 1fr;">
        <div class="chart-container-card">
            <div class="chart-header">
                <h3>Dépenses par Catégorie</h3>
            </div>
            <div style="height: 300px;">
                <canvas id="categoryOutcomeChart"></canvas>
            </div>
        </div>
        <div class="chart-container-card">
            <div class="chart-header">
                <h3>Revenus par Catégorie</h3>
            </div>
            <div style="height: 300px;">
                <canvas id="categoryIncomeChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Premium AI Insight Call-to-Action -->
    <div class="mt-5 mb-5 px-1">
        <a href="{{ path('ai_analyse') }}" class="ai-premium-card">
            <div class="ai-card-content">
                <div class="ai-robot-wrapper">
                    <div class="ai-glow-orbit"></div>
                    <span class="ai-robot-icon">🤖</span>
                </div>
                <div class="ai-text-group">
                    <div class="ai-badge">FUTURISTE</div>
                    <h3 class="ai-title">Analyse Financière Prédictive</h3>
                    <p class="ai-description">Laissez notre intelligence artificielle scanner vos transactions pour identifier des opportunités d'épargne cachées et optimiser votre budget.</p>
                </div>
            </div>
            <div class="ai-action-area">
                <div class="ai-link-btn">
                    <span>Explorer l'IA</span>
                    <i class="bi bi-stars"></i>
                </div>
            </div>
        </a>
    </div>

<style>
    .ai-premium-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: linear-gradient(135deg, #1e1b4b 0%, #4338ca 100%);
        padding: 30px 40px;
        border-radius: 28px;
        color: white;
        text-decoration: none;
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 25px 50px -12px rgba(67, 56, 202, 0.4);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .ai-premium-card::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 60%);
        pointer-events: none;
    }

    .ai-premium-card:hover {
        transform: translateY(-8px) scale(1.01);
        box-shadow: 0 35px 60px -12px rgba(99, 102, 241, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .ai-card-content {
        display: flex;
        align-items: center;
        gap: 30px;
        z-index: 2;
    }

    .ai-robot-wrapper {
        position: relative;
        width: 80px;
        height: 80px;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border-radius: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 34px;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .ai-glow-orbit {
        position: absolute;
        width: 100%;
        height: 100%;
        border-radius: 22px;
        border: 2px solid #818cf8;
        opacity: 0.5;
        animation: ai-pulse 2s infinite ease-out;
    }

    @keyframes ai-pulse {
        0% { transform: scale(1); opacity: 0.6; }
        100% { transform: scale(1.4); opacity: 0; }
    }

    .ai-text-group {
        max-width: 500px;
    }

    .ai-badge {
        display: inline-block;
        background: rgba(129, 140, 248, 0.2);
        color: #c7d2fe;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 1.5px;
        padding: 4px 10px;
        border-radius: 6px;
        margin-bottom: 10px;
        border: 1px solid rgba(129, 140, 248, 0.3);
    }

    .ai-title {
        font-size: 24px;
        font-weight: 800;
        margin: 0 0 8px;
        background: linear-gradient(to right, #fff, #c7d2fe);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .ai-description {
        margin: 0;
        font-size: 14px;
        color: rgba(255, 255, 255, 0.7);
        line-height: 1.5;
    }

    .ai-action-area {
        z-index: 2;
    }

    .ai-link-btn {
        background: white;
        color: #4338ca;
        padding: 14px 28px;
        border-radius: 100px;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        transition: all 0.3s;
    }

    .ai-premium-card:hover .ai-link-btn {
        background: #818cf8;
        color: white;
        box-shadow: 0 15px 25px rgba(0,0,0,0.2);
    }

    @media (max-width: 768px) {
        .ai-premium-card {
            flex-direction: column;
            text-align: center;
            padding: 40px 20px;
        }
        .ai-card-content {
            flex-direction: column;
            gap: 20px;
        }
        .ai-action-area {
            margin-top: 30px;
        }
    }
</style>

</div>

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // General Config
    Chart.defaults.font.family = "'Inter', sans-serif";
    Chart.defaults.color = '#64748b';

    // Data from Backend
    const mainLabels = {{ chartLabels|json_encode|raw }};
    const incomeSeries = {{ incomeData|json_encode|raw }};
    const outcomeSeries = {{ outcomeData|json_encode|raw }};
    
    const catLabelsOut = {{ outcomeChartLabels|json_encode|raw }};
    const catDataOut = {{ outcomeChartData|json_encode|raw }};
    
    const catLabelsInc = {{ incomeChartLabels|json_encode|raw }};
    const catDataInc = {{ incomeChartData|json_encode|raw }};

    // 1. Main Flow Chart (Area Chart)
    new Chart(document.getElementById('mainFlowChart'), {
        type: 'line',
        data: {
            labels: mainLabels,
            datasets: [
                {
                    label: 'Revenus',
                    data: incomeSeries,
                    borderColor: '#22c55e',
                    backgroundColor: 'rgba(34, 197, 94, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointHoverRadius: 6
                },
                {
                    label: 'Dépenses',
                    data: outcomeSeries,
                    borderColor: '#ef4444',
                    backgroundColor: 'rgba(239, 68, 68, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointHoverRadius: 6
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'top', labels: { usePointStyle: true, padding: 20 } }
            },
            scales: {
                y: { grid: { color: '#f1f5f9' }, border: { display: false } },
                x: { grid: { display: false } }
            }
        }
    });

    // 2. Global Donut
    new Chart(document.getElementById('globalDonut'), {
        type: 'doughnut',
        data: {
            labels: ['Revenus', 'Dépenses'],
            datasets: [{
                data: [{{ income }}, {{ outcome }}],
                backgroundColor: ['#22c55e', '#ef4444'],
                borderWidth: 0,
                hoverOffset: 15
            }]
        },
        options: {
            cutout: '75%',
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true } }
            }
        }
    });

    // 3. Category Outcome Chart (Horizontal Bar)
    new Chart(document.getElementById('categoryOutcomeChart'), {
        type: 'bar',
        data: {
            labels: catLabelsOut,
            datasets: [{
                label: 'Dépenses par catégorie',
                data: catDataOut,
                backgroundColor: '#7c3aed',
                borderRadius: 8
            }]
        },
        options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { color: '#f1f5f9' } },
                y: { grid: { display: false } }
            }
        }
    });

    // 4. Category Income Chart (Radial Bar style via Radar or stick to Bar)
    new Chart(document.getElementById('categoryIncomeChart'), {
        type: 'bar',
        data: {
            labels: catLabelsInc,
            datasets: [{
                label: 'Revenus par catégorie',
                data: catDataInc,
                backgroundColor: '#22c55e',
                borderRadius: 8
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { grid: { color: '#f1f5f9' } },
                x: { grid: { display: false } }
            }
        }
    });

</script>
{% endblock %}
{% endblock %}