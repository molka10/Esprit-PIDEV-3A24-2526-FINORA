{% extends 'base.html.twig' %}

{% block content %}
<div class="clean-dashboard">

    <div class="clean-header">
        <h1>Tableau de Bord</h1>

         <div class="header-actions">
        <div class="export-under d-flex align-items-center" style="gap: 12px;">
            <!-- Notification Button -->
            <div class="dropdown" style="display: inline-block;">
                <a class="btn-outline position-relative d-flex align-items-center justify-content-center bg-white" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside" style="padding: 6px 12px; margin-right: 10px;">
                    <i class="bi bi-bell fa-fw m-0" style="font-size: 1.1rem; color: #7c3aed;"></i>
                    <span id="notif-badge" class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle d-none">
                        <span class="visually-hidden">Nouvelles alertes</span>
                    </span>
                </a>
                
                <div class="dropdown-menu dropdown-animation dropdown-menu-end p-0 shadow-lg border-0" style="min-width: 320px; z-index: 1050;">
                    <div class="card bg-transparent border-0">
                        <div class="card-header bg-transparent border-bottom p-3 d-flex justify-content-between align-items-center">
                            <h6 class="m-0 fw-bold" style="color:var(--text-dark);">Notifications <span id="notif-count" class="badge text-danger" style="background:#fee2e2; border-radius:5px; margin-left:5px;">0</span></h6>
                        </div>
                        <div class="card-body p-0">
                            <ul class="list-group list-unstyled list-group-flush m-0" id="notif-list">
                                <li class="list-group-item p-3 text-center text-muted small border-0" style="color:var(--text-light);">Chargement...</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <a href="{{ path('transactions_pdf') }}" class="btn-outline">PDF</a>
            <a href="{{ path('transactions_excel') }}" class="btn-outline">Excel</a>
        </div>
    </div>
    </div>

    <div class="dash-row">

        <div class="left-side">

<div class="currency-buttons" style="margin-bottom: 20px; display: flex; gap: 10px;">
    <a href="?currency=DT" class="btn-outline" style="text-decoration:none; padding:5px 15px; border:1px solid #ccc; border-radius:5px; color:{{ currencySymbol == 'DT' ? '#fff' : '#333' }}; background:{{ currencySymbol == 'DT' ? '#2563eb' : 'transparent' }};">DT</a>
    <a href="?currency=EUR" class="btn-outline" style="text-decoration:none; padding:5px 15px; border:1px solid #ccc; border-radius:5px; color:{{ currencySymbol == 'EUR' ? '#fff' : '#333' }}; background:{{ currencySymbol == 'EUR' ? '#2563eb' : 'transparent' }};">EUR</a>
    <a href="?currency=USD" class="btn-outline" style="text-decoration:none; padding:5px 15px; border:1px solid #ccc; border-radius:5px; color:{{ currencySymbol == 'USD' ? '#fff' : '#333' }}; background:{{ currencySymbol == 'USD' ? '#2563eb' : 'transparent' }};">USD</a>
</div>

            <div class="clean-stats">

    <div>
        <span>Solde</span>
        <h2>{{ balance }} {{ currencySymbol }}</h2>
    </div>

    <div>
        <span>Revenus</span>
        <h2 class="green">{{ income }} {{ currencySymbol }}</h2>
    </div>

    <div>
        <span>Dépenses</span>
        <h2 class="red">{{ outcome }} {{ currencySymbol }}</h2>
    </div>

    <div>
        <span>Transactions</span>
        <h2>{{ transactions|length }}</h2>
    </div>

</div>
<div class="charts-row">

    <div class="chart-box">
        <h3 class="chart-title">Revenus</h3>
        <canvas id="incomeChart"></canvas>
    </div>

    <div class="chart-box">
        <h3 class="chart-title">Dépenses</h3>
        <canvas id="outcomeChart"></canvas>
    </div>

</div>

            

        </div>

       

   <div class="charts-right">
        <div class="chart-box small-chart">
            <h3 class="center-title">RÉPARTITION</h3>
          <canvas id="pieChart" style="max-height:150px;"></canvas> 
        </div>

        <div class="chart-box small-chart">
            <h3 class="center-title">TRANSACTIONS PAR DATE</h3>
            <canvas id="dateChart"></canvas>
        </div>
    </div>

</div>

     

    </div>


    <div style="margin-top: 10px; margin-bottom: 30px; display: flex; justify-content: center; width: 100%; position: relative; z-index: 10;">
  <a href="{{ path('ai_analyse') }}" style="
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(135deg, #7c3aed, #4f46e5);
    padding: 16px 24px;
    border-radius: 16px;
    color: white;
    text-decoration: none;
    box-shadow: 0 10px 15px -3px rgba(124, 58, 237, 0.4);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
    max-width: 650px;
    gap: 20px;
  ">
    <div style="display: flex; flex-direction: column; gap: 4px;">
        <h3 style="font-size:20px; font-weight:800; margin:0; color: white;">
            🤖 Analyse IA Financière
        </h3>
        <p style="margin: 0; font-size: 14px; color: rgba(255,255,255,0.8);">
            Découvrez nos recommandations intelligentes.
        </p>
    </div>
    <div style="
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(10px);
        padding: 10px 20px;
        border-radius: 10px;
        font-weight: bold;
        display: flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
    ">
        Accéder <i class="bi bi-arrow-right"></i>
    </div>
  </a>
</div>
</div>

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
const transactions = {{ transactions|json_encode|raw }};
const currencySymbol = '{{ currencySymbol }}';
const exchangeRate = {{ rate }};
</script>

<script>
new Chart(document.getElementById('pieChart'), {
    type: 'doughnut',
    data: {
        labels: ['Revenus', 'Dépenses'],
        datasets: [{
            data: [{{ income }}, {{ outcome }}],
            backgroundColor: ['#2563eb', '#e5e7eb']
        }]
    },
    options: {
        cutout: '70%',  
        radius: '90%',
        plugins: {
            legend: { 
            position: 'bottom' ,
        labels: {
                boxWidth: 15,   // 🔥 أصغر rectangle
                boxHeight: 8,
                padding: 8,

                font: {
                    size: 10   // 🔥 تصغير الكتابة
                },

                color: '#475569' // لون نص خفيف
            }
        }
        }
    }
});

function showIncomeTransactions(label) {

    let filtered = transactions.filter(t => {
        return t.category.nom === label && t.montant > 0;
    });

    updateTable(filtered);
}

function showOutcomeTransactions(label) {

    let filtered = transactions.filter(t => {
        return t.category.nom === label && t.montant < 0;
    });

    updateTable(filtered);
}

function updateTable(data) {

    let table = document.querySelector("table tbody");
    table.innerHTML = "";

    data.forEach(t => {
        let amount = (t.montant * exchangeRate).toFixed(2);
        table.innerHTML += `
            <tr>
                <td>${t.nomTransaction}</td>
                <td>${t.type}</td>
                <td>${amount} ${currencySymbol}</td>
                <td>${t.category.nom}</td>
                <td>${t.dateTransaction}</td>
            </tr>
        `;
    });
}
// INCOME
new Chart(document.getElementById('incomeChart'), {
    type: 'line',
    data: {
        labels: {{ incomeChartLabels|json_encode|raw }},
        datasets: [{
            data: {{ incomeChartData|json_encode|raw }},
            borderColor: '#2563eb',
            backgroundColor: 'rgba(37,99,235,0.15)',
            fill: true,
            pointBackgroundColor: '#2563eb',
            borderWidth: 2,
            pointRadius: 2,
            tension: 0.4 
        }]
    },
    
    options: {
        plugins: { legend: { display: false } },
    onClick: function(evt, elements) {
        if (elements.length > 0) {
            let index = elements[0].index;
            let label = this.data.labels[index];

            showIncomeTransactions(label);
        }
    }
}
});


// OUTCOME
new Chart(document.getElementById('outcomeChart'), {
    type: 'line',
    data: {
        labels: {{ outcomeChartLabels|json_encode|raw }},
        datasets: [{
            data: {{ outcomeChartData|json_encode|raw }},
            borderColor: '#7c3aed',
            backgroundColor: 'rgba(124,58,237,0.15)',
            fill: true,
            pointBackgroundColor: '#7c3aed',
            borderWidth: 2,
            pointRadius: 2,
            tension: 0.4
        }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
        legend: { display: false }
    },
    scales: {
        x: {
            grid: { display: false },
            ticks: {
                color: '#999',
                font: { size: 11 }
            }
        },
        y: {
            grid: {
                color: '#eee'
            },
            ticks: {
                color: '#999',
                font: { size: 11 }
            }
        }
    },

    onClick: function(evt, elements) {
        if (elements.length > 0) {
            let index = elements[0].index;
            let label = this.data.labels[index];

            showOutcomeTransactions(label);
        }
    }
}
});

new Chart(document.getElementById('dateChart'), {
    type: 'bar',
    data: {
        labels: {{ chartLabels|json_encode|raw }},
        datasets: [
            {
                label: 'Revenus',
                data: {{ incomeData|json_encode|raw }},
                backgroundColor: '#2563eb' 
            },
            {
                label: 'Dépenses',
                data: {{ outcomeData|json_encode|raw }},
                backgroundColor: '#c7d2fe' 
            }
        ]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,

        plugins: {
            legend: {
                position: 'top'
            }
        },

        scales: {
            x: {
                stacked: true,
                grid: { display: false }
            },
            y: {
                stacked: true,
                grid: { color: '#eee' }
            }
        }
    }
});

</script>
{% endblock %}

{% endblock %}