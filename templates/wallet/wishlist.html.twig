{% extends 'base.html.twig' %}

{% block title %}Wishlist — Finora{% endblock %}

{% block stylesheets %}
<style>
/* ===== VARIABLES ===== */
{% set pct = (goal > 0 and balance > 0) ? min((balance / goal) * 100, 100) : 0 %}
{% set remain = (goal > 0) ? max(goal - balance, 0) : null %}
{% set sorted = wishlist %}
{% set maxPrice = sorted is not empty ? sorted[0].getPrice() : 1 %}
{% set need = max(total - balance, 0) %}

/* ===== LAYOUT ===== */
.wl-page {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 24px;
    align-items: start;
}

@media (max-width: 992px) { .wl-page { grid-template-columns: 1fr; } }

/* ===== EDU CARD ===== */
.edu-card {
    background: #fff;
    border-radius: 24px;
    padding: 28px;
    box-shadow: 0 10px 40px -10px rgba(124, 58, 237, 0.12);
    border: 1px solid rgba(124, 58, 237, 0.05);
    margin-bottom: 24px;
}

.edu-card:last-child { margin-bottom: 0; }

.edu-card-title {
    font-family: 'Heebo', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #1e1b4b;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
}

.edu-card-title .title-icon {
    width: 38px;
    height: 38px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: .95rem;
    box-shadow: 0 4px 10px rgba(124, 58, 237, 0.2);
}

.icon-blue   { background: linear-gradient(135deg, #7c3aed, #8b5cf6); }
.icon-orange { background: linear-gradient(135deg, #8b5cf6, #a78bfa); }
.icon-green  { background: linear-gradient(135deg, #6d28d9, #7c3aed); }
.icon-purple { background: linear-gradient(135deg, #5b21b6, #6d28d9); }
.icon-teal   { background: linear-gradient(135deg, #c4b5fd, #ddd6fe); color: #5b21b6 !important; }

/* ===== BACK BUTTON ===== */
.btn-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #f5f3ff;
    color: #6d28d9;
    padding: 8px 16px;
    border-radius: 50px;
    font-size: .85rem;
    font-weight: 600;
    text-decoration: none;
    margin-bottom: 20px;
    transition: background .2s, color .2s;
}
.btn-back:hover { background: #ede9fe; color: #5b21b6; }

/* ===== ADD FORM ===== */
.wl-add-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 22px;
}

.wl-add-form input {
    padding: 12px 16px;
    border: 1.5px solid #ede9fe;
    border-radius: 14px;
    font-size: .9rem;
    background: #fcfaff;
    color: #1e1b4b;
    outline: none;
    transition: border-color .2s, box-shadow .2s;
    width: 100%;
}

.wl-add-form input:focus {
    border-color: #8b5cf6;
    box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.15);
    background: #fff;
}

.btn-add {
    background: linear-gradient(135deg, #7c3aed, #8b5cf6);
    box-shadow: 0 4px 12px rgba(124, 58, 237, 0.25);
    color: #fff;
    border: none;
    padding: 12px;
    border-radius: 14px;
    font-size: .95rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity .2s, transform .15s, box-shadow .2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
}

.btn-add:hover { opacity: .9; transform: translateY(-1px); box-shadow: 0 6px 16px rgba(124, 58, 237, 0.35); }

/* ===== WISHLIST ITEMS ===== */
.wl-items {
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-height: 280px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: #ede9fe transparent;
}

.wl-row {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #fcfaff;
    padding: 14px 16px;
    border-radius: 16px;
    border: 1px solid #f3efff;
    transition: background .2s, border-color .2s, transform .2s;
}

.wl-row:hover { background: #f5f3ff; border-color: #ede9fe; transform: translateX(2px); }

.wl-row .wl-name {
    flex: 1;
    font-weight: 600;
    color: #1e1b4b;
    font-size: .9rem;
}

.wl-row .wl-price {
    font-weight: 700;
    color: #7c3aed;
    font-size: .9rem;
    white-space: nowrap;
}

.wl-row .wl-delete {
    width: 32px;
    height: 32px;
    border-radius: 10px;
    background: #fee2e2;
    color: #ef4444;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-size: .85rem;
    transition: background .2s, color .2s;
    flex-shrink: 0;
}

.wl-row .wl-delete:hover { background: #fca5a5; color: #b91c1c; }

/* Total bar */
.wl-total-bar {
    margin-top: 18px;
    padding: 16px 20px;
    background: linear-gradient(135deg, #1e1b4b, #312e81);
    border-radius: 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 4px 15px rgba(30, 27, 75, 0.15);
}

.wl-total-bar span { color: rgba(255,255,255,.8); font-size: .9rem; font-weight: 500; }
.wl-total-bar strong { color: #fff; font-size: 1.25rem; font-family: 'Heebo', sans-serif; }

/* ===== RIGHT GRID ===== */
.wl-right {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
}

@media (max-width: 768px) { .wl-right { grid-template-columns: 1fr; } }

/* ===== GOAL CARD ===== */
.goal-stats {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 20px;
}

.goal-stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    background: #fcfaff;
    border: 1px solid #f3efff;
    border-radius: 14px;
    font-size: .9rem;
}

.goal-stat-row span { color: #6b7280; font-weight: 500; }
.goal-stat-row strong { color: #1e1b4b; font-weight: 700; }

.goal-form {
    display: flex;
    gap: 10px;
    margin-top: 16px;
}

.goal-form input {
    flex: 1;
    padding: 10px 14px;
    border: 1.5px solid #ede9fe;
    border-radius: 12px;
    font-size: .9rem;
    background: #fcfaff;
    outline: none;
    transition: border-color .2s;
}

.goal-form input:focus { border-color: #8b5cf6; background: #fff; }

.goal-form button {
    background: linear-gradient(135deg, #8b5cf6, #a78bfa);
    box-shadow: 0 4px 12px rgba(139, 92, 246, 0.25);
    color: #fff;
    border: none;
    padding: 10px 18px;
    border-radius: 12px;
    font-size: .9rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity .2s, transform .15s;
}
.goal-form button:hover { opacity: .9; transform: translateY(-1px); }

/* Progress bar */
.wl-progress-wrap {
    margin-top: 18px;
}

.wl-progress-wrap label {
    font-size: .8rem;
    color: #6b7280;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .05em;
    margin-bottom: 8px;
    display: block;
}

.wl-progress {
    height: 10px;
    background: #f3efff;
    border-radius: 10px;
    overflow: hidden;
}

.wl-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #7c3aed, #8b5cf6);
    border-radius: 10px;
    transition: width .6s ease;
}

/* ===== MONTHS PLAN ===== */
.months-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 18px;
}

.btn-month {
    padding: 10px 4px;
    border: 1.5px solid #ede9fe;
    background: #fcfaff;
    border-radius: 12px;
    font-size: .85rem;
    font-weight: 600;
    color: #4b5563;
    cursor: pointer;
    transition: all .2s;
}

.btn-month:hover {
    border-color: #8b5cf6;
    background: #f5f3ff;
    color: #7c3aed;
    box-shadow: 0 2px 8px rgba(124, 58, 237, 0.1);
}

.monthly-result {
    text-align: center;
    font-size: 1.3rem;
    font-weight: 700;
    color: #7c3aed;
    font-family: 'Heebo', sans-serif;
    padding: 12px;
    background: #f5f3ff;
    border-radius: 14px;
    border: 1px solid #ede9fe;
}

/* ===== CHART ===== */
.chart-wrap {
    position: relative;
    height: 180px;
}

/* ===== PRIORITY ===== */
.priority-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.p-item .p-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
    font-size: .9rem;
}

.p-item .p-name {
    font-weight: 600;
    color: #1e1b4b;
}

.p-item .p-price {
    font-weight: 700;
    color: #7c3aed;
}

.p-bar {
    height: 8px;
    background: #f3efff;
    border-radius: 10px;
    overflow: hidden;
}

.p-fill {
    height: 100%;
    background: linear-gradient(90deg, #7c3aed, #8b5cf6);
    border-radius: 10px;
    transition: width .6s ease;
}
</style>
{% endblock %}

{% block content %}

{# Variables Twig — logique inchangée #}
{# Variables Twig — logique inchangée #}
{% set pct     = (goal > 0 and balance > 0) ? min((balance / goal) * 100, 100) : 0 %}
{% set remain  = (goal > 0) ? max(goal - balance, 0) : null %}
{% set sorted  = wishlist %}
{% set maxPrice = sorted is not empty ? sorted[0].getPrice() : 1 %}
{% set need    = max(total - balance, 0) %}

<div class="wl-page">

    <!-- ===== LEFT ===== -->
    <div class="wl-left">
        <div class="edu-card">

            <a href="{{ path('dashboard') }}" class="btn-back">
                <i class="bi bi-arrow-left"></i> Dashboard
            </a>

            <div class="edu-card-title">
                <div class="title-icon icon-blue"><i class="bi bi-cart3"></i></div>
                Ma Wishlist
            </div>

            <!-- ADD FORM -->
            <form method="post" action="{{ path('wishlist') }}" class="wl-add-form">
                <input type="text" name="name" placeholder="Nom du produit..." required>
                <input type="number" name="price" placeholder="Montant (DT)" required>
                <button type="submit" class="btn-add">
                    <i class="bi bi-plus-lg"></i> Ajouter
                </button>
            </form>

            <!-- ITEMS LIST -->
            <div class="wl-items">
                {% for item in wishlist %}
                    {% set pred = predictions[item.getId()] %}
                    <div class="wl-row">
                        <div class="wl-name">
                            {{ item.getName() }}
                            {% if pred.can_afford %}
                                <span class="badge bg-success ms-2 rounded-pill"><i class="bi bi-check-circle me-1"></i>Affordable</span>
                            {% else %}
                                <span class="badge bg-warning text-dark ms-2 rounded-pill"><i class="bi bi-exclamation-circle me-1"></i>Need {{ pred.remaining_needed|number_format(0) }} DT</span>
                            {% endif %}
                        </div>
                        <span class="wl-price">{{ item.getPrice() }} DT</span>
                        <a href="{{ path('wishlist_delete', {id: item.getId()}) }}" class="wl-delete" title="Supprimer">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    </div>
                {% else %}
                    <div style="text-align:center; padding:30px; color:#aaa;">
                        <i class="bi bi-bag" style="font-size:2rem; display:block; margin-bottom:8px;"></i>
                        Aucun article pour le moment
                    </div>
                {% endfor %}
            </div>

            <!-- TOTAL -->
            <div class="wl-total-bar">
                <span>Total wishlist</span>
                <strong>{{ total }} DT</strong>
            </div>

            <div class="wl-total-bar" style="background: linear-gradient(135deg, #6d28d9, #7c3aed); margin-top: 10px; box-shadow: 0 4px 15px rgba(109, 40, 217, 0.2);">
                <span>Mon Solde Actuel</span>
                <strong>{{ balance|number_format(2) }} DT</strong>
            </div>

        </div>
    </div>

    <!-- ===== RIGHT ===== -->
    <div class="wl-right">

        <!-- OBJECTIF -->
        <div class="edu-card">
            <div class="edu-card-title">
                <div class="title-icon icon-orange"><i class="bi bi-bullseye"></i></div>
                Objectif d'épargne
            </div>

            <div class="goal-stats">
                <div class="goal-stat-row">
                    <span>Mon Solde</span>
                    <strong>{{ balance|number_format(0) }} DT</strong>
                </div>
                <div class="goal-stat-row">
                    <span>Objectif</span>
                    <strong>{{ goal > 0 ? goal ~ ' DT' : '—' }}</strong>
                </div>
                <div class="goal-stat-row">
                    <span>Reste</span>
                    <strong>{{ remain is not null ? remain ~ ' DT' : '—' }}</strong>
                </div>
            </div>

            {% if goal > 0 %}
                <div class="wl-progress-wrap">
                    <label>Progression — {{ pct|round }}%</label>
                    <div class="wl-progress">
                        <div class="wl-progress-fill" style="width: {{ pct }}%;"></div>
                    </div>
                </div>
            {% endif %}

            <form method="post" action="{{ path('wishlist') }}" class="goal-form">
                <input type="hidden" name="_action" value="set_goal">
                <input type="number" name="goal" placeholder="Objectif (ex: 1000)">
                <button type="submit">Définir</button>
            </form>
        </div>

        <!-- PLAN MENSUEL -->
        <div class="edu-card">
            <div class="edu-card-title">
                <div class="title-icon icon-green"><i class="bi bi-calendar3"></i></div>
                Plan mensuel
            </div>

            <div class="months-grid">
                {% for m in [3, 6, 12, 18, 24, 36] %}
                    <button type="button" class="btn-month" onclick="calc({{ m }}, {{ need }})">{{ m }} mois</button>
                {% endfor %}
            </div>

            <div class="monthly-result" id="monthly">
    {% if need > 0 %}
        {{ (need / 3)|round }} DT / mois
    {% else %}
        Objectif atteint ✅
    {% endif %}
</div>
        </div>

        <!-- CHART -->
        <div class="edu-card">
            <div class="edu-card-title">
                <div class="title-icon icon-purple"><i class="bi bi-pie-chart"></i></div>
                Statistiques
            </div>
            <div class="chart-wrap">
                <canvas id="chart"></canvas>
            </div>
        </div>

        <!-- PRIORITY -->
        <div class="edu-card">
            <div class="edu-card-title">
                <div class="title-icon icon-teal"><i class="bi bi-star"></i></div>
                Priorité des articles
            </div>

            <div class="priority-list">
                {% for item in sorted %}
                    {% set w = (item.getPrice() / maxPrice) * 100 %}
                    <div class="p-item">
                        <div class="p-header">
                            <span class="p-name">#{{ loop.index }} {{ item.getName() }}</span>
                            <span class="p-price">{{ item.getPrice() }} DT</span>
                        </div>
                        <div class="p-bar">
                            <div class="p-fill" style="width: {{ w }}%;"></div>
                        </div>
                    </div>
                {% else %}
                    <div style="color:#aaa; font-size:.85rem; text-align:center; padding:20px 0;">
                        Aucun article dans la wishlist
                    </div>
                {% endfor %}
            </div>
        </div>

    </div>
</div>

{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
function calc(months, need) {
    let val = Math.round(need / months);
    document.getElementById('monthly').innerText = val + " DT / mois";
}

new Chart(document.getElementById('chart'), {
    type: 'doughnut',
    data: {
        labels: ['Épargné', 'Restant'],
        datasets: [{
            data: [{{ balance }}, {{ goal > balance ? goal - balance : 0 }}],
            backgroundColor: ['#7c3aed', '#f3efff'],
            borderWidth: 0
        }]
    },
    options: {
        cutout: '72%',
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                position: 'bottom',
                labels: { boxWidth: 12, padding: 10, font: { size: 11 }, color: '#6c757d' }
            }
        }
    }
});
</script>
{% endblock %}