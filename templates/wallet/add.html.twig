{% extends 'base.html.twig' %}

{% block content %}

<div class="page">

    <div class="card">

        <div class="header-form">
            <h2>Add Transaction</h2>

            <a href="{{ path('transactions') }}" class="btn" style="background:#636e72;">
                ⬅ Back
            </a>
        </div>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

        <div class="form-group">
            <div class="label-row">
                {{ form_label(form.nomTransaction) }}
                {{ form_errors(form.nomTransaction) }}
            </div>
            {{ form_widget(form.nomTransaction) }}
        </div>

        <div class="form-group">
           <label>Type</label>

    <div class="type-toggle">

        {% for choice in form.type %}
            <label class="type-btn">
                {{ form_widget(choice) }}
                <span>{{ choice.vars.label }}</span>
            </label>
        {% endfor %}

    </div>
</div>
           

        <div class="form-group">
            <div class="label-row">
                {{ form_label(form.montant) }}
                {{ form_errors(form.montant) }}
            </div>
            {{ form_widget(form.montant) }}
        </div>

        <div class="form-group">
            <div class="label-row">
                {{ form_label(form.dateTransaction) }}
                {{ form_errors(form.dateTransaction) }}
            </div>
            {{ form_widget(form.dateTransaction) }}
        </div>

     <div class="form-group">
    <label>Category</label>

    <select id="transaction_wallet_category"
            name="transaction_wallet[category]"
            class="form-control">
        <option value="">Select category</option>
    </select>
</div>

        <div class="actions">
            {{ form_row(form.save) }}
        </div>

        {{ form_end(form, {'render_rest': false}) }}

    </div>

</div>
{% block javascripts %}
<script>
document.addEventListener("DOMContentLoaded", function () {

    const radios = document.querySelectorAll('input[name="transaction_wallet[type]"]');
    const categorySelect = document.getElementById('transaction_wallet_category');

    function loadCategories(type) {

        fetch('/api/categories/' + type.toUpperCase())
            .then(res => res.json())
            .then(data => {

                categorySelect.innerHTML = '<option value="">Select category</option>';

                data.forEach(cat => {
                    let option = document.createElement('option');
                    option.value = cat.id;
                    option.textContent = cat.nom;
                    categorySelect.appendChild(option);
                });
            });
    }

    radios.forEach(radio => {
        radio.addEventListener("change", function () {
            loadCategories(this.value);
        });
    });

    // default load
    const checked = document.querySelector('input[name="transaction_wallet[type]"]:checked');
    if (checked) {
        loadCategories(checked.value);
    } else {
        loadCategories('INCOME');
    }

});
document.addEventListener("DOMContentLoaded", function () {

    const radios = document.querySelectorAll('input[name="transaction_wallet[type]"]');
    const labels = document.querySelectorAll('.type-btn');
    const categorySelect = document.getElementById('transaction_wallet_category');

    function loadCategories(type) {
        console.log("TYPE:", type);

        fetch('/api/categories/' + type)
            .then(res => res.json())
            .then(data => {

                categorySelect.innerHTML = '<option value="">Select category</option>';

                data.forEach(cat => {
                    let option = document.createElement('option');
                    option.value = cat.id;
                    option.textContent = cat.nom;
                    categorySelect.appendChild(option);
                });
            });
    }

    // 🔥 الحل هنا: click على label
    labels.forEach(label => {
        label.addEventListener("click", function () {

            const radio = this.querySelector('input');
            radio.checked = true;

            loadCategories(radio.value.toUpperCase());
        });
    });

    // default
    const checked = document.querySelector('input[name="transaction_wallet[type]"]:checked');
    loadCategories(checked ? checked.value.toUpperCase() : 'INCOME');

});
</script>
{% endblock %}
{% endblock %}