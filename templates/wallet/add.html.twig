{% extends 'base.html.twig' %}

{% block title %}Ajouter une Transaction — Finora{% endblock %}

{% block stylesheets %}
<style>
.fp-form-page {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 16px 72px;
    background: linear-gradient(135deg, #f8f5ff 0%, #fdfaff 100%);
}

.fp-form-card {
    width: 100%;
    max-width: 560px;
    background: #fff;
    border-radius: 28px;
    box-shadow: 0 24px 64px -16px rgba(124,58,237,0.22);
    border: 1px solid rgba(124,58,237,0.08);
    overflow: hidden;
    animation: fp-in 0.45s cubic-bezier(0.34,1.56,0.64,1) both;
}

@keyframes fp-in {
    from { opacity:0; transform: translateY(32px) scale(0.95); }
    to   { opacity:1; transform: translateY(0) scale(1); }
}

.fp-form-head {
    background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 50%, #4f46e5 100%);
    padding: 30px 36px 26px;
    position: relative;
    overflow: hidden;
}
.fp-form-head::before {
    content: '';
    position: absolute;
    top: -50px; right: -50px;
    width: 200px; height: 200px;
    border-radius: 50%;
    background: rgba(255,255,255,0.07);
}
.fp-form-head::after {
    content: '';
    position: absolute;
    bottom: -40px; left: -30px;
    width: 130px; height: 130px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
}

.fp-form-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: rgba(255,255,255,0.78);
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.18);
    padding: 6px 14px;
    border-radius: 40px;
    transition: all 0.2s;
    position: relative;
    z-index: 1;
    margin-bottom: 16px;
    letter-spacing: 0.01em;
}
.fp-form-back:hover { background: rgba(255,255,255,0.2); color: #fff; }

.fp-form-head-icon {
    width: 54px; height: 54px;
    border-radius: 16px;
    background: rgba(255,255,255,0.14);
    border: 1px solid rgba(255,255,255,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 24px; color: #fff;
    margin-bottom: 14px;
    position: relative; z-index: 1;
}

.fp-form-head h2 {
    color: #fff !important;
    font-size: 21px !important;
    font-weight: 800 !important;
    margin: 0 !important;
    position: relative; z-index: 1;
}
.fp-form-head p {
    color: rgba(255,255,255,0.68) !important;
    font-size: 13px !important;
    margin: 5px 0 0 !important;
    position: relative; z-index: 1;
}

.fp-form-body { padding: 30px 36px 36px; }

.fp-field { margin-bottom: 20px; }
.fp-field label {
    display: block;
    font-size: 12.5px;
    font-weight: 700;
    color: #1e1b4b;
    margin-bottom: 7px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
}

.fp-field input,
.fp-field select {
    width: 100%;
    padding: 11px 16px;
    border: 1.5px solid #e9d5ff;
    border-radius: 13px;
    font-size: 14px;
    background: #fcfaff;
    color: #1e1b4b;
    transition: all 0.2s;
    outline: none;
    font-family: 'Inter', sans-serif;
}
.fp-field input:focus, .fp-field select:focus {
    border-color: #8b5cf6;
    box-shadow: 0 0 0 4px rgba(139,92,246,0.12);
    background: #fff;
}

/* ─── Type Toggle ─── */
.type-toggle-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
}
.type-option { position: relative; }
.type-option input[type="radio"] {
    position: absolute; opacity: 0;
    width: 100%; height: 100%;
    cursor: pointer; z-index: 1; margin: 0;
}
.type-option input:checked + .type-label.income {
    background: #dcfce7;
    border-color: #22c55e;
    color: #16a34a;
    box-shadow: 0 0 20px rgba(34, 197, 94, 0.4), 0 4px 12px rgba(34, 197, 94, 0.15);
    transform: scale(1.02);
}
.type-option input:checked + .type-label.outcome {
    background: #fee2e2;
    border-color: #ef4444;
    color: #dc2626;
    box-shadow: 0 0 20px rgba(239, 68, 68, 0.4), 0 4px 12px rgba(239, 68, 68, 0.15);
    transform: scale(1.02);
}
.type-label {
    /* ... existing props ... */
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 13px 12px;
    border-radius: 13px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    border: 2px solid #e9d5ff;
    background: #fcfaff;
    color: #6b7280;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    user-select: none;
}
.type-option:hover .type-label:not(.income):not(.outcome) {
    border-color: #a78bfa;
    background: #f5f3ff;
    color: #7c3aed;
}

/* ─── Submit Button ─── */
.fp-submit {
    width: 100%;
    padding: 14px;
    border: none;
    border-radius: 14px;
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(135deg, #7c3aed, #8b5cf6);
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 6px 18px rgba(124,58,237,0.32);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    letter-spacing: 0.01em;
    font-family: 'Inter', sans-serif;
    margin-top: 8px;
}
.fp-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(124,58,237,0.42);
}

/* ─── Divider ─── */
.fp-divider {
    border: none;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(124,58,237,0.12), transparent);
    margin: 22px 0;
}

/* ─── Error text ─── */
.fp-error { font-size: 12px; color: #dc2626; font-weight: 600; margin-top: 5px; display: block; }
</style>
{% endblock %}

{% block body %}
<div class="fp-form-page">
    <div class="fp-form-card">

        <div class="fp-form-head">
            <a href="{{ path('transactions') }}" class="fp-form-back">
                <i class="bi bi-arrow-left"></i> Retour aux transactions
            </a>
            <div class="fp-form-head-icon">
                <i class="bi bi-plus-circle-fill"></i>
            </div>
            <h2>Ajouter une Transaction</h2>
            <p>Enregistrez une nouvelle entrée ou sortie financière</p>
        </div>

        <div class="fp-form-body">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            
            {% if not form.vars.valid %}
                <div class="alert alert-danger py-2 mb-3" style="font-size:13px; border-radius:12px;">
                    <i class="bi bi-exclamation-octagon-fill me-2"></i> Veuillez corriger les erreurs ci-dessous :
                    <ul class="mb-0 mt-1 ps-3">
                        {% if form.vars.errors is defined %}
                            {% for error in form.vars.errors %}
                                <li>{{ error.message }}</li>
                            {% endfor %}
                        {% endif %}
                        {% for child in form %}
                            {% if child.vars.errors is defined %}
                                {% for error in child.vars.errors %}
                                    <li><strong>{{ child.vars.label|default(child.vars.name)|trans }}</strong> : {{ error.message }}</li>
                                {% endfor %}
                            {% endif %}
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

            <div class="fp-field">
                {{ form_label(form.nomTransaction) }}
                {{ form_widget(form.nomTransaction, {'attr': {'placeholder': 'Ex: Loyer, Salaire, Courses…'}}) }}
                {% if form_errors(form.nomTransaction) %}
                    <span class="fp-error">{{ form_errors(form.nomTransaction) }}</span>
                {% endif %}
            </div>

            <div class="fp-field">
                <label>Type de Transaction</label>
                <div class="type-toggle-grid">
                    {% for choice in form.type %}
                        <div class="type-option">
                            <input
                                type="radio"
                                id="{{ choice.vars.id }}"
                                name="{{ choice.vars.full_name }}"
                                value="{{ choice.vars.value }}"
                                {% if choice.vars.checked %}checked{% endif %}
                            >
                            <label class="type-label {{ choice.vars.value == 'INCOME' ? 'income' : 'outcome' }}" for="{{ choice.vars.id }}">
                                {% if choice.vars.value == 'INCOME' %}
                                    <i class="bi bi-arrow-down-circle-fill"></i> Revenu
                                {% else %}
                                    <i class="bi bi-arrow-up-circle-fill"></i> Dépense
                                {% endif %}
                            </label>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <hr class="fp-divider">

            <div class="fp-field">
                {{ form_label(form.montant) }}
                {{ form_widget(form.montant, {'attr': {'placeholder': '0.00'}}) }}
                {% if form_errors(form.montant) %}
                    <span class="fp-error">{{ form_errors(form.montant) }}</span>
                {% endif %}
            </div>

            <div class="fp-field">
                {{ form_label(form.dateTransaction) }}
                {{ form_widget(form.dateTransaction) }}
                {% if form_errors(form.dateTransaction) %}
                    <span class="fp-error">{{ form_errors(form.dateTransaction) }}</span>
                {% endif %}
            </div>

            <div class="fp-field">
                <label>Catégorie</label>
                {# Hidden field submitted to Symfony - value set by JS #}
                <input type="hidden" id="category_hidden" name="transaction_wallet[category]" value="">
                {# Visible select populated by JS #}
                <select id="category_visible" style="width:100%;padding:12px 16px;border-radius:12px;border:1.5px solid #e9d5ff;background:#faf5ff;outline:none;">
                    <option value="">Sélectionner une catégorie</option>
                </select>
                <span class="fp-error" id="category_error" style="display:none;color:#dc2626;font-size:12px;">Veuillez sélectionner une catégorie</span>
            </div>

            <button type="submit" id="form_submit_btn" class="fp-submit">
                <i class="bi bi-save-fill me-1"></i>
                Sauvegarder
            </button>

            {{ form_widget(form._token) }}
            {{ form_end(form, {'render_rest': false}) }}
        </div>

    </div>
</div>

{% block javascripts %}
<script>
document.addEventListener("DOMContentLoaded", function () {
    const categoryVisible = document.getElementById('category_visible');
    const categoryHidden  = document.getElementById('category_hidden');
    const categoryError   = document.getElementById('category_error');

    let currentController = null;

    // Sync visible select → hidden field
    categoryVisible.addEventListener('change', function () {
        categoryHidden.value = this.value;
        categoryError.style.display = this.value ? 'none' : 'block';
    });

    function loadCategories(type) {
        if (!type) return;
        type = type.toUpperCase();

        if (currentController) currentController.abort();
        currentController = new AbortController();

        categoryVisible.innerHTML = '<option value="">Chargement…</option>';
        categoryHidden.value = '';

        // Add a timestamp cache buster to completely bypass browser caching
        const url = '/api/categories/' + type + '?_t=' + new Date().getTime();

        fetch(url, { signal: currentController.signal, cache: "no-store" })
            .then(res => res.json())
            .then(data => {
                // Show the type in the default option to confirm what was fetched
                categoryVisible.innerHTML = '<option value="">— Catégories ' + (type === 'INCOME' ? 'Revenus' : 'Dépenses') + ' —</option>';
                
                if (!Array.isArray(data) || data.length === 0) {
                    const opt = document.createElement('option');
                    opt.disabled = true;
                    opt.textContent = 'Aucune catégorie configurée';
                    categoryVisible.appendChild(opt);
                } else {
                    data.forEach(cat => {
                        const option = document.createElement('option');
                        option.value = cat.id;
                        option.textContent = cat.nom;
                        categoryVisible.appendChild(option);
                    });
                }
            })
            .catch(err => {
                if (err.name !== 'AbortError') {
                    categoryVisible.innerHTML = '<option value="">Erreur de chargement</option>';
                }
            });
    }

    // Attach a single click event to the container, using event delegation
    document.querySelector('.type-toggle-grid').addEventListener('change', function(e) {
        if (e.target && e.target.type === 'radio') {
            loadCategories(e.target.value);
        }
    });

    // Guard: block submit if no category selected
    document.getElementById('form_submit_btn').addEventListener('click', function (e) {
        if (!categoryHidden.value) {
            e.preventDefault();
            categoryError.style.display = 'block';
            categoryVisible.focus();
        }
    });

    // Initial load
    const checked = document.querySelector('input[name="transaction_wallet[type]"]:checked');
    loadCategories(checked ? checked.value : 'INCOME');
});
</script>
{% endblock %}
{% endblock %}