{% extends 'base.html.twig' %}

{% block content %}

<div class="page">

    <div class="left">

        <div class="card">

            <div class="header-form">
                <h2>Add Transaction</h2>

                <a href="{{ path('dashboard') }}" class="btn" style="background:#636e72;">
                    ⬅ Dashboard
                </a>
            </div>

            {{ form_start(form) }}

            <div class="form-group">
                {{ form_row(form.nomTransaction) }}
            </div>

            <div class="form-group">
                <div class="form-group">
    <label>Type</label>

    <div class="type-toggle">

        {% for choice in form.type %}
            <label class="type-btn">
                {{ form_widget(choice) }}
                <span>{{ choice.vars.label }}</span>
            </label>
        {% endfor %}

    </div>
</div>
            </div>

            <div class="form-group">
                {{ form_row(form.montant) }}
            </div>

            <div class="form-group">
                {{ form_row(form.dateTransaction) }}
            </div>

            <div class="form-group">
                <label>Category</label>
                <select id="transaction_wallet_category" name="transaction_wallet[category]">
                    <option value="">Select category</option>
                </select>
            </div>

            <div class="actions">
                {{ form_row(form.save) }}

                <a href="{{ path('category_list') }}" class="btn" style="background:#00cec9;">
                     Category
                </a>
            </div>

            {{ form_end(form, {'render_rest': false}) }}

        </div>

    </div>

    <div class="right">

        <div class="card">

            <h2> Transactions</h2>

            <table>
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Type</th>
                        <th>Montant</th>
                        <th>Category</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                {% for t in transactions %}
                    <tr>
                        <td>{{ t.nomTransaction }}</td>

                        <td>
                            <span class="badge {{ t.type == 'INCOME' ? 'income' : 'outcome' }}">
                                {{ t.type }}
                            </span>
                        </td>

                        <td>
                            <span class="badge {{ t.montant > 0 ? 'income' : 'outcome' }}">
                                {{ t.montant }} DT
                            </span>
                        </td>

                        <td>{{ t.category ? t.category.nom : 'No category' }}</td>

                        <td>{{ t.dateTransaction|date('Y-m-d') }}</td>

                        <td>
                            <a href="/edit/{{ t.id }}" class="btn">✏️</a>
                            <a href="/delete/{{ t.id }}" class="btn delete">🗑</a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>

        </div>

    </div>

</div>

{% block javascripts %}
<script>
document.addEventListener("DOMContentLoaded", function () {

    const radios = document.querySelectorAll('input[name="transaction_wallet[type]"]');
    const categorySelect = document.getElementById('transaction_wallet_category');

    function loadCategories(type) {

        fetch('/api/categories/' + type.toUpperCase())
            .then(res => res.json())
            .then(data => {

                categorySelect.innerHTML = '<option value="">Select category</option>';

                data.forEach(cat => {
                    let option = document.createElement('option');
                    option.value = cat.id;
                    option.textContent = cat.nom;
                    categorySelect.appendChild(option);
                });
            });
    }

    radios.forEach(radio => {
        radio.addEventListener("change", function () {
            loadCategories(this.value);
        });
    });

    // default load
    const checked = document.querySelector('input[name="transaction_wallet[type]"]:checked');
    if (checked) {
        loadCategories(checked.value);
    } else {
        loadCategories('INCOME');
    }

});
document.addEventListener("DOMContentLoaded", function () {

    const radios = document.querySelectorAll('input[name="transaction_wallet[type]"]');
    const labels = document.querySelectorAll('.type-btn');
    const categorySelect = document.getElementById('transaction_wallet_category');

    function loadCategories(type) {
        console.log("TYPE:", type);

        fetch('/api/categories/' + type)
            .then(res => res.json())
            .then(data => {

                categorySelect.innerHTML = '<option value="">Select category</option>';

                data.forEach(cat => {
                    let option = document.createElement('option');
                    option.value = cat.id;
                    option.textContent = cat.nom;
                    categorySelect.appendChild(option);
                });
            });
    }

    // 🔥 الحل هنا: click على label
    labels.forEach(label => {
        label.addEventListener("click", function () {

            const radio = this.querySelector('input');
            radio.checked = true;

            loadCategories(radio.value.toUpperCase());
        });
    });

    // default
    const checked = document.querySelector('input[name="transaction_wallet[type]"]:checked');
    loadCategories(checked ? checked.value.toUpperCase() : 'INCOME');

});
</script>
{% endblock %}

{% endblock %}