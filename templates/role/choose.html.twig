{% extends 'base.html.twig' %}

{% block body %}

<style>
    body {
        background: linear-gradient(135deg, #1e1b4b 0%, #312e81 40%, #4c1d95 100%);
        font-family: 'Inter', 'Segoe UI', sans-serif;
        min-height: 100vh;
    }

    .main-container {
        min-height: 100vh;
    }

    .title {
        font-size: 38px;
        font-weight: 800;
        color: #ffffff;
    }

    .subtitle {
        color: rgba(255,255,255,0.6);
        font-size: 16px;
    }

    .role-card {
        border-radius: 24px;
        padding: 48px 32px;
        text-align: center;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(255,255,255,0.1);
        backdrop-filter: blur(20px);
    }

    .role-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 24px 60px rgba(0,0,0,0.3);
    }

    .admin {
        background: linear-gradient(145deg, rgba(124,58,237,0.9), rgba(139,92,246,0.85));
    }

    .invest {
        background: linear-gradient(145deg, rgba(16,185,129,0.9), rgba(5,150,105,0.85));
    }

    .user-role {
        background: linear-gradient(145deg, rgba(59,130,246,0.9), rgba(37,99,235,0.85));
    }

    .role-icon-circle {
        width: 80px;
        height: 80px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(10px);
    }

    .role-icon-circle i {
        font-size: 32px;
        color: white;
    }

    .role-title {
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 8px;
        color: white;
    }

    .role-desc {
        font-size: 14px;
        opacity: 0.8;
        line-height: 1.6;
        color: rgba(255,255,255,0.85);
    }

    .logout-btn {
        margin-top: 32px;
        border-radius: 50px;
        padding: 12px 32px;
        border-color: rgba(255,255,255,0.3);
        color: rgba(255,255,255,0.8);
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .logout-btn:hover {
        background: rgba(255,255,255,0.1);
        border-color: rgba(255,255,255,0.5);
        color: white;
    }

    .brand-badge {
        display: inline-block;
        padding: 8px 20px;
        border-radius: 50px;
        background: rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.7);
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 1px;
        margin-bottom: 24px;
        border: 1px solid rgba(255,255,255,0.08);
    }

    .role-alert {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 16px;
        color: rgba(255,255,255,0.85);
        padding: 12px 20px;
    }
</style>

<div class="container d-flex justify-content-center align-items-center main-container">

    <div class="text-center" style="max-width: 900px;">

        <div class="brand-badge">
            <i class="bi bi-shield-check me-1"></i> FINORA INVESTMENT PLATFORM
        </div>

        <h1 class="title mb-2">Bienvenue sur Finora</h1>
        <p class="subtitle mb-5">Sélectionnez votre profil pour accéder à la plateforme</p>

        {% set role = app.session.get('role') %}

        {% if role %}
            <div class="role-alert mb-4 d-inline-block">
                <i class="bi bi-person-check me-1"></i> Connecté en tant que : <strong>{{ role|upper }}</strong>
            </div>
        {% endif %}

        <div class="row justify-content-center g-4">

            <!-- ADMIN -->
            <div class="col-md-4">
                <a href="{{ path('set_role', {role: 'admin'}) }}" class="text-decoration-none">
                    <div class="role-card admin">
                        <div class="role-icon-circle">
                            <i class="bi bi-speedometer2"></i>
                        </div>
                        <div class="role-title">Administrateur</div>
                        <div class="role-desc">
                            Tableau de bord complet<br>
                            Gestion & Statistiques
                        </div>
                    </div>
                </a>
            </div>

            <!-- INVESTISSEUR -->
            <div class="col-md-4">
                <a href="{{ path('set_role', {role: 'investisseur'}) }}" class="text-decoration-none">
                    <div class="role-card invest">
                        <div class="role-icon-circle">
                            <i class="bi bi-graph-up-arrow"></i>
                        </div>
                        <div class="role-title">Investisseur</div>
                        <div class="role-desc">
                            Portefeuille personnel<br>
                            Investir & Suivre rendements
                        </div>
                    </div>
                </a>
            </div>

            <!-- USER -->
            <div class="col-md-4">
                <a href="{{ path('set_role', {role: 'user'}) }}" class="text-decoration-none">
                    <div class="role-card user-role">
                        <div class="role-icon-circle">
                            <i class="bi bi-building"></i>
                        </div>
                        <div class="role-title">Gestionnaire</div>
                        <div class="role-desc">
                            Créer des projets<br>
                            CRUD Investissements
                        </div>
                    </div>
                </a>
            </div>

        </div>

        {% if role %}
            <a href="{{ path('logout_role') }}" class="btn logout-btn">
                <i class="bi bi-arrow-repeat me-1"></i> Changer de profil
            </a>
        {% endif %}

    </div>

</div>

{% endblock %}