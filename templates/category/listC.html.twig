{% extends 'base.html.twig' %}

{% block title %}Gestion des Catégories — Finora{% endblock %}

{% block stylesheets %}
<style>
/* ── Design tokens ── */
:root {
    --p:  #7c3aed; --p2: #8b5cf6; --p3: #ede9fe;
    --g:  #22c55e; --r:  #ef4444; --o: #f59e0b;
    --ink:#1e1b4b; --muted:#94a3b8;
    --card-shadow: 0 8px 32px -8px rgba(124,58,237,0.13);
    --border: rgba(124,58,237,0.10);
}

/* ── Page ── */
.cat-page { padding: 36px 0 60px; background: #f8f5ff; min-height: 100vh; }

/* ── Hero banner ── */
.cat-hero {
    background: linear-gradient(135deg,#7c3aed,#4f46e5);
    border-radius: 22px;
    padding: 24px 28px;
    margin-bottom: 26px;
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap:14px;
    box-shadow: 0 16px 40px rgba(124,58,237,0.28);
    position: relative; overflow: hidden;
}
.cat-hero::after {
    content:''; position: absolute; right:-50px; top:-50px;
    width:200px;height:200px; border-radius:50%; background:rgba(255,255,255,0.06);
}
.cat-hero h1 { margin:0; font-size:24px; font-weight:900; color:#fff; }
.cat-hero p  { margin:4px 0 0; font-size:13px; color:rgba(255,255,255,0.65); }
.cat-hero-btns { display:flex; gap:10px; flex-wrap:wrap; position:relative; z-index:1; }
.btn-hero {
    display:inline-flex; align-items:center; gap:7px;
    padding:9px 18px; border-radius:11px; font-size:13px; font-weight:700;
    text-decoration:none; border:none; cursor:pointer;
    transition:transform 0.15s, box-shadow 0.15s;
}
.btn-hero:hover { transform:translateY(-2px); }
.btn-glass { background:rgba(255,255,255,0.15); color:#fff; border:1px solid rgba(255,255,255,0.25); }
.btn-white { background:#fff; color:var(--p); box-shadow:0 4px 14px rgba(0,0,0,0.12); }

/* ── Stat cards ── */
.cat-stats { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:14px; margin-bottom:22px; }
.cat-stat {
    background:#fff; border-radius:16px; padding:18px 20px;
    box-shadow:var(--card-shadow); border:1px solid var(--border);
    display:flex; align-items:center; gap:12px;
    animation: fadeUp 0.4s ease both;
}
.stat-icon { width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0; }
.si-total { background:#ede9fe;color:var(--p); }
.si-alert { background:#fee2e2;color:#dc2626; }
.stat-info span { display:block;font-size:10.5px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.5px; }
.stat-info strong { font-size:18px;font-weight:900;color:var(--ink); }

@keyframes fadeUp { from { opacity:0;transform:translateY(14px);} to { opacity:1;transform:translateY(0);} }

/* ── Progress bar ── */
.health-bar-wrap {
    background:#fff; border-radius:16px; padding:16px 20px;
    box-shadow:var(--card-shadow); border:1px solid var(--border);
    margin-bottom:22px; display:flex; align-items:center; gap:18px; flex-wrap:wrap;
}
.health-bar-outer { flex:1; background:#f1f5f9; border-radius:20px; height:10px; overflow:hidden; min-width:120px; }
.health-bar-inner { height:100%; border-radius:20px; transition:width 0.8s ease; }

/* ── Table ── */
.cat-table-card {
    background:#fff; border-radius:18px;
    box-shadow:var(--card-shadow); border:1px solid var(--border);
    overflow:hidden;
}
.cat-table-header { padding:16px 22px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; background:#fff; }
.cat-table-title { font-size:13px;font-weight:700;text-transform:uppercase;color:var(--p);gap:7px;display:flex;align-items:center; }
.cat-table { width:100%; border-collapse:collapse; font-size:13.5px; }
.cat-table thead th { padding:12px 16px; text-align:left; font-size:11px; font-weight:700; text-transform:uppercase; color:var(--muted); border-bottom:2px solid var(--p3); }
.cat-table tbody tr { border-bottom:1px solid rgba(124,58,237,0.05); transition:background 0.15s; }
.cat-table tbody tr:hover { background:#faf5ff; }
.cat-table tbody td { padding:14px 16px; color:#374151; vertical-align:middle; }

/* ── Badges ── */
.badge-type { display:inline-flex;padding:3px 10px;border-radius:20px;font-size:10.5px;font-weight:700;align-items:center;gap:4px; }
.badge-income  { background:#dcfce7;color:#16a34a; }
.badge-outcome { background:#fee2e2;color:#dc2626; }

.badge-prio { display:inline-flex;padding:3px 10px;border-radius:20px;font-size:10.5px;font-weight:700; }
.prio-haute  { background:#fee2e2;color:#dc2626; }
.prio-moyenne{ background:#fef3c7;color:#d97706; }
.prio-basse  { background:#dcfce7;color:#16a34a; }

.btn-edit { background:#1e1b4b; color:#fff; border-radius:8px; padding:6px 12px; font-size:12px; text-decoration:none; }
.btn-del  { background:transparent; color:#dc2626; border:1.5px solid #fecaca; border-radius:8px; padding:6px 12px; font-size:12px; text-decoration:none; }
.btn-del:hover { background:#fee2e2; }
</style>
{% endblock %}

{% block body %}
<div class="cat-page">
<div class="container">

    {# ── Hero ── #}
    <div class="cat-hero">
        <div>
            <h1><i class="bi bi-tags-fill me-2"></i>Mes Catégories</h1>
            <p>{{ categories.getTotalItemCount() }} catégories configurées pour votre portefeuille</p>
        </div>
        <div class="cat-hero-btns">
            <a href="{{ path('category_add') }}" class="btn-hero btn-white">
                <i class="bi bi-plus-lg"></i> Ajouter une Catégorie
            </a>
        </div>
    </div>


    {# ── Table ── #}
    <div class="cat-table-card">
        <div class="cat-table-header">
            <div class="cat-table-title"><i class="bi bi-list-stars"></i> Liste des Catégories</div>
            <span style="font-size:12px;color:var(--muted);">Page {{ categories.getCurrentPageNumber() }} sur {{ categories.getPageCount() }}</span>
        </div>
        <div style="overflow-x:auto;">
            <table class="cat-table">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Type</th>
                        <th>Priorité</th>
                        <th>Dernier Mois</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for c in categories %}
                    {% set stats = categoryStats[c.id] ?? {count:0,income:0,outcome:0,isAlert:false} %}
                    <tr style="{{ stats.isAlert ? 'background:rgba(239,68,68,0.03);' : '' }}">
                        <td style="font-weight:700; color:var(--ink);">{{ c.nom }}</td>
                        <td>
                            {% if c.type == 'INCOME' %}
                                <span class="badge-type badge-income"><i class="bi bi-arrow-down-circle-fill"></i> Revenu</span>
                            {% else %}
                                <span class="badge-type badge-outcome"><i class="bi bi-arrow-up-circle-fill"></i> Dépense</span>
                            {% endif %}
                        </td>
                        <td>
                            {% set prio = c.priorite|upper %}
                            <span class="badge-prio {{ prio == 'HAUTE' ? 'prio-haute' : (prio == 'BASSE' ? 'prio-basse' : 'prio-moyenne') }}">
                                {{ c.priorite }}
                            </span>
                        </td>
                        <td>
                            <div style="font-size:12px;">
                                {% if stats.outcome > 0 %}<span style="color:#dc2626;font-weight:600;">-{{ stats.outcome|number_format(2,'.','') }} DT</span>{% endif %}
                                {% if stats.income > 0 %}<span style="color:#16a34a;font-weight:600;">+{{ stats.income|number_format(2,'.','') }} DT</span>{% endif %}
                                <span style="display:block;opacity:.6;font-size:11px;">{{ stats.count }} tx</span>
                            </div>
                        </td>
                        <td>
                            <div style="display:flex;gap:8px;">
                                <a href="{{ path('category_edit', {'id': c.id}) }}" class="btn-edit"><i class="bi bi-pencil"></i></a>
                                <a href="{{ path('category_delete', {'id': c.id}) }}" class="btn-del" onclick="return confirm('Supprimer cette catégorie ?')"><i class="bi bi-trash"></i></a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="5" style="padding:40px;text-align:center;color:var(--muted);">Aucune catégorie.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        <div style="padding:16px 22px;">
            {{ knp_pagination_render(categories) }}
        </div>
    </div>

</div>
</div>
{% endblock %}