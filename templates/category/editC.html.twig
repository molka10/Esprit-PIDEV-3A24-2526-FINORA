{% extends 'base.html.twig' %}

{% block title %}Modifier la Catégorie — Finora{% endblock %}

{% block stylesheets %}
<style>
.fp-form-page {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 16px 72px;
    background: linear-gradient(135deg, #f8f5ff 0%, #fdfaff 100%);
}

.fp-form-card {
    width: 100%;
    max-width: 520px;
    background: #fff;
    border-radius: 28px;
    box-shadow: 0 24px 64px -16px rgba(124,58,237,0.22);
    border: 1px solid rgba(124,58,237,0.08);
    overflow: hidden;
    animation: fp-in 0.45s cubic-bezier(0.34,1.56,0.64,1) both;
}

@keyframes fp-in {
    from { opacity:0; transform: translateY(32px) scale(0.95); }
    to   { opacity:1; transform: translateY(0) scale(1); }
}

.fp-form-head {
    background: linear-gradient(135deg, #5b21b6 0%, #7c3aed 60%, #8b5cf6 100%);
    padding: 30px 36px 26px;
    position: relative; overflow: hidden;
}
.fp-form-head::before {
    content: ''; position: absolute; top:-50px; right:-50px;
    width:180px; height:180px; border-radius:50%; background: rgba(255,255,255,0.07);
}

.fp-form-back {
    display: inline-flex; align-items: center; gap: 6px;
    color: rgba(255,255,255,0.78); font-size: 13px; font-weight: 600;
    text-decoration: none; background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.18);
    padding: 6px 14px; border-radius: 40px; transition: all 0.2s;
    position: relative; z-index: 1; margin-bottom: 16px;
}
.fp-form-back:hover { background: rgba(255,255,255,0.2); color: #fff; }

.fp-form-head-icon {
    width: 54px; height: 54px; border-radius: 16px;
    background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 24px; color: #fff; margin-bottom: 14px;
    position: relative; z-index: 1;
}
.fp-form-head h1 {
    color: #fff !important; font-size: 21px !important; font-weight: 800 !important;
    margin: 0 !important; position: relative; z-index: 1;
}
.fp-form-head p {
    color: rgba(255,255,255,0.68) !important; font-size: 13px !important;
    margin: 5px 0 0 !important; position: relative; z-index: 1;
}

.fp-form-body { padding: 30px 36px 36px; }

.fp-field { margin-bottom: 20px; }
.fp-field label {
    display: block; font-size: 12.5px; font-weight: 700;
    color: #1e1b4b; margin-bottom: 7px;
    text-transform: uppercase; letter-spacing: 0.04em;
}
.fp-field input, .fp-field select {
    width: 100%; padding: 11px 16px;
    border: 1.5px solid #e9d5ff; border-radius: 13px;
    font-size: 14px; background: #fcfaff; color: #1e1b4b;
    transition: all 0.2s; outline: none; font-family: 'Inter', sans-serif;
}
.fp-field input:focus, .fp-field select:focus {
    border-color: #8b5cf6; box-shadow: 0 0 0 4px rgba(139,92,246,0.12); background: #fff;
}

.type-select-wrap { position: relative; }
.type-select-wrap select { padding-left: 42px !important; appearance: none; }
.type-select-icon {
    position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
    color: #7c3aed; font-size: 16px; pointer-events: none;
}

.fp-submit {
    width: 100%; padding: 14px; border: none; border-radius: 14px;
    font-size: 15px; font-weight: 700; color: #fff;
    background: linear-gradient(135deg, #7c3aed, #8b5cf6); cursor: pointer;
    transition: all 0.2s; box-shadow: 0 6px 18px rgba(124,58,237,0.32);
    display: flex; align-items: center; justify-content: center; gap: 8px;
    font-family: 'Inter', sans-serif; margin-top: 8px;
}
.fp-submit:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(124,58,237,0.42); }

.fp-error { font-size: 12px; color: #dc2626; font-weight: 600; margin-top: 5px; display: block; }
.fp-divider {
    border: none; height: 1px;
    background: linear-gradient(to right, transparent, rgba(124,58,237,0.12), transparent);
    margin: 22px 0;
}
</style>
{% endblock %}

{% block content %}
<div class="fp-form-page">
    <div class="fp-form-card">

        <div class="fp-form-head">
            <a href="{{ path('category_list') }}" class="fp-form-back">
                <i class="bi bi-arrow-left"></i> Retour aux catégories
            </a>
            <div class="fp-form-head-icon">
                <i class="bi bi-pencil-square"></i>
            </div>
            <h1>Modifier la Catégorie</h1>
            <p>Mettez à jour les informations de cette catégorie</p>
        </div>

        <div class="fp-form-body">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="fp-field">
                {{ form_label(form.nom) }}
                {{ form_widget(form.nom) }}
                {% if form_errors(form.nom) %}
                    <span class="fp-error">{{ form_errors(form.nom) }}</span>
                {% endif %}
            </div>

            <hr class="fp-divider">

            <div class="fp-field">
                {{ form_label(form.type) }}
                <div class="type-select-wrap">
                    <i class="bi bi-grid-fill type-select-icon"></i>
                    {{ form_widget(form.type) }}
                </div>
                {% if form_errors(form.type) %}
                    <span class="fp-error">{{ form_errors(form.type) }}</span>
                {% endif %}
            </div>

            <div class="fp-field">
                {{ form_label(form.priorite) }}
                <div class="type-select-wrap">
                    <i class="bi bi-flag-fill type-select-icon"></i>
                    {{ form_widget(form.priorite) }}
                </div>
                {% if form_errors(form.priorite) %}
                    <span class="fp-error">{{ form_errors(form.priorite) }}</span>
                {% endif %}
            </div>

            <button type="submit" class="fp-submit">
                <i class="bi bi-check-circle-fill"></i>
                Enregistrer les Modifications
            </button>

            {{ form_end(form) }}
        </div>

    </div>
</div>
{% endblock %}