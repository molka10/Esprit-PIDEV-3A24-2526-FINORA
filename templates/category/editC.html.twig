{% extends 'base.html.twig' %}

{% block title %}Modifier la Catégorie — Finora{% endblock %}

{% block stylesheets %}
<style>
.fp-form-page {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 16px;
    background: #fdfaff;
}

.fp-form-card {
    width: 100%;
    max-width: 500px;
    background: #fff;
    border-radius: 24px;
    box-shadow: 0 20px 50px rgba(124,58,237,0.15);
    overflow: hidden;
    animation: fadeIn 0.4s ease both;
}

@keyframes fadeIn { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }

.fp-form-head {
    background: linear-gradient(135deg, #1e1b4b, #312e81);
    padding: 32px;
    color: #fff;
}
.fp-form-head h2 { margin:0; font-size:22px; font-weight:800; }
.fp-form-head p { margin:6px 0 0; font-size:13px; opacity:0.8; }

.fp-form-body { padding: 32px; }

.fp-field { margin-bottom: 20px; }
.fp-field label { display:block; font-size:12px; font-weight:700; color:#1e1b4b; text-transform:uppercase; margin-bottom:8px; }
.fp-field input, .fp-field select {
    width:100%; padding:12px 16px; border-radius:12px; border:1.5px solid #e9d5ff;
    background:#faf5ff; outline:none; transition:all 0.2s;
}
.fp-field input:focus, .fp-field select:focus { border-color:#7c3aed; box-shadow:0 0 0 4px rgba(124,58,237,0.1); background:#fff; }

.fp-submit {
    width:100%; padding:14px; border:none; border-radius:12px;
    background:linear-gradient(135deg, #1e1b4b, #312e81);
    color:#fff; font-weight:700; cursor:pointer;
    box-shadow: 0 8px 20px rgba(30,27,75,0.3);
    transition: all 0.2s;
}
.fp-submit:hover { transform:translateY(-2px); box-shadow: 0 12px 28px rgba(30,27,75,0.4); }

.fp-back { display:inline-flex; align-items:center; gap:6px; font-size:13px; color:#7c3aed; text-decoration:none; margin-bottom:20px; font-weight:600; }
</style>
{% endblock %}

{% block body %}
<div class="fp-form-page">
    <div class="fp-form-card">
        <div class="fp-form-head">
            <h2>Modifier la Catégorie</h2>
            <p>Ajustez les paramètres de votre catégorie budgétaire</p>
        </div>
        <div class="fp-form-body">
            <a href="{{ path('category_list') }}" class="fp-back">
                <i class="bi bi-arrow-left"></i> Retour à la liste
            </a>

            {{ form_start(form, {'attr': {'id': 'category_form', 'novalidate': 'novalidate'}}) }}
                <div class="fp-field">
                    {{ form_label(form.nom, 'Nom de la catégorie') }}
                    {{ form_widget(form.nom, {'attr': {'required': false}}) }}
                </div>

                <div class="row">
                    <div class="col-6">
                        <div class="fp-field">
                            {{ form_label(form.type) }}
                            {{ form_widget(form.type) }}
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="fp-field">
                            {{ form_label(form.priorite, 'Priorité') }}
                            {{ form_widget(form.priorite) }}
                        </div>
                    </div>
                </div>

                <div id="form_feedback" class="mb-3" style="display:none; font-size:13px; font-weight:600;"></div>

                <button type="button" id="ajax_save_btn" class="fp-submit">
                    <i class="bi bi-save-fill me-1"></i> Mettre à jour (AJAX)
                </button>
            {{ form_end(form) }}
        </div>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
    const btn = document.getElementById('ajax_save_btn');
    const form = document.getElementById('category_form');
    const feedback = document.getElementById('form_feedback');

    btn.addEventListener('click', function() {
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Mise à jour...';
        feedback.style.display = 'none';

        const formData = new FormData(form);
        
        fetch(window.location.href, {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest',
                'Accept': 'application/json'
            }
        })
        .then(async res => {
            const data = await res.json();
            if (res.ok) {
                feedback.style.color = '#16a34a';
                feedback.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i> ' + data.message;
                feedback.style.display = 'block';
                setTimeout(() => window.location.href = "{{ path('category_list') }}", 1000);
            } else {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-save-fill me-1"></i> Mettre à jour (AJAX)';
                feedback.style.color = '#dc2626';
                feedback.innerHTML = '<i class="bi bi-x-circle-fill me-1"></i> ' + (data.errors ? data.errors.join('<br>') : 'Erreur réseau');
                feedback.style.display = 'block';
            }
        })
        .catch(err => {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-save-fill me-1"></i> Mettre à jour (AJAX)';
            feedback.style.color = '#dc2626';
            feedback.innerHTML = 'Une erreur est survenue.';
            feedback.style.display = 'block';
        });
    });
});
</script>
        </div>
    </div>
</div>
{% endblock %}