{% block javascripts %}{% endblock %}

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Hidden flash messages to be processed by SweetAlert
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            (function() {
                const msg = `{{ message|raw }}`;
                const label = `{{ label }}`;
                
                // Logic for "Solde insuffisant" Popup
                if (msg.includes('Solde insuffisant') || msg.includes('portefeuille')) {
                    Swal.fire({
                        title: '<strong>Solde Insuffisant</strong>',
                        icon: 'warning',
                        html: msg,
                        showCloseButton: true,
                        showCancelButton: true,
                        focusConfirm: false,
                        confirmButtonText: '<i class="bi bi-wallet2"></i> Recharger mon Wallet',
                        confirmButtonColor: '#7c3aed',
                        cancelButtonText: 'Fermer',
                        background: '#fff',
                        customClass: {
                            popup: 'animated fadeInDown'
                        }
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = "{{ path('dashboard') }}";
                        }
                    });
                } 
                // Success popups
                else if (label === 'success') {
                    Swal.fire({
                        title: 'Succès !',
                        text: msg.replace(/<[^>]*>?/gm, ''), // strip html for text
                        icon: 'success',
                        timer: 3000,
                        showConfirmButton: false,
                        toast: true,
                        position: 'top-end'
                    });
                }
                // General Danger popups (if not balance error)
                else if (label === 'danger' || label === 'error') {
                   Swal.fire({
                        title: 'Erreur',
                        text: msg.replace(/<[^>]*>?/gm, ''),
                        icon: 'error',
                        confirmButtonColor: '#dc3545'
                    });
                }
            })();
        {% endfor %}
    {% endfor %}
});
</script>

