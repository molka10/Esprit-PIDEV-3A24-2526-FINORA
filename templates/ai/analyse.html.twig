{% extends 'base.html.twig' %}

{% block title %}Analyse IA — Finora{% endblock %}

{% block breadcrumb %}Analyse IA{% endblock %}

{% block stylesheets %}
<style>
.ai-page { padding: 40px 0 72px; background: #f8f5ff; min-height: 100vh; }

/* ── Hero ── */
.ai-hero {
    background: linear-gradient(135deg, #1e1b4b 0%, #4338ca 60%, #7c3aed 100%);
    border-radius: 22px; padding: 28px 32px; margin-bottom: 30px;
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;
    box-shadow: 0 20px 50px rgba(67,56,202,0.35);
    position: relative; overflow: hidden;
    animation: aiIn 0.4s ease both;
}
.ai-hero::before {
    content: ''; position: absolute; right: -60px; top: -60px;
    width: 240px; height: 240px; border-radius: 50%; background: rgba(255,255,255,0.05);
}
.ai-hero::after {
    content: ''; position: absolute; left: -40px; bottom: -50px;
    width: 160px; height: 160px; border-radius: 50%; background: rgba(255,255,255,0.03);
}
.ai-hero h1 { color: #fff !important; font-size: 24px !important; font-weight: 900 !important; margin: 0 !important; position: relative; z-index: 1; }
.ai-hero p  { color: rgba(255,255,255,0.7) !important; font-size: 14px !important; margin: 5px 0 0; position: relative; z-index: 1; }
.ai-hero-icon {
    width: 60px; height: 60px; border-radius: 18px;
    background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 28px; color: #fff; position: relative; z-index: 1;
}
.ai-hero-right { position: relative; z-index: 1; }

@keyframes aiIn { from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);} }

/* ── Stat Cards Grid ── */
.ai-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 28px; }

.ai-stat {
    background: #fff; border-radius: 20px;
    border: 1px solid rgba(124,58,237,0.07);
    box-shadow: 0 8px 28px -8px rgba(124,58,237,0.10);
    padding: 24px; display: flex; flex-direction: column; gap: 12px;
    animation: aiIn 0.4s ease both; transition: transform 0.2s, box-shadow 0.2s;
}
.ai-stat:hover { transform: translateY(-4px); box-shadow: 0 16px 40px -8px rgba(124,58,237,0.16); }
.ai-stat:nth-child(1) { animation-delay: 0.05s; }
.ai-stat:nth-child(2) { animation-delay: 0.10s; }
.ai-stat:nth-child(3) { animation-delay: 0.15s; }
.ai-stat:nth-child(4) { animation-delay: 0.20s; }

.ai-stat-head { display: flex; align-items: center; gap: 12px; }
.ai-stat-icon {
    width: 48px; height: 48px; border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; flex-shrink: 0;
}
.asi-blue   { background: #dbeafe; color: #2563eb; }
.asi-purple { background: #ede9fe; color: #7c3aed; }
.asi-red    { background: #fee2e2; color: #dc2626; }
.asi-green  { background: #dcfce7; color: #16a34a; }

.ai-stat-label { font-size: 11.5px; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; }
.ai-stat-value { font-size: 28px; font-weight: 900; color: #1e1b4b; line-height: 1.1; font-family: 'Inter', sans-serif; }
.ai-stat-value sup { font-size: 14px; color: #6b7280; font-weight: 600; }
.ai-stat-sub { font-size: 12px; color: #9ca3af; font-weight: 500; }

/* ── Recommendations ── */
.ai-reco-card {
    background: #fff; border-radius: 22px; padding: 32px 36px;
    border: 1px solid rgba(124,58,237,0.07);
    box-shadow: 0 16px 48px -12px rgba(124,58,237,0.12);
    animation: aiIn 0.4s 0.25s ease both;
}
.ai-reco-header { display: flex; align-items: center; gap: 16px; margin-bottom: 26px; }
.ai-reco-icon {
    width: 58px; height: 58px; border-radius: 18px;
    background: linear-gradient(135deg, #7c3aed, #4f46e5);
    display: flex; align-items: center; justify-content: center;
    font-size: 26px; color: #fff;
    box-shadow: 0 8px 20px rgba(124,58,237,0.3);
    flex-shrink: 0;
}
.ai-reco-header h2 { font-size: 22px; font-weight: 800; color: #1e1b4b; margin: 0; }
.ai-reco-header p { color: #6b7280; font-size: 14px; margin: 4px 0 0; }

.ai-reco-list { display: flex; flex-direction: column; gap: 14px; }
.ai-reco-item {
    display: flex; align-items: flex-start; gap: 14px;
    background: linear-gradient(135deg, #faf5ff, #f5f3ff);
    border-radius: 14px; padding: 18px 22px;
    border-left: 5px solid #7c3aed;
    font-size: 15px; color: #334155; line-height: 1.6;
    transition: transform 0.2s, box-shadow 0.2s;
}
.ai-reco-item:hover { transform: translateX(4px); box-shadow: 0 4px 16px rgba(124,58,237,0.10); }
.ai-reco-item i { color: #7c3aed; margin-top: 2px; flex-shrink: 0; font-size: 16px; }

/* ── Back button ── */
.ai-back-btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 9px 20px; border-radius: 50px; font-size: 13px; font-weight: 600;
    color: rgba(255,255,255,0.84); text-decoration: none;
    background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2);
    transition: all 0.2s; position: relative; z-index: 1;
}
.ai-back-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }
</style>
{% endblock %}

{% block body %}


    {# ── NEW: Financial Health Score Meter ── #}
    <div class="ai-reco-card mb-4" style="background: linear-gradient(135deg, #ffffff 0%, #fdfcff 100%); border: none; box-shadow: 0 10px 40px rgba(124, 58, 237, 0.06);">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <div class="d-flex align-items-center gap-4">
                    <div class="health-gauge-container">
                        {% set score = (100 - data.ratio)|round %}
                        {% if score < 0 %}{% set score = 0 %}{% endif %}
                        <div class="health-gauge" style="--p:{{ score }}; --c:#7c3aed;">
                            <div class="gauge-value">{{ score }}%</div>
                        </div>
                    </div>
                    <div>
                        <h2 class="fw-900 mb-1" style="font-size: 28px; color: #1e1b4b;">Score de Santé Financière</h2>
                        <p class="text-muted mb-0">Basé sur vos flux de {{ "now"|date("F Y") }}. Votre gestion est 
                            <strong style="color: {{ score > 70 ? '#10b981' : (score > 40 ? '#f59e0b' : '#dc2626') }}">
                                {{ score > 70 ? 'Excellente' : (score > 40 ? 'Équilibrée' : 'Critique') }}
                            </strong>.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 text-end">
                {# Decorative badge removed as per request #}
            </div>
        </div>
    </div>

    {# ── Stats Grid ── #}
    <div class="ai-stats">
        <div class="ai-stat">
            <div class="ai-stat-head">
                <div class="ai-stat-icon asi-blue"><i class="bi bi-wallet2"></i></div>
                <span class="ai-stat-label">Solde Actuel</span>
            </div>
            <div class="ai-stat-value">{{ data.balance|number_format(2, ',', ' ') }} <sup>DT</sup></div>
            <div class="progress mt-2" style="height: 4px; background: #eef2ff;">
                <div class="progress-bar bg-primary" style="width: 85%"></div>
            </div>
        </div>

        <div class="ai-stat">
            <div class="ai-stat-head">
                <div class="ai-stat-icon asi-purple"><i class="bi bi-pie-chart-fill"></i></div>
                <span class="ai-stat-label">Ratio d'Activité</span>
            </div>
            <div class="ai-stat-value">{{ data.ratio }}<sup>%</sup></div>
            <p class="ai-stat-sub text-{{ data.ratio > 80 ? 'danger' : 'success' }} fw-bold">
                <i class="bi bi-{{ data.ratio > 80 ? 'arrow-up' : 'arrow-down' }}-right me-1"></i>
                {{ data.ratio > 80 ? 'Attention au sur-endettement' : 'Ratio sain et maîtrisé' }}
            </p>
        </div>

        <div class="ai-stat">
            <div class="ai-stat-head">
                <div class="ai-stat-icon asi-red"><i class="bi bi-shield-exclamation"></i></div>
                <span class="ai-stat-label">Niveau de Risque</span>
            </div>
            <div class="ai-stat-value" style="color: {{ colorMap[data.cssClass] | default('#1e1b4b') }}; font-size: 24px;">
                {{ data.risk }}
            </div>
            <div class="d-flex gap-1 mt-2">
                <div class="flex-grow-1" style="height:4px; border-radius:2px; background: {{ data.cssClass == 'low' ? '#16a34a' : '#f3f4f6' }}"></div>
                <div class="flex-grow-1" style="height:4px; border-radius:2px; background: {{ data.cssClass == 'medium' ? '#f59e0b' : '#f3f4f6' }}"></div>
                <div class="flex-grow-1" style="height:4px; border-radius:2px; background: {{ data.cssClass == 'high' ? '#dc2626' : '#f3f4f6' }}"></div>
            </div>
        </div>

        <div class="ai-stat">
            <div class="ai-stat-head">
                <div class="ai-stat-icon asi-green"><i class="bi bi-graph-up-arrow"></i></div>
                <span class="ai-stat-label">Dépenses Futures</span>
            </div>
            <div class="ai-stat-value">{{ data.predictedExpenses }} <sup>DT</sup></div>
            <p class="ai-stat-sub">Estimation pour la prochaine période</p>
        </div>
    </div>

    {# ── Prediction & Coach Row ── #}
    <div class="row g-4 mb-5">
        <div class="col-lg-6">
            <div class="ai-reco-card h-100 overflow-hidden position-relative" style="border-top: 5px solid #3b82f6;">
                <div class="prediction-pulse-bg"></div>
                <div class="ai-reco-header">
                    <div class="ai-reco-icon" style="background: linear-gradient(135deg, #3b82f6, #2563eb);"><i class="bi bi-cpu"></i></div>
                    <div>
                        <h2>Moteur de Prédiction</h2>
                        <p>Algorithme de projection à 30 jours</p>
                    </div>
                </div>
                <div class="text-center py-4">
                    <div class="prediction-value-wrap">
                        <div class="display-3 fw-900 mb-0" style="color: #1e1b4b;">
                            {{ data.predictedBalance|number_format(2, ',', ' ') }} <small style="font-size: 20px;">DT</small>
                        </div>
                        <div class="prediction-status-badge {{ (data.predictedBalance >= data.balance) ? 'positive' : 'negative' }}">
                            <i class="bi {{ (data.predictedBalance >= data.balance) ? 'bi-graph-up' : 'bi-graph-down' }} me-2"></i>
                            {{ (data.predictedBalance - data.balance)|abs|number_format(2, ',', ' ') }} DT vs Aujourd'hui
                        </div>
                    </div>
                </div>
                <div class="p-3 bg-light rounded-4 border border-blue-100">
                    <p class="small text-muted mb-0 fst-italic">
                        <i class="bi bi-info-circle me-1"></i> Notre IA prévoit une {{ (data.predictedBalance >= data.balance) ? 'croissance' : 'diminution' }} de votre solde basée sur votre historique de consommation de {{ data.predictedExpenses }} DT.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="ai-reco-card h-100" style="border-top: 5px solid #7c3aed;">
                <div class="ai-reco-header">
                    <div class="ai-reco-icon"><i class="bi bi-robot"></i></div>
                    <div>
                        <h2>Smart Coach Financier</h2>
                        <p>Vos recommandations personnalisées</p>
                    </div>
                </div>
                <div class="ai-reco-list">
                    {% for r in data.recommendation %}
                        <div class="coach-bubble {{ loop.index is odd ? 'left' : 'right' }}">
                            <div class="bubble-content">
                                <i class="bi bi-stars text-primary me-2"></i>
                                {{ r }}
                            </div>
                        </div>
                    {% else %}
                        <div class="text-center py-5 opacity-50">
                            <i class="bi bi-check2-all display-4"></i>
                            <p class="mt-2">Tout est parfait ! Votre coach n'a aucune alerte.</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    {# ── Comparaison Mensuelle ── #}
    <div class="ai-reco-card border-0 shadow-lg mb-5" style="background: linear-gradient(135deg, #ffffff 0%, #f1f5f9 100%);">
        <div class="ai-reco-header mb-4">
            <div class="ai-reco-icon" style="background: linear-gradient(135deg, #10b981, #059669);"><i class="bi bi-bar-chart-steps"></i></div>
            <div>
                <h2 class="fw-900">Performance Mensuelle</h2>
                <p>Analyse comparative des flux de trésorerie</p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="month-card prev">
                    <div class="month-label">MOIS PRÉCÉDENT <small style="opacity:0.6;font-size:10px;">({{ data.debugPrevMonth }}/{{ data.debugPrevYear }})</small></div>
                    <div class="month-stats">
                        <div class="m-stat"><span class="l">Entrées</span><span class="v">+{{ data.prevMonth.income|number_format(0, ',', ' ') }} DT</span></div>
                        <div class="m-stat"><span class="l">Sorties</span><span class="v">-{{ data.prevMonth.expenses|number_format(0, ',', ' ') }} DT</span></div>
                        <div class="m-stat total"><span class="l">Net</span><span class="v">{{ data.prevMonth.balance|number_format(0, ',', ' ') }} DT</span></div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="month-card current">
                    {% set balDiff = data.currentMonth.balance - data.prevMonth.balance %}
                    <div class="month-label">CE MOIS-CI <span class="badge bg-success ms-2">ACTIF</span></div>
                    <div class="month-stats">
                        <div class="m-stat">
                            <span class="l">Entrées</span>
                            <span class="v">+{{ data.currentMonth.income|number_format(0, ',', ' ') }} DT</span>
                        </div>
                        <div class="m-stat">
                            <span class="l">Sorties</span>
                            <span class="v">-{{ data.currentMonth.expenses|number_format(0, ',', ' ') }} DT</span>
                        </div>
                        <div class="m-stat total">
                            <span class="l">Solde Net</span>
                            <div class="v-group">
                                <span class="v text-success">{{ data.currentMonth.balance|number_format(0, ',', ' ') }} DT</span>
                                <span class="diff {{ balDiff >= 0 ? 'up' : 'down' }}">
                                    <i class="bi bi-caret-{{ balDiff >= 0 ? 'up' : 'down' }}-fill"></i>
                                    {{ balDiff|abs|number_format(0) }} DT
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

<style>
    /* Premium Health Gauge */
    .health-gauge-container {
        width: 100px; height: 100px;
        filter: drop-shadow(0 10px 20px rgba(124, 58, 237, 0.2));
    }
    .health-gauge {
        width: 100%; height: 100%;
        border-radius: 50%;
        background: radial-gradient(closest-side, white 79%, transparent 80% 100%),
                    conic-gradient(var(--c) calc(var(--p) * 1%), #f3f4f6 0);
        display: flex; align-items: center; justify-content: center;
    }
    .gauge-value { font-size: 24px; font-weight: 900; color: #1e1b4b; }

    .ai-badge-premium {
        background: rgba(124, 58, 237, 0.1);
        color: #7c3aed;
        padding: 8px 16px;
        border-radius: 12px;
        font-weight: 800;
        font-size: 11px;
        letter-spacing: 1px;
        display: inline-block;
        border: 1px solid rgba(124, 58, 237, 0.2);
    }

    /* Prediction Animations */
    .prediction-pulse-bg {
        position: absolute; top: 50%; left: 50%;
        width: 300px; height: 300px;
        background: radial-gradient(circle, rgba(59, 130, 246, 0.05) 0%, transparent 70%);
        transform: translate(-50%, -50%);
        animation: pulsePredict 4s infinite;
        z-index: 0;
    }
    @keyframes pulsePredict {
        0% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
        50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.8; }
        100% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
    }

    .prediction-status-badge {
        display: inline-flex; align-items: center;
        padding: 8px 20px; border-radius: 100px;
        font-weight: 800; font-size: 14px;
        margin-top: 15px;
    }
    .prediction-status-badge.positive { background: #dcfce7; color: #16a34a; }
    .prediction-status-badge.negative { background: #fee2e2; color: #dc2626; }

    /* Coach Bubbles */
    .coach-bubble {
        margin-bottom: 20px;
        max-width: 90%;
    }
    .bubble-content {
        background: #fdfcff;
        padding: 16px 20px;
        border-radius: 20px;
        border: 1px solid #f3f0ff;
        font-size: 14px;
        color: #334155;
        line-height: 1.6;
        box-shadow: 0 4px 12px rgba(124, 58, 237, 0.05);
    }
    .coach-bubble.left { margin-right: auto; .bubble-content { border-bottom-left-radius: 4px; } }
    .coach-bubble.right { margin-left: auto; .bubble-content { border-bottom-right-radius: 4px; background: #fff; } }
    .bubble-actions { margin-top: 8px; padding-left: 10px; }

    /* Month Cards */
    .month-card {
        padding: 30px; border-radius: 24px;
        height: 100%; transition: all 0.3s;
    }
    .month-card.prev { background: #f8fafc; border: 1px solid #e2e8f0; }
    .month-card.current { background: white; border: 1.5px solid #10b981; box-shadow: 0 15px 35px rgba(16, 185, 129, 0.1); }
    
    .month-label { font-size: 11px; font-weight: 900; color: #94a3b8; letter-spacing: 1px; margin-bottom: 20px; }
    .month-stats { display: flex; flex-direction: column; gap: 15px; }
    .m-stat { display: flex; justify-content: space-between; align-items: center; }
    .m-stat .l { font-size: 14px; color: #64748b; font-weight: 500; }
    .m-stat .v { font-size: 16px; font-weight: 700; color: #1e1b4b; }
    .m-stat.total { margin-top: 10px; padding-top: 15px; border-top: 1px dashed rgba(0,0,0,0.1); }
    .m-stat.total .l { font-weight: 800; color: #1e1b4b; }
    .m-stat.total .v { font-size: 22px; font-weight: 900; }
    
    .v-group { text-align: right; }
    .diff { font-size: 12px; font-weight: 800; display: block; }
    .diff.up { color: #10b981; }
    .diff.down { color: #dc2626; }

    .fw-900 { font-weight: 900; }
</style>

    {# ── Legacy Recommendations (Hidden or removed if redundant) ── #}
    {# <div class="ai-reco-card"> ... </div> #}


{% endblock %}

