{% extends 'base.html.twig' %}

{% block title %}Analyse IA — Finora{% endblock %}

{% block stylesheets %}
<style>
.ai-page { padding: 40px 0 72px; background: #f8f5ff; min-height: 100vh; }

/* ── Hero ── */
.ai-hero {
    background: linear-gradient(135deg, #1e1b4b 0%, #4338ca 60%, #7c3aed 100%);
    border-radius: 22px; padding: 28px 32px; margin-bottom: 30px;
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;
    box-shadow: 0 20px 50px rgba(67,56,202,0.35);
    position: relative; overflow: hidden;
    animation: aiIn 0.4s ease both;
}
.ai-hero::before {
    content: ''; position: absolute; right: -60px; top: -60px;
    width: 240px; height: 240px; border-radius: 50%; background: rgba(255,255,255,0.05);
}
.ai-hero::after {
    content: ''; position: absolute; left: -40px; bottom: -50px;
    width: 160px; height: 160px; border-radius: 50%; background: rgba(255,255,255,0.03);
}
.ai-hero h1 { color: #fff !important; font-size: 24px !important; font-weight: 900 !important; margin: 0 !important; position: relative; z-index: 1; }
.ai-hero p  { color: rgba(255,255,255,0.7) !important; font-size: 14px !important; margin: 5px 0 0; position: relative; z-index: 1; }
.ai-hero-icon {
    width: 60px; height: 60px; border-radius: 18px;
    background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 28px; color: #fff; position: relative; z-index: 1;
}
.ai-hero-right { position: relative; z-index: 1; }

@keyframes aiIn { from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);} }

/* ── Stat Cards Grid ── */
.ai-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 28px; }

.ai-stat {
    background: #fff; border-radius: 20px;
    border: 1px solid rgba(124,58,237,0.07);
    box-shadow: 0 8px 28px -8px rgba(124,58,237,0.10);
    padding: 24px; display: flex; flex-direction: column; gap: 12px;
    animation: aiIn 0.4s ease both; transition: transform 0.2s, box-shadow 0.2s;
}
.ai-stat:hover { transform: translateY(-4px); box-shadow: 0 16px 40px -8px rgba(124,58,237,0.16); }
.ai-stat:nth-child(1) { animation-delay: 0.05s; }
.ai-stat:nth-child(2) { animation-delay: 0.10s; }
.ai-stat:nth-child(3) { animation-delay: 0.15s; }
.ai-stat:nth-child(4) { animation-delay: 0.20s; }

.ai-stat-head { display: flex; align-items: center; gap: 12px; }
.ai-stat-icon {
    width: 48px; height: 48px; border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; flex-shrink: 0;
}
.asi-blue   { background: #dbeafe; color: #2563eb; }
.asi-purple { background: #ede9fe; color: #7c3aed; }
.asi-red    { background: #fee2e2; color: #dc2626; }
.asi-green  { background: #dcfce7; color: #16a34a; }

.ai-stat-label { font-size: 11.5px; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; }
.ai-stat-value { font-size: 28px; font-weight: 900; color: #1e1b4b; line-height: 1.1; font-family: 'Inter', sans-serif; }
.ai-stat-value sup { font-size: 14px; color: #6b7280; font-weight: 600; }
.ai-stat-sub { font-size: 12px; color: #9ca3af; font-weight: 500; }

/* ── Recommendations ── */
.ai-reco-card {
    background: #fff; border-radius: 22px; padding: 32px 36px;
    border: 1px solid rgba(124,58,237,0.07);
    box-shadow: 0 16px 48px -12px rgba(124,58,237,0.12);
    animation: aiIn 0.4s 0.25s ease both;
}
.ai-reco-header { display: flex; align-items: center; gap: 16px; margin-bottom: 26px; }
.ai-reco-icon {
    width: 58px; height: 58px; border-radius: 18px;
    background: linear-gradient(135deg, #7c3aed, #4f46e5);
    display: flex; align-items: center; justify-content: center;
    font-size: 26px; color: #fff;
    box-shadow: 0 8px 20px rgba(124,58,237,0.3);
    flex-shrink: 0;
}
.ai-reco-header h2 { font-size: 22px; font-weight: 800; color: #1e1b4b; margin: 0; }
.ai-reco-header p { color: #6b7280; font-size: 14px; margin: 4px 0 0; }

.ai-reco-list { display: flex; flex-direction: column; gap: 14px; }
.ai-reco-item {
    display: flex; align-items: flex-start; gap: 14px;
    background: linear-gradient(135deg, #faf5ff, #f5f3ff);
    border-radius: 14px; padding: 18px 22px;
    border-left: 5px solid #7c3aed;
    font-size: 15px; color: #334155; line-height: 1.6;
    transition: transform 0.2s, box-shadow 0.2s;
}
.ai-reco-item:hover { transform: translateX(4px); box-shadow: 0 4px 16px rgba(124,58,237,0.10); }
.ai-reco-item i { color: #7c3aed; margin-top: 2px; flex-shrink: 0; font-size: 16px; }

/* ── Back button ── */
.ai-back-btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 9px 20px; border-radius: 50px; font-size: 13px; font-weight: 600;
    color: rgba(255,255,255,0.84); text-decoration: none;
    background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2);
    transition: all 0.2s; position: relative; z-index: 1;
}
.ai-back-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }
</style>
{% endblock %}

{% block content %}
<div class="ai-page">
<div class="container">

    {# ── Hero ── #}
    <div class="ai-hero">
        <div style="display:flex;align-items:center;gap:18px;position:relative;z-index:1;">
            <div class="ai-hero-icon">🤖</div>
            <div>
                <h1><i class="bi bi-robot me-2"></i>Analyse IA Financière</h1>
                <p>Prédictions intelligentes générées à partir de votre portefeuille</p>
            </div>
        </div>
        <div class="ai-hero-right">
            <a href="{{ path('dashboard') }}" class="ai-back-btn">
                <i class="bi bi-arrow-left"></i> Tableau de Bord
            </a>
        </div>
    </div>

    {# ── Stats Grid ── #}
    <div class="ai-stats">

        {# Solde Actuel #}
        <div class="ai-stat">
            <div class="ai-stat-head">
                <div class="ai-stat-icon asi-blue"><i class="bi bi-wallet2"></i></div>
                <span class="ai-stat-label">Solde Actuel</span>
            </div>
            <div class="ai-stat-value">{{ data.balance|number_format(2, ',', ' ') }} <sup>DT</sup></div>
            <p class="ai-stat-sub">État réel de votre portefeuille</p>
        </div>

        {# Ratio #}
        <div class="ai-stat">
            <div class="ai-stat-head">
                <div class="ai-stat-icon asi-purple"><i class="bi bi-pie-chart-fill"></i></div>
                <span class="ai-stat-label">Ratio d'Activité</span>
            </div>
            <div class="ai-stat-value">{{ data.ratio }}<sup>%</sup></div>
            <p class="ai-stat-sub">Dépenses par rapport aux revenus</p>
        </div>

        {# Risk #}
        {% set colorMap = {'high': '#dc2626', 'medium': '#d97706', 'low': '#16a34a'} %}
        <div class="ai-stat">
            <div class="ai-stat-head">
                <div class="ai-stat-icon asi-red"><i class="bi bi-shield-exclamation"></i></div>
                <span class="ai-stat-label">Niveau de Risque</span>
            </div>
            <div class="ai-stat-value" style="color: {{ colorMap[data.cssClass] | default('#1e1b4b') }}; font-size: 24px;">
                {{ data.risk }}
            </div>
            <p class="ai-stat-sub">Analyse de la volatilité financière</p>
        </div>

        {# Future expenses #}
        <div class="ai-stat">
            <div class="ai-stat-head">
                <div class="ai-stat-icon asi-green"><i class="bi bi-graph-up-arrow"></i></div>
                <span class="ai-stat-label">Dépenses Futures</span>
            </div>
            <div class="ai-stat-value">{{ data.predictedExpenses }} <sup>DT</sup></div>
            <p class="ai-stat-sub">Estimation pour la prochaine période</p>
        </div>

    </div>

    {# ── Prediction & Coach Row ── #}
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 28px; margin-bottom: 30px;">
        
        {# ── MODULE: Prédire Futur Solde ── #}
        <div class="ai-reco-card" style="margin:0; border-top: 5px solid #3b82f6;">
            <div class="ai-reco-header">
                <div class="ai-reco-icon" style="background: linear-gradient(135deg, #3b82f6, #2563eb);"><i class="bi bi-graph-up"></i></div>
                <div>
                    <h2>Prédire Futur Solde</h2>
                    <p>Projection financière sur 30 jours</p>
                </div>
            </div>
            <div style="text-align:center; padding: 20px 0;">
                <div style="font-size: 42px; font-weight: 900; color: #1e1b4b;">
                    {{ data.predictedBalance|number_format(2, ',', ' ') }} <span style="font-size: 18px; color: #64748b;">DT</span>
                </div>
                <div style="margin-top: 10px; display: inline-flex; align-items: center; gap: 8px; padding: 6px 15px; border-radius: 50px; background: {{ (data.predictedBalance >= data.balance) ? '#dcfce7' : '#fee2e2' }}; color: {{ (data.predictedBalance >= data.balance) ? '#15803d' : '#991b1b' }}; font-weight: 700; font-size: 14px;">
                    <i class="bi {{ (data.predictedBalance >= data.balance) ? 'bi-caret-up-fill' : 'bi-caret-down-fill' }}"></i>
                    {{ (data.predictedBalance - data.balance)|abs|number_format(2, ',', ' ') }} DT vs Aujourd'hui
                </div>
            </div>
            <p style="font-size: 13px; color: #64748b; text-align: center; font-style: italic;">
                *Cette prédiction utilise une courbe de tendance basée sur vos dépenses futures estimées à {{ data.predictedExpenses }} DT.
            </p>
        </div>

        {# ── MODULE: Coach Financier ── #}
        <div class="ai-reco-card" style="margin:0; border-top: 5px solid #7c3aed;">
            <div class="ai-reco-header">
                <div class="ai-reco-icon"><i class="bi bi-person-badge"></i></div>
                <div>
                    <h2>Coach Financier</h2>
                    <p>Votre guide digital intelligent</p>
                </div>
            </div>
            <div class="ai-reco-list">
                {% for r in data.recommendation %}
                    <div class="ai-reco-item" style="border-left-color: #7c3aed;">
                        <i class="bi bi-chat-right-dots-fill"></i>
                        <span>{{ r }}</span>
                    </div>
                {% else %}
                    <div style="text-align:center;padding:40px;color:#9ca3af;">
                        Tout est parfait ! Votre coach n'a aucune alerte à signaler.
                    </div>
                {% endfor %}
            </div>
        </div>

    </div>

    {# ── Comparaison Mensuelle ── #}
    <div class="ai-reco-card" style="margin-top: 28px; border-top: 5px solid #10b981;">
        <div class="ai-reco-header">
            <div class="ai-reco-icon" style="background: linear-gradient(135deg, #10b981, #059669);"><i class="bi bi-calendar-range"></i></div>
            <div>
                <h2>Comparaison Mensuelle</h2>
                <p>Évolution de votre santé financière par rapport au mois dernier</p>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
            {# Last Month Card #}
            <div style="background: #f8fafc; border-radius: 20px; padding: 24px; border: 1px solid #e2e8f0;">
                <h6 style="font-size: 11px; font-weight: 800; color: #64748b; text-transform: uppercase; margin-bottom: 15px;">Mois Précédent</h6>
                <div style="display: flex; flex-direction: column; gap: 10px;">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-size: 13px; color: #475569;">Revenus</span>
                        <span style="font-size: 15px; font-weight: 700; color: #1e1b4b;">{{ data.prevMonth.income|number_format(2, ',', ' ') }} DT</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-size: 13px; color: #475569;">Dépenses</span>
                        <span style="font-size: 15px; font-weight: 700; color: #1e1b4b;">{{ data.prevMonth.expenses|number_format(2, ',', ' ') }} DT</span>
                    </div>
                    <hr style="margin: 10px 0; border: none; border-top: 1px dashed #cbd5e1;">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-size: 13px; font-weight: 700; color: #1e1b4b;">Auto-Financement</span>
                        <span style="font-size: 15px; font-weight: 800; color: #4f46e5;">{{ data.prevMonth.balance|number_format(2, ',', ' ') }} DT</span>
                    </div>
                </div>
            </div>

            {# Current Month Card #}
            <div style="background: white; border-radius: 20px; padding: 24px; border: 1px solid #10b981; box-shadow: 0 10px 25px rgba(16,185,129,0.1);">
                {% set balDiff = data.currentMonth.balance - data.prevMonth.balance %}
                <h6 style="font-size: 11px; font-weight: 800; color: #10b981; text-transform: uppercase; margin-bottom: 15px;">Ce Mois-ci (En Cours)</h6>
                <div style="display: flex; flex-direction: column; gap: 10px;">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-size: 13px; color: #475569;">Revenus</span>
                        {% set incDiffPct = data.prevMonth.income > 0 ? (data.currentMonth.income - data.prevMonth.income) / data.prevMonth.income * 100 : 100 %}
                        <span style="font-size: 15px; font-weight: 700; color: #1e1b4b;">
                            {{ data.currentMonth.income|number_format(2, ',', ' ') }} DT
                            <small style="font-size: 11px; color: {{ incDiffPct >= 0 ? '#10b981' : '#dc2626' }};">({{ incDiffPct >= 0 ? '+' : '' }}{{ incDiffPct|round(1) }}%)</small>
                        </span>
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-size: 13px; color: #475569;">Dépenses</span>
                        {% set expDiffPct = data.prevMonth.expenses > 0 ? (data.currentMonth.expenses - data.prevMonth.expenses) / data.prevMonth.expenses * 100 : 0 %}
                        <span style="font-size: 15px; font-weight: 700; color: #1e1b4b;">
                            {{ data.currentMonth.expenses|number_format(2, ',', ' ') }} DT
                            <small style="font-size: 11px; color: {{ expDiffPct <= 0 ? '#10b981' : '#dc2626' }};">({{ expDiffPct >= 0 ? '+' : '' }}{{ expDiffPct|round(1) }}%)</small>
                        </span>
                    </div>
                    <hr style="margin: 10px 0; border: none; border-top: 1px dashed #10b981;">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-size: 13px; font-weight: 700; color: #1e1b4b;">Solde Net Actuel</span>
                        <div style="text-align: right;">
                            <div style="font-size: 18px; font-weight: 900; color: #059669;">{{ data.currentMonth.balance|number_format(2, ',', ' ') }} DT</div>
                            <div style="font-size: 11px; font-weight: 700; color: {{ balDiff >= 0 ? '#10b981' : '#dc2626' }};">
                                {{ balDiff >= 0 ? '▲ +' : '▼ ' }}{{ balDiff|abs|number_format(2, ',', ' ') }} DT vs mois dernier
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ── Legacy Recommendations (Hidden or removed if redundant) ── #}
    {# <div class="ai-reco-card"> ... </div> #}


</div>
</div>
{% endblock %}

