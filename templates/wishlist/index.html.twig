{% extends 'base.html.twig' %}

{% block title %}Finora - Ma Wishlist{% endblock %}

{% block body %}
<main>
    <section class="pt-5 pb-0">
        <div class="container">
            <div class="row align-items-center g-4 purple-section p-4 p-lg-5" style="border-radius: 25px; background: linear-gradient(135deg, #f5f3ff 0%, #ede9fe 100%);">
                <div class="col-lg-6">
                    <span class="badge bg-primary bg-opacity-10 text-primary mb-3">Tableau de bord</span>
                    <h1 class="display-5 mb-3 finora-title" style="color: #1e1b4b; font-weight: 800;">Ma Wishlist</h1>
                    <p class="mb-4 text-muted">
                        Retrouvez ici toutes les formations que vous avez marquées comme favorites. 
                        Prenez votre temps pour apprendre et inscrivez-vous quand vous êtes prêt.
                    </p>
                </div>
                <div class="col-lg-6 text-center">
                    <div class="icon-xl bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 120px; height: 120px;">
                        <i class="bi bi-heart-fill display-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-5">
        <div class="container">
            <div id="wishlist-container">
                {% if wishlist|length > 0 %}
                    <div class="row g-4">
                        {% for formation in wishlist %}
                            <div class="col-md-6 col-xl-4 wishlist-item-wrapper" id="wishlist-item-{{ formation.id }}">
                                <div class="card formation-card border-0 h-100 overflow-hidden shadow-sm" style="border-radius: 20px; transition: all 0.3s ease;">
                                    <div class="position-relative">
                                        {% if formation.imageUrl %}
                                            <img src="{{ asset('uploads/formations/' ~ formation.imageUrl) }}" class="card-img-top" alt="{{ formation.titre }}" style="height: 200px; object-fit: cover;">
                                        {% else %}
                                            <img src="{{ asset('assets/images/courses/4by3/16.jpg') }}" class="card-img-top" alt="{{ formation.titre }}" style="height: 200px; object-fit: cover;">
                                        {% endif %}
                                        <button class="wishlist-remove-btn position-absolute top-0 end-0 m-3 btn btn-white btn-round shadow-sm" 
                                                data-id="{{ formation.id }}"
                                                style="border-radius: 50%; width: 35px; height: 35px; background: rgba(255,255,255,0.9); padding: 0; display: flex; align-items: center; justify-content: center; border: none;">
                                            <i class="bi bi-x-lg text-danger"></i>
                                        </button>
                                        <div class="position-absolute bottom-0 start-0 p-3 w-100" style="background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);">
                                            <span class="badge bg-white text-primary rounded-pill px-3">{{ formation.niveau }}</span>
                                        </div>
                                    </div>
                                    <div class="card-body d-flex flex-column p-4">
                                        <h5 class="card-title fw-bold mb-3">{{ formation.titre }}</h5>
                                        <p class="text-muted small mb-4 flex-grow-1">
                                            {{ formation.description|slice(0, 100) }}...
                                        </p>
                                        <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
                                            <span class="fw-bold text-dark">{{ formation.prix ? formation.prix ~ ' TND' : 'Gratuit' }}</span>
                                            <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn btn-primary btn-sm rounded-pill px-4">
                                                Voir la formation
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center py-5">
                        <div class="mb-4">
                            <i class="bi bi-heart-break display-1 text-light"></i>
                        </div>
                        <h3 class="fw-bold">Votre wishlist est vide</h3>
                        <p class="text-muted mb-4">Explorez nos formations et ajoutez celles qui vous intéressent à vos favoris.</p>
                        <a href="{{ path('app_formations') }}" class="btn btn-primary px-5 py-3 rounded-pill fw-bold">
                            Découvrir les formations
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>
</main>

<style>
    .wishlist-item-wrapper {
        transition: all 0.5s ease;
    }
    .wishlist-item-wrapper.fade-out {
        opacity: 0;
        transform: scale(0.9);
    }
</style>

<script>
    document.addEventListener('click', async function(e) {
        const btn = e.target.closest('.wishlist-remove-btn');
        if (!btn) return;

        const id = btn.getAttribute('data-id');
        const wrapper = document.getElementById(`wishlist-item-${id}`);

        if (confirm('Voulez-vous retirer cette formation de votre wishlist ?')) {
            try {
                const response = await fetch(`/wishlist/toggle/${id}`, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const data = await response.json();
                
                if (data.status === 'removed') {
                    wrapper.classList.add('fade-out');
                    setTimeout(() => {
                        wrapper.remove();
                        if (document.querySelectorAll('.wishlist-item-wrapper').length === 0) {
                            location.reload();
                        }
                    }, 500);
                }
            } catch (err) {
                console.error('Error removing from wishlist:', err);
            }
        }
    });
</script>
{% endblock %}
