{% extends 'base.html.twig' %}

{% block title %}Ma Wishlist Formations — Finora{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="h3 fw-bold"><i class="fas fa-heart text-danger me-2"></i>Ma Wishlist Formations</h1>
            <p class="text-muted">Retrouvez toutes les formations que vous avez mises de côté.</p>
        </div>
    </div>

    {% if wishlist|length > 0 %}
        <div class="row g-4">
            {% for formation in wishlist %}
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body">
                            <span class="badge bg-primary bg-opacity-10 text-primary mb-2">Formation</span>
                            <h5 class="card-title fw-bold">{{ formation.titre }}</h5>
                            <p class="card-text text-muted small mb-3">{{ formation.description|slice(0, 100) }}...</p>
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <span class="h5 mb-0 text-primary fw-bold">{{ formation.prix }} TND</span>
                                <div class="d-flex gap-2">
                                    <a href="{{ path('app_formations') }}" class="btn btn-sm btn-outline-primary">Détails</a>
                                    <form action="{{ path('app_wishlist_toggle', {id: formation.id}) }}" method="POST">
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {# Sinon message vide #}
    {% else %}
        <div class="text-center py-5">
            <div class="avatar avatar-xxl bg-light text-muted rounded-circle mb-3 mx-auto d-flex align-items-center justify-content-center">
                <i class="fas fa-heart fa-3x"></i>
            </div>
            <h5>Votre wishlist est vide</h5>
            <p class="text-muted">Explorez nos formations et ajoutez-en à vos favoris !</p>
            <a href="{{ path('app_formations') }}" class="btn btn-primary mt-2">Voir les formations</a>
        </div>
    {% endif %}
</div>
{% endblock %}
