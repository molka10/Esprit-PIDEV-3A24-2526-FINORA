{% extends 'base.html.twig' %}

{% block title %}Investment Details{% endblock %}

{% block body %}

<div class="container mt-5">

    <h1 class="text-primary mb-4">📊 Investment Details</h1>

    <div class="card shadow p-4">

        <table class="table table-bordered">

            <tbody>

                <tr>
                    <th>ID</th>
                    <td>{{ investment.id }}</td>
                </tr>

                <tr>
                    <th>Name</th>
                    <td>{{ investment.name }}</td>
                </tr>

                <tr>
                    <th>Category</th>
                    <td>{{ investment.category }}</td>
                </tr>

                <tr>
                    <th>Location</th>
                    <td>{{ investment.location }}</td>
                </tr>

                <tr>
                    <th>Estimated Value</th>
                    <td class="text-success fw-bold">
                        {{ investment.estimatedValue }} TND
                    </td>
                </tr>

                <tr>
                    <th>Risk Level</th>
                    <td>
                        <span class="badge 
                            {% if investment.riskLevel == 'HIGH' %}bg-danger
                            {% elseif investment.riskLevel == 'MEDIUM' %}bg-warning
                            {% else %}bg-success
                            {% endif %}">
                            {{ investment.riskLevel }}
                        </span>
                    </td>
                </tr>

                <tr>
                    <th>Status</th>
                    <td>{{ investment.status }}</td>
                </tr>

                <tr>
                    <th>Description</th>
                    <td>{{ investment.description ?: 'No description' }}</td>
                </tr>

                <tr>
                    <th>Image</th>
                    <td>
                        {% if investment.imageUrl %}
                            <img src="{{ investment.imageUrl }}" 
                                 class="img-fluid rounded"
                                 style="max-height:200px;">
                        {% else %}
                            <span class="text-muted">No image</span>
                        {% endif %}
                    </td>
                </tr>

                <tr>
                    <th>Created At</th>
                    <td>
                        {{ investment.createdAt ? investment.createdAt|date('Y-m-d H:i') : '' }}
                    </td>
                </tr>

            </tbody>

        </table>

    </div>

    <!-- 🔥 ACTIONS -->
    <div class="mt-4 d-flex gap-2">

        <a href="{{ path('app_investment_index') }}" class="btn btn-secondary">
            ← Back
        </a>

        <a href="{{ path('app_investment_edit', {'id': investment.id}) }}" class="btn btn-warning">
            ✏️ Edit
        </a>

        <form method="post"
              action="{{ path('app_investment_delete', {'id': investment.id}) }}"
              onsubmit="return confirm('Are you sure?')">

            <input type="hidden"
                   name="_token"
                   value="{{ csrf_token('delete' ~ investment.id) }}">

            <button class="btn btn-danger">🗑 Delete</button>
        </form>

    </div>

</div>

{% endblock %}