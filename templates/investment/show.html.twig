{% extends 'base.html.twig' %}

{% block title %}Investissement : {{ investment.name }}{% endblock %}

{% block body %}
<!-- ======================= HEADER START ======================= -->
<header class="navbar-light navbar-sticky">
    <nav class="navbar navbar-expand-xl z-index-9">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}">
                <img class="light-mode-item navbar-brand-item" src="{{ asset('assets/images/logo.svg') }}" alt="FINORA" style="height:40px;">
                <img class="dark-mode-item navbar-brand-item" src="{{ asset('assets/images/logo-light.svg') }}" alt="FINORA" style="height:40px;">
            </a>
            <button class="navbar-toggler ms-auto" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarCollapse"
                    aria-controls="navbarCollapse" aria-expanded="false">
                <span class="navbar-toggler-animation">
                    <span></span><span></span><span></span>
                </span>
            </button>
            <div class="navbar-collapse w-100 collapse" id="navbarCollapse">
                <ul class="navbar-nav navbar-nav-scroll mx-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="{{ path('app_investment_index') }}">Investissements</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_management_index') }}">Management</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('admin_dashboard') }}">Dashboard</a>
                    </li>
                </ul>
            </div>
            <!-- Profile -->
            <div class="dropdown ms-1 ms-lg-0">
                <a class="avatar avatar-sm p-0" href="#"
                   id="profileDropdown" role="button"
                   data-bs-toggle="dropdown" aria-expanded="false">
                    <img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/01.jpg') }}" alt="avatar">
                </a>
                <ul class="dropdown-menu dropdown-animation dropdown-menu-end shadow pt-3" aria-labelledby="profileDropdown">
                    <li class="px-3 mb-3">
                        <div class="d-flex align-items-center">
                            <div class="avatar me-3">
                                <img class="avatar-img rounded-circle shadow" src="{{ asset('assets/images/avatar/01.jpg') }}" alt="avatar">
                            </div>
                            <div>
                                <a class="h6" href="#">Mon Compte</a>
                            </div>
                        </div>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item" href="{{ path('admin_dashboard') }}"><i class="bi bi-speedometer2 fa-fw me-2"></i>Dashboard</a></li>
                </ul>
            </div>
        </div>
    </nav>
</header>
<!-- ======================= HEADER END ======================= -->

<main>
    <!-- ======================= PAGE BANNER START ======================= -->
    <section class="bg-dark align-items-center d-flex position-relative overflow-hidden" style="min-height: 250px;">
        <!-- Background Image -->
        {% set imgSrc = investment_image_src(investment) %}
        {% if imgSrc %}
            <div style="background: url('{{ imgSrc }}') no-repeat center center; background-size: cover; position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.3; filter: blur(3px);"></div>
        {% else %}
            <div style="background: url('{{ asset('assets/images/pattern/04.png') }}') no-repeat center center; background-size: cover; position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.3;"></div>
        {% endif %}
        
        <div class="container position-relative z-index-9">
            <div class="row">
                <div class="col-12 text-center">
                    <h1 class="text-white display-4">{{ investment.name }}</h1>
                    <div class="d-flex justify-content-center">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb breadcrumb-dark breadcrumb-dots mb-0">
                                <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                                <li class="breadcrumb-item"><a href="{{ path('app_investment_index') }}">Investissements</a></li>
                                <li class="breadcrumb-item active" aria-current="page">{{ investment.name }}</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- ======================= PAGE BANNER END ======================= -->

    <!-- ======================= DETAIL SECTION START ======================= -->
    <section class="pt-5 pb-0">
        <div class="container">
            <div class="row g-4 g-sm-5">
                
                <!-- Left Sidebar: Details & Info -->
                <div class="col-xl-8">
                    
                    <!-- Cover Image -->
                    {% if imgSrc %}
                        <div class="card shadow-sm mb-4 border-0">
                            <img src="{{ imgSrc }}" class="card-img-top object-fit-cover" style="max-height: 400px;" alt="{{ investment.name }}">
                        </div>
                    {% endif %}

                    <!-- About -->
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-body p-sm-5">
                            <h3 class="mb-3">À propos de ce projet</h3>
                            <p class="text-muted fs-6" style="line-height: 1.8;">
                                {{ investment.description|nl2br ?: 'Aucune description complète n\'a été fournie pour ce projet pour le moment. Veuillez contacter notre équipe d\'analyse pour plus d\'informations.' }}
                            </p>
                            
                            <hr class="my-4">

                            <!-- Feature Grid -->
                            <h5 class="mb-3">Informations Clés</h5>
                            <div class="row g-4">
                                <div class="col-sm-6">
                                    <div class="d-flex align-items-center">
                                        <div class="icon-lg bg-primary bg-opacity-10 text-primary rounded flex-shrink-0">
                                            <i class="bi bi-tag fs-4"></i>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="mb-0 text-muted fw-normal">Catégorie</h6>
                                            <h5 class="mb-0">{{ investment.category }}</h5>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-sm-6">
                                    <div class="d-flex align-items-center">
                                        <div class="icon-lg bg-info bg-opacity-10 text-info rounded flex-shrink-0">
                                            <i class="bi bi-geo-alt fs-4"></i>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="mb-0 text-muted fw-normal">Localisation</h6>
                                            <h5 class="mb-0">{{ investment.location ?: 'Non spécifiée' }}</h5>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-sm-6">
                                    <div class="d-flex align-items-center">
                                        <div class="icon-lg bg-warning bg-opacity-10 text-warning rounded flex-shrink-0">
                                            <i class="bi bi-activity fs-4"></i>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="mb-0 text-muted fw-normal">Statut du Projet</h6>
                                            <h5 class="mb-0">
                                                {% if investment.status == 'ACTIVE' %}
                                                    <span class="badge bg-success">Actif</span>
                                                {% else %}
                                                    <span class="badge bg-secondary">{{ investment.status }}</span>
                                                {% endif %}
                                            </h5>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-sm-6">
                                    <div class="d-flex align-items-center">
                                        <div class="icon-lg bg-purple bg-opacity-10 text-purple rounded flex-shrink-0">
                                            <i class="bi bi-calendar-event fs-4"></i>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="mb-0 text-muted fw-normal">Création</h6>
                                            <h5 class="mb-0">{{ investment.createdAt ? investment.createdAt|date('d M Y') : 'N/A' }}</h5>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Right Sidebar: Sticky Action Card -->
                <div class="col-xl-4">
                    <div style="position: sticky; top: 100px;">
                        
                        <!-- Actions & Price -->
                        <div class="card shadow border-0 mb-4">
                            <div class="card-body p-4 p-sm-5 text-center">
                                
                                <span class="badge bg-primary text-white py-2 px-3 fw-normal mb-3 rounded-pill">
                                    <i class="fas fa-star text-warning me-1"></i>Opportunité Validée
                                </span>

                                <h6 class="text-muted mb-1">Valeur Estimée</h6>
                                <div class="d-flex justify-content-center align-items-center gap-2 mb-4">
                                    <h1 class="text-success mb-0 fw-bold">
                                        {{ investment.estimatedValue|format_currency }}
                                    </h1>
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-light border lh-1" type="button" data-bs-toggle="dropdown"><i class="bi bi-arrow-left-right"></i></button>
                                        <ul class="dropdown-menu dropdown-menu-end min-w-auto shadow-sm">
                                            <li><a class="dropdown-item small py-1" href="{{ path('app_switch_currency', {'currency': 'TND'}) }}">🇹🇳 TND</a></li>
                                            <li><a class="dropdown-item small py-1" href="{{ path('app_switch_currency', {'currency': 'EUR'}) }}">🇪🇺 EUR</a></li>
                                            <li><a class="dropdown-item small py-1" href="{{ path('app_switch_currency', {'currency': 'USD'}) }}">🇺🇸 USD</a></li>
                                        </ul>
                                    </div>
                                </div>

                                <h6 class="text-muted mb-2">Profil de Risque</h6>
                                <div class="mb-4">
                                    {% if investment.riskLevel == 'HIGH' %}
                                        <span class="fs-5 fw-bold text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>Élevé</span>
                                    {% elseif investment.riskLevel == 'MEDIUM' %}
                                        <span class="fs-5 fw-bold text-warning"><i class="bi bi-exclamation-circle-fill me-2"></i>Moyen</span>
                                    {% else %}
                                        <span class="fs-5 fw-bold text-success"><i class="bi bi-shield-check me-2"></i>Faible</span>
                                    {% endif %}
                                </div>

                                <hr>

                                <!-- INVEST BUTTON -->
                                <div class="mt-4">
                                    <div class="d-grid">
                                        <a href="{{ path('app_management_new', {'inv_id': investment.id}) }}" class="btn btn-primary btn-lg mb-2">
                                            <i class="bi bi-wallet2 me-2"></i>Investir Maintenant
                                        </a>
                                    </div>
                                    <p class="small text-muted mb-0">Participez à ce projet dès aujourd'hui.</p>
                                </div>

                            </div>
                        </div>

                        <!-- Admin Actions -->
                        {% if app.session.get('role', 'user') == 'user' %}
                            <div class="card shadow-sm border-0 border-top border-warning border-3">
                                <div class="card-header bg-transparent mb-0 pb-0">
                                    <h6 class="text-warning mb-0"><i class="bi bi-shield-lock me-1"></i>Gestion de l'Investissement</h6>
                                </div>
                                <div class="card-body">
                                    <div class="d-grid gap-2">
                                        <a href="{{ path('app_investment_edit', {'id': investment.id}) }}" class="btn btn-outline-warning">
                                            <i class="bi bi-pencil me-1"></i>Modifier
                                        </a>

                                        <form method="post" action="{{ path('app_investment_delete', {'id': investment.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet investissement ?')" class="d-grid">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ investment.id) }}">
                                            <button class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i>Supprimer</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        {% endif %}

                    </div>
                </div>

            </div>
        </div>
    </section>
    <!-- ======================= DETAIL SECTION END ======================= -->
</main>

{% endblock %}