{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/vendor/choices/js/choices.min.js') }}"></script>

    <script>
    // Grid / List toggle
    document.addEventListener('DOMContentLoaded', function () {

        const btnGrid = document.getElementById('btn-grid');
        const btnList = document.getElementById('btn-list');
        const container = document.getElementById('investments-container');

        function setGrid() {
            container.classList.remove('row');
            container.classList.add('row');
            container.querySelectorAll('.investment-item').forEach(function(item) {
                item.classList.remove('col-12');
                item.classList.add('col-md-6', 'col-xl-4');
                // Make the inner card full-height grid style
                const row = item.querySelector('.row.g-0');
                if (row) {
                    row.classList.remove('row', 'g-0');
                    row.classList.add('d-block');
                }
                const imgCol = item.querySelector('.col-md-4');
                if (imgCol) imgCol.className = 'w-100';
                const bodyCol = item.querySelector('.col-md-8');
                if (bodyCol) bodyCol.className = 'w-100';
            });
            btnGrid.classList.add('active');
            btnList.classList.remove('active');
        }

        function setList() {
            container.querySelectorAll('.investment-item').forEach(function(item) {
                item.classList.remove('col-md-6', 'col-xl-4');
                item.classList.add('col-12');
                const block = item.querySelector('.d-block');
                if (block) {
                    block.classList.remove('d-block');
                    block.classList.add('row', 'g-0');
                }
                const imgCol = item.querySelector('.w-100:first-child');
                if (imgCol) imgCol.className = 'col-md-4 overflow-hidden position-relative';
                const bodyCol = item.querySelector('.card-body')?.parentElement;
                if (bodyCol && bodyCol !== imgCol) bodyCol.className = 'col-md-8';
            });
            btnList.classList.add('active');
            btnGrid.classList.remove('active');
        }

        if (btnGrid) btnGrid.addEventListener('click', setGrid);
        if (btnList) btnList.addEventListener('click', setList);
    });
    </script>
{% endblock %}
