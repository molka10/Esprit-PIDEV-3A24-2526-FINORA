{% extends 'base.html.twig' %}

{% block title %}Opportunités d'Investissement - FINORA{% endblock %}

{% block breadcrumb %}Investissements{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --finora-purple-light: #ede9fe;
            --finora-purple: #7c3aed;
            --finora-purple-dark: #4c1d95;
            --finora-indigo: #4338ca;
            --glass-bg: rgba(255, 255, 255, 0.9);
            --glass-border: rgba(124, 58, 237, 0.15);
        }
        
        .filter-sidebar {
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 10px 40px rgba(124, 58, 237, 0.08);
            border: 1px solid var(--glass-border);
        }

        .investment-card {
            background: #fff;
            border-radius: 20px;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: 1px solid var(--glass-border);
            overflow: hidden;
            margin-bottom: 25px;
            animation: fadeInUp 0.6s ease forwards;
            opacity: 0;
            transform: translateY(20px);
        }

        .investment-card:hover {
            transform: translateY(-8px) scale(1.01);
            box-shadow: 0 20px 40px rgba(124, 58, 237, 0.15);
            border-color: rgba(124, 58, 237, 0.4);
        }

        .invest-btn, .btn-primary {
            background: linear-gradient(135deg, var(--finora-purple) 0%, var(--finora-indigo) 100%);
            border: none;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        
        .invest-btn:hover, .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(124, 58, 237, 0.3);
        }

        .badge-en-cours {
            background: linear-gradient(135deg, var(--finora-purple) 0%, var(--finora-indigo) 100%);
            color: white;
            padding: 5px 15px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
            box-shadow: 0 4px 10px rgba(124, 58, 237, 0.3);
        }

        .badge-risk {
            background: var(--finora-purple-light);
            color: var(--finora-purple-dark);
            padding: 5px 15px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
            border: 1px solid rgba(124, 58, 237, 0.2);
        }
        
        .risk-pill.active {
            background: linear-gradient(135deg, var(--finora-purple) 0%, var(--finora-indigo) 100%) !important;
            border: none !important;
            color: white !important;
            box-shadow: 0 4px 15px rgba(124, 58, 237, 0.3);
        }

        .metric-badge {
            padding: 5px 12px;
            border-radius: 50px;
            font-size: 0.8rem;
            font-weight: 600;
        }
        
        /* Overriding green/blue generic colors with purple tones */
        .metric-yield { background: var(--finora-purple-light); color: var(--finora-purple-dark); }
        .metric-duration { background: #f1f5f9; color: #475569; }

        .progress {
            height: 8px;
            background-color: var(--finora-purple-light);
            border-radius: 10px;
        }
        
        .progress-bar {
            background: linear-gradient(90deg, var(--finora-indigo) 0%, var(--finora-purple) 100%);
            border-radius: 10px;
            position: relative;
            overflow: hidden;
        }
        
        .progress-bar::after {
            content: "";
            position: absolute;
            top: 0; left: 0; bottom: 0; right: 0;
            background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.4) 50%, rgba(255,255,255,0) 100%);
            animation: shimmer 2s infinite;
        }

        @keyframes fadeInUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        @keyframes shimmer {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }
        
        /* Form controls focus & interaction */
        .form-control:focus, .form-select:focus, .form-check-input:checked {
            border-color: var(--finora-purple) !important;
            box-shadow: 0 0 0 0.25rem rgba(124, 58, 237, 0.25) !important;
        }
        
        .form-check-input:checked {
            background-color: var(--finora-purple) !important;
        }

        .text-primary, .text-decoration-none:hover {
            color: var(--finora-purple) !important;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="row g-4">
        <!-- Sidebar Filters -->
        <div class="col-lg-3">
            <div class="filter-sidebar shadow-sm">
                <form id="investment-filter-form" method="get" action="{{ path('app_investment_index') }}">
                    <!-- RECHERCHE -->
                    <h6 class="fw-bold mb-3 text-uppercase small text-primary" style="letter-spacing: 1px;">Recherche</h6>
                    <div class="input-group mb-4">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                        <input type="text" name="search" class="form-control bg-light border-0" placeholder="Nom, lieu..." value="{{ app.request.query.get('search') }}">
                    </div>

                    <!-- TRI -->
                    <h6 class="fw-bold mb-3 text-uppercase small text-primary" style="letter-spacing: 1px;">Trier par</h6>
                    <select name="sortBy" class="form-select bg-light border-0 mb-4 rounded-3">
                        <option value="new">Plus récents</option>
                        <option value="asc">Prix croissant</option>
                        <option value="desc">Prix décroissant</option>
                    </select>

                    <!-- CATÉGORIES -->
                    <h6 class="fw-bold mb-3 text-uppercase small text-primary" style="letter-spacing: 1px;">Catégories</h6>
                    <div class="mb-4">
                        {% for cat in ['MAISON', 'STARTUP', 'AGRICULTURE', 'ENERGIE', 'HOTEL'] %}
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="category[]" value="{{ cat }}" id="cat_{{ loop.index }}" 
                                       {{ cat in (app.request.query.all('category')|default([])) ? 'checked' : '' }}>
                                <label class="form-check-label small" for="cat_{{ loop.index }}">
                                    {{ investment_category_label(cat) }}
                                </label>
                            </div>
                        {% endfor %}
                    </div>

                    <!-- PRIX -->
                    <h6 class="fw-bold mb-3 text-uppercase small text-primary" style="letter-spacing: 1px;">Tranche de Prix</h6>
                    <select name="price" class="form-select bg-light border-0 mb-4 rounded-3">
                        <option value="">Tous les prix</option>
                        <option value="<10k">Moins de 10k TND</option>
                        <option value="10k-50k">10k - 50k TND</option>
                        <option value="50k-200k">50k - 200k TND</option>
                        <option value=">200k">Plus de 200k TND</option>
                    </select>

                    <!-- NIVEAU DE RISQUE -->
                    <h6 class="fw-bold mb-3 text-uppercase small text-primary" style="letter-spacing: 1px;">Niveau de risque</h6>
                    <input type="hidden" name="risk" id="risk-filter-value" value="{{ app.request.query.get('risk', '') }}">
                    <div class="d-flex flex-wrap gap-2 mb-4" id="risk-pills">
                        <button type="button" data-risk="" class="btn btn-sm btn-light rounded-pill px-3 risk-pill {{ app.request.query.get('risk') == '' ? 'active bg-primary text-white' : '' }}">Tous</button>
                        <button type="button" data-risk="LOW" class="btn btn-sm btn-light rounded-pill px-3 risk-pill {{ app.request.query.get('risk') == 'LOW' ? 'active bg-primary text-white' : '' }}">Faible</button>
                        <button type="button" data-risk="MEDIUM" class="btn btn-sm btn-light rounded-pill px-3 risk-pill {{ app.request.query.get('risk') == 'MEDIUM' ? 'active bg-primary text-white' : '' }}">Moyen</button>
                        <button type="button" data-risk="HIGH" class="btn btn-sm btn-light rounded-pill px-3 risk-pill {{ app.request.query.get('risk') == 'HIGH' ? 'active bg-primary text-white' : '' }}">Élevé</button>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 rounded-pill shadow-sm">
                        <i class="bi bi-filter me-2"></i>Réinitialiser
                    </button>
                </form>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h4 class="fw-bold mb-0" id="project-count-title">
                        <span id="project-count-number">{{ investments.getTotalItemCount() }}</span> investissement(s) trouvé(s)
                    </h4>
                    <p class="text-muted small mb-0">Découvrez les meilleures opportunités du moment</p>
                </div>
                {% if is_granted('ROLE_ENTREPRISE') %}
                    <a href="{{ path('app_investment_new') }}" class="btn btn-success rounded-pill px-4 shadow-sm">
                        <i class="bi bi-plus-circle me-2"></i>Publier un projet
                    </a>
                {% endif %}
            </div>

            <!-- Smart Learning Recommendations (CONTEXTUAL CAROUSEL) -->
            {% if recommendations is defined and recommendations|length > 0 %}
            <div class="row mb-4">
                <div class="col-12">
                    <div id="smartRecCarousel" class="carousel slide" data-bs-ride="carousel">
                        <div class="carousel-inner" style="border-radius: 24px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
                            {% for rec in recommendations %}
                            <div class="carousel-item {{ loop.first ? 'active' : '' }}">
                                <div class="card border-0 position-relative" style="background: white; border-radius: 24px; border-left: 5px solid #6366f1 !important;">
                                    <div class="card-body p-0">
                                        <div class="row g-0 align-items-center">
                                            <div class="col-md-auto p-4 d-flex align-items-center justify-content-center" style="background: rgba(99, 102, 241, 0.05); min-width: 100px;">
                                                <div class="icon-circle bg-primary text-white fs-2 shadow-sm" style="width: 60px; height: 60px; display: flex; align-items:center; justify-content:center; border-radius: 18px;">
                                                    <i class="bi {{ rec.icon }}"></i>
                                                </div>
                                            </div>
                                            <div class="col-md p-4">
                                                <div class="d-flex align-items-center gap-2 mb-1">
                                                    <span class="badge bg-warning bg-opacity-10 text-warning xsmall fw-bold px-2 py-1 rounded-pill">
                                                        <i class="bi bi-stars me-1"></i>RECOMMANDATION SMART {{ recommendations|length > 1 ? '#' ~ loop.index : '' }}
                                                    </span>
                                                </div>
                                                <h5 class="fw-bold text-dark mb-1">{{ rec.title }}</h5>
                                                <p class="text-muted small mb-0">{{ rec.reason }}</p>
                                            </div>
                                            <div class="col-md-auto p-4">
                                                {% if rec.formation %}
                                                    <a href="{{ path('app_formation_show', {id: rec.formation.id}) }}" class="btn btn-primary rounded-pill px-4 fw-bold">
                                                        Apprendre & Agir <i class="bi bi-arrow-right ms-2"></i>
                                                    </a>
                                                {% else %}
                                                    <a href="{{ path('app_formations', {categorie: rec.category_slug}) }}" class="btn btn-outline-primary rounded-pill px-4 fw-bold">
                                                        Explorer {{ rec.category_slug }}
                                                    </a>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                        {% if recommendations|length > 1 %}
                        <button class="carousel-control-prev" type="button" data-bs-target="#smartRecCarousel" data-bs-slide="prev" style="width: 5%;">
                            <span class="carousel-control-prev-icon bg-dark rounded-circle" aria-hidden="true" style="width: 30px; height: 30px;"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#smartRecCarousel" data-bs-slide="next" style="width: 5%;">
                            <span class="carousel-control-next-icon bg-dark rounded-circle" aria-hidden="true" style="width: 30px; height: 30px;"></span>
                        </button>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endif %}

            <div id="project-list-container" class="position-relative">
                <div id="project-loader" class="position-absolute top-50 start-50 translate-middle" style="display: none; z-index: 10;">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
                <div id="project-list-content">
                    {% include 'investment/_project_list.html.twig' %}
                </div>
            </div>
        </div>
    </div>
    {% include 'investment/_ai_chat_widget.html.twig' %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const filterForm = document.getElementById('investment-filter-form');
            const containerContent = document.getElementById('project-list-content');
            const countNumber = document.getElementById('project-count-number');
            const loader = document.getElementById('project-loader');
            const riskValueInput = document.getElementById('risk-filter-value');
            const riskPills = document.querySelectorAll('.risk-pill');
            
            let debounceTimer;

            if (filterForm) {
                // Change event for selects and checkboxes
                filterForm.querySelectorAll('select, input[type="checkbox"]').forEach(input => {
                    input.addEventListener('change', () => updateResults());
                });

                // Input event for search (with debounce)
                const searchInput = filterForm.querySelector('input[name="search"]');
                if (searchInput) {
                    searchInput.addEventListener('input', () => {
                        clearTimeout(debounceTimer);
                        debounceTimer = setTimeout(() => updateResults(), 500);
                    });
                }

                // Risk pills handling
                riskPills.forEach(pill => {
                    pill.addEventListener('click', function() {
                        riskPills.forEach(p => p.classList.remove('active', 'bg-primary', 'text-white'));
                        this.classList.add('active', 'bg-primary', 'text-white');
                        
                        riskValueInput.value = this.getAttribute('data-risk');
                        updateResults();
                    });
                });

                // Reset handling (if needed, but here simple submit)
                filterForm.addEventListener('submit', (e) => {
                    e.preventDefault();
                    filterForm.reset();
                    // Need to manually clear checkboxes and risk pills
                    riskPills.forEach(p => p.classList.remove('active', 'bg-primary', 'text-white'));
                    riskPills[0].classList.add('active', 'bg-primary', 'text-white');
                    riskValueInput.value = "";
                    updateResults();
                });
            }

            function updateResults() {
                loader.style.display = 'block';
                containerContent.style.opacity = '0.4';
                
                const formData = new FormData(filterForm);
                const params = new URLSearchParams(formData);
                
                // Clean empty params
                const cleanParams = new URLSearchParams();
                for (const [key, value] of params) {
                    if (value !== "") cleanParams.append(key, value);
                }

                const url = `{{ path('app_investment_index') }}?${cleanParams.toString()}`;

                fetch(url, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(res => res.text())
                .then(html => {
                    // Create a dummy element to parse HTML and extract the count if we want,
                    // but it's easier to just update the content.
                    containerContent.innerHTML = html;
                    
                    // Update count: We can find it in the HTML if we add a data-attribute to the list container
                    const newCount = containerContent.querySelector('[data-total-count]')?.getAttribute('data-total-count');
                    if(newCount) countNumber.innerText = newCount;

                    containerContent.style.opacity = '1';
                    loader.style.display = 'none';
                    window.history.pushState({}, '', url);
                })
                .catch(err => {
                    console.error(err);
                    containerContent.style.opacity = '1';
                    loader.style.display = 'none';
                });
            }

            // AJAX Pagination
            containerContent.addEventListener('click', (e) => {
                const link = e.target.closest('.pagination a');
                if (link) {
                    e.preventDefault();
                    loader.style.display = 'block';
                    containerContent.style.opacity = '0.4';
                    
                    fetch(link.href, {
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(res => res.text())
                    .then(html => {
                        containerContent.innerHTML = html;
                        containerContent.style.opacity = '1';
                        loader.style.display = 'none';
                        window.history.pushState({}, '', link.href);
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    });
                }
            });
        });
    </script>

{% if app.user %}
<script>
(function() {
    'use strict';
    var wishlistIds = new Set();

    function initWishlistHeartStates() {
        fetch('{{ path("app_investment_wishlist_my_ids") }}')
            .then(function(res) { return res.json(); })
            .then(function(data) {
                wishlistIds = new Set(data.ids || []);
                syncHeartIcons();
            })
            .catch(function(err) { console.error('Wishlist init error:', err); });
    }

    function syncHeartIcons() {
        document.querySelectorAll('.heart-icon').forEach(function(icon) {
            var btn = icon.closest('.wishlist-toggle-btn');
            if (!btn) return;
            var id = parseInt(btn.getAttribute('data-investment-id'));
            if (wishlistIds.has(id)) {
                icon.classList.remove('bi-heart');
                icon.classList.add('bi-heart-fill');
            } else {
                icon.classList.remove('bi-heart-fill');
                icon.classList.add('bi-heart');
            }
        });
    }

    function showToast(msg, color) {
        var t = document.createElement('div');
        t.style.cssText = 'position:fixed;bottom:20px;right:20px;z-index:99999;padding:12px 20px;border-radius:12px;font-weight:600;color:white;box-shadow:0 4px 20px rgba(0,0,0,0.25);transition:opacity 0.4s ease;font-family:sans-serif;font-size:14px;';
        t.style.background = color;
        t.innerHTML = msg;
        document.body.appendChild(t);
        setTimeout(function() {
            t.style.opacity = '0';
            setTimeout(function() { t.remove(); }, 400);
        }, 2600);
    }

    // Clic délégué (fonctionne même après rechargement AJAX)
    document.addEventListener('click', function(e) {
        var btn = e.target.closest('.wishlist-toggle-btn');
        if (!btn) return;
        e.preventDefault();
        e.stopPropagation();

        var id = parseInt(btn.getAttribute('data-investment-id'));
        var icon = document.getElementById('heart-icon-' + id);
        if (!icon) return;

        var isFavorite = wishlistIds.has(id);

        // Mise à jour optimiste immédiate
        if (isFavorite) {
            wishlistIds.delete(id);
            icon.classList.remove('bi-heart-fill');
            icon.classList.add('bi-heart');
            showToast('♥ Retiré de la wishlist', '#6b7280');
        } else {
            wishlistIds.add(id);
            icon.classList.remove('bi-heart');
            icon.classList.add('bi-heart-fill');
            showToast('♥ Ajouté à votre wishlist !', '#10b981');
        }

        // Animation pulse
        icon.style.transform = 'scale(1.5)';
        icon.style.transition = 'transform 0.15s ease';
        setTimeout(function() { icon.style.transform = 'scale(1)'; }, 150);

        // Appel API
        fetch('/api/investment-wishlist/toggle/' + id, { method: 'POST' })
            .then(function(res) { return res.json(); })
            .then(function(data) {
                if (data.status === 'error') {
                    // Revert si erreur serveur
                    if (isFavorite) { wishlistIds.add(id); } else { wishlistIds.delete(id); }
                    syncHeartIcons();
                    showToast('⚠️ ' + (data.message || 'Erreur'), '#ef4444');
                }
            })
            .catch(function() {
                showToast('⚠️ Connexion impossible', '#ef4444');
                initWishlistHeartStates();
            });
    });

    // Synchronise après chaque rechargement AJAX
    var catalogContainer = document.getElementById('project-list-content');
    if (catalogContainer) {
        new MutationObserver(function() { syncHeartIcons(); })
            .observe(catalogContainer, { childList: true, subtree: true });
    }

    // Lancement initial
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initWishlistHeartStates);
    } else {
        initWishlistHeartStates();
    }
})();
</script>
{% endif %}
{% endblock %}
