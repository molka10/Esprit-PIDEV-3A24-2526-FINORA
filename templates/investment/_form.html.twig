<style>
    .investment-form-wrapper .form-control:focus, 
    .investment-form-wrapper .form-select:focus {
        border-color: #7c3aed !important;
        box-shadow: 0 0 0 0.25rem rgba(124, 58, 237, 0.25) !important;
    }
    .btn-purple {
        background: linear-gradient(135deg, #7c3aed 0%, #4338ca 100%);
        border: none;
        color: white;
        transition: all 0.3s ease;
        box-shadow: 0 5px 15px rgba(124, 58, 237, 0.3);
    }
    .btn-purple:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(124, 58, 237, 0.4);
        color: white;
    }
    .alert-purple {
        background-color: #ede9fe !important; 
        color: #4c1d95 !important;
    }
    .text-purple {
        color: #7c3aed !important;
    }
</style>

{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

<div class="row g-4 investment-form-wrapper">
    <!-- Nom du projet -->
    <div class="col-12">
        {{ form_label(form.name, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
        {{ form_widget(form.name, {'attr': {'class': 'form-control border-opacity-25'}}) }}
        {{ form_errors(form.name) }}
    </div>

    <!-- Catégorie et Risque -->
    <div class="col-md-6">
        {{ form_label(form.category, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
        {{ form_widget(form.category, {'attr': {'class': 'form-select'}}) }}
        {{ form_errors(form.category) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.riskLevel, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
        {{ form_widget(form.riskLevel, {'attr': {'class': 'form-select'}}) }}
        {{ form_errors(form.riskLevel) }}
    </div>

    <!-- Localisation et Valeur -->
    <div class="col-md-6">
        {{ form_label(form.location, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
        {{ form_widget(form.location, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.location) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.estimatedValue, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
        <div class="input-group">
            {{ form_widget(form.estimatedValue, {'attr': {'class': 'form-control'}}) }}
            <span class="input-group-text badge-primary-soft text-purple" style="background-color: #ede9fe; border-color: #ede9fe;">TND</span>
        </div>
        {{ form_errors(form.estimatedValue) }}
    </div>

    <!-- Image -->
    <div class="col-12">
        {{ form_label(form.imageFile, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
        {{ form_widget(form.imageFile, {'attr': {'class': 'form-control', 'id': 'imageInput'}}) }}
        {{ form_errors(form.imageFile) }}
        <img id="preview" class="mt-3 rounded shadow-sm" style="max-width: 100%; height: 200px; object-fit: cover; display: none;">
    </div>

    <!-- Description -->
    <div class="col-12">
        {{ form_label(form.description, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
        {{ form_errors(form.description) }}
    </div>

    <!-- Info Box for auto-calculations -->
    <div class="col-12">
        <div class="alert alert-purple border-0 d-flex align-items-center p-4 mb-4" style="border-radius: 15px;">
            <div class="display-6 text-purple me-3">
                <i class="bi bi-info-circle"></i>
            </div>
            <div>
                <h6 class="fw-bold mb-1">Informations calculées automatiquement</h6>
                <p class="small mb-0 opacity-75">Le rendement annuel, la durée et l'objectif de collecte sont déterminés selon le niveau de risque et la valeur du bien.</p>
            </div>
        </div>
    </div>

    <!-- Statut (Admin seulement) -->
    {% if form.status is defined %}
        <div class="col-12">
            {{ form_label(form.status, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
            {{ form_widget(form.status, {'attr': {'class': 'form-select'}}) }}
            {{ form_errors(form.status) }}
        </div>
    {% endif %}

    <div class="col-12 mt-4 text-center">
        <button type="submit" class="btn btn-purple btn-lg rounded-pill px-5 fw-bold">
            {{ button_label|default('Enregistrer le projet') }}
        </button>
    </div>
</div>

{{ form_end(form) }}

<script>
    const input = document.getElementById('imageInput');
    const preview = document.getElementById('preview');
    if (input) {
        input.addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                }
                reader.readAsDataURL(file);
            } else {
                preview.style.display = 'none';
            }
        });
    }
</script>
