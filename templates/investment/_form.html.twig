{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

<div class="container mt-5 mb-5">
<div class="row justify-content-center">
<div class="col-lg-8 col-xl-7">

    <div class="text-center mb-4">
        <div class="mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 72px; height: 72px; border-radius: 20px; background: linear-gradient(135deg, #7c3aed, #8b5cf6);">
            <i class="bi bi-building fs-2 text-white"></i>
        </div>
        <h2 class="fw-bold mb-1">{{ button_label|default('Créer un Projet') }}</h2>
        <p class="text-muted">Renseignez les informations de votre opportunité d'investissement</p>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 20px;">
        <div class="card-body p-4 p-sm-5">

            <div class="row g-4">

                <!-- NAME -->
                <div class="col-12">
                    <label class="form-label fw-bold"><i class="bi bi-building me-2" style="color: #7c3aed;"></i>Nom du projet</label>
                    {{ form_widget(form.name, {
                        'attr': {'class': 'form-control form-control-lg bg-light ' ~ (form_errors(form.name) ? 'is-invalid' : ''), 'style': 'border-radius: 12px;'}
                    }) }}
                    <div class="invalid-feedback d-block">{{ form_errors(form.name) }}</div>
                </div>

                <!-- CATEGORY & RISK -->
                <div class="col-md-6">
                    <label class="form-label fw-bold"><i class="bi bi-tag me-2" style="color: #7c3aed;"></i>Type de bien</label>
                    {{ form_widget(form.category, {
                        'attr': {'class': 'form-select bg-light ' ~ (form_errors(form.category) ? 'is-invalid' : ''), 'style': 'border-radius: 12px;'}
                    }) }}
                    <div class="invalid-feedback d-block">{{ form_errors(form.category) }}</div>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold"><i class="bi bi-shield-exclamation me-2" style="color: #7c3aed;"></i>Niveau de risque</label>
                    {{ form_widget(form.riskLevel, {
                        'attr': {'class': 'form-select bg-light ' ~ (form_errors(form.riskLevel) ? 'is-invalid' : ''), 'style': 'border-radius: 12px;'}
                    }) }}
                    <div class="invalid-feedback d-block">{{ form_errors(form.riskLevel) }}</div>
                    <small class="text-muted mt-1 d-block">Le rendement et la durée sont calculés automatiquement selon le risque</small>
                </div>

                <!-- LOCATION & VALUE -->
                <div class="col-md-6">
                    <label class="form-label fw-bold"><i class="bi bi-geo-alt me-2" style="color: #3b82f6;"></i>Localisation</label>
                    {{ form_widget(form.location, {
                        'attr': {'class': 'form-control bg-light ' ~ (form_errors(form.location) ? 'is-invalid' : ''), 'style': 'border-radius: 12px;'}
                    }) }}
                    <div class="invalid-feedback d-block">{{ form_errors(form.location) }}</div>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold"><i class="bi bi-cash-stack me-2" style="color: #10b981;"></i>Valeur totale du bien (TND)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0" style="border-radius: 12px 0 0 12px;"><i class="bi bi-currency-dollar" style="color: #7c3aed;"></i></span>
                        {{ form_widget(form.estimatedValue, {
                            'attr': {'class': 'form-control bg-light border-start-0 ' ~ (form_errors(form.estimatedValue) ? 'is-invalid' : ''), 'style': 'border-radius: 0 12px 12px 0;'}
                        }) }}
                    </div>
                    <div class="invalid-feedback d-block">{{ form_errors(form.estimatedValue) }}</div>
                </div>

                <!-- IMAGE -->
                <div class="col-12">
                    <label class="form-label fw-bold"><i class="bi bi-image me-2" style="color: #f59e0b;"></i>Photo du projet</label>
                    {{ form_widget(form.imageFile, {
                        'attr': {
                            'class': 'form-control bg-light ' ~ (form_errors(form.imageFile) ? 'is-invalid' : ''),
                            'id': 'imageInput',
                            'style': 'border-radius: 12px;'
                        }
                    }) }}
                    <div class="invalid-feedback d-block">{{ form_errors(form.imageFile) }}</div>
                    <img id="preview" style="margin-top: 12px; max-width: 100%; height: 180px; object-fit: cover; border-radius: 16px; display: none; border: 2px solid #ede9fe;">
                </div>

                <!-- DESCRIPTION -->
                <div class="col-12">
                    <label class="form-label fw-bold"><i class="bi bi-card-text me-2" style="color: #7c3aed;"></i>Description du projet</label>
                    {{ form_widget(form.description, {
                        'attr': {'class': 'form-control bg-light ' ~ (form_errors(form.description) ? 'is-invalid' : ''), 'style': 'border-radius: 12px;'}
                    }) }}
                    <div class="invalid-feedback d-block">{{ form_errors(form.description) }}</div>
                </div>

                <!-- STATUS -->
                <div class="col-12">
                    <label class="form-label fw-bold"><i class="bi bi-toggle-on me-2" style="color: #10b981;"></i>Statut du projet</label>
                    {{ form_widget(form.status, {
                        'attr': {'class': 'form-select bg-light ' ~ (form_errors(form.status) ? 'is-invalid' : ''), 'style': 'border-radius: 12px;'}
                    }) }}
                    <div class="invalid-feedback d-block">{{ form_errors(form.status) }}</div>
                </div>

                <!-- Info box -->
                <div class="col-12">
                    <div class="p-3 rounded-3" style="background: #faf5ff; border: 1px solid #ede9fe;">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-info-circle fs-4 me-3" style="color: #7c3aed;"></i>
                            <div>
                                <small class="text-muted d-block">Informations calculées automatiquement</small>
                                <span class="small" style="color: #7c3aed;">Le rendement annuel, la durée et l'objectif de collecte sont déterminés selon le niveau de risque et la valeur du bien.</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- BUTTONS -->
                <div class="col-12 mt-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <a href="{{ path('app_investment_index') }}" class="btn btn-link text-muted px-0 text-decoration-none">
                            <i class="bi bi-arrow-left me-1"></i>Retour au catalogue
                        </a>
                        <button class="btn btn-lg text-white px-5 rounded-pill shadow-sm" style="background: linear-gradient(135deg, #7c3aed, #8b5cf6); border: none;">
                            <i class="bi bi-check-circle me-1"></i>{{ button_label|default('Publier le projet') }}
                        </button>
                    </div>
                </div>

            </div>

        </div>
    </div>

</div>
</div>
</div>

{{ form_end(form) }}

<!-- IMAGE PREVIEW SCRIPT -->
<script>
    const input = document.getElementById('imageInput');
    const preview = document.getElementById('preview');

    if (input) {
        input.addEventListener('change', function () {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                }
                reader.readAsDataURL(file);
            } else {
                preview.style.display = 'none';
            }
        });
    }
</script>
