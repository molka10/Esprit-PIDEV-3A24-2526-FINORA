    <style>
        /**
         * PDF RENDERING OPTIMIZATIONS (DomPDF)
         */
        @page {
            margin: 100px 50px 80px 50px; /* Space for fixed header/footer */
        }
        
        body {
            font-family: 'Helvetica', 'Arial', sans-serif;
            color: #111827;
            margin: 0;
            padding: 0;
            line-height: 1.5;
            background-color: #ffffff;
        }

        /* ──── FIXED HEADER & FOOTER (PAGINATION) ──── */
        #header {
            position: fixed;
            top: -90px;
            left: 0;
            right: 0;
            height: 70px;
            border-bottom: 3px solid #7c3aed;
            padding-bottom: 10px;
            background-color: #ffffff;
        }

        #footer {
            position: fixed;
            bottom: -50px;
            left: 0;
            right: 0;
            height: 40px;
            border-top: 1px solid #e5e7eb;
            padding-top: 10px;
            font-size: 9px;
            color: #9ca3af;
        }

        .page-number:after {
            content: "Page " counter(page);
        }

        /* ──── NAVIGATION ELEMENTS ──── */
        .nav-breadcrumb { font-size: 8px; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.5px; }
        .nav-breadcrumb span { color: #4f46e5; font-weight: bold; }
        
        .badge-official {
            background-color: #1e1b4b;
            color: white;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 7px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: inline-block;
        }

        /* ──── COLORS ──── */
        .text-navy { color: #1e1b4b; }
        .text-indigo { color: #4f46e5; }
        .text-muted { color: #6b7280; }
        .bg-navy { background-color: #1e1b4b; }
        .bg-indigo { background-color: #4f46e5; }
        
        /* ──── HERO AREA ──── */
        .hero-container { margin-bottom: 30px; border-radius: 12px; overflow: hidden; border: 1px solid #e5e7eb; }
        .hero-img { width: 100%; height: 280px; object-fit: cover; display: block; }

        /* ──── DASHBOARD (Pills Style) ──── */
        .metrics-table { width: 100%; border-collapse: separate; border-spacing: 10px 0; margin-bottom: 30px; }
        .metric-pill {
            background-color: #f9fafb;
            border: 1px solid #ede9fe;
            border-radius: 100px;
            padding: 10px 20px;
            text-align: center;
        }
        .metric-label { font-size: 8px; text-transform: uppercase; color: #7c3aed; font-weight: bold; }
        .metric-value { font-size: 16px; font-weight: bold; color: #1e1b4b; }

        /* ──── CONTENT SECTIONS ──── */
        .section-title {
            font-size: 13px;
            font-weight: 800;
            color: #1e1b4b;
            padding-bottom: 8px;
            margin-bottom: 15px;
            border-bottom: 2px solid #4f46e5;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .content-box { background-color: #ffffff; border-left: 4px solid #4f46e5; padding: 15px 20px; margin-bottom: 25px; }
        .content-text { font-size: 11.5px; color: #374151; text-align: justify; line-height: 1.7; }

        /* ──── CARDS ──── */
        .info-grid { width: 100%; border-collapse: separate; border-spacing: 15px 0; margin-left: -15px; }
        .info-card {
            background: #ffffff;
            border-radius: 10px;
            padding: 18px;
            border: 1px solid #e5e7eb;
            text-align: center;
        }
        .info-label { font-size: 8.5px; color: #6b7280; font-weight: bold; text-transform: uppercase; margin-bottom: 6px; }
        .info-value { font-size: 15px; font-weight: 800; color: #1e1b4b; }

        /* ──── FINANCIAL TABLE ──── */
        .financial-table { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 10.5px; }
        .financial-table th { background: #1e1b4b; color: white; text-align: left; padding: 12px; font-weight: bold; }
        .financial-table td { padding: 12px; border-bottom: 1px solid #f3f4f6; }
        .row-accent { background-color: #f5f3ff; font-weight: bold; }
        .row-total { background-color: #4f46e5; color: white; font-weight: bold; font-size: 12px; }

        /* ──── RISK DISPLAY ──── */
        .risk-bar { height: 10px; border-radius: 5px; background: #e5e7eb; position: relative; margin: 15px 0; }
        .risk-indicator { height: 10px; border-radius: 5px; position: absolute; left: 0; top: 0; }

        /* ──── ALIGNMENT ──── */
        .text-right { text-align: right; }
        .text-center { text-align: center; }
    </style>
</head>
<body>

    <!-- ──── FIXED HEADER ──── -->
    <div id="header">
        <table style="width: 100%; border-collapse: collapse;">
            <tr>
                <!-- Brand & Breadcrumb -->
                <td style="width: 50%; vertical-align: middle;">
                    {% if logo_base64 %}
                        <img src="{{ logo_base64 }}" style="height: 38px; margin-bottom: 5px;">
                    {% else %}
                        <div style="font-size: 22px; font-weight: 900; color: #1e1b4b; margin-bottom: 2px;">FINORA</div>
                    {% endif %}
                    <div class="nav-breadcrumb">Plateforme <span>&rsaquo;</span> Rapport <span>&rsaquo;</span> Factsheet</div>
                </td>
                
                <!-- Status & ID -->
                <td style="width: 50%; text-align: right; vertical-align: middle;">
                    <div style="margin-bottom: 6px;">
                        <span class="badge-official">Document Certifié</span>
                    </div>
                    <div style="font-size: 10px; font-weight: 800; color: #1e1b4b; text-transform: uppercase;">ID REF : FN-{{ project.id|default('000') }}</div>
                    <div style="font-size: 8px; color: #9ca3af; margin-top: 2px;">Extrait du {{ "now"|date("d/m/Y à H:i") }}</div>
                </td>
            </tr>
        </table>
    </div>

    <!-- ──── FIXED FOOTER (PAGINATION) ──── -->
    <div id="footer">
        <table style="width: 100%;">
            <tr>
                <td style="width: 70%;">Finora.io — Dossier technique confidentiel à usage exclusif.</td>
                <td style="width: 30%; text-align: right;" class="page-number"></td>
            </tr>
        </table>
    </div>

    <!-- ──── MAIN CONTENT ──── -->
    <div class="hero-container">
        {% if image_base64 %}
            <img src="{{ image_base64 }}" class="hero-img">
        {% else %}
            <img src="https://images.unsplash.com/photo-1560518883-ce09059ee712?auto=format&fit=crop&w=1200" class="hero-img">
        {% endif %}
    </div>

    <div style="margin-bottom: 25px;">
        <h1 style="font-size: 24px; color: #1e1b4b; margin: 0 0 5px 0; letter-spacing: -0.5px;">{{ project.name }}</h1>
        <div style="font-size: 12px; font-weight: 600; color: #4f46e5;">
            {{ project.category|upper }} • <span style="color: #6b7280;">{{ project.location|default('Paris, France') }}</span>
        </div>
    </div>

    <!-- QUICK STATS -->
    <table class="metrics-table">
        <tr>
            <td style="width: 25%;">
                <div class="metric-pill">
                    <div class="metric-label">Rendement</div>
                    <div class="metric-value" style="color: #4f46e5;">{{ project.annualReturn|default('9.50') }}%</div>
                </div>
            </td>
            <td style="width: 25%;">
                <div class="metric-pill">
                    <div class="metric-label">Horizon</div>
                    <div class="metric-value">{{ project.durationMonths|default('24') }} m.</div>
                </div>
            </td>
            <td style="width: 25%;">
                <div class="metric-pill">
                    <div class="metric-label">Objectif</div>
                    <div class="metric-value">{{ (project.fundingGoal|default('150000')/1000)|number_format(0) }}k TND</div>
                </div>
            </td>
            <td style="width: 25%;">
                <div class="metric-pill">
                    <div class="metric-label">Risque</div>
                    <div class="metric-value">{{ project.riskLevel|default('B+') }}</div>
                </div>
            </td>
        </tr>
    </table>

    <div class="section-title">Synthèse de l'Investissement</div>
    <div class="content-box">
        <div class="content-text">
            {{ project.description|default("Ce document présente une analyse technique détaillée de l'opportunité d'investissement. Nos experts ont validé les fondamentaux du projet, incluant la solvabilité du porteur et la résilience du marché sous-jacent. L'actif s'inscrit dans une stratégie de rendement stabilisé avec une perspective de valorisation attractive à moyen terme.") }}
        </div>
    </div>

    <div class="section-title">Indicateurs de Performance</div>
    <table class="info-grid" style="margin-bottom: 30px;">
        <tr>
            <td style="width: 33%;">
                <div class="info-card">
                    <div class="info-label">Ticket Entrée</div>
                    <div class="info-value">{{ project.minInvestment|default('1 000')|number_format(0, ',', ' ') }} TND</div>
                </div>
            </td>
            <td style="width: 33%;">
                <div class="info-card">
                    <div class="info-label">Type Actif</div>
                    <div class="info-value">Core +</div>
                </div>
            </td>
            <td style="width: 33%;">
                <div class="info-card">
                    <div class="info-label">Récurrence</div>
                    <div class="info-value">Trimestrielle</div>
                </div>
            </td>
        </tr>
    </table>

    <div class="section-title">Analyse Synthétique du Risque</div>
    
    <div style="background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 20px; margin-bottom: 30px;">
        <table style="width: 100%; border-collapse: collapse;">
            <tr>
                <!-- Institutional SRRI Scale -->
                <td style="width: 55%; vertical-align: top; padding-right: 30px; border-right: 1px solid #e2e8f0;">
                    <div style="font-size: 10px; font-weight: 800; color: #1e1b4b; text-transform: uppercase; margin-bottom: 15px; letter-spacing: 0.5px;">Indicateur de Risque (SRRI)</div>
                    
                    <table style="width: 100%; border-collapse: collapse;">
                        <tr>
                            {% set stages = [
                                {'v': '1', 'c': '#10b981', 'n': 'Prudent'},
                                {'v': '2', 'c': '#34d399', 'n': 'Stable'},
                                {'v': '3', 'c': '#facc15', 'n': 'Modéré'},
                                {'v': '4', 'c': '#fb923c', 'n': 'Dynamique'},
                                {'v': '5', 'c': '#ef4444', 'n': 'Agressif'}
                            ] %}
                            
                            {# Logical mapping for Marker #}
                            {% set risk_val = project.riskLevel == 'LOW' ? 2 : (project.riskLevel == 'MEDIUM' ? 3 : 4) %}
                            
                            {% for s in stages %}
                                <td style="width: 20%; padding: 0 1.5px; text-align: center;">
                                    <div style="height: 30px; background-color: {{ s.c }}; border-radius: 4px; opacity: {{ risk_val == s.v ? '1' : '0.15' }}; border: {{ risk_val == s.v ? '2px solid #1e1b4b' : 'none' }}; position: relative;">
                                        <span style="font-size: 11px; font-weight: 900; color: {{ risk_val == s.v ? '#1e1b4b' : '#94a3b8' }}; line-height: 30px;">{{ s.v }}</span>
                                        {% if risk_val == s.v %}
                                            <div style="position: absolute; bottom: -8px; left: 50%; margin-left: -4px; width: 0; height: 0; border-left: 4px solid transparent; border-right: 4px solid transparent; border-bottom: 4px solid #1e1b4b;"></div>
                                        {% endif %}
                                    </div>
                                    <div style="font-size: 7px; margin-top: 6px; font-weight: {{ risk_val == s.v ? '800' : '500' }}; color: {{ risk_val == s.v ? '#1e1b4b' : '#94a3b8' }}; text-transform: uppercase;">{{ s.n }}</div>
                                </td>
                            {% endfor %}
                        </tr>
                    </table>
                </td>

                <!-- Factor breakdown -->
                <td style="width: 45%; vertical-align: top; padding-left: 30px;">
                    <div style="font-size: 10px; font-weight: 800; color: #1e1b4b; text-transform: uppercase; margin-bottom: 12px; letter-spacing: 0.5px;">Composantes Principales</div>
                    <table style="width: 100%; font-size: 9px; line-height: 1.8;">
                        <tr>
                            <td style="color: #64748b;">Risque de Capital</td>
                            <td style="text-align: right; font-weight: 800; color: #1e1b4b;">MODÉRÉ</td>
                        </tr>
                        <tr>
                            <td style="color: #64748b;">Liquidité de l'Actif</td>
                            <td style="text-align: right; font-weight: 800; color: #1e1b4b;">{{ project.riskLevel == 'HIGH' ? 'FAIBLE' : 'MODÉRÉE' }}</td>
                        </tr>
                        <tr>
                            <td style="color: #64748b;">Audit Technique</td>
                            <td style="text-align: right; font-weight: 800; color: #10b981;">VALIDÉ</td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </div>

    <!-- ──── FINANCIAL SIMULATION (DYNAMICALLY LINKED) ──── -->
    <div class="section-title">Projection de Performance Prévisionnelle</div>
    
    <div style="margin-bottom: 30px;">
        <table class="financial-table">
            <thead>
                <tr>
                    <th style="border-radius: 8px 0 0 0;">Scénario de Rendement</th>
                    <th class="text-center">Année 1</th>
                    <th class="text-center">Année 2</th>
                    <th class="text-center" style="border-radius: 0 8px 0 0;">Sortie (TRI)</th>
                </tr>
            </thead>
            <tbody>
                {% set target = project.annualReturn|default(9) %}
                <tr>
                    <td>Distribution de Coupons (Estimée)</td>
                    <td class="text-center">{{ (target * 0.8)|number_format(1) }}%</td>
                    <td class="text-center">{{ (target * 0.85)|number_format(1) }}%</td>
                    <td class="text-center">{{ (target * 1.65)|number_format(1) }}%</td>
                </tr>
                <tr>
                    <td>Valorisation Capital (Perspective)</td>
                    <td class="text-center">+2.0%</td>
                    <td class="text-center">+2.5%</td>
                    <td class="text-center">+4.5%</td>
                </tr>
                <tr class="row-accent">
                    <td>Performance Intermédiaire</td>
                    <td class="text-center">{{ (target * 0.8 + 2)|number_format(1) }}%</td>
                    <td class="text-center">{{ (target * 0.85 + 2.5)|number_format(1) }}%</td>
                    <td class="text-center">--</td>
                </tr>
                <tr class="row-total">
                    <td style="border-radius: 0 0 0 8px;">PERFORMANCE GLOBALE CIBLE</td>
                    <td class="text-center">--</td>
                    <td class="text-center">--</td>
                    <td class="text-center" style="border-radius: 0 0 8px 0;">{{ target }}% / an</td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- ──── COMPLEMENTARY DETAILS (PRESERVATION) ──── -->
    <div style="background-color: #f1f5f9; border-radius: 8px; padding: 15px; margin-top: 20px;">
        <table style="width: 100%; border-collapse: collapse;">
            <tr>
                <td style="width: 60%; vertical-align: top; padding-right: 20px;">
                    <div style="font-size: 10px; font-weight: 800; color: #1e1b4b; margin-bottom: 8px;">Informations Complémentaires</div>
                    <div style="font-size: 9px; color: #475569; line-height: 1.5;">
                        Le ticket minimum d'investissement est fixé à <strong>{{ project.minInvestment|default(500)|number_format(0, ',', ' ') }} TND</strong>. 
                        Les capitaux sont déposés sur un compte de séquestre sécurisé. Le projet bénéficie d'une garantie hypothécaire de premier rang inscrite au SPF.
                    </div>
                </td>
                <td style="width: 40%; vertical-align: top; text-align: right;">
                    <div style="font-size: 9px; font-weight: bold; color: #1e1b4b; margin-bottom: 5px;">CERTIFICATION FINORA</div>
                    <div style="font-size: 8px; color: #64748b;">
                        Audit Conformité : <strong>OK</strong><br>
                        Audit Financier : <strong>OK</strong><br>
                        Garanties : <strong>VÉRIFIÉES</strong>
                    </div>
                </td>
            </tr>
        </table>
    </div>

    <!-- ──── LEGAL FOOTER NOTE (PRESERVATION) ──── -->
    <div style="margin-top: 40px; border-top: 1px solid #e2e8f0; padding-top: 20px;">
        <div style="font-size: 10px; font-weight: 800; color: #e11d48; margin-bottom: 8px; text-transform: uppercase;">Avertissement sur les Risques</div>
        <div style="font-size: 9px; color: #64748b; line-height: 1.6; text-align: justify;">
            L'investissement dans des projets participatifs comporte des risques de perte totale ou partielle du capital investi ainsi que des risques d'illiquidité. 
            Les rendements ne sont pas garantis et les performances passées ne préjugent pas des performances futures. 
            Veuillez consulter les termes du contrat d'investissement avant toute souscription. Document confidentiel édité par FINORA.
        </div>
    </div>

</body>
</html>
