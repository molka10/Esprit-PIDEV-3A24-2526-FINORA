{% extends 'base.html.twig' %}

{% block title %}{{ formation.titre }} - FINORA{% endblock %}

{% block body %}
<section class="py-5" style="background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);">
    <div class="container">
        <div class="row g-4 g-lg-5">
            <!-- Left: Info -->
            <div class="col-lg-8">
                <div class="mb-4">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-3">
                            <li class="breadcrumb-item"><a href="{{ path('app_formations') }}">Formations</a></li>
                            <li class="breadcrumb-item active">{{ formation.titre }}</li>
                        </ol>
                    </nav>
                    <h1 class="display-5 fw-bold mb-3">{{ formation.titre }}</h1>
                    <div class="d-flex gap-3 align-items-center flex-wrap">
                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 fw-bold"><i class="bi bi-tag me-1"></i>{{ formation.categorie }}</span>
                        <span class="badge bg-info bg-opacity-10 text-info px-3 py-2 fw-bold"><i class="bi bi-reception-3 me-1"></i>{{ formation.niveau }}</span>
                        <span class="text-muted small"><i class="bi bi-journal-text me-1"></i>{{ lessons|length }} Leçons</span>
                    </div>
                </div>

                <div class="card border-0 mb-4 overflow-hidden">
                    {% if formation.imageUrl %}
                        <img src="{{ asset('uploads/formations/' ~ formation.imageUrl) }}" class="img-fluid rounded-4 shadow-sm" style="max-height: 400px; object-fit: cover; width: 100%">
                    {% endif %}
                </div>

                <div class="mb-5">
                    <h4 class="fw-bold mb-3">Description du cours</h4>
                    <div class="text-muted lead-sm" style="line-height: 1.8;">{{ formation.description|nl2br }}</div>
                </div>

                <div class="mb-5">
                    <h4 class="fw-bold mb-4">Programme de la formation</h4>
                    <div class="accordion accordion-icon accordion-bg-light" id="accordionLessons">
                        {% for lesson in lessons %}
                        <div class="accordion-item mb-3 border-0">
                            <h2 class="accordion-header">
                                <button class="accordion-button rounded-3 text-dark fw-bold {{ loop.first ? '' : 'collapsed' }}" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{ lesson.id }}">
                                    <span class="me-2 text-primary">#{{ lesson.ordre }}</span> {{ lesson.titre }}
                                    <span class="ms-auto small text-muted fw-normal">{{ lesson.dureeMinutes }} min</span>
                                </button>
                            </h2>
                            <div id="collapse{{ lesson.id }}" class="accordion-collapse collapse {{ loop.first ? 'show' : '' }}" data-bs-parent="#accordionLessons">
                                <div class="accordion-body text-muted small">
                                    {{ lesson.contenu|slice(0, 150) }}...
                                    <div class="mt-3">
                                        {% if isPurchased %}
                                            <a href="{{ path('app_lesson_show', {id: lesson.id}) }}" class="btn btn-primary btn-sm rounded-pill px-4">Commencer la leçon</a>
                                        {% else %}
                                            <button class="btn btn-secondary btn-sm rounded-pill px-4" disabled><i class="bi bi-lock-fill me-1"></i> Verrouillé</button>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <!-- Right: Sidebar -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-lg p-4 rounded-4 sticky-top" style="top: 100px;">
                    <h3 class="fw-bold text-primary mb-3">{{ formation.prix ? formation.prix ~ ' TND' : 'Gratuit' }}</h3>
                    
                    {% if not isPurchased %}
                        <div class="bg-light p-3 rounded-3 mb-4">
                            <h6 class="small fw-bold mb-2">Inclus dans la formation :</h6>
                            <ul class="list-unstyled mb-0 small text-muted">
                                <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Accès illimité aux leçons</li>
                                <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Contenu multimédia</li>
                                <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Quiz d'évaluation</li>
                                <li><i class="bi bi-check-circle text-success me-2"></i>Certificat de réussite</li>
                            </ul>
                        </div>
                        
                        <form action="{{ path('app_formation_inscription', {id: formation.id}) }}" method="post">
                            <button type="submit" class="btn btn-primary w-100 py-3 fw-bold rounded-3 mb-3">S'inscrire Maintenant</button>
                        </form>
                        <p class="text-center small text-muted mb-0">Satisfait ou remboursé sous 15 jours</p>
                    {% else %}
                        <div class="text-center py-4">
                            <i class="bi bi-check-circle-fill text-success display-4 mb-3"></i>
                            <h5 class="fw-bold">Vous êtes inscrit !</h5>
                            <p class="text-muted small">Reprenez votre apprentissage là où vous l'avez laissé.</p>
                            {% if lessons|length > 0 %}
                                <a href="{{ path('app_lesson_show', {id: lessons[0].id}) }}" class="btn btn-primary w-100 py-3 fw-bold rounded-3">Reprendre le cours</a>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
