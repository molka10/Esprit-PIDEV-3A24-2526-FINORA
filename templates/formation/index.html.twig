{% extends 'admin/base_admin.html.twig' %}

{% block title %}FINORA - Formations{% endblock %}

{% block admin_content %}
<div class="row mb-3">
    <div class="col-12 d-sm-flex justify-content-between align-items-center">
        <h1 class="h3 mb-2 mb-sm-0">Formations</h1>
        <a href="{{ path('formation_new') }}" class="btn btn-sm btn-primary mb-0">Ajouter une formation</a>
    </div>
</div>

<div class="card bg-transparent border">
    <div class="card-header bg-light border-bottom">
        <form method="get" action="{{ path('formation_index') }}">
            <div class="row g-3 align-items-center justify-content-between">
                <div class="col-md-3">
                    <input class="form-control bg-body" type="text" name="titre" value="{{ titre }}" placeholder="Rechercher par titre">
                </div>

                <div class="col-md-2">
                    <select class="form-select border-0 z-index-9" name="categorie">
                        <option value="">Toutes catégories</option>
                        {% for cat in categories %}
                            <option value="{{ cat }}" {{ categorie == cat ? 'selected' : '' }}>{{ cat }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="col-md-2">
                    <select class="form-select border-0 z-index-9" name="niveau">
                        <option value="">Tous niveaux</option>
                        <option value="Débutant" {{ niveau == 'Débutant' ? 'selected' : '' }}>Débutant</option>
                        <option value="Intermédiaire" {{ niveau == 'Intermédiaire' ? 'selected' : '' }}>Intermédiaire</option>
                        <option value="Avancé" {{ niveau == 'Avancé' ? 'selected' : '' }}>Avancé</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <select class="form-select border-0 z-index-9" name="tri">
                        <option value="id" {{ tri == 'id' ? 'selected' : '' }}>Trier par ID</option>
                        <option value="titre" {{ tri == 'titre' ? 'selected' : '' }}>Titre</option>
                        <option value="categorie" {{ tri == 'categorie' ? 'selected' : '' }}>Catégorie</option>
                        <option value="niveau" {{ tri == 'niveau' ? 'selected' : '' }}>Niveau</option>
                    </select>
                </div>

                <div class="col-md-1">
                    <select class="form-select border-0 z-index-9" name="ordre">
                        <option value="asc" {{ ordre == 'asc' ? 'selected' : '' }}>ASC</option>
                        <option value="desc" {{ ordre == 'desc' ? 'selected' : '' }}>DESC</option>
                    </select>
                </div>

                <div class="col-md-2 d-flex gap-2">
                    <button class="btn btn-primary w-100" type="submit">Filtrer</button>
                    <a href="{{ path('formation_index') }}" class="btn btn-secondary w-100">Reset</a>
                </div>
            </div>
        </form>
    </div>

    <div class="card-body">
        <div class="table-responsive border-0 rounded-3">
            <table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
                <thead>
                    <tr>
                        <th class="border-0 rounded-start">Titre</th>
                        <th class="border-0">Catégorie</th>
                        <th class="border-0">Niveau</th>
                        <th class="border-0">Publié</th>
                        <th class="border-0">Image</th>
                        <th class="border-0 rounded-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for formation in formations %}
                        <tr>
                            <td>
                                <strong>{{ formation.titre }}</strong><br>
                                <small>{{ formation.description ?: 'Pas de description' }}</small>
                            </td>
                            <td>{{ formation.categorie }}</td>
                            <td>
                                <span class="badge text-bg-primary">{{ formation.niveau }}</span>
                            </td>
                            <td>
                                {% if formation.isPublished %}
                                    <span class="badge bg-success bg-opacity-15 text-success">Oui</span>
                                {% else %}
                                    <span class="badge bg-warning bg-opacity-15 text-warning">Non</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if formation.imageUrl %}
                                    <a href="{{ formation.imageUrl }}" target="_blank" class="btn btn-sm btn-light">Voir</a>
                                {% else %}
                                    <span class="text-muted">Aucune</span>
                                {% endif %}
                            </td>
                            <td>
                                <a href="{{ path('formation_edit', {'id': formation.id}) }}" class="btn btn-sm btn-dark me-1 mb-1 mb-md-0">Modifier</a>

                                <form method="post" action="{{ path('formation_delete', {'id': formation.id}) }}" style="display:inline-block;" onsubmit="return confirm('Supprimer cette formation ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ formation.id) }}">
                                    <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center">Aucune formation trouvée.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}