{% extends 'base.html.twig' %}

{% block title %}FINORA - Formations{% endblock %}

{% block body %}
    <div style="padding: 30px; font-family: Arial, sans-serif;">
        <h1>Liste des formations</h1>

        <form method="get" action="{{ path('formation_index') }}" style="margin-bottom: 25px; padding: 15px; border: 1px solid #ddd; border-radius: 10px;">
            <div style="display: flex; flex-wrap: wrap; gap: 15px; align-items: end;">
                <div>
                    <label for="titre">Titre</label><br>
                    <input type="text" id="titre" name="titre" value="{{ titre }}" placeholder="Rechercher par titre">
                </div>

                <div>
                    <label for="categorie">Catégorie</label><br>
                    <select id="categorie" name="categorie">
                        <option value="">Toutes</option>
                        {% for cat in categories %}
                            <option value="{{ cat }}" {{ categorie == cat ? 'selected' : '' }}>
                                {{ cat }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div>
                    <label for="niveau">Niveau</label><br>
                    <select id="niveau" name="niveau">
                        <option value="">Tous</option>
                        <option value="Débutant" {{ niveau == 'Débutant' ? 'selected' : '' }}>Débutant</option>
                        <option value="Intermédiaire" {{ niveau == 'Intermédiaire' ? 'selected' : '' }}>Intermédiaire</option>
                        <option value="Avancé" {{ niveau == 'Avancé' ? 'selected' : '' }}>Avancé</option>
                    </select>
                </div>

                <div>
                    <label for="tri">Trier par</label><br>
                    <select id="tri" name="tri">
                        <option value="id" {{ tri == 'id' ? 'selected' : '' }}>ID</option>
                        <option value="titre" {{ tri == 'titre' ? 'selected' : '' }}>Titre</option>
                        <option value="categorie" {{ tri == 'categorie' ? 'selected' : '' }}>Catégorie</option>
                        <option value="niveau" {{ tri == 'niveau' ? 'selected' : '' }}>Niveau</option>
                    </select>
                </div>

                <div>
                    <label for="ordre">Ordre</label><br>
                    <select id="ordre" name="ordre">
                        <option value="asc" {{ ordre == 'asc' ? 'selected' : '' }}>Ascendant</option>
                        <option value="desc" {{ ordre == 'desc' ? 'selected' : '' }}>Descendant</option>
                    </select>
                </div>

                <div>
                    <button type="submit" style="padding: 8px 14px; background: #7C3AED; color: white; border: none; border-radius: 6px;">
                        Rechercher
                    </button>
                </div>

                <div>
                    <a href="{{ path('formation_index') }}" style="padding: 8px 14px; background: #6b7280; color: white; text-decoration: none; border-radius: 6px;">
                        Réinitialiser
                    </a>
                </div>
            </div>
        </form>

        <a href="{{ path('formation_new') }}"
           style="display:inline-block; margin-bottom:20px; padding:10px 15px; background:#7C3AED; color:white; text-decoration:none; border-radius:8px;">
            Ajouter une formation
        </a>

        {% if formations is empty %}
            <p>Aucune formation trouvée.</p>
        {% else %}
            <ul>
                {% for formation in formations %}
                    <li style="margin-bottom: 20px; padding:15px; border:1px solid #ddd; border-radius:10px;">
                        <strong>{{ formation.titre }}</strong><br>
                        Catégorie : {{ formation.categorie }}<br>
                        Niveau : {{ formation.niveau }}<br>
                        Description : {{ formation.description ?? 'Pas de description' }}<br>
                        Publiée : {{ formation.ispublished ? 'Oui' : 'Non' }}<br>
                        {% if formation.imageUrl %}
                            Image URL : {{ formation.imageUrl }}<br>
                        {% endif %}
                        <br>

                        <a href="{{ path('formation_edit', {'id': formation.id}) }}"
                           style="margin-right:10px; padding:8px 12px; background:#2563eb; color:white; text-decoration:none; border-radius:6px;">
                            Modifier
                        </a>

                        <form method="post"
                              action="{{ path('formation_delete', {'id': formation.id}) }}"
                              style="display:inline-block;"
                              onsubmit="return confirm('Supprimer cette formation ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ formation.id) }}">
                            <button type="submit"
                                    style="padding:8px 12px; background:#dc2626; color:white; border:none; border-radius:6px; cursor:pointer;">
                                Supprimer
                            </button>
                        </form>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>
{% endblock %}