{% extends 'admin/base_admin.html.twig' %}

{% block title %}Modifier une formation{% endblock %}

{% block admin_content %}
<div class="container py-4">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <h1 class="h3 mb-4">Modifier une formation</h1>

            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                {% if not form.vars.valid %}
                    <div class="alert alert-danger">
                        {{ form_errors(form) }}
                    </div>
                {% endif %}

                <div class="mb-3">
                    {{ form_label(form.titre) }}
                    {{ form_widget(form.titre, {'attr': {'class': 'form-control'}}) }}
                    <div class="text-danger small mt-1">{{ form_errors(form.titre) }}</div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.description) }}
                    {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                    <div class="text-danger small mt-1">{{ form_errors(form.description) }}</div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.pourquoiAcheter) }}
                    {{ form_widget(form.pourquoiAcheter, {'attr': {'class': 'form-control', 'rows': 3}}) }}
                    <div class="form-text">Texte incitatif affiché aux visiteurs lorsque les leçons sont verrouillées.</div>
                    <div class="text-danger small mt-1">{{ form_errors(form.pourquoiAcheter) }}</div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.categorie) }}
                    {{ form_widget(form.categorie, {'attr': {'class': 'form-select', 'size': '8'}}) }}
                    <div class="form-text">Maintenez Ctrl pour sélectionner plusieurs catégories.</div>
                    <div class="text-danger small mt-1">{{ form_errors(form.categorie) }}</div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.niveau) }}
                    {{ form_widget(form.niveau, {'attr': {'class': 'form-select'}}) }}
                    <div class="text-danger small mt-1">{{ form_errors(form.niveau) }}</div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.is_published) }}
                    {{ form_widget(form.is_published, {'attr': {'class': 'form-select'}}) }}
                    <div class="text-danger small mt-1">{{ form_errors(form.is_published) }}</div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.prix) }}
                    <div class="input-group">
                        {{ form_widget(form.prix, {'attr': {'class': 'form-control'}}) }}
                        <span class="input-group-text">TND</span>
                    </div>
                    <div class="text-danger small mt-1">{{ form_errors(form.prix) }}</div>
                </div>

                {% if formation.imageUrl %}
                    <div class="mb-3">
                        <label class="form-label">Image actuelle</label><br>
                        <img src="{{ asset('uploads/formations/' ~ formation.imageUrl) }}" alt="{{ formation.titre }}" style="max-width: 220px; border-radius: 12px;">
                    </div>
                {% endif %}

                <div class="mb-3">
                    {{ form_label(form.imageFile) }}
                    {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                    <div class="text-danger small mt-1">{{ form_errors(form.imageFile) }}</div>
                </div>

                <button class="btn btn-primary">Mettre à jour</button>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}