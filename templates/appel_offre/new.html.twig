{% extends 'base.html.twig' %}

{% block title %}Nouvel Appel d'Offre{% endblock %}

{% block body %}

<div class="py-3 mb-4" style="background: linear-gradient(135deg, #1a1a2e, #16213e); border-radius: 10px;">
    <div class="container text-white text-center py-2">
        <h2 class="font-weight-bold"><i class="fas fa-plus-circle"></i> Nouvel Appel d'Offre</h2>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header" style="background:#1a1a2e; color:white;">
                <h5 class="mb-0"><i class="fas fa-file-contract"></i> Informations de l'Appel d'Offre</h5>
            </div>
            <div class="card-body">
                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                <div class="row">
                    <div class="col-md-12 mb-3">
                        {{ form_label(form.titre) }}
                        {{ form_widget(form.titre) }}
                        {% if form_errors(form.titre) %}
                            <div class="text-danger small mt-1">
                                <i class="fas fa-exclamation-circle"></i>
                                {{ form_errors(form.titre) }}
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 mb-3">
                        {{ form_label(form.description) }}
                        {{ form_widget(form.description) }}
                        {% if form_errors(form.description) %}
                            <div class="text-danger small mt-1">
                                <i class="fas fa-exclamation-circle"></i>
                                {{ form_errors(form.description) }}
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.type) }}
                        {{ form_widget(form.type) }}
                        {% if form_errors(form.type) %}
                            <div class="text-danger small mt-1">
                                <i class="fas fa-exclamation-circle"></i>
                                {{ form_errors(form.type) }}
                            </div>
                        {% endif %}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.statut) }}
                        {{ form_widget(form.statut) }}
                        {% if form_errors(form.statut) %}
                            <div class="text-danger small mt-1">
                                <i class="fas fa-exclamation-circle"></i>
                                {{ form_errors(form.statut) }}
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        {{ form_label(form.budgetMin) }}
                        {{ form_widget(form.budgetMin) }}
                        {% if form_errors(form.budgetMin) %}
                            <div class="text-danger small mt-1">
                                <i class="fas fa-exclamation-circle"></i>
                                {{ form_errors(form.budgetMin) }}
                            </div>
                        {% endif %}
                    </div>
                    <div class="col-md-4 mb-3">
                        {{ form_label(form.budgetMax) }}
                        {{ form_widget(form.budgetMax) }}
                        {% if form_errors(form.budgetMax) %}
                            <div class="text-danger small mt-1">
                                <i class="fas fa-exclamation-circle"></i>
                                {{ form_errors(form.budgetMax) }}
                            </div>
                        {% endif %}
                    </div>
                    <div class="col-md-4 mb-3">
                        {{ form_label(form.devise) }}
                        {{ form_widget(form.devise) }}
                        {% if form_errors(form.devise) %}
                            <div class="text-danger small mt-1">
                                <i class="fas fa-exclamation-circle"></i>
                                {{ form_errors(form.devise) }}
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.dateLimite) }}
                        {{ form_widget(form.dateLimite) }}
                        {% if form_errors(form.dateLimite) %}
                            <div class="text-danger small mt-1">
                                <i class="fas fa-exclamation-circle"></i>
                                {{ form_errors(form.dateLimite) }}
                            </div>
                        {% endif %}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.categorie) }}
                        {{ form_widget(form.categorie) }}
                        {% if form_errors(form.categorie) %}
                            <div class="text-danger small mt-1">
                                <i class="fas fa-exclamation-circle"></i>
                                {{ form_errors(form.categorie) }}
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-3">
                    <a href="{{ path('app_appel_offre_index') }}" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Retour
                    </a>
                    <button type="submit" class="btn btn-warning">
                        <i class="fas fa-save"></i> Enregistrer
                    </button>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

{% endblock %}