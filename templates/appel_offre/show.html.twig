{% extends app.request.query.get('role') == 'admin' ? 'admin_base.html.twig' : 'base.html.twig' %}

{% block title %}{{ appel_offre.titre }}{% endblock %}

{% block body %}

{# HERO #}
<div class="py-3 mb-4" style="background: linear-gradient(135deg, #1a1a2e, #16213e); border-radius: 10px;">
    <div class="container text-white text-center py-2">
        <h2 class="font-weight-bold"><i class="fas fa-file-contract"></i> {{ appel_offre.titre }}</h2>
        <p class="mb-0">
            {% if appel_offre.statut == 'published' %}
                <span class="badge bg-success text-white">Publié</span>
            {% elseif appel_offre.statut == 'draft' %}
                <span class="badge bg-secondary text-white">Brouillon</span>
            {% else %}
                <span class="badge bg-danger text-white">Clôturé</span>
            {% endif %}
            <span class="badge bg-info text-dark ml-2">{{ appel_offre.type }}</span>
        </p>
    </div>
</div>

<div class="row">

    {# COLONNE GAUCHE - Détails #}
    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header" style="background:#1a1a2e;">
                <h5 class="mb-0 text-white"><i class="fas fa-info-circle text-white"></i> Détails de l'Appel d'Offre</h5>
            </div>
            <div class="card-body">
                {# DESCRIPTION BLOCK #}
                <div class="mb-4 p-3" style="background: #f8f9fa; border-left: 5px solid #1a1a2e; border-radius: 5px;">
                    <h6 class="font-weight-bold text-muted mb-2"><i class="fas fa-align-left"></i> Description de l'offre</h6>
                    <p class="mb-0" style="font-size: 1.1rem; color: #333; line-height: 1.6;">
                        {{ appel_offre.description ?? 'Aucune description disponible pour cet appel d\'offre.' }}
                    </p>
                </div>

                <table class="table table-borderless">
                    <tr>
                        <th width="35%"><i class="fas fa-heading text-muted"></i> Titre</th>
                        <td>{{ appel_offre.titre }}</td>
                    </tr>
                    <tr>
                        <th><i class="fas fa-tag text-muted"></i> Type</th>
                        <td><span class="badge bg-info text-dark">{{ appel_offre.type }}</span></td>
                    </tr>
                    <tr>
                        <th><i class="fas fa-folder text-muted"></i> Catégorie</th>
                        <td>{{ appel_offre.categorie ? appel_offre.categorie.nom : 'Non définie' }}</td>
                    </tr>
                    <tr>
                        <th><i class="fas fa-money-bill text-muted"></i> Budget</th>
                        <td>
                            {% if appel_offre.budgetMin and appel_offre.budgetMax %}
                                <div class="fw-bold text-primary">{{ appel_offre.budgetMin|number_format(0, '.', ' ') }} - {{ appel_offre.budgetMax|number_format(0, '.', ' ') }} TND</div>
                                <div class="small text-muted">
                                    {% if budgetEur %}
                                        <i class="fas fa-euro-sign"></i> {{ budgetEur.min|number_format(0, '.', ' ') }} - {{ budgetEur.max|number_format(0, '.', ' ') }} EUR
                                    {% endif %}
                                    {% if budgetUsd %}
                                        <br><i class="fas fa-dollar-sign"></i> {{ budgetUsd.min|number_format(0, '.', ' ') }} - {{ budgetUsd.max|number_format(0, '.', ' ') }} USD
                                    {% endif %}
                                </div>
                            {% else %}
                                <span class="text-muted">Non défini</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th><i class="fas fa-calendar text-muted"></i> Date Limite</th>
                        <td>
                            {% if appel_offre.dateLimite %}
                                {% if appel_offre.dateLimite < date() %}
                                    <span class="text-danger">
                                        <i class="fas fa-exclamation-circle"></i>
                                        {{ appel_offre.dateLimite|date('d/m/Y') }} (Expiré)
                                    </span>
                                {% else %}
                                    <span class="text-success">
                                        <i class="fas fa-clock"></i>
                                        {{ appel_offre.dateLimite|date('d/m/Y') }}
                                    </span>
                                {% endif %}
                            {% else %}
                                <span class="text-muted">Non définie</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th><i class="fas fa-clock text-muted"></i> Créé le</th>
                        <td>{{ appel_offre.createdAt|date('d/m/Y à H:i') }}</td>
                    </tr>
                </table>
            </div>
        </div>

        {# CANDIDATURES - ADMIN seulement #}
        {% if app.session.get('role') == 'admin' %}
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center" style="background:#1a1a2e;">
                <h5 class="mb-0 text-white">
                    <i class="fas fa-users text-white"></i> Candidatures
                    <span class="badge bg-warning text-dark ml-2">{{ appel_offre.candidatures|length }}</span>
                </h5>
            </div>
            <div class="card-body p-0">
                {% if appel_offre.candidatures|length > 0 %}
                    <table class="table table-hover mb-0">
                        <thead class="thead-dark">
                            <tr>
                                <th>Candidat</th>
                                <th>Montant Proposé</th>
                                <th>Statut</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for candidature in appel_offre.candidatures %}
                            <tr>
                                <td>
                                    <i class="fas fa-user text-muted"></i>
                                    {{ candidature.user ? candidature.user.nom : 'Anonyme' }}
                                </td>
                                <td>
                                    {% if candidature.montantPropose %}
                                        <strong>{{ candidature.montantPropose }}</strong> TND
                                    {% else %}
                                        <span class="text-muted">N/A</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if candidature.statut == 'accepted' %}
                                        <span class="badge bg-success text-white">Acceptée</span>
                                    {% elseif candidature.statut == 'rejected' %}
                                        <span class="badge bg-danger text-white">Rejetée</span>
                                    {% else %}
                                        <span class="badge bg-warning text-dark">En attente</span>
                                    {% endif %}
                                </td>
                                <td>{{ candidature.createdAt|date('d/m/Y') }}</td>
                                <td>
                                    <a href="{{ path('app_candidature_show', {'id': candidature.id, 'role': app.request.query.get('role')}) }}"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_candidature_edit', {'id': candidature.id, 'role': app.request.query.get('role')}) }}"
                                       class="btn btn-sm btn-outline-warning">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <div class="text-center text-muted py-4">
                        <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                        Aucune candidature pour le moment
                    </div>
                {% endif %}
            </div>
        </div>
        {% endif %}

        {# ENTREPRISE - Soumettre candidature #}
        {% if app.session.get('role') == 'entreprise' %}
        <div class="card shadow-sm mt-4">
            <div class="card-header" style="background:#1a1a2e; color:white;">
                <h5 class="mb-0"><i class="fas fa-paper-plane"></i> Votre Candidature</h5>
            </div>
            <div class="card-body text-center">
                <a href="{{ path('app_candidature_new') }}" class="btn btn-success">
                    <i class="fas fa-paper-plane"></i> Soumettre une Candidature
                </a>
            </div>
        </div>
        {% endif %}

    </div>

    {# COLONNE DROITE - Actions #}
    <div class="col-md-4">

        {# ACTIONS #}
        <div class="card shadow-sm mb-3">
            <div class="card-header" style="background:#1a1a2e; color:white;">
                <h5 class="mb-0"><i class="fas fa-cogs"></i> Actions</h5>
            </div>
            <div class="card-body">
                {# ADMIN #}
                {% if app.session.get('role') == 'admin' %}
                    <a href="{{ path('app_appel_offre_edit', {'id': appel_offre.id, 'role': app.request.query.get('role')}) }}"
                       class="btn btn-warning btn-block mb-2">
                        <i class="fas fa-edit"></i> Modifier
                    </a>
                    <hr>
                    {{ include('appel_offre/_delete_form.html.twig') }}
                {% endif %}

                {# VISITEUR #}
                {% if app.session.get('role') == 'visiteur' or app.session.get('role') == null %}
                    <div class="alert alert-warning text-center">
                        <i class="fas fa-lock fa-2x mb-2 d-block"></i>
                        <small>Sélectionnez le rôle <strong>Entreprise</strong> pour soumettre une candidature</small>
                    </div>
                {% endif %}

                <a href="{{ path('app_appel_offre_index', {'role': app.request.query.get('role')}) }}"
                   class="btn btn-secondary btn-block mt-2">
                    <i class="fas fa-arrow-left"></i> Retour à la liste
                </a>
            </div>
        </div>

        {# STATS - ADMIN seulement #}
        {% if app.session.get('role') == 'admin' %}
        <div class="card shadow-sm mb-3">
            <div class="card-header" style="background:#1a1a2e; color:white;">
                <h5 class="mb-0"><i class="fas fa-chart-bar"></i> Statistiques</h5>
            </div>
            <div class="card-body text-center">
                <div class="row">
                    <div class="col-6 border-right">
                        <h3 class="text-warning">{{ appel_offre.candidatures|length }}</h3>
                        <small class="text-muted">Candidatures</small>
                    </div>
                    <div class="col-6">
                        <h3 class="text-success">
                            {{ appel_offre.candidatures|filter(c => c.statut == 'accepted')|length }}
                        </h3>
                        <small class="text-muted">Acceptées</small>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        {# RATING - ENTREPRISE seulement #}
        {% if app.session.get('role') == 'entreprise' %}
        <div class="card shadow-sm mb-3">
            <div class="card-header" style="background:#1a1a2e; color:white;">
                <h5 class="mb-0"><i class="fas fa-star"></i> Évaluation</h5>
            </div>
            <div class="card-body text-center">
                <p class="text-muted mb-2">Notez cet appel d'offre</p>
                <div id="star-rating" class="mb-3">
                    {% for i in 1..5 %}
                        <i class="fas fa-star fa-2x star-btn"
                           data-note="{{ i }}"
                           style="cursor:pointer; color:#ddd;"
                           onclick="noterAppel({{ i }})">
                        </i>
                    {% endfor %}
                </div>
                <div id="rating-message"></div>
            </div>
        </div>
        {% endif %}

        {# MOYENNE RATING - TOUS #}
        <div class="card shadow-sm mb-3">
            <div class="card-header" style="background:#1a1a2e; color:white;">
                <h5 class="mb-0"><i class="fas fa-star text-warning"></i> Note Moyenne</h5>
            </div>
            <div class="card-body text-center">
                <h2 class="text-warning" id="moyenne-value">--</h2>
                <div id="stars-display" class="mb-1"></div>
                <small class="text-muted"><span id="total-votes">0</span> vote(s)</small>
            </div>
        </div>

    </div>

</div>

{% endblock %}

{% block javascripts %}
<script>
    const appelOffreId = {{ appel_offre.id }};

    // Charger les stats au démarrage
    fetch(`/rating/stats/${appelOffreId}`)
        .then(r => r.json())
        .then(data => {
            updateStarsDisplay(data.moyenne, data.total_votes);
            // Si déjà noté → désactiver les étoiles
            if (data.deja_note) {
                document.querySelectorAll('.star-btn').forEach(star => {
                    star.style.pointerEvents = 'none';
                    star.style.color = '#ddd';
                });
                const ratingMessage = document.getElementById('rating-message');
                if (ratingMessage) {
                    ratingMessage.innerHTML =
                        '<div class="alert alert-info mt-2"><i class="fas fa-info-circle"></i> Vous avez déjà noté cet appel d\'offre.</div>';
                }
            }
        });

    // Hover sur les étoiles
    document.querySelectorAll('.star-btn').forEach(star => {
        star.addEventListener('mouseover', function() {
            highlightStars(parseInt(this.dataset.note));
        });
        star.addEventListener('mouseout', function() {
            resetStars();
        });
    });

    function highlightStars(note) {
        document.querySelectorAll('.star-btn').forEach(star => {
            star.style.color = parseInt(star.dataset.note) <= note ? '#ffc107' : '#ddd';
        });
    }

    function resetStars() {
        document.querySelectorAll('.star-btn').forEach(star => {
            star.style.color = '#ddd';
        });
    }

    function noterAppel(note) {
        const formData = new FormData();
        formData.append('note', note);

        fetch(`/rating/noter/${appelOffreId}`, {
            method: 'POST',
            body: formData,
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                highlightStars(note);
                updateStarsDisplay(data.moyenne, data.total_votes);
                document.getElementById('rating-message').innerHTML =
                    '<div class="alert alert-success mt-2"><i class="fas fa-check"></i> Merci pour votre note !</div>';
                // Désactiver les étoiles après vote
                document.querySelectorAll('.star-btn').forEach(star => {
                    star.style.pointerEvents = 'none';
                });
            } else if (data.already_rated) {
                document.getElementById('rating-message').innerHTML =
                    '<div class="alert alert-warning mt-2"><i class="fas fa-exclamation-triangle"></i> Vous avez déjà noté cet appel d\'offre !</div>';
            } else {
                document.getElementById('rating-message').innerHTML =
                    '<div class="alert alert-danger mt-2"><i class="fas fa-times"></i> ' + data.error + '</div>';
            }
        });
    }

    function updateStarsDisplay(moyenne, totalVotes) {
        document.getElementById('moyenne-value').textContent = moyenne > 0 ? moyenne : '--';
        document.getElementById('total-votes').textContent = totalVotes;

        let starsHtml = '';
        for (let i = 1; i <= 5; i++) {
            if (i <= Math.floor(moyenne)) {
                starsHtml += '<i class="fas fa-star text-warning"></i>';
            } else if (i - 0.5 <= moyenne) {
                starsHtml += '<i class="fas fa-star-half-alt text-warning"></i>';
            } else {
                starsHtml += '<i class="far fa-star text-warning"></i>';
            }
        }
        document.getElementById('stars-display').innerHTML = starsHtml;
    }
</script>
{% endblock %}