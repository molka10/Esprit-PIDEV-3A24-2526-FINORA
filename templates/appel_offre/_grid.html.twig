<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4" id="appelOffreGrid">
{% for appel in appel_offres %}
    <div class="col appel-item">
        <div class="card h-100 card-premium border-0 shadow-sm overflow-hidden" style="transition: transform 0.2s ease, box-shadow 0.2s ease;">
            
            {# Card Header / Status #}
            <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                <div class="d-flex gap-2">
                    <span class="badge py-2 px-3 rounded-pill bg-primary-soft text-primary fw-bold" style="font-size: 0.7rem;">
                        {{ appel.type|capitalize }}
                    </span>
                    {% if appel.statut == 'published' %}
                        <span class="badge py-2 px-3 rounded-pill bg-success-soft text-success fw-bold" style="font-size: 0.7rem;">Publié</span>
                    {% elseif appel.statut == 'closed' %}
                        <span class="badge py-2 px-3 rounded-pill bg-danger-soft text-danger fw-bold" style="font-size: 0.7rem;">Clôturé</span>
                    {% else %}
                        <span class="badge py-2 px-3 rounded-pill bg-light text-muted fw-bold" style="font-size: 0.7rem;">Brouillon</span>
                    {% endif %}
                </div>
                
                {% if app.user and not is_granted('ROLE_ADMIN') %}
                    <button class="btn btn-link p-0 favorite-toggle text-decoration-none" 
                            type="button"
                            data-id="{{ appel.id }}" 
                            title="Ajouter aux favoris">
                        <i class="{{ app.user.favoriteAppels.contains(appel) ? 'fas' : 'far' }} fa-heart text-danger fs-5"></i>
                    </button>
                {% endif %}
            </div>

            {# Card Body #}
            <div class="card-body px-4">
                <h5 class="mb-3">
                    <a href="{{ path('app_appel_offre_show', {'id': appel.id, 'role': app.request.query.get('role')}) }}" class="text-dark text-decoration-none fw-bold hover-primary">
                        {{ appel.titre }}
                    </a>
                </h5>

                <div class="d-flex align-items-center mb-4">
                    <div class="bg-primary-soft p-2 rounded-3 me-3">
                        <i class="bi bi-tag-fill text-primary"></i>
                    </div>
                    <div>
                        <p class="text-muted small mb-0">Catégorie</p>
                        <p class="fw-bold mb-0 text-dark" style="font-size: 0.85rem;">
                            {{ appel.categorie ? appel.categorie.nom : 'Non catégorisé' }}
                        </p>
                    </div>
                </div>

                <div class="p-3 bg-light rounded-4 mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted small">Budget Estimé</span>
                        <span class="badge bg-white text-dark border shadow-xs">DT</span>
                    </div>
                    <div class="fw-extrabold text-primary h5 mb-0">
                        {% if appel.budgetMin and appel.budgetMax %}
                            {{ appel.budgetMin|number_format(0, '.', ' ') }} - {{ appel.budgetMax|number_format(0, '.', ' ') }}
                        {% else %}
                            <span class="text-muted">À définir</span>
                        {% endif %}
                    </div>
                </div>

                <div class="d-flex align-items-center text-muted small">
                    <i class="bi bi-clock-history me-2"></i>
                    {% if appel.dateLimite %}
                        <span class="{{ appel.dateLimite < date() ? 'text-danger fw-bold' : '' }}">
                            Expire le {{ appel.dateLimite|date('d/m/Y') }}
                        </span>
                    {% else %}
                        Pas de date limite
                    {% endif %}
                </div>
            </div>

            {# Card Footer #}
            <div class="card-footer bg-white border-0 pb-4 px-4">
                <div class="d-grid gap-2">
                    {% if is_granted('ROLE_ENTREPRISE') and not is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_candidature_new', {'role': app.request.query.get('role'), 'appelOffre': appel.id}) }}" class="btn btn-primary rounded-pill py-2 fw-bold text-white shadow-sm">
                            <i class="bi bi-send me-2"></i>Postuler maintenant
                        </a>
                    {% endif %}
                    
                    <a href="{{ path('app_appel_offre_show', {'id': appel.id, 'role': app.request.query.get('role')}) }}" class="btn btn-outline-primary rounded-pill py-2 fw-bold">
                        Détails de l'offre
                    </a>
                </div>
            </div>
        </div>
    </div>
{% else %}
    <div class="col-12 text-center py-5">
        <div class="bg-light p-5 rounded-5">
            <i class="bi bi-inbox fa-4x mb-3 text-muted"></i>
            <h4 class="text-dark">Aucune offre trouvée</h4>
            <p class="text-muted">Essayez de modifier vos filtres ou revenez plus tard.</p>
        </div>
    </div>
{% endfor %}
</div>

<style>
    .card-premium:hover { transform: translateY(-5px); box-shadow: 0 15px 35px rgba(109, 40, 217, 0.1) !important; }
    .bg-primary-soft { background-color: rgba(109, 40, 217, 0.08); }
    .bg-success-soft { background-color: rgba(25, 135, 84, 0.1); }
    .bg-danger-soft { background-color: rgba(220, 53, 69, 0.1); }
    .fw-extrabold { font-weight: 800; }
    .hover-primary:hover { color: #6d28d9 !important; }
</style>


{# PAGINATION #}
{% if total_pages > 1 %}
<div class="card-footer bg-white py-3 border-top">
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center mb-0">
            {# PREVIOUS #}
            <li class="page-item {{ current_page <= 1 ? 'disabled' : '' }}">
                <a class="page-link ajax-page-link" href="{{ path('app_appel_offre_index', app.request.query.all|merge({'page': current_page - 1})) }}">
                    <i class="fas fa-chevron-left"></i>
                </a>
            </li>

            {# PAGES #}
            {% for i in 1..total_pages %}
                <li class="page-item {{ i == current_page ? 'active' : '' }}">
                    <a class="page-link ajax-page-link" href="{{ path('app_appel_offre_index', app.request.query.all|merge({'page': i})) }}">{{ i }}</a>
                </li>
            {% endfor %}

            {# NEXT #}
            <li class="page-item {{ current_page >= total_pages ? 'disabled' : '' }}">
                <a class="page-link ajax-page-link" href="{{ path('app_appel_offre_index', app.request.query.all|merge({'page': current_page + 1})) }}">
                    <i class="fas fa-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
</div>
{% endif %}
