<form method="post" action="{{ path('app_appel_offre_delete', {'id': appel_offre.id}) }}">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ appel_offre.id) }}">
    <button type="submit" class="btn btn-danger"
        onclick="return confirm('Êtes-vous sûr de vouloir supprimer cet appel d\'offre ?')">
        <i class="fas fa-trash"></i> Supprimer
    </button>
</form>