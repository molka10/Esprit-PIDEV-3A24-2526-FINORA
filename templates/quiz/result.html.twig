{% extends 'base.html.twig' %}

{% block title %}Résultat du quiz{% endblock %}

{% block body %}


<main>
    <section class="py-5" style="background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%); min-height: 100vh;">
        <div class="container">
            <div class="mx-auto" style="max-width: 760px;">

                <div class="card border-0 shadow-sm overflow-hidden">
                    <div class="p-4 p-md-5 text-center" style="background: linear-gradient(135deg, #ede9fe 0%, #f5f3ff 55%, #ffffff 100%);">
                        
                        {% if fraudSuspected %}
                            <span class="badge bg-danger mb-3">Triche Suspectée</span>
                        {% else %}
                            <span class="badge {{ passed ? 'bg-success' : 'bg-warning text-dark' }} mb-3">
                                {{ passed ? 'Quiz réussi' : 'Quiz non réussi' }}
                            </span>
                        {% endif %}

                        <h1 class="h2 fw-bold mb-2">Résultat de {{ studentName }}</h1>
                        <p class="text-muted mb-4">{{ lesson.titre }}</p>

                        <div class="display-5 fw-bold mb-3" style="color:#6d28d9;">
                            {% if fraudSuspected %}
                                N/A
                            {% else %}
                                {{ score }}%
                            {% endif %}
                        </div>

                        {% if fraudSuspected %}
                            <div class="alert text-start border-0 shadow-sm mb-4" style="background:#fef2f2; color:#991b1b; border-left: 4px solid #dc2626 !important;">
                                <h4 class="h5 fw-bold mb-2 d-flex align-items-center gap-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                                    Évaluation invalidée
                                </h4>
                                <p class="mb-0 fs-6">
                                    {{ fraudExplanation|nl2br }}
                                </p>
                            </div>
                        {% else %}
                            <p class="mb-4 fs-5 text-muted">
                                Bonnes réponses : <strong>{{ correctAnswers }}/{{ totalQuestions }}</strong>
                            </p>

                            {% if passed %}
                                <div class="alert border-0 mb-4" style="background:#ecfdf3; color:#166534; border-left: 4px solid #16a34a !important;">
                                    Félicitations {{ studentName }} ! Vous avez réussi le quiz et obtenu votre certificat FINORA.
                                </div>
                            {% endif %}
                        {% endif %}

                        <div class="d-flex justify-content-center gap-2 flex-wrap">
                            <a href="{{ path('app_quiz_take', {'id': lesson.id}) }}" class="btn btn-primary px-4 py-2">
                                Refaire le quiz
                            </a>

                            <a href="{{ path('app_lesson_show', {'id': lesson.id}) }}" class="btn btn-outline-secondary px-4 py-2">
                                Retour à la leçon
                            </a>

                            {% if passed and quizResult is defined and not fraudSuspected %}
                                <a href="{{ path('app_quiz_certificate', {'id': quizResult.id}) }}" class="btn btn-warning px-4 py-2" target="_blank">
                                    🎓 Télécharger mon certificat
                                </a>
                            {% endif %}
                        </div>
                    </div>
                    </div>
                </div>

                {% if not fraudSuspected and reviewData|length > 0 %}
                <div class="mt-5">
                    <h3 class="h4 fw-bold mb-4" style="color: #4c1d95;">Mode Révision</h3>
                    <div class="row g-4">
                        {% for i, data in reviewData %}
                            <div class="col-12">
                                <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
                                    <div class="card-header border-0 bg-white d-flex align-items-center gap-3 py-3" style="border-bottom: 2px solid {% if data.isCorrect %}#86efac{% else %}#fca5a5{% endif %} !important;">
                                        <div style="width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; background: {% if data.isCorrect %}#dcfce7; color: #166534{% else %}#fee2e2; color: #991b1b{% endif %};">
                                            {% if data.isCorrect %}&#10003;{% else %}&#10007;{% endif %}
                                        </div>
                                        <h4 class="h6 mb-0 fw-bold m-0 flex-grow-1">Question {{ i + 1 }}</h4>
                                        <button class="btn btn-sm btn-outline-primary explain-btn" data-question-index="{{ i }}" style="border-radius: 20px;">
                                            🤖 Expliquer avec l'IA
                                        </button>
                                    </div>
                                    <div class="card-body p-4 bg-light">
                                        <p class="fw-bold mb-3">{{ data.question }}</p>
                                        
                                        <div class="d-flex flex-column gap-2 mb-3">
                                            {% for optIndex, optionText in data.options %}
                                                {% set isUserChoice = (optIndex == data.given) %}
                                                {% set isCorrectChoice = (optIndex == data.correct) %}
                                                
                                                <div class="p-2 px-3 border rounded 
                                                    {% if isCorrectChoice %}bg-success text-white border-success
                                                    {% elseif isUserChoice and not data.isCorrect %}bg-danger text-white border-danger
                                                    {% else %}bg-white text-muted{% endif %}
                                                ">
                                                    {{ ['A', 'B', 'C', 'D'][optIndex] }}. {{ optionText }}
                                                    {% if isUserChoice %} <small class="float-end fw-bold">(Votre choix)</small>{% endif %}
                                                    {% if isCorrectChoice and not isUserChoice %} <small class="float-end fw-bold">(Bonne réponse)</small>{% endif %}
                                                </div>
                                            {% endfor %}
                                        </div>

                                        <div id="explanation-container-{{ i }}" class="alert alert-info d-none mb-0 mt-3" style="background: #f5f3ff; border: 1px solid #ddd6fe; color: #5b21b6;">
                                            <div class="d-flex align-items-center gap-2 mb-2">
                                                <span class="spinner-border spinner-border-sm explanation-spinner d-none" role="status" aria-hidden="true"></span>
                                                <strong class="explanation-title">Explication IA :</strong>
                                            </div>
                                            <p class="mb-0 explanation-text"></p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}

            </div>
        </div>
    </section>
</main>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const explainBtns = document.querySelectorAll('.explain-btn');
    // PHP to JS data bridge
    const reviewData = {{ reviewData|default([])|json_encode|raw }};
    const lessonId = {{ lesson.id|default(0) }};

    explainBtns.forEach(btn => {
        btn.addEventListener('click', async function() {
            const idx = this.dataset.questionIndex;
            const container = document.getElementById('explanation-container-' + idx);
            const spinner = container.querySelector('.explanation-spinner');
            const textEl = container.querySelector('.explanation-text');
            const dataItem = reviewData[idx];

            if (!dataItem) return;

            // Show container & spinner
            container.classList.remove('d-none');
            spinner.classList.remove('d-none');
            textEl.textContent = 'Génération de l\'explication en cours...';
            this.disabled = true;

            try {
                const response = await fetch(`/quiz/lesson/${lessonId}/explain`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify({
                        question: dataItem.question,
                        correct: dataItem.options[dataItem.correct],
                        given: dataItem.given >= 0 ? dataItem.options[dataItem.given] : "Aucune réponse"
                    })
                });

                const result = await response.json();
                spinner.classList.add('d-none');
                
                if (response.ok && result.explanation) {
                    textEl.textContent = result.explanation;
                } else {
                    textEl.textContent = "Désolé, impossible de générer l'explication pour le moment.";
                }
            } catch (error) {
                spinner.classList.add('d-none');
                textEl.textContent = "Erreur de connexion.";
            }
            this.disabled = false;
        });
    });
});
</script>
{% endblock %}