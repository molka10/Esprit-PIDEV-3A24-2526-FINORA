{% extends 'base.html.twig' %}

{% block title %}Mes Certificats - FINORA{% endblock %}

{% block body %}
<main>
    <section class="pt-5 pb-5">
        <div class="container">
            <div class="row align-items-center g-4 purple-section p-4 p-lg-5 rounded-4 overflow-hidden mb-5">
                <div class="col-lg-7">
                    <span class="badge bg-primary bg-opacity-10 text-primary mb-3">Tableau de bord</span>
                    <h1 class="display-5 mb-3 finora-title">Félicitations, {{ studentName ?: 'Apprenant' }} !</h1>
                    <p class="mb-0">
                        Vous trouverez ici tous vos certificats durement gagnés. Chaque certificat témoigne de votre engagement et de vos compétences acquises sur Finora.
                    </p>
                </div>
                <div class="col-lg-5 text-center">
                    <div class="icon-xxl bg-white bg-opacity-25 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 120px; height: 120px; font-size: 60px;">
                        🏆
                    </div>
                </div>
            </div>

            <div class="row g-4">
                {% if certificates|length > 0 %}
                    {% for cert in certificates %}
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 border-0 shadow-sm cert-card">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div class="icon-lg bg-primary bg-opacity-10 text-primary rounded-3">
                                            <i class="fas fa-certificate fs-4"></i>
                                        </div>
                                        <span class="badge bg-success bg-opacity-10 text-success">Réussi</span>
                                    </div>
                                    
                                    <h5 class="fw-bold mb-1">{{ cert.lessonTitle }}</h5>
                                    <p class="text-muted small mb-3">Formation: {{ cert.formationTitle }}</p>
                                    
                                    <div class="d-flex align-items-center gap-3 mb-4">
                                        <div class="text-center">
                                            <div class="fw-bold text-primary">{{ cert.score }}%</div>
                                            <div class="small text-muted">Score</div>
                                        </div>
                                        <div class="vr"></div>
                                        <div class="text-center">
                                            <div class="fw-bold">{{ cert.takenAt|date('d/m/Y') }}</div>
                                            <div class="small text-muted">Obtenu le</div>
                                        </div>
                                    </div>

                                    <div class="d-grid">
                                        <a href="{{ path('app_quiz_certificate', {id: cert.id}) }}" class="btn btn-primary" target="_blank">
                                            <i class="fas fa-download me-2"></i>Télécharger PDF
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="col-12 text-center py-5">
                        <div class="mb-4" style="font-size: 80px;">🎓</div>
                        <h3>Aucun certificat pour le moment</h3>
                        <p class="text-muted mb-4">Passez un quiz avec un score d'au moins 80% pour obtenir votre premier certificat !</p>
                        <a href="{{ path('app_lessons') }}" class="btn btn-primary px-4 py-2">Parcourir les leçons</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>
</main>

<style>
    .cert-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 20px;
        overflow: hidden;
    }
    .cert-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(124, 58, 237, 0.15) !important;
    }
    .icon-lg {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>
{% endblock %}
