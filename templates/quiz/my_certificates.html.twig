{% extends 'base.html.twig' %}

{% block title %}Mes Certificats - FINORA{% endblock %}

{% block body %}
<main>
    <section class="pt-5 pb-5">
        <div class="container">
            <div class="row align-items-center g-4 purple-section p-4 p-lg-5 rounded-4 overflow-hidden mb-5">
                <div class="col-lg-7">
                    <span class="badge bg-primary bg-opacity-10 text-primary mb-3">Tableau de bord</span>
                    <h1 class="display-5 mb-3 finora-title">Félicitations, {{ studentName ?: 'Apprenant' }} !</h1>
                    <p class="mb-0">
                        Vous trouverez ici tous vos certificats durement gagnés. Chaque certificat témoigne de votre engagement et de vos compétences acquises sur Finora.
                    </p>
                </div>
                <div class="col-lg-5 text-center">
                    <div class="icon-xxl bg-white bg-opacity-25 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 120px; height: 120px; font-size: 60px;">
                        🏆
                    </div>
                </div>
            </div>

            <div class="row g-4 mb-5">
                <div class="col-12">
                    <h3 class="fw-bold mb-4 d-flex align-items-center">
                        <i class="fas fa-award text-primary me-2"></i>Mes Certificats Obtenus
                    </h3>
                </div>
                {% if certificates|length > 0 %}
                    {% for cert in certificates %}
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 border-0 diploma-card">
                                <div class="diploma-border"></div>
                                <div class="card-body p-4 text-center">
                                    <div class="diploma-seal mb-3">
                                        <i class="fas fa-certificate"></i>
                                    </div>
                                    
                                    <div class="small text-muted text-uppercase fw-bold mb-2" style="letter-spacing: 2px;">Certificat de Réussite</div>
                                    
                                    <h5 class="fw-bold mb-1" style="font-family: 'Playfair Display', serif;">{{ cert.lessonTitle }}</h5>
                                    <p class="text-muted small mb-3 fst-italic">Formation: {{ cert.formationTitle }}</p>
                                    
                                    <div class="divider-gold mb-3 mx-auto"></div>

                                    <div class="d-flex justify-content-center align-items-center gap-4 mb-4">
                                        <div>
                                            <div class="fw-bold text-dark h4 mb-0">{{ cert.score }}%</div>
                                            <div class="small text-muted fw-bold" style="font-size: 0.65rem; text-transform: uppercase;">Score Final</div>
                                        </div>
                                        <div class="vr" style="height: 30px;"></div>
                                        <div>
                                            <div class="fw-bold text-dark h5 mb-0" style="font-size: 0.9rem;">{{ cert.takenAt|date('d/m/Y') }}</div>
                                            <div class="small text-muted fw-bold" style="font-size: 0.65rem; text-transform: uppercase;">Délivré le</div>
                                        </div>
                                    </div>

                                    <div class="d-grid">
                                        <a href="{{ path('app_quiz_certificate', {id: cert.id}) }}" class="btn btn-gold" target="_blank">
                                            <i class="fas fa-file-pdf me-2"></i>Voir le Diplôme
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="col-12 text-center py-5">
                        <div class="mb-4" style="font-size: 80px;">🎓</div>
                        <h3>Aucun certificat pour le moment</h3>
                        <p class="text-muted mb-4">Passez un quiz avec un score d'au moins 80% pour obtenir votre premier certificat !</p>
                        <a href="{{ path('app_lessons') }}" class="btn btn-primary px-4 py-2">Parcourir les leçons</a>
                    </div>
                {% endif %}
            </div>

            {# --- Suggested Quizzes Section --- #}
            {% if suggestedQuizzes is defined and suggestedQuizzes|length > 0 %}
                <div class="row g-4 mt-5">
                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-end mb-4">
                            <div>
                                <h3 class="fw-bold mb-1">Défis Recommandés</h3>
                                <p class="text-muted mb-0">Continuez votre progression dans vos formations achetées.</p>
                            </div>
                            <a href="{{ path('app_lessons') }}" class="btn btn-link text-primary fw-bold text-decoration-none">Voir tout <i class="fas fa-arrow-right ms-1"></i></a>
                        </div>
                    </div>
                    
                    {% for lesson in suggestedQuizzes %}
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 border-0 shadow-sm hover-elevate overflow-hidden">
                                <div class="card-body p-4">
                                    <div class="d-flex align-items-center gap-3 mb-3">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                            <i class="fas fa-brain"></i>
                                        </div>
                                        <div>
                                            <span class="badge bg-warning bg-opacity-10 text-warning px-2 py-1" style="font-size: 0.65rem;">Quiz disponible</span>
                                            <h6 class="fw-bold mb-0 text-truncate" style="max-width: 180px;">{{ lesson.titre }}</h6>
                                        </div>
                                    </div>
                                    <p class="small text-muted mb-4">
                                        Terminez le contenu pour débloquer le certificat de la formation <strong>{{ lesson.formation ? lesson.formation.titre : 'Inconnue' }}</strong>.
                                    </p>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="small text-muted"><i class="far fa-clock me-1"></i>{{ lesson.dureeMinutes }} min</span>
                                        <a href="{{ path('app_quiz_take', {id: lesson.id}) }}" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            Lancer le Quiz
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

        </div>
    </section>
</main>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap');

    .diploma-card {
        background: #fff;
        position: relative;
        padding: 4px;
        transition: all 0.3s ease;
        border-radius: 4px !important;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
    .diploma-border {
        position: absolute;
        top: 10px; left: 10px; right: 10px; bottom: 10px;
        border: 2px solid #d4af37;
        pointer-events: none;
    }
    .diploma-card:hover {
        transform: scale(1.02);
        box-shadow: 0 20px 40px rgba(124, 58, 237, 0.15);
    }
    .diploma-seal {
        color: #d4af37;
        font-size: 40px;
    }
    .divider-gold {
        width: 60%;
        height: 1px;
        background: linear-gradient(90deg, transparent, #d4af37, transparent);
    }
    .btn-gold {
        background: #d4af37;
        color: white;
        border: none;
        font-weight: 700;
        transition: all 0.2s;
    }
    .btn-gold:hover {
        background: #b8962e;
        color: white;
        box-shadow: 0 4px 15px rgba(212, 175, 55, 0.4);
    }
    .hover-elevate {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-elevate:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.08) !important;
    }
</style>
{% endblock %}
