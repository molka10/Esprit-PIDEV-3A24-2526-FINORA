{% extends 'base_user_dashboard.html.twig' %}

{% block title %}Vendre {{ action.symbole }} — FINORA{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm" style="border-radius: 20px; overflow: hidden;">
            <div class="card-header p-4 text-white" style="background: linear-gradient(135deg, #1a0505 0%, #3b0f0f 100%);">
                <div class="d-flex align-items-center gap-3">
                    <div style="background: rgba(239,68,68,0.2); width:48px; height:48px; border-radius:12px; display:flex; align-items:center; justify-content:center;">
                        <i class="bi bi-arrow-up-circle text-danger fs-4"></i>
                    </div>
                    <div>
                        <h4 class="mb-0 text-white">Ordre de Vente</h4>
                        <span class="opacity-75 small">{{ action.symbole }} — {{ action.nomEntreprise }}</span>
                    </div>
                </div>
            </div>
            
            <div class="card-body p-4">
                <div class="alert alert-warning border-0 mb-4" style="background-color: rgba(245,158,11,0.1); border-radius: 12px; color: #92400e;">
                    <div class="d-flex">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <div>
                            <div class="fw-bold">Attention</div>
                            <div class="small">La vente d'actions est irréversible une fois confirmée.</div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-12">
                        <div class="p-3 bg-light rounded-3 text-center border">
                            <div class="text-muted small mb-1">Prix de vente actuel</div>
                            <div class="fw-bold fs-4 text-danger">{{ action.prixUnitaire }} TND</div>
                        </div>
                    </div>
                </div>

                <form method="post">
                    <div class="mb-4">
                        <label class="form-label fw-bold">Quantité à vendre</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-hash text-muted"></i></span>
                            <input type="number" name="quantite" id="sellQty" class="form-control border-start-0 ps-0 fw-bold" min="1" required placeholder="0" oninput="updateTotal()">
                            <span class="input-group-text bg-white">unités</span>
                        </div>
                    </div>

                    <div class="p-4 rounded-3 mb-4" style="background-color: #fffafb; border: 1px dashed #fee2e2;">
                         <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Crédit brut</span>
                            <span class="fw-bold text-dark" id="subtotal">0.00 TND</span>
                         </div>
                         <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Taxe/Comm. (1%)</span>
                            <span class="text-warning fw-bold" id="commission">0.00 TND</span>
                         </div>
                         <hr>
                         <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold">Net à Recevoir</span>
                            <span class="fs-3 fw-bolder text-danger" id="total">0.00 TND</span>
                         </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-lg py-3 fw-bold" style="border-radius: 12px;">
                            <i class="bi bi-check-circle me-2"></i> Confirmer la Vente
                        </button>
                        <a href="{{ path('app_market') }}" class="btn btn-light btn-lg py-3 text-muted fw-semibold" style="border-radius: 12px;">
                            Annuler
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    const price = {{ action.prixUnitaire }};
    
    function updateTotal() {
        const qty = document.getElementById('sellQty').value || 0;
        const sub = qty * price;
        const comm = sub * 0.01;
        const tot = sub - comm; // Substract commission on sell
        
        document.getElementById('subtotal').textContent = sub.toFixed(2) + ' TND';
        document.getElementById('commission').textContent = comm.toFixed(2) + ' TND';
        document.getElementById('total').textContent = tot.toFixed(2) + ' TND';
    }
</script>
{% endblock %}
