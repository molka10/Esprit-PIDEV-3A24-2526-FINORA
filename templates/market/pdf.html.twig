<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Historique des Transactions - Finora</title>
    <style>
        body { font-family: 'Helvetica', 'Arial', sans-serif; font-size: 12px; color: #333; margin: 30px; }
        .header { text-align: center; margin-bottom: 30px; border-bottom: 2px solid #6d28d9; padding-bottom: 10px; }
        .logo { font-size: 24px; font-weight: bold; color: #6d28d9; }
        .title { font-size: 18px; margin-top: 5px; }
        
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th { background-color: #f8f9fa; color: #6d28d9; text-align: left; padding: 10px; border-bottom: 2px solid #dee2e6; }
        td { padding: 10px; border-bottom: 1px solid #dee2e6; vertical-align: middle; }
        
        .badge { padding: 4px 8px; border-radius: 4px; font-size: 10px; font-weight: bold; text-transform: uppercase; }
        .bg-success { background-color: #d1fae5; color: #065f46; }
        .bg-danger { background-color: #fee2e2; color: #991b1b; }
        
        .footer { margin-top: 40px; font-size: 10px; color: #777; text-align: center; border-top: 1px solid #ddd; padding-top: 10px; }
        .totals { margin-top: 20px; text-align: right; }
        .total-item { margin-bottom: 5px; }
        .total-bold { font-weight: bold; font-size: 14px; color: #6d28d9; }
    </style>
</head>
<body>
    <div class="header">
        <div class="logo">FINORA</div>
        <div class="title">Rapport de Trading - Historique des Transactions</div>
        <div>Généré le {{ "now"|date("d/m/Y H:i") }}</div>
    </div>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Date</th>
                <th>Type</th>
                <th>Action</th>
                <th>Quantité</th>
                <th>Prix Unit.</th>
                <th>Commission</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            {% set totalAchat = 0 %}
            {% set totalVente = 0 %}
            {% set totalComm = 0 %}

            {% for t in transactions %}
                <tr>
                    <td>#{{ t.id }}</td>
                    <td>{{ t.dateTransaction|date('d/m/Y H:i') }}</td>
                    <td>
                        <span class="badge {{ t.typeTransaction == 'ACHAT' ? 'bg-success' : 'bg-danger' }}">
                            {{ t.typeTransaction }}
                        </span>
                    </td>
                    <td><strong>{{ t.action ? t.action.symbole : 'N/A' }}</strong></td>
                    <td>{{ t.quantite }}</td>
                    <td>{{ t.prixUnitaire|number_format(2, '.', ' ') }} DT</td>
                    <td>{{ t.commission|number_format(2, '.', ' ') }} DT</td>
                    <td><strong>{{ t.montantTotal|number_format(2, '.', ' ') }} DT</strong></td>
                </tr>

                {% if t.typeTransaction == 'ACHAT' %}
                    {% set totalAchat = totalAchat + t.montantTotal %}
                {% else %}
                    {% set totalVente = totalVente + t.montantTotal %}
                {% endif %}
                {% set totalComm = totalComm + t.commission %}
            {% else %}
                <tr>
                    <td colspan="8" style="text-align: center; padding: 30px;">Aucune transaction trouvée.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="totals">
        <div class="total-item">Total Investi (Achats) : <strong>{{ totalAchat|number_format(2, '.', ' ') }} DT</strong></div>
        <div class="total-item">Total Récupéré (Ventes) : <strong>{{ totalVente|number_format(2, '.', ' ') }} DT</strong></div>
        <div class="total-item">Total Commissions : <strong>{{ totalComm|number_format(2, '.', ' ') }} DT</strong></div>
        <div class="total-item total-bold">Performance Nette : {{ (totalVente - totalAchat)|number_format(2, '.', ' ') }} DT</div>
    </div>

    <div class="footer">
        Finora Platform - Votre partenaire en éducation financière et investissement boursier.<br>
        Ce document est un relevé officiel généré par le système.
    </div>
</body>
</html>
