                        </div>
                        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal"></button>
                    </div>
                </div>
                <div class="modal-body p-4">
                    <div class="order-summary">
                        <div class="row-item"><span class="key">Symbole</span><span class="val">{{ action.symbole }}</span></div>
                        <div class="row-item"><span class="key">Prix unitaire</span><span class="val text-danger">{{ action.prixUnitaire }} TND</span></div>
                    </div>
                    <label class="form-label fw-semibold mb-2">Quantité à vendre</label>
                    <div class="input-group mb-1">
