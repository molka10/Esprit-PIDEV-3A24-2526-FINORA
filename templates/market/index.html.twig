{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script>
/* ── Modals ── */
function updateBuyTotal(id, price) {
    var qty = document.getElementById('buyQty' + id).value;
    document.getElementById('buyTotal' + id).textContent = (qty ? (qty * price).toFixed(2) : '0.00') + ' TND';
}
function updateSellTotal(id, price) {
    var qty = document.getElementById('sellQty' + id).value;
    document.getElementById('sellTotal' + id).textContent = (qty ? (qty * price).toFixed(2) : '0.00') + ' TND';
}

/* ═══ ASSISTANT IA ═══ */
var aiChatOpen = false;
function toggleAiChat() {
    aiChatOpen = !aiChatOpen;
    var p = document.getElementById('aiChatPanel');
    var deck = document.getElementById('bourseActionDeck');
    if (aiChatOpen) { 
        p.classList.add('open'); 
        if (deck) deck.style.display = 'none'; 
        document.getElementById('aiChatInput').focus(); 
    }
    else { 
        p.classList.remove('open'); 
        if (deck) deck.style.display = 'flex'; 
    }
}
function sendQuickMsg(t) { document.getElementById('aiChatInput').value = t; sendAiMessage(); }
function sendAiMessage() {
    var input = document.getElementById('aiChatInput');
    var text = input.value.trim();
    if (!text) return;

    var el = document.getElementById('aiChatMessages');
    el.innerHTML += '<div class="ai-msg user">' + text.replace(/</g, '&lt;') + '</div>';
    input.value = '';
    el.scrollTop = el.scrollHeight;

    var tid = 't-' + Date.now();
    el.innerHTML += '<div class="ai-msg bot typing" id="' + tid + '"><div class="msg-label"><i class="bi bi-stars"></i> FINORA AI</div><div class="dots"><span></span><span></span><span></span></div></div>';
    el.scrollTop = el.scrollHeight;

    // Appel API Backend
    const formData = new FormData();
    formData.append('message', text);

    fetch('{{ path('app_chatbot_message') }}', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        var te = document.getElementById(tid);
        if (te) te.remove();

        if (data.success) {
            let richMsg = `<div class="ai-msg bot"><div class="msg-label"><i class="bi bi-stars"></i> FINORA AI</div>${data.message.replace(/\n/g, '<br>')}`;
            
            // Ajouter suggestions
            if (data.suggestions && data.suggestions.length > 0) {
                richMsg += `<div class="ai-quick-actions">`;
                data.suggestions.forEach(s => {
                    richMsg += `<button class="ai-quick-btn" onclick="sendQuickMsg('${s}')">${s}</button>`;
                });
                richMsg += `</div>`;
            }

            // Ajouter actions (Acheter/Vendre)
            if (data.actions && data.actions.length > 0) {
                richMsg += `<div class="d-flex gap-2 mt-2">`;
                data.actions.forEach(a => {
                    richMsg += `<a href="${a.url}" class="btn btn-sm btn-outline-primary" style="font-size:10px; border-radius:8px;">${a.label}</a>`;
                });
                richMsg += `</div>`;
            }

            richMsg += `</div>`;
            el.innerHTML += richMsg;
        } else {
            el.innerHTML += '<div class="ai-msg bot"><div class="msg-label">⚠️ Erreur</div>Désolé, je rencontre un problème technique.</div>';
        }
        el.scrollTop = el.scrollHeight;
    })
    .catch(error => {
        var te = document.getElementById(tid);
        if (te) te.remove();
        el.innerHTML += '<div class="ai-msg bot"><div class="msg-label">⚠️ Erreur</div>Impossible de contacter le serveur.</div>';
        el.scrollTop = el.scrollHeight;
    });
}

/* ═══ EXCHANGE PANEL ═══ */
var exchangePanelOpen = false;
function toggleExchangePanel() {
    exchangePanelOpen = !exchangePanelOpen;
    var p = document.getElementById('exchangePanel');
    var deck = document.getElementById('bourseActionDeck');
    if (exchangePanelOpen) { 
        p.classList.add('open'); 
        if (deck) deck.style.display = 'none'; 
        loadExchangeData(); 
    }
    else { 
        p.classList.remove('open'); 
        if (deck) deck.style.display = 'flex'; 
    }
}
function loadExchangeData() {
    var now = new Date();
    var day = now.getUTCDay();
    var hour = now.getUTCHours() + 1;
    var isOpen = day >= 1 && day <= 5 && hour >= 9 && hour < 17;
    var sessionEl = document.getElementById('exSession');
    if (isOpen) {
        sessionEl.innerHTML = '<span class="ex-status-badge open"><span class="sd"></span> Ouvert</span>';
        var minsLeft = (17 - hour) * 60 - now.getUTCMinutes();
        document.getElementById('exNextOpen').innerHTML = 'Ferme dans <span style="color:#f59e0b;">' + minsLeft + ' min</span>';
    } else {
        sessionEl.innerHTML = '<span class="ex-status-badge closed"><span class="sd"></span> Fermé</span>';
        if (day === 5 || day === 6 || day === 0) document.getElementById('exNextOpen').innerHTML = '<span style="color:#60a5fa;">Lundi 09:00</span>';
        else if (hour < 9) document.getElementById('exNextOpen').innerHTML = '<span style="color:#60a5fa;">Aujourd\'hui 09:00</span>';
        else document.getElementById('exNextOpen').innerHTML = '<span style="color:#60a5fa;">Demain 09:00</span>';
    }
    document.getElementById('exConnStatus').innerHTML = isOpen
        ? '<i class="bi bi-check-circle-fill me-1" style="color:#22c55e;"></i><span style="color:#22c55e;">BVMT Connecté</span>'
        : '<i class="bi bi-moon me-1" style="color:#64748b;"></i><span style="color:#64748b;">BVMT Hors ligne</span>';
    var rateStart = performance.now();
    fetch('https://api.exchangerate-api.com/v4/latest/TND')
        .then(function(r) { return r.json(); })
        .then(function(data) {
            var lat = Math.round(performance.now() - rateStart);
            var rates = data.rates;
            if (rates.USD) document.getElementById('rateUSD').textContent = rates.USD.toFixed(4);
            if (rates.EUR) document.getElementById('rateEUR').textContent = rates.EUR.toFixed(4);
            if (rates.GBP) document.getElementById('rateGBP').textContent = rates.GBP.toFixed(4);
            if (rates.MAD) document.getElementById('rateMAD').textContent = rates.MAD.toFixed(4);
            if (rates.DZD) document.getElementById('rateDZD').textContent = rates.DZD.toFixed(4);
            updateSyncInfo(lat);
        })
        .catch(function() {
            var fb = { USD: 0.3206, EUR: 0.2965, GBP: 0.2542, MAD: 3.1940, DZD: 43.12 };
            document.getElementById('rateUSD').textContent = fb.USD.toFixed(4);
            document.getElementById('rateEUR').textContent = fb.EUR.toFixed(4);
            document.getElementById('rateGBP').textContent = fb.GBP.toFixed(4);
            document.getElementById('rateMAD').textContent = fb.MAD.toFixed(4);
            document.getElementById('rateDZD').textContent = fb.DZD.toFixed(4);
            updateSyncInfo(null);
        });
}
function updateSyncInfo(latency) {
    var now = new Date();
    document.getElementById('exLastSync').textContent = now.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    if (latency) {
        document.getElementById('exAvgLatency').textContent = latency + ' ms';
        document.getElementById('exAvgLatency').style.color = latency < 300 ? '#22c55e' : latency < 800 ? '#f59e0b' : '#ef4444';
    }
    setTimeout(function() { var s = document.getElementById('exSpinner'); if (s) s.style.display = 'none'; }, 2000);
}

/* ═══ SPARKLINES ═══ */
function seededRandom(seed) {
    var x = Math.sin(seed) * 10000;
    return x - Math.floor(x);
}
function generateSparkData(price, actionId, count) {
    var pts = [];
    var cur = price * (0.88 + seededRandom(actionId) * 0.12);
    for (var i = 0; i < count; i++) {
        var ch = (seededRandom(actionId * 100 + i) - 0.45) * price * 0.04;
        cur += ch;
        cur = Math.max(price * 0.78, Math.min(price * 1.15, cur));
        pts.push(cur);
    }
    pts[pts.length - 1] = price;
    return pts;
}
function createSparklineSVG(points) {
    var w = 120, h = 38;
    if (points.length < 2) return '';
    var min = Math.min.apply(null, points);
    var max = Math.max.apply(null, points);
    var range = max - min || 1;
    var isUp = points[points.length - 1] >= points[0];
    var color = isUp ? '#22c55e' : '#ef4444';
    var fillId = 'sg' + Math.random().toString(36).substr(2, 6);
    var svgPts = points.map(function(p, i) {
        var x = (i / (points.length - 1)) * w;
        var y = h - ((p - min) / range) * (h - 6) - 3;
        return x.toFixed(1) + ',' + y.toFixed(1);
    }).join(' ');
    var lastX = w;
    var lastY = h - ((points[points.length - 1] - min) / range) * (h - 6) - 3;
    return '<svg width="100%" height="' + h + '" viewBox="0 0 ' + w + ' ' + h + '" preserveAspectRatio="none">' +
        '<defs><linearGradient id="' + fillId + '" x1="0" y1="0" x2="0" y2="1">' +
        '<stop offset="0%" stop-color="' + color + '" stop-opacity="0.25"/>' +
        '<stop offset="100%" stop-color="' + color + '" stop-opacity="0"/>' +
        '</linearGradient></defs>' +
        '<polygon fill="url(#' + fillId + ')" points="' + svgPts + ' ' + w + ',' + h + ' 0,' + h + '"/>' +
        '<polyline class="sparkline-path" fill="none" stroke="' + color + '" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" points="' + svgPts + '"/>' +
        '<circle cx="' + lastX + '" cy="' + lastY + '" r="2.5" fill="' + color + '"/>' +
        '</svg>';
}
function initSparklines() {
    document.querySelectorAll('.sparkline-wrap').forEach(function(el) {
        var id = parseInt(el.dataset.id);
        var price = parseFloat(el.dataset.price);
        if (price > 0) {
            var pts = generateSparkData(price, id, 7);
            el.innerHTML = createSparklineSVG(pts);
        } else {
            el.innerHTML = '<svg width="100%" height="38" viewBox="0 0 120 38"><line x1="0" y1="19" x2="120" y2="19" stroke="#e2e8f0" stroke-width="1.5" stroke-dasharray="4 3"/><line x1="60" y1="12" x2="60" y2="26" stroke="#e2e8f0" stroke-width="1.5" stroke-dasharray="4 3"/></svg>';
        }
    });
}

/* ═══ DEPTH BARS ═══ */
function initDepthBars() {
    document.querySelectorAll('.depth-bar-container').forEach(function(el) {
        var id = el.id.replace('depth-', '');
        var buyPct = 25 + Math.round(seededRandom(parseInt(id) * 7) * 50);
        var sellPct = 100 - buyPct;
        el.innerHTML =
            '<div class="depth-buy" style="width:' + buyPct + '%"></div>' +
            '<div class="depth-sell" style="width:' + sellPct + '%; right:0;"></div>' +
            '<div class="depth-marker" style="left:calc(' + buyPct + '% - 1px)"></div>';
    });
}

/* ═══ WATCHLIST ═══ */
function getWatchlist() {
    try { return JSON.parse(localStorage.getItem('finora_watchlist')) || []; }
    catch(e) { return []; }
}
function saveWatchlist(list) {
    localStorage.setItem('finora_watchlist', JSON.stringify(list));
}
function toggleWatchlist(id, symbole) {
    if (!id || id === 0) {
        showToast('Erreur: Action non identifiée', 'remove');
        return;
    }
    console.log('Toggling watchlist for ID:', id);
    var btn = document.querySelector(`.watchlist-star[data-id="${id}"]`);
    if (btn) btn.disabled = true;

    fetch(`{{ path('app_bourse_wishlist_toggle', {id: 0}) }}`.replace('0', id), {
        method: 'POST',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(async res => {
        const data = await res.json();
        console.log('Toggle response:', data);
        if (res.ok) {
            showToast(data.message, data.status === 'added' ? 'add' : 'remove');
            updateWatchlistUI();
        } else {
            showToast(data.message || 'Erreur lors de l\'ajout', 'remove');
        }
    })
    .catch(err => {
        console.error('Watchlist error:', err);
        showToast('Erreur de connexion au serveur', 'remove');
    })
    .finally(() => {
        if (btn) btn.disabled = false;
    });
}
function updateWatchlistUI() {
    fetch('{{ path('app_bourse_wishlist_my_ids') }}')
    .then(res => res.json())
    .then(data => {
        const list = data.ids || [];
        document.querySelectorAll('.watchlist-star').forEach(function(btn) {
            var id = parseInt(btn.dataset.id);
            if (list.indexOf(id) > -1) {
                btn.classList.add('active');
                btn.querySelector('i').className = 'bi bi-star-fill';
            } else {
                btn.classList.remove('active');
                btn.querySelector('i').className = 'bi bi-star';
            }
        });
        var badge = document.getElementById('watchlistCount');
        if (badge) badge.innerHTML = list.length;
    });
}
function showToast(msg, type) {
    var toast = document.getElementById('watchlistToast');
    var icon = document.getElementById('toastIcon');
    icon.className = 'bi bi-star-fill toast-icon ' + type;
    document.getElementById('toastMsg').textContent = msg;
    toast.classList.add('show');
    setTimeout(function() { toast.classList.remove('show'); }, 2200);
}

/* ═══ CANDLESTICK ═══ */
var candleChart = null;
var currentCandleDays = 7;

function generateOHLC(price, days, actionId) {
    var data = [];
    var p = price * (0.85 + seededRandom(actionId) * 0.15);
    for (var i = 0; i < days; i++) {
        var ch = (seededRandom(actionId * 100 + i) - 0.48) * price * 0.04;
        var open = p;
        var close = p + ch;
        var high = Math.max(open, close) + Math.random() * price * 0.015;
        var low = Math.min(open, close) - Math.random() * price * 0.015;
        var d = new Date();
        d.setDate(d.getDate() - (days - 1 - i));
        data.push({
            x: d.toISOString().split('T')[0],
            y: [
                parseFloat(open.toFixed(2)),
                parseFloat(high.toFixed(2)),
                parseFloat(low.toFixed(2)),
                parseFloat(close.toFixed(2))
            ]
        });
        p = close;
    }
    if (data.length > 0) {
        var last = data[data.length - 1];
        var diff = price - last.y[3];
        last.y[0] = parseFloat((last.y[0] + diff * 0.3).toFixed(2));
        last.y[1] = parseFloat((last.y[1] + Math.max(0, diff)).toFixed(2));
        last.y[2] = parseFloat((last.y[2] + Math.min(0, diff)).toFixed(2));
        last.y[3] = parseFloat(price.toFixed(2));
    }
    return data;
}

function initCandleChart() {
    var select = document.getElementById('candleSelector');
    if (!select || select.selectedOptions.length === 0) return;
    var price = parseFloat(select.selectedOptions[0].dataset.price);
    var id = parseInt(select.value);
    var ohlc = generateOHLC(price, currentCandleDays, id);

    if (ohlc.length > 0) {
        document.getElementById('candleOpen').textContent = ohlc[0].y[0] + ' TND';
        var allHighs = ohlc.map(function(d) { return d.y[1]; });
        var allLows = ohlc.map(function(d) { return d.y[2]; });
        document.getElementById('candleHigh').textContent = Math.max.apply(null, allHighs).toFixed(2) + ' TND';
        document.getElementById('candleLow').textContent = Math.min.apply(null, allLows).toFixed(2) + ' TND';
        document.getElementById('candleClose').textContent = ohlc[ohlc.length - 1].y[3] + ' TND';

        var changeVal = ((ohlc[ohlc.length - 1].y[3] - ohlc[0].y[0]) / ohlc[0].y[0] * 100);
        var changeEl = document.getElementById('candleChange');
        changeEl.textContent = (changeVal >= 0 ? '+' : '') + changeVal.toFixed(2) + '%';
        changeEl.className = 'ohlc-val ' + (changeVal >= 0 ? 'ohlc-up' : 'ohlc-down');
    }

    var options = {
        chart: {
            type: 'candlestick',
            height: 280,
            background: '#0c0e1a',
            toolbar: { show: false },
            fontFamily: 'Inter, sans-serif'
        },
        grid: {
            borderColor: '#1e2a45',
            strokeDashArray: 0
        },
        xaxis: {
            type: 'category',
            labels: { style: { colors: '#4b5c78', fontSize: '11px' } },
            axisBorder: { show: false }
        },
        yaxis: {
            labels: {
                style: { colors: '#4b5c78', fontSize: '11px' },
                formatter: function(v) { return v.toFixed(2) + ' TND'; }
            }
        },
        tooltip: {
            theme: 'dark',
            style: { fontSize: '13px' }
        },
        plotOptions: {
            candlestick: {
                colors: { upward: '#22c55e', downward: '#ef4444' },
                wick: { useFillColor: true }
            }
        },
        series: [{
            name: 'Prix',
            type: 'candlestick',
            data: ohlc
        }]
    };

    if (candleChart) {
        candleChart.updateSeries([{ data: ohlc }]);
    } else {
        candleChart = new ApexCharts(document.getElementById('candleChart'), options);
        candleChart.render();
    }
}

function switchCandlePeriod(days, btn) {
    document.querySelectorAll('.candle-period').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    currentCandleDays = days;
    initCandleChart();
}

function switchCandleAction() {
    initCandleChart();
}

/* ═══ INIT ═══ */
document.addEventListener('DOMContentLoaded', function() {
    initSparklines();
    initDepthBars();
    updateWatchlistUI();
    initCandleChart();
});
</script>
