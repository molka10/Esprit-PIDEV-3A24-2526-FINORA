                            <i class="bi bi-arrow-down-circle text-success fs-5"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">Ordre d'Achat</h5>
                            <span style="color:#c4b5fd; font-size:13px;">{{ action.symbole }} — {{ action.nomEntreprise }}</span>
                        </div>
                        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal"></button>
                    </div>
                </div>
                <div class="modal-body p-4">
                    <div class="order-summary">
                        <div class="row-item"><span class="key">Symbole</span><span class="val">{{ action.symbole }}</span></div>
                        <div class="row-item"><span class="key">Prix unitaire</span><span class="val text-success">{{ action.prixUnitaire }} TND</span></div>
                        <div class="row-item"><span class="key">Disponible</span><span class="val">{{ action.quantiteDisponible }} unités</span></div>
                    </div>
                    <label class="form-label fw-semibold mb-2">Quantité à acheter</label>
                    <div class="input-group mb-1">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-hash text-muted"></i></span>
                        <input type="number" name="quantite" id="buyQty{{ action.id }}" class="form-control border-start-0 ps-0 fs-5 fw-bold" min="1" max="{{ action.quantiteDisponible }}" required placeholder="0" oninput="updateBuyTotal('{{ action.id }}', {{ action.prixUnitaire }})">
