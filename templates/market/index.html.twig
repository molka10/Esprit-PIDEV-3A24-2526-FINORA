{% extends 'base_user.html.twig' %}

{% block title %}Marché — FINORA{% endblock %}

{% block body %}
<style>
    .market-hero {
        background: linear-gradient(135deg, #1e0a3c 0%, #2d1155 50%, #1e0a3c 100%);
        padding: 30px 0 20px;
        border-bottom: 1px solid #3b1278;
    }
    .ticker-bar {
        background: #1e0a3c;
        border-bottom: 1px solid #3b1278;
        padding: 8px 0;
        overflow: hidden;
        white-space: nowrap;
    }
    .ticker-wrap {
        display: inline-flex;
        animation: ticker 30s linear infinite;
        gap: 40px;
    }
    .ticker-wrap:hover { animation-play-state: paused; }
    @keyframes ticker {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .ticker-item { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; color: #94a3b8; }
    .ticker-item .symbol { color: white; font-weight: 700; }
    .ticker-item .price { color: white; }
    .ticker-item .up { color: #22c55e; }
    .ticker-item .down { color: #ef4444; }

    .stat-pill {
        background: rgba(255,255,255,0.07);
        border: 1px solid rgba(168,85,247,0.3);
        border-radius: 12px;
        padding: 16px 24px;
        color: white;
        text-align: center;
    }
    .stat-pill .value { font-size: 22px; font-weight: 700; }
    .stat-pill .label { font-size: 12px; color: #94a3b8; margin-top: 2px; }

    .live-badge {
        background: #22c55e; color: white;
        padding: 4px 12px; border-radius: 20px;
        font-size: 12px; font-weight: 600;
        display: inline-flex; align-items: center; gap: 6px;
    }
    .live-dot {
        width: 7px; height: 7px;
        background: white; border-radius: 50%;
        animation: pulse 1.5s infinite;
    }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

    .market-table-wrapper {
        background: white; border-radius: 16px;
        overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    }
    .market-table-header {
        background: #1e0a3c; padding: 20px 28px;
        display: flex; justify-content: space-between; align-items: center;
    }
    .market-table-header h5 { color: white; margin: 0; font-weight: 600; font-size: 16px; }

    .market-table thead th {
        background: #f8fafc; color: #64748b;
        font-size: 11px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.8px;
        padding: 14px 20px; border: none;
        border-bottom: 2px solid #f1f5f9;
    }
    .market-table tbody td {
        padding: 18px 20px; vertical-align: middle;
        border-color: #f8fafc; font-size: 14px;
    }
    .market-table tbody tr { transition: background 0.15s; cursor: pointer; }
    .market-table tbody tr:hover { background: #faf5ff; }

    .symbol-badge {
        background: #2d1155; color: white;
        padding: 6px 12px; border-radius: 8px;
        font-weight: 700; font-size: 13px;
        font-family: monospace; letter-spacing: 1px;
    }
    .company-name { font-weight: 600; color: #1e293b; font-size: 14px; }
    .company-sector { font-size: 12px; color: #94a3b8; margin-top: 2px; }
    .price-cell { font-size: 16px; font-weight: 700; color: #1e293b; font-family: monospace; }

    .change-up { background: #dcfce7; color: #16a34a; padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 600; }
    .change-down { background: #fee2e2; color: #dc2626; padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 600; }

    .qty-bar-wrap { display: flex; align-items: center; gap: 10px; }
    .qty-bar { flex: 1; height: 4px; background: #f1f5f9; border-radius: 4px; overflow: hidden; max-width: 80px; }
    .qty-bar-fill { height: 100%; background: linear-gradient(90deg, #7c3aed, #a855f7); border-radius: 4px; }

    .btn-buy {
        background: linear-gradient(135deg, #22c55e, #16a34a);
        color: white; border: none; padding: 8px 20px;
        border-radius: 8px; font-size: 13px; font-weight: 600;
        transition: 0.2s; display: inline-flex; align-items: center; gap: 6px;
    }
    .btn-buy:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(34,197,94,0.4); color: white; }

    .btn-sell {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: white; border: none; padding: 8px 20px;
        border-radius: 8px; font-size: 13px; font-weight: 600;
        transition: 0.2s; display: inline-flex; align-items: center; gap: 6px;
    }
    .btn-sell:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(239,68,68,0.4); color: white; }

    .modal-content { border-radius: 16px; overflow: hidden; }
    .modal-buy-header { background: linear-gradient(135deg, #1e0a3c, #3b1278); color: white; padding: 20px 24px; }
    .modal-sell-header { background: linear-gradient(135deg, #1a0505, #3b0f0f); color: white; padding: 20px 24px; }

    .order-summary { background: #faf5ff; border-radius: 12px; padding: 16px; margin-bottom: 16px; border: 1px solid #e9d5ff; }
    .order-summary .row-item { display: flex; justify-content: space-between; padding: 6px 0; font-size: 14px; border-bottom: 1px solid #ede9fe; }
    .order-summary .row-item:last-child { border-bottom: none; }
    .order-summary .row-item .key { color: #64748b; }
    .order-summary .row-item .val { font-weight: 600; color: #1e293b; }

    .total-amount { font-size: 28px; font-weight: 800; color: #7c3aed; text-align: center; margin: 12px 0; }
</style>

{# TICKER #}
<div class="ticker-bar">
    <div class="ticker-wrap">
        {% for action in actions %}
        <div class="ticker-item">
            <span class="symbol">{{ action.symbole }}</span>
            <span class="price">{{ action.prixUnitaire }} TND</span>
            <span class="up"><i class="bi bi-caret-up-fill"></i> 0.00%</span>
        </div>
        {% endfor %}
        {% for action in actions %}
        <div class="ticker-item">
            <span class="symbol">{{ action.symbole }}</span>
            <span class="price">{{ action.prixUnitaire }} TND</span>
            <span class="up"><i class="bi bi-caret-up-fill"></i> 0.00%</span>
        </div>
        {% endfor %}
    </div>
</div>

{# HERO #}
<div class="market-hero">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
            <div>
                <h1 class="text-white fw-bold mb-1" style="font-size:28px;">
                    Marché Boursier
                    <span class="live-badge d-inline-flex ms-2" style="font-size:12px;">
                        <span class="live-dot"></span> EN DIRECT
                    </span>
                </h1>
                <p class="mb-0" style="color:#94a3b8; font-size:14px;">
                    <i class="bi bi-calendar3 me-1"></i>
                    {{ "now"|date("d/m/Y") }} — Bourse de Tunis (BVMT)
                </p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <div class="stat-pill">
                    <div class="value" style="color:#a855f7;">{{ actions|length }}</div>
                    <div class="label">Actions disponibles</div>
                </div>
                <div class="stat-pill">
                    <div class="value text-warning">BVMT</div>
                    <div class="label">Marché</div>
                </div>
                <div class="stat-pill">
                    <div class="value text-info">TND</div>
                    <div class="label">Devise</div>
                </div>
            </div>
        </div>
    </div>
</div>

{# TABLE #}
<section class="py-4" style="background:#f5f3ff; min-height:60vh;">
    <div class="container">
        <div class="market-table-wrapper">
            <div class="market-table-header">
                <h5><i class="bi bi-bar-chart-line me-2" style="color:#a855f7;"></i> Cours des Actions</h5>
                <div class="d-flex align-items-center gap-3">
                    <span class="live-badge"><span class="live-dot"></span> LIVE</span>
                    <span style="color:#94a3b8; font-size:13px;">
                        <i class="bi bi-clock me-1"></i> {{ "now"|date("H:i:s") }}
                    </span>
                </div>
            </div>

            <table class="table market-table mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Symbole</th>
                        <th>Entreprise</th>
                        <th>Prix</th>
                        <th>Variation</th>
                        <th>Quantité</th>
                        <th class="text-center">Ordre</th>
                    </tr>
                </thead>
                <tbody>
                    {% for action in actions %}
                    <tr>
                        <td style="color:#94a3b8; font-size:13px;">{{ loop.index }}</td>
                        <td><span class="symbol-badge">{{ action.symbole }}</span></td>
                        <td>
                            <div class="company-name">{{ action.nomEntreprise }}</div>
                            <div class="company-sector">Bourse de Tunis</div>
                        </td>
                        <td>
                            <div class="price-cell">{{ action.prixUnitaire }} <small style="font-size:11px; color:#94a3b8;">TND</small></div>
                        </td>
                        <td>
                            {% if action.prixUnitaire > 0 %}
                                <span class="change-up"><i class="bi bi-caret-up-fill me-1"></i>+0.00%</span>
                            {% else %}
                                <span class="change-down"><i class="bi bi-caret-down-fill me-1"></i>0.00%</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="qty-bar-wrap">
                                <span class="fw-semibold">{{ action.quantiteDisponible }}</span>
                                <div class="qty-bar">
                                    <div class="qty-bar-fill" style="width: {{ [action.quantiteDisponible * 5, 100]|sort|first }}%"></div>
                                </div>
                            </div>
                        </td>
                        <td class="text-center">
                            <button class="btn-buy me-1" data-bs-toggle="modal" data-bs-target="#buyModal{{ action.id }}">
                                <i class="bi bi-arrow-down-circle"></i> Acheter
                            </button>
                            <button class="btn-sell" data-bs-toggle="modal" data-bs-target="#sellModal{{ action.id }}">
                                <i class="bi bi-arrow-up-circle"></i> Vendre
                            </button>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                            Aucune action disponible
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</section>

{# MODALS #}
{% for action in actions %}

<div class="modal fade" id="buyModal{{ action.id }}" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <form method="post" action="{{ path('app_buy', {id: action.id}) }}">
                <div class="modal-buy-header">
                    <div class="d-flex align-items-center gap-3">
                        <div style="background:rgba(168,85,247,0.2); width:44px; height:44px; border-radius:12px; display:flex; align-items:center; justify-content:center;">
                            <i class="bi bi-arrow-down-circle text-success fs-5"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">Ordre d'Achat</h5>
                            <span style="color:#c4b5fd; font-size:13px;">{{ action.symbole }} — {{ action.nomEntreprise }}</span>
                        </div>
                        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal"></button>
                    </div>
                </div>
                <div class="modal-body p-4">
                    <div class="order-summary">
                        <div class="row-item">
                            <span class="key">Symbole</span>
                            <span class="val">{{ action.symbole }}</span>
                        </div>
                        <div class="row-item">
                            <span class="key">Prix unitaire</span>
                            <span class="val text-success">{{ action.prixUnitaire }} TND</span>
                        </div>
                        <div class="row-item">
                            <span class="key">Disponible</span>
                            <span class="val">{{ action.quantiteDisponible }} unités</span>
                        </div>
                    </div>
                    <label class="form-label fw-semibold mb-2">Quantité à acheter</label>
                    <div class="input-group mb-1">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-hash text-muted"></i></span>
                        <input type="number" name="quantite" id="buyQty{{ action.id }}"
                               class="form-control border-start-0 ps-0 fs-5 fw-bold"
                               min="1" max="{{ action.quantiteDisponible }}" required placeholder="0"
                               oninput="updateBuyTotal('{{ action.id }}', {{ action.prixUnitaire }})">
                        <span class="input-group-text">unités</span>
                    </div>
                    <small class="text-muted">Max : {{ action.quantiteDisponible }} unités</small>
                    <div class="total-amount mt-3" id="buyTotal{{ action.id }}">0.00 TND</div>
                    <p class="text-center text-muted" style="font-size:12px; margin-top:-8px;">Montant total estimé</p>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Annuler</button>
                    <button class="btn btn-success px-5 fw-bold">
                        <i class="bi bi-check-circle me-1"></i> Confirmer l'achat
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="sellModal{{ action.id }}" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <form method="post" action="{{ path('app_sell', {id: action.id}) }}">
                <div class="modal-sell-header">
                    <div class="d-flex align-items-center gap-3">
                        <div style="background:rgba(239,68,68,0.2); width:44px; height:44px; border-radius:12px; display:flex; align-items:center; justify-content:center;">
                            <i class="bi bi-arrow-up-circle text-danger fs-5"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">Ordre de Vente</h5>
                            <span style="color:#fca5a5; font-size:13px;">{{ action.symbole }} — {{ action.nomEntreprise }}</span>
                        </div>
                        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal"></button>
                    </div>
                </div>
                <div class="modal-body p-4">
                    <div class="order-summary">
                        <div class="row-item">
                            <span class="key">Symbole</span>
                            <span class="val">{{ action.symbole }}</span>
                        </div>
                        <div class="row-item">
                            <span class="key">Prix unitaire</span>
                            <span class="val text-danger">{{ action.prixUnitaire }} TND</span>
                        </div>
                    </div>
                    <label class="form-label fw-semibold mb-2">Quantité à vendre</label>
                    <div class="input-group mb-1">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-hash text-muted"></i></span>
                        <input type="number" name="quantite" id="sellQty{{ action.id }}"
                               class="form-control border-start-0 ps-0 fs-5 fw-bold"
                               min="1" required placeholder="0"
                               oninput="updateSellTotal('{{ action.id }}', {{ action.prixUnitaire }})">
                        <span class="input-group-text">unités</span>
                    </div>
                    <div class="total-amount mt-3 text-danger" id="sellTotal{{ action.id }}">0.00 TND</div>
                    <p class="text-center text-muted" style="font-size:12px; margin-top:-8px;">Montant total estimé</p>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Annuler</button>
                    <button class="btn btn-danger px-5 fw-bold">
                        <i class="bi bi-check-circle me-1"></i> Confirmer la vente
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

{% endfor %}

{% block javascripts %}
<script>
function updateBuyTotal(id, price) {
    const qty = document.getElementById('buyQty' + id).value;
    const total = (qty * price).toFixed(2);
    document.getElementById('buyTotal' + id).textContent = (qty ? total : '0.00') + ' TND';
}
function updateSellTotal(id, price) {
    const qty = document.getElementById('sellQty' + id).value;
    const total = (qty * price).toFixed(2);
    document.getElementById('sellTotal' + id).textContent = (qty ? total : '0.00') + ' TND';
}
</script>
{% endblock %}

{% endblock %}