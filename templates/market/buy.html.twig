{% extends 'base.html.twig' %}

{% block title %}Acheter {{ action.symbole }} — FINORA{% endblock %}

{% block body %}
<div class="container py-5">
<div class="row justify-content-center g-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm" style="border-radius: 20px; overflow: hidden;">
            <div class="card-header p-4 text-white" style="background: linear-gradient(135deg, #1e0a3c 0%, #3b1278 100%);">
                <div class="d-flex align-items-center gap-3">
                    <div style="background: rgba(168,85,247,0.2); width:48px; height:48px; border-radius:12px; display:flex; align-items:center; justify-content:center;">
                        <i class="bi bi-arrow-down-circle text-success fs-4"></i>
                    </div>
                    <div>
                        <h4 class="mb-0 text-white">Ordre d'Achat</h4>
                        <span class="opacity-75 small">{{ action.symbole }} — {{ action.nomEntreprise }}</span>
                    </div>
                </div>
            </div>
            
            <div class="card-body p-4">
                <div class="row g-3 mb-4">
                    <div class="col-md-7">
                        <div class="alert alert-info border-0 h-100 m-0" style="background-color: rgba(99,102,241,0.1); border-radius: 12px; color: #4338ca;">
                            <div class="d-flex h-100 align-items-center">
                                <i class="bi bi-info-circle-fill fs-4 me-3"></i>
                                <div>
                                    <div class="fw-bold">Infos Marché</div>
                                    <div class="small">L'achat sera exécuté au prix du marché actuel. Pensez à vérifier votre solde.</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-5">
                        <div class="alert alert-success border-0 h-100 m-0 d-flex flex-column justify-content-center" style="background-color: rgba(34, 197, 94, 0.1); border-radius: 12px;">
                            <div class="text-success small fw-semibold"><i class="bi bi-wallet2 me-1"></i>Solde Disponible</div>
                            <div class="fs-4 fw-bold text-success">{{ walletBalance|number_format(2, '.', '') }} TND</div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <div class="p-3 bg-light rounded-3 text-center border">
                            <div class="text-muted small mb-1">Prix unitaire</div>
                            <div class="fw-bold fs-5 text-success">{{ action.prixUnitaire }} TND</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 bg-light rounded-3 text-center border">
                            <div class="text-muted small mb-1">Disponible</div>
                            <div class="fw-bold fs-5">{{ action.quantiteDisponible }} unités</div>
                        </div>
                    </div>
                </div>

                <form method="post">
                    <div class="mb-4">
                        <label class="form-label fw-bold">Quantité à acheter</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-hash text-muted"></i></span>
                            <input type="number" name="quantite" id="buyQty" class="form-control border-start-0 ps-0 fw-bold" min="1" max="{{ action.quantiteDisponible }}" required placeholder="0" oninput="updateTotal()">
                            <span class="input-group-text bg-white">unités</span>
                        </div>
                        <div class="d-flex justify-content-between mt-2">
                           <small class="text-muted">Maximum : {{ action.quantiteDisponible }} unités</small>
                           <small class="text-primary fw-bold" style="cursor: pointer;" onclick="setMaxQty()">Acheter max</small>
                        </div>
                    </div>

                    <div class="p-4 rounded-3 mb-4" style="background-color: #f8fafc; border: 1px dashed #e2e8f0;">
                         <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Sous-total</span>
                            <span class="fw-bold" id="subtotal">0.00 TND</span>
                         </div>
                         <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Commission (1%)</span>
                            <span class="text-warning fw-bold" id="commission">0.00 TND</span>
                         </div>
                         <hr>
                         <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold">Total Estimé</span>
                            <span class="fs-3 fw-bolder text-primary" id="total">0.00 TND</span>
                         </div>
                    </div>

                    <div id="insufficientFundsAlert" class="alert alert-danger" style="display: none; border-radius: 12px;">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> Solde insuffisant pour cet achat!
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" id="btnConfirm" class="btn btn-success btn-lg py-3 fw-bold" style="border-radius: 12px;">
                            <i class="bi bi-check-circle me-2"></i> Confirmer l'Achat
                        </button>
                        <a href="{{ path('app_market') }}" class="btn btn-light btn-lg py-3 text-muted fw-semibold" style="border-radius: 12px;">
                            Annuler
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Right Column: Simulated Order Book (Carnet d'Ordres) -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm" style="border-radius: 20px; overflow: hidden; background: #fff;">
            <div class="card-header bg-transparent border-bottom p-4 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="bi bi-list-columns-reverse me-2 text-primary"></i>Carnet d'Ordres</h5>
                <span class="badge bg-primary bg-opacity-10 text-primary">En Temps Réel</span>
            </div>
            <div class="card-body p-0">
                <table class="table table-borderless table-sm mb-0 text-center" style="font-family: monospace; font-size: 0.9rem;">
                    <thead class="text-muted small border-bottom" style="background: #f8fafc;">
                        <tr>
                            <th class="py-2 text-start ps-4">Prix (TND)</th>
                            <th class="py-2">Qté</th>
                            <th class="py-2 text-end pe-4">Total</th>
                        </tr>
                    </thead>
                    <tbody id="orderBookAsks" class="border-bottom">
                        <!-- Asks (Ventes) generated by JS -->
                    </tbody>
                    <tbody>
                        <tr style="background: #f8fafc;">
                            <td colspan="3" class="py-3">
                                <div class="d-flex align-items-center justify-content-center gap-2">
                                    <span class="fs-4 fw-bolder text-dark">{{ action.prixUnitaire|number_format(2, '.', ' ') }}</span>
                                    {% set var = (action.id * 1.5) % 5 + 0.1 %}
                                    {% if action.id % 2 == 0 %}
                                        <i class="bi bi-arrow-up text-success fs-5"></i>
                                    {% else %}
                                        <i class="bi bi-arrow-down text-danger fs-5"></i>
                                    {% endif %}
                                </div>
                                <div class="small fw-semibold text-muted">Prix du marché actuel</div>
                            </td>
                        </tr>
                    </tbody>
                    <tbody id="orderBookBids">
                        <!-- Bids (Achats) generated by JS -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    const price = {{ action.prixUnitaire }};
    const maxQty = {{ action.quantiteDisponible }};
    const walletBalance = {{ walletBalance }};
    
    function updateTotal() {
        const qty = document.getElementById('buyQty').value || 0;
        const sub = qty * price;
        const comm = sub * 0.01;
        const tot = sub + comm;
        
        document.getElementById('subtotal').textContent = sub.toFixed(2) + ' TND';
        document.getElementById('commission').textContent = comm.toFixed(2) + ' TND';
        document.getElementById('total').textContent = tot.toFixed(2) + ' TND';

        const btnConfirm = document.getElementById('btnConfirm');
        const alertS = document.getElementById('insufficientFundsAlert');
        
        if (tot > walletBalance) {
            btnConfirm.disabled = true;
            alertS.style.display = 'block';
            document.getElementById('total').classList.replace('text-primary', 'text-danger');
        } else {
            btnConfirm.disabled = false;
            alertS.style.display = 'none';
            document.getElementById('total').classList.replace('text-danger', 'text-primary');
        }
    }

    function setMaxQty() {
        // Calculate max quantity user can afford WITH 1% commission
        const maxAffordableQty = Math.floor(walletBalance / (price * 1.01));
        const finalMax = Math.min(maxAffordableQty, maxQty);
        
        document.getElementById('buyQty').value = finalMax > 0 ? finalMax : 0;
        updateTotal();
    }

    // Generate simulated order book
    function generateOrderBook() {
        const asksBody = document.getElementById('orderBookAsks');
        const bidsBody = document.getElementById('orderBookBids');
        
        let asksHtml = '';
        let bidsHtml = '';
        
        // Generate Asks (red, descending down to current price)
        for (let i = 5; i >= 1; i--) {
            const p = price + (i * 0.05); // Price goes up from current
            const q = Math.floor(Math.random() * 50) + 10;
            const t = p * q;
            asksHtml += `
                <tr class="position-relative" style="background: linear-gradient(90deg, transparent 0%, rgba(239,68,68,0.05) 100%);">
                    <td class="text-danger fw-bold text-start ps-4">${p.toFixed(2)}</td>
                    <td class="text-dark">${q}</td>
                    <td class="text-muted text-end pe-4">${t.toFixed(2)}</td>
                </tr>`;
        }
        
        // Generate Bids (green, descending from current price)
        for (let i = 1; i <= 5; i++) {
            const p = price - (i * 0.05); // Price goes down from current
            const q = Math.floor(Math.random() * 80) + 20;
            const t = p * q;
            bidsHtml += `
                <tr class="position-relative" style="background: linear-gradient(90deg, transparent 0%, rgba(34,197,94,0.05) 100%);">
                    <td class="text-success fw-bold text-start ps-4">${p.toFixed(2)}</td>
                    <td class="text-dark">${q}</td>
                    <td class="text-muted text-end pe-4">${t.toFixed(2)}</td>
                </tr>`;
        }

        if(asksBody) asksBody.innerHTML = asksHtml;
        if(bidsBody) bidsBody.innerHTML = bidsHtml;
    }

    document.addEventListener('DOMContentLoaded', () => {
        generateOrderBook();
        // Slightly fluctuate the order book quantities every 2 seconds for ultra-realism
        setInterval(generateOrderBook, 2000);
    });
</script>
</div>
{% endblock %}
