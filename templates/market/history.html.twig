<script>
/* ═══ ANIMATED COUNTERS ═══ */
function animateCounters() {
    document.querySelectorAll('.counter').forEach(function(el) {
        var target = parseFloat(el.dataset.target);
        var suffix = el.dataset.suffix || '';
        if (isNaN(target)) return;
        var hasDecimals = el.dataset.target.indexOf('.') > -1;
        var decimals = hasDecimals ? 2 : 0;
        var duration = 1200;
        var startTime = null;

        function step(timestamp) {
            if (!startTime) startTime = timestamp;
            var progress = Math.min((timestamp - startTime) / duration, 1);
            var eased = 1 - Math.pow(1 - progress, 3);
            var current = target * eased;
            el.textContent = current.toLocaleString('fr-FR', {
                minimumFractionDigits: decimals,
                maximumFractionDigits: decimals
            }) + suffix;
            if (progress < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
    });
}

/* ═══ BEST / WORST TRADE ═══ */
function detectBestWorst() {
    var rows = document.querySelectorAll('#tableBody tr[data-type]');
    var bestAmount = 0, worstAmount = 0;
    var bestInfo = '', worstInfo = '';

    rows.forEach(function(row) {
        var cells = row.querySelectorAll('td');
        if (cells.length < 10) return;
        var type = row.dataset.type;
        var amountText = cells[6] ? cells[6].textContent.trim() : '0';
        var amount = parseFloat(amountText.replace(/[^\d.-]/g, '')) || 0;
        var symbole = cells[2] ? cells[2].textContent.trim() : '';
        var date = cells[8] ? cells[8].textContent.trim() : '';

        if (type === 'VENTE' && amount > bestAmount) {
            bestAmount = amount;
            bestInfo = symbole + ' — ' + date;
        }
        if (type === 'ACHAT' && amount > worstAmount) {
            worstAmount = amount;
            worstInfo = symbole + ' — ' + date;
        }
    });

    if (bestAmount > 0) {
        document.getElementById('bestTrade').textContent = '+' + bestAmount.toLocaleString('fr-FR', { minimumFractionDigits: 2 }) + ' TND';
        document.getElementById('bestTradeInfo').textContent = bestInfo;
    }
    if (worstAmount > 0) {
        document.getElementById('worstTrade').textContent = '-' + worstAmount.toLocaleString('fr-FR', { minimumFractionDigits: 2 }) + ' TND';
        document.getElementById('worstTradeInfo').textContent = worstInfo;
    }
}

/* ═══ PNL CHART ═══ */
var pnlChartInstance = null;

function seededRand(seed) {
    var x = Math.sin(seed) * 10000;
    return x - Math.floor(x);
}

function generatePnlData(days) {
    var data = [], val = 0;
    var baseInvesti = {{ stats.total_investi|default(0) }};
    var baseVendu = {{ stats.total_vendu|default(0) }};
    var net = baseVendu - baseInvesti;

    for (var i = 0; i < days; i++) {
        val += (seededRand(i * 137 + 42) - 0.45) * (Math.abs(net) / days * 2 + 20);
        data.push(parseFloat(val.toFixed(2)));
    }
    return data;
}

function generateDates(days) {
    var dates = [];
    for (var i = days - 1; i >= 0; i--) {
        var d = new Date();
        d.setDate(d.getDate() - i);
        dates.push(d.getDate() + '/' + (d.getMonth() + 1));
    }
    return dates;
}

function initPnlChart(days) {
    days = days || 30;
    var isPositive = {{ stats.total_vendu|default(0) }} >= {{ stats.total_investi|default(0) }};
    var color = isPositive ? '#22c55e' : '#ef4444';

    var options = {
        chart: {
            type: 'area', height: 220,
            background: 'transparent',
            toolbar: { show: false },
            fontFamily: 'Inter, sans-serif'
        },
        series: [{ name: 'P&L Cumulé', data: generatePnlData(days) }],
        colors: [color],
        fill: {
            type: 'gradient',
            gradient: {
                shadeIntensity: 1,
                opacityFrom: 0.35,
                opacityTo: 0.02,
                stops: [0, 100]
            }
        },
        stroke: { width: 2.5, curve: 'smooth' },
        grid: { borderColor: '#f1f5f9', strokeDashArray: 4, yaxis: { lines: { show: true } }, xaxis: { lines: { show: false } } },
        xaxis: {
            categories: generateDates(days),
            labels: { style: { colors: '#94a3b8', fontSize: '11px' }, rotate: 0 },
            axisBorder: { show: false },
            axisTicks: { show: false }
        },
        yaxis: {
            labels: {
                style: { colors: '#94a3b8', fontSize: '11px' },
                formatter: function(v) { return (v >= 0 ? '+' : '') + v.toFixed(0) + ' TND'; }
            }
        },
        tooltip: {
            theme: 'light',
            y: { formatter: function(v) { return (v >= 0 ? '+' : '') + v.toFixed(2) + ' TND'; } }
        },
        dataLabels: { enabled: false }
    };

    if (pnlChartInstance) {
        pnlChartInstance.destroy();
    }
    pnlChartInstance = new ApexCharts(document.getElementById('pnlChart'), options);
    pnlChartInstance.render();
}

function switchChartPeriod(days, btn) {
    document.querySelectorAll('.chart-period-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    initPnlChart(days);
}

/* ═══ SEARCH + DATE FILTER ═══ */
function filterTable() {
    var search = document.getElementById('searchInput').value.toLowerCase();
    var from = document.getElementById('dateFrom').value;
    var to = document.getElementById('dateTo').value;
    var visibleCount = 0;
    var totalCount = 0;

    document.querySelectorAll('#tableBody tr[data-type]').forEach(function(row) {
        totalCount++;
        var cells = row.querySelectorAll('td');
        if (cells.length < 10) return;

        var text = row.textContent.toLowerCase();
        var dateCell = cells[8] ? cells[8].textContent.trim() : '';
        var dateParts = dateCell.split(/[\/\s:]/);
        var rowDate = '';
        if (dateParts.length >= 3) {
            rowDate = dateParts[2] + '-' + dateParts[1].padStart(2, '0') + '-' + dateParts[0].padStart(2, '0');
        }

        var matchSearch = !search || text.includes(search);
        var matchFrom = !from || rowDate >= from;
        var matchTo = !to || rowDate <= to;

        if (matchSearch && matchFrom && matchTo) {
            row.classList.remove('hidden-row');
            visibleCount++;
        } else {
            row.classList.add('hidden-row');
        }
    });

    var badge = document.getElementById('resultsCountBadge');
    var text = document.getElementById('resultsCountText');
    if (search || from || to) {
        badge.classList.add('visible');
        text.textContent = visibleCount;
    } else {
        badge.classList.remove('visible');
    }

    var emptyRow = document.getElementById('emptyRow');
    if (emptyRow) {
        emptyRow.style.display = (totalCount > 0 && visibleCount === 0) ? '' : 'none';
    }
}

function clearFilters() {
    document.getElementById('searchInput').value = '';
    document.getElementById('dateFrom').value = '';
    document.getElementById('dateTo').value = '';
    filterTable();
}

/* ═══ SORT TABLE ═══ */
var sortState = {};

function sortTable(colIdx, type) {
    var key = colIdx + '-' + type;
    sortState[key] = !sortState[key];
    var asc = sortState[key];

    document.querySelectorAll('.history-table thead th').forEach(function(th, i) {
        th.classList.toggle('sort-active', i === colIdx);
        var icon = th.querySelector('.sort-icon');
        if (icon) {
            icon.className = 'bi sort-icon ' + (i === colIdx
                ? (asc ? 'bi-chevron-up' : 'bi-chevron-down')
                : 'bi-chevron-expand');
        }
    });

    var tbody = document.getElementById('tableBody');
    var rows = Array.from(tbody.querySelectorAll('tr[data-type]'));

    rows.sort(function(a, b) {
        var aVal = a.cells[colIdx] ? a.cells[colIdx].textContent.trim() : '';
        var bVal = b.cells[colIdx] ? b.cells[colIdx].textContent.trim() : '';

        if (type === 'num') {
            aVal = parseFloat(aVal.replace(/[^\d.-]/g, '')) || 0;
            bVal = parseFloat(bVal.replace(/[^\d.-]/g, '')) || 0;
            return asc ? aVal - bVal : bVal - aVal;
        }
        if (type === 'date') {
            var pA = aVal.split(/[\s/]+/), pB = bVal.split(/[\s/]+/);
            if (pA.length >= 3 && pB.length >= 3) {
                aVal = new Date(pA[2], pA[1] - 1, pA[0]);
                bVal = new Date(pB[2], pB[1] - 1, pB[0]);
                return asc ? aVal - bVal : bVal - aVal;
            }
        }
        return asc ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
    });

    rows.forEach(function(row) { tbody.appendChild(row); });
}

/* ═══ PDF TOAST ═══ */
var pdfToastTimeout = null;

function showPdfToast(msg, done) {
    var toast = document.getElementById('pdfToast');
    document.getElementById('pdfToastMsg').textContent = msg;
    toast.classList.remove('done');
    toast.classList.add('show');
    if (pdfToastTimeout) clearTimeout(pdfToastTimeout);
    if (done) {
        toast.classList.add('done');
        pdfToastTimeout = setTimeout(function() { toast.classList.remove('show'); }, 3000);
    }
}

function hidePdfToast() {
    document.getElementById('pdfToast').classList.remove('show', 'done');
}

/* ═══ EXPORT PDF ═══ */
function exportPDF(id) {
    showPdfToast('Génération du PDF en cours...', false);
    var el = document.getElementById('pdfContent' + id);
    html2pdf().set({
        margin: 10,
        filename: 'FINORA-Transaction-' + id + '.pdf',
        image: { type: 'jpeg', quality: 0.98 },
        html2canvas: { scale: 2 },
        jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
    }).from(el).save().then(function() {
        showPdfToast('✅ PDF téléchargé avec succès !', true);
    }).catch(function() {
        showPdfToast('❌ Erreur lors de la génération du PDF', true);
    });
}

