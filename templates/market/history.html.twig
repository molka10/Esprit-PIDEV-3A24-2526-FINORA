{% extends 'base.html.twig' %}

{% block title %}Mon Historique Bourse — Finora{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <!-- Header Section -->
    <div class="card border-0 mb-5 position-relative overflow-hidden" style="background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%); border-radius: 24px; box-shadow: 0 15px 35px rgba(15, 23, 42, 0.2);">
        <!-- Abstract Glowing Orbs -->
        <div style="position:absolute; top:-80px; left:-50px; width:250px; height:250px; background:#7c3aed; filter:blur(80px); opacity:0.4; pointer-events:none;"></div>
        <div style="position:absolute; bottom:-80px; right:10%; width:200px; height:200px; background:#3b82f6; filter:blur(80px); opacity:0.3; pointer-events:none;"></div>
        
        <div class="card-body p-4 p-md-5 position-relative z-index-1">
            <div class="row align-items-center">
                <div class="col-lg-8 text-white">
                    <h1 class="display-6 fw-bolder mb-2" style="letter-spacing: -1px;">📜 Historique des Transactions</h1>
                    <p class="lead text-white-50 mb-4 fw-semibold" style="font-size: 16px;">Analysez vos performances, suivez vos gains et débloquez des trophées exclusifs.</p>
                    <div class="d-flex gap-3 flex-wrap">
                        <a href="{{ path('app_history_pdf') }}" class="btn btn-danger btn-lg rounded-pill px-4 shadow-sm fw-bold" style="background: linear-gradient(135deg, #ef4444, #b91c1c); border:none; transition: all 0.3s;" onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 10px 20px rgba(239, 68, 68, 0.3)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';">
                            <i class="bi bi-file-earmark-pdf me-2"></i>Télécharger Relevé PDF
                        </a>
                        <button class="btn btn-outline-light btn-lg rounded-pill px-4 fw-bold" style="transition: all 0.3s; background: rgba(255,255,255,0.05); backdrop-filter: blur(10px);" onmouseover="this.style.background='rgba(255,255,255,0.15)';" onmouseout="this.style.background='rgba(255,255,255,0.05)';">
                            <i class="bi bi-download me-2"></i>Exporter CSV
                        </button>
                    </div>
                </div>
                <div class="col-lg-4 d-none d-lg-block text-center">
                    <div style="background: rgba(255,255,255,0.05); padding: 20px; border-radius: 50%; display:inline-block; backdrop-filter: blur(5px); border: 1px solid rgba(255,255,255,0.1);">
                        <i class="bi bi-clock-history text-white opacity-75" style="font-size: 100px; display:block;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ROW 1: Summary Widgets -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 p-4 stat-card-hover" style="border-radius: 20px; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-primary bg-opacity-10 p-2 rounded-4 text-primary me-3 shadow-sm" style="width:40px; height:40px; display:flex; align-items:center; justify-content:center;"><i class="bi bi-wallet2 fs-5"></i></div>
                    <span class="text-muted fw-bolder text-uppercase" style="font-size: 11px; letter-spacing: 0.5px;">Valeur Portefeuille</span>
                </div>
                <h3 class="fw-bolder mb-1 text-dark" style="letter-spacing: -0.5px;">{{ stats.valeur_estimee|number_format(2) }} <small class="h6 text-muted fw-bold">TND</small></h3>
                <div class="text-{{ stats.valeur_estimee >= stats.total_investi ? 'success' : 'danger' }} fw-bold" style="font-size: 12px; margin-top:5px;">
                    <i class="bi bi-caret-{{ stats.valeur_estimee >= stats.total_investi ? 'up' : 'down' }}-fill me-1"></i>
                    {{ (stats.valeur_estimee - stats.total_investi)|number_format(2) }} TND de différence
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 p-4 stat-card-hover" style="border-radius: 20px; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-success bg-opacity-10 p-2 rounded-4 text-success me-3 shadow-sm" style="width:40px; height:40px; display:flex; align-items:center; justify-content:center;"><i class="bi bi-graph-up-arrow fs-5"></i></div>
                    <span class="text-muted fw-bolder text-uppercase" style="font-size: 11px; letter-spacing: 0.5px;">Total Investi</span>
                </div>
                <h3 class="fw-bolder mb-1 text-dark" style="letter-spacing: -0.5px;">{{ stats.total_investi|number_format(2) }} <small class="h6 text-muted fw-bold">TND</small></h3>
                <div class="text-muted fw-semibold" style="font-size: 12px; margin-top:5px;">Cumul de tous vos achats</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 p-4 stat-card-hover" style="border-radius: 20px; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-warning bg-opacity-10 p-2 rounded-4 text-warning me-3 shadow-sm" style="width:40px; height:40px; display:flex; align-items:center; justify-content:center;"><i class="bi bi-percent fs-5"></i></div>
                    <span class="text-muted fw-bolder text-uppercase" style="font-size: 11px; letter-spacing: 0.5px;">Commissions (1%)</span>
                </div>
                <h3 class="fw-bolder mb-1 text-dark" style="letter-spacing: -0.5px;">{{ stats.commissions|number_format(2) }} <small class="h6 text-muted fw-bold">TND</small></h3>
                <div class="text-muted fw-semibold" style="font-size: 12px; margin-top:5px;">Frais de trading totaux</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 p-4 stat-card-hover" style="border-radius: 20px; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-info bg-opacity-10 p-2 rounded-4 text-info me-3 shadow-sm" style="width:40px; height:40px; display:flex; align-items:center; justify-content:center;"><i class="bi bi-lightning-charge fs-5"></i></div>
                    <span class="text-muted fw-bolder text-uppercase" style="font-size: 11px; letter-spacing: 0.5px;">Transactions</span>
                </div>
                <h3 class="fw-bolder mb-1 text-dark" style="letter-spacing: -0.5px;">{{ stats.nb_transactions }}</h3>
                <div class="text-muted fw-semibold" style="font-size: 12px; margin-top:5px;">Opérations exécutées</div>
            </div>
        </div>
    </div>

    <!-- 🧠 INTELLIGENCE & DIAGNOSTIC SECTION -->
    <div class="row g-4 mb-5">
        <!-- AI Analyst Insights -->
        <div class="col-xl-8">
            <div class="card border-0 shadow-lg h-100 overflow-hidden" style="border-radius: 24px; background: white; border: 1px solid rgba(124, 58, 237, 0.1) !important;">
                <div class="card-header p-4 border-0 d-flex align-items-center justify-content-between" style="background: linear-gradient(135deg, rgba(124, 58, 237, 0.05), rgba(79, 70, 229, 0.05));">
                    <div class="d-flex align-items-center">
                        <div class="ai-avatar me-3 shadow-sm" style="width: 48px; height: 48px; background: linear-gradient(135deg, #7c3aed, #4f46e5); border-radius: 14px; display: flex; align-items: center; justify-content: center; color: white;">
                            <i class="bi bi-stars fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bolder text-dark">Diagnostic Finora Analyst AI</h5>
                            <span class="badge bg-purple-soft text-purple" style="font-size: 10px; background: rgba(124, 58, 237, 0.1); color: #7c3aed;">INTELLIGENCE ARTIFICIELLE</span>
                        </div>
                    </div>
                    <div class="status-indicator d-flex align-items-center">
                        <span class="live-dot me-2" style="background: #10b981; width: 8px; height: 8px; border-radius: 50%; display: inline-block;"></span>
                        <small class="text-success fw-bold" style="font-size: 11px;">Analyse en temps réel</small>
                    </div>
                </div>
                <div class="card-body p-4 p-md-5 d-flex flex-column align-items-center justify-content-center" id="aiContentWrapper" style="min-height: 300px;">
                    <!-- State 1: Action Required -->
                    <div id="aiStateInitial" class="text-center">
                        <div class="mb-4">
                            <i class="bi bi-robot fs-1 text-primary opacity-25"></i>
                        </div>
                        <h4 class="fw-bold text-dark mb-3">Besoin d'un diagnostic ?</h4>
                        <p class="text-muted mb-4 mx-auto" style="max-width: 400px;">Notre intelligence artificielle peut analyser vos performances pour vous donner des conseils personnalisés.</p>
                        <button class="btn btn-primary rounded-pill px-5 py-3 fw-bold shadow-lg" onclick="runAiAnalysis()" style="background: linear-gradient(135deg, #7c3aed, #4f46e5); border: none;">
                            <i class="bi bi-lightning-charge-fill me-2"></i>Lancer l'Analyse Stratégique
                        </button>
                    </div>

                    <!-- State 2: Thinking -->
                    <div id="aiStateThinking" class="text-center d-none">
                        <div class="spinner-grow text-primary mb-4" role="status" style="width: 3rem; height: 3rem;">
                            <span class="visually-hidden">Analyse...</span>
                        </div>
                        <h5 class="fw-bold text-primary mb-2 animate-pulse">L'IA Finora analyse votre portefeuille...</h5>
                        <p class="text-muted small">Vérification de la diversification, du risque et des opportunités.</p>
                    </div>

                    <!-- State 3: Results -->
                    <div id="aiStateResults" class="ai-analysis-content w-100 d-none" style="line-height: 1.6; font-size: 15px; animation: fadeIn 0.8s ease-out;">
                        {{ ai_insights|raw }}
                        <div class="text-center mt-5">
                            <button class="btn btn-outline-secondary btn-sm rounded-pill px-4" onclick="resetAiAnalysis()">
                                <i class="bi bi-arrow-counterclockwise me-1"></i>Nouvelle Analyse
                            </button>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light border-0 p-3">
                    <small class="text-muted"><i class="bi bi-info-circle me-1"></i> Cette analyse est générée automatiquement en fonction de vos <strong>{{ stats.nb_transactions }}</strong> dernières opérations.</small>
                </div>
            </div>
        </div>

        <!-- Risk & Diversification Gauge -->
        <div class="col-xl-4">
            <div class="card border-0 shadow-lg h-100 p-4" style="border-radius: 24px; background: white;">
                <h5 class="fw-bolder mb-4 text-dark"><i class="bi bi-shield-lock-fill me-2 text-primary"></i>Analyse du Risque</h5>
                
                <div class="text-center my-auto d-flex flex-column align-items-center justify-content-center" style="min-height: 350px;">
                    <div id="diversificationGauge" style="width: 100%; max-width: 300px;"></div>
                    
                    <div class="mt-auto w-100 p-3 rounded-4" style="background: rgba(248, 250, 252, 1); border: 1px solid rgba(0,0,0,0.05);">
                        <div class="text-muted fw-bold mb-1" style="font-size: 11px; text-transform: uppercase;">Plus forte exposition</div>
                        <div class="d-flex align-items-center justify-content-center">
                            <span class="h4 mb-0 fw-bolder text-dark me-2">{{ max_weight }}%</span>
                            <span class="text-muted fw-bold">du portefeuille</span>
                        </div>
                        <div class="mt-2">
                            {% if max_weight > 70 %}
                                <span class="badge bg-danger rounded-pill px-3 py-2 fw-bold" style="font-size: 10px;"><i class="bi bi-exclamation-triangle-fill me-1"></i> Concentration critique</span>
                            {% elseif max_weight > 40 %}
                                <span class="badge bg-warning rounded-pill px-3 py-2 fw-bold" style="font-size: 10px; color: #92400e !important;"><i class="bi bi-info-circle-fill me-1"></i> Concentration modérée</span>
                            {% else %}
                                <span class="badge bg-success rounded-pill px-3 py-2 fw-bold" style="font-size: 10px;"><i class="bi bi-check-circle-fill me-1"></i> Portefeuille équilibré</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <!-- 🔥 WHAT-IF SIMULATOR -->
        <div class="col-xl-8">
            <div class="card border-0 shadow-sm h-100 overflow-hidden" style="border-radius: 24px;">
                <div class="card-header py-4 border-0" style="background: transparent;">
                    <h4 class="m-0 fw-bolder text-dark" style="letter-spacing: -0.5px;"><i class="bi bi-magic me-2 text-primary"></i>What-If Simulator <span class="badge bg-primary bg-opacity-10 text-primary ms-2 fs-6 rounded-pill">Prédiction</span></h4>
                </div>
                <div class="card-body p-4 p-md-5" style="background: linear-gradient(180deg, rgba(248, 250, 252, 0) 0%, rgba(241, 245, 249, 1) 100%);">
                    <p class="text-muted fw-semibold mb-5" style="font-size: 14px;">Simulez une variation du marché sur vos actifs actuels pour estimer vos futurs gains potentiels en temps réel.</p>
                    
                    <div class="row g-4 align-items-center">
                        <div class="col-md-7">
                            <label class="form-label d-flex justify-content-between fw-bold mb-3" style="font-size:13px;">
                                <span class="text-dark">Variation du Marché (%)</span>
                                <span id="percentLabel" class="badge bg-primary rounded-pill px-3 py-2 fs-6 shadow-sm">+10%</span>
                            </label>
                            <input type="range" class="form-range" id="marketRange" min="-50" max="50" value="10" step="1">
                            <div class="d-flex justify-content-between text-muted fw-bold mt-2" style="font-size: 11px;">
                                <span>Krach (-50%)</span>
                                <span>Neutre</span>
                                <span>Bull (+50%)</span>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="p-4 bg-white shadow-sm" style="border-radius: 20px; border: 1px solid rgba(124, 58, 237, 0.1);">
                                <span class="text-muted fw-bolder text-uppercase d-block mb-2" style="font-size:11px; letter-spacing:1px;">Valeur Estimée</span>
                                <h2 class="fw-bolder mb-0" style="color: #7c3aed; letter-spacing:-1px;" id="simVal">{{ stats.valeur_estimee|number_format(2) }}</h2>
                                <div class="badge bg-success bg-opacity-10 text-success mt-3 fs-6 rounded-pill px-3 py-2" id="simProfit">+0.00 TND</div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 table-responsive bg-white shadow-sm" style="border-radius: 16px; border: 1px solid rgba(0,0,0,0.05);">
                        <table class="table table-hover align-middle mb-0">
                            <thead style="background: rgba(248, 250, 252, 1);">
                                <tr>
                                    <th class="ps-4 py-3 text-muted fw-bold text-uppercase border-0" style="font-size:11px;">Actif</th>
                                    <th class="py-3 text-muted fw-bold text-uppercase border-0" style="font-size:11px;">Quantité</th>
                                    <th class="py-3 text-muted fw-bold text-uppercase border-0" style="font-size:11px;">Prix Actuel</th>
                                    <th class="pe-4 py-3 text-end text-muted fw-bold text-uppercase border-0" style="font-size:11px;">Valeur Simu.</th>
                                </tr>
                            </thead>
                            <tbody id="simTable">
                                {% for item in simulatorData %}
                                <tr data-qty="{{ item.qty }}" data-price="{{ item.currentPrice }}">
                                    <td class="ps-4"><span class="badge" style="background: rgba(15, 23, 42, 0.05); color: #0f172a; border: 1px solid rgba(15, 23, 42, 0.1); font-weight:700;">{{ item.symbole }}</span></td>
                                    <td class="fw-bold text-dark">{{ item.qty }}</td>
                                    <td class="text-muted fw-semibold" style="font-size:13px;">{{ item.currentPrice|number_format(2) }} TND</td>
                                    <td class="pe-4 text-end fw-bold text-primary sim-row-val" style="font-size:14px;">--</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- 🏆 TROPHÉES SECTION -->
        <div class="col-xl-4">
            <div class="card border-0 shadow-sm h-100 overflow-hidden" style="border-radius: 24px;">
                <div class="card-header py-4 border-0" style="background: transparent;">
                    <h4 class="m-0 fw-bolder text-dark" style="letter-spacing: -0.5px;"><i class="bi bi-trophy-fill me-2 text-warning"></i>Mes Trophées</h4>
                </div>
                <div class="card-body p-4 pt-0">
                    <div class="row g-3">
                        {% for badge in badges %}
                        <div class="col-6">
                            <div class="p-4 border text-center transition-all h-100 {{ badge.unlocked ? 'shadow-sm' : 'opacity-50 filter-grayscale bg-light' }}" 
                                 style="border-radius: 16px; {{ badge.unlocked ? 'border-color:' ~ badge.color ~ '; background: linear-gradient(180deg, white 0%, ' ~ badge.color ~ '05 100%);' : 'border-color: rgba(0,0,0,0.05);' }}"
                                 data-bs-toggle="tooltip" title="{{ badge.description }}">
                                <div style="font-size: 32px; margin-bottom: 12px; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));">{{ badge.icon }}</div>
                                <div class="fw-bold text-dark text-truncate" style="font-size:12px;">{{ badge.name }}</div>
                                {% if not badge.unlocked %}
                                    <div class="text-muted mt-2" style="font-size:14px;"><i class="bi bi-lock-fill"></i></div>
                                {% endif %}
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                    <div class="mt-4 p-3 shadow-sm d-flex align-items-center" style="background: rgba(59, 130, 246, 0.05); border: 1px solid rgba(59, 130, 246, 0.1); border-radius: 16px;">
                        <i class="bi bi-info-circle-fill text-primary fs-3 me-3"></i>
                        <span class="text-muted fw-semibold" style="font-size: 12px; line-height:1.4;">Continuez à trader pour débloquer de nouveaux badges et améliorer votre rang.</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ROW 3: Detailed History Table -->
    <div class="card border-0 shadow-sm overflow-hidden mb-5" style="border-radius: 24px;">
        <div class="card-header bg-white py-4 border-bottom border-light d-flex justify-content-between align-items-center">
            <h4 class="m-0 fw-bolder text-dark" style="letter-spacing:-0.5px;">📜 Journal des Opérations</h4>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:14px;">
                    <thead style="background: rgba(248, 250, 252, 1);">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase text-muted fw-bold border-0" style="font-size:11px; letter-spacing:0.5px;">ID</th>
                            <th class="py-3 text-uppercase text-muted fw-bold border-0" style="font-size:11px; letter-spacing:0.5px;">Type</th>
                            <th class="py-3 text-uppercase text-muted fw-bold border-0" style="font-size:11px; letter-spacing:0.5px;">Action</th>
                            <th class="py-3 text-uppercase text-muted fw-bold border-0 text-center" style="font-size:11px; letter-spacing:0.5px;">Quantité</th>
                            <th class="py-3 text-uppercase text-muted fw-bold border-0 text-end" style="font-size:11px; letter-spacing:0.5px;">Prix Unit.</th>
                            <th class="py-3 text-uppercase text-muted fw-bold border-0 text-end" style="font-size:11px; letter-spacing:0.5px;">Total</th>
                            <th class="py-3 text-uppercase text-muted fw-bold border-0 text-end" style="font-size:11px; letter-spacing:0.5px;">Commission</th>
                            <th class="pe-4 py-3 text-uppercase text-muted fw-bold border-0 text-end" style="font-size:11px; letter-spacing:0.5px;">Date</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        {% for t in transactions %}
                        <tr>
                            <td class="ps-4"><span class="text-muted fw-semibold">#{{ t.id }}</span></td>
                            <td>
                                <span class="badge {{ t.typeTransaction == 'ACHAT' ? 'bg-success bg-opacity-10 text-success' : 'bg-danger bg-opacity-10 text-danger' }} rounded-pill px-3 py-2 border {{ t.typeTransaction == 'ACHAT' ? 'border-success border-opacity-25' : 'border-danger border-opacity-25' }}">
                                    {{ t.typeTransaction == 'ACHAT' ? 'Achat' : 'Vente' }}
                                </span>
                            </td>
                            <td>
                                <div class="fw-bolder text-dark">{{ t.action ? t.action.symbole : 'N/A' }}</div>
                                <div class="text-muted fw-semibold" style="font-size: 11px;">{{ t.action ? t.action.nomEntreprise : 'Bourse' }}</div>
                            </td>
                            <td class="text-center"><span class="fw-bolder">{{ t.quantite }}</span></td>
                            <td class="text-end fw-semibold text-muted">{{ t.prixUnitaire|number_format(2) }} TND</td>
                            <td class="text-end fw-bolder text-dark">{{ t.montantTotal|number_format(2) }} TND</td>
                            <td class="text-end text-warning fw-bold">{{ t.commission|number_format(2) }} TND</td>
                            <td class="pe-4 text-end">
                                <div class="fw-bold text-dark">{{ t.dateTransaction|date('d M Y') }}</div>
                                <div class="text-muted fw-semibold" style="font-size: 11px;">{{ t.dateTransaction|date('H:i') }}</div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            
            <!-- PAGINATION -->
            <div class="card-footer bg-white py-4 border-top border-light d-flex justify-content-between align-items-center">
                <span class="text-muted fw-bold" style="font-size: 13px;">Page {{ currentPage }} sur {{ totalPages }}</span>
                <nav>
                    <ul class="pagination pagination-sm mb-0 gap-2">
                        <li class="page-item {{ currentPage <= 1 ? 'disabled' }}">
                            <a class="page-link shadow-sm border-0 rounded-pill px-3" href="{{ path('app_history', {page: currentPage - 1}) }}" style="color:#0f172a;"><i class="bi bi-chevron-left"></i></a>
                        </li>
                        <li class="page-item {{ currentPage >= totalPages ? 'disabled' }}">
                            <a class="page-link shadow-sm border-0 rounded-pill px-3" href="{{ path('app_history', {page: currentPage + 1}) }}" style="color:#0f172a;"><i class="bi bi-chevron-right"></i></a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
    <!-- ROW 4: Portfolio Flow & Events -->
    <div class="row g-4 mb-5">
        <!-- 🥧 PORTFOLIO ALLOCATION (Donut) -->
        <div class="col-xl-5">
            <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden" style="border-radius: 24px;">
                <div class="card-header bg-white py-4 border-0">
                    <h5 class="m-0 fw-bold text-dark"><i class="bi bi-pie-chart-fill me-2 text-primary"></i>Répartition du Portefeuille</h5>
                </div>
                <div class="card-body p-4 pt-0 d-flex flex-column align-items-center justify-content-center">
                    <div id="allocationChart" style="min-height: 250px; width: 100%;"></div>
                    <div class="mt-3 w-100">
                        {% for item in allocation_data %}
                        <div class="d-flex justify-content-between align-items-center mb-2 px-3 py-2 rounded-3 bg-light">
                            <span class="small fw-bold text-dark">{{ item.label }}</span>
                            <span class="badge bg-white text-primary border shadow-sm">{{ item.value }}%</span>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        <!-- 📈 PERFORMANCE CURVE (Area) -->
        <div class="col-xl-7">
            <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden" style="border-radius: 24px;">
                <div class="card-header bg-white py-4 border-0 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 fw-bold text-dark"><i class="bi bi-graph-up me-2 text-success"></i>Performance de l'Investissement</h5>
                    <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill" style="font-size: 11px;">ROIs de cette session</span>
                </div>
                <div class="card-body p-0">
                    <div id="performanceChart" style="min-height: 300px;"></div>
                </div>
                <div class="card-footer bg-white border-0 p-4 text-center">
                    <div class="row">
                        <div class="col-4 border-end">
                            <div class="xsmall text-muted mb-1">Moyenne</div>
                            <div class="fw-bold text-dark">+2.4%</div>
                        </div>
                        <div class="col-4 border-end">
                            <div class="xsmall text-muted mb-1">Volatilité</div>
                            <div class="fw-bold text-dark">Bas</div>
                        </div>
                        <div class="col-4">
                            <div class="xsmall text-muted mb-1">Projection 30j</div>
                            <div class="fw-bold text-success">+8.5%</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

<style>
    .bg-success-soft { background-color: rgba(25, 135, 84, 0.1); }
    .bg-danger-soft { background-color: rgba(220, 53, 69, 0.1); }
    .xsmall { font-size: 0.75rem; }
    .filter-grayscale { filter: grayscale(1); }
    .transition-all { transition: all 0.3s ease; }
    .transition-all:hover { transform: translateY(-5px); }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @keyframes pulse {
        0% { opacity: 1; }
        50% { opacity: 0.5; }
        100% { opacity: 1; }
    }
    .animate-pulse { animation: pulse 1.5s infinite; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const range = document.getElementById('marketRange');
        const label = document.getElementById('percentLabel');
        const simVal = document.getElementById('simVal');
        const simProfit = document.getElementById('simProfit');
        const rows = document.querySelectorAll('#simTable tr');
        
        const initialVal = {{ stats.valeur_estimee }};

        function updateSim() {
            const percent = parseInt(range.value);
            label.textContent = (percent >= 0 ? '+' : '') + percent + '%';
            
            let totalSim = 0;
            rows.forEach(row => {
                const qty = parseFloat(row.dataset.qty);
                const price = parseFloat(row.dataset.price);
                const newPrice = price * (1 + percent / 100);
                const val = qty * newPrice;
                totalSim += val;
                row.querySelector('.sim-row-val').textContent = val.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' TND';
            });

            simVal.textContent = totalSim.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' TND';
            const diff = totalSim - initialVal;
            simProfit.textContent = (diff >= 0 ? '+' : '') + diff.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' TND';
            simProfit.className = 'badge mt-2 ' + (diff >= 0 ? 'bg-success-soft text-success' : 'bg-danger-soft text-danger');
        }

        range.addEventListener('input', updateSim);
        updateSim(); // Init

        // Tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    });
/* ═══ DIVERSIFICATION GAUGE ═══ */
document.addEventListener('DOMContentLoaded', function() {
    var options = {
        series: [{{ diversification_score }}],
        chart: {
            height: 300,
            type: 'radialBar',
            fontFamily: 'Outfit, sans-serif'
        },
        plotOptions: {
            radialBar: {
                startAngle: -135,
                endAngle: 135,
                hollow: { size: '70%' },
                track: {
                    background: '#f1f5f9',
                    strokeWidth: '97%',
                },
                dataLabels: {
                    name: {
                        show: true,
                        fontSize: '13px',
                        color: '#64748b',
                        offsetY: 20,
                        label: 'Diversification'
                    },
                    value: {
                        offsetY: -20,
                        fontSize: '32px',
                        fontWeight: '800',
                        color: '#0f172a',
                        formatter: function (val) { return val + "%"; }
                    }
                }
            }
        },
        fill: {
            type: 'gradient',
            gradient: {
                shade: 'dark',
                type: 'horizontal',
                gradientToColors: ['#3b82f6'],
                stops: [0, 100]
            }
        },
        stroke: { lineCap: 'round' },
        labels: ['Score de Diversification'],
    };

    setTimeout(() => {
        var chart = new ApexCharts(document.querySelector("#diversificationGauge"), options);
        chart.render();
    }, 100);
});

/* ═══ AI ANALYSIS INTERACTION ═══ */
function runAiAnalysis() {
    const initial = document.getElementById('aiStateInitial');
    const thinking = document.getElementById('aiStateThinking');
    const results = document.getElementById('aiStateResults');

    initial.classList.add('d-none');
    thinking.classList.remove('d-none');

    // Simulate thinking time
    setTimeout(() => {
        thinking.classList.add('d-none');
        results.classList.remove('d-none');
        
        // Scroll slightly to show content if needed
        results.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 2500);
}

function resetAiAnalysis() {
    document.getElementById('aiStateInitial').classList.remove('d-none');
    document.getElementById('aiStateResults').classList.add('d-none');
}

/* ═══ ALLOCATION & PERFORMANCE CHARTS ═══ */
document.addEventListener('DOMContentLoaded', function() {
    // 🥧 Allocation Donut
    var allocOptions = {
        series: [{% for item in allocation_data %}{{ item.value }}{% if not loop.last %}, {% endif %}{% endfor %}],
        chart: { type: 'donut', height: 250, fontFamily: 'Outfit, sans-serif' },
        labels: [{% for item in allocation_data %}'{{ item.label }}'{% if not loop.last %}, {% endif %}{% endfor %}],
        colors: ['#7c3aed', '#3b82f6', '#10b981', '#f59e0b', '#ef4444'],
        legend: { show: false },
        plotOptions: { pie: { donut: { size: '75%' } } },
        dataLabels: { enabled: false }
    };
    new ApexCharts(document.querySelector("#allocationChart"), allocOptions).render();

    // 📈 Performance Area
    var perfOptions = {
        series: [{ name: 'ROI (%)', data: {{ performance_data|json_encode|raw }} }],
        chart: { type: 'area', height: 300, toolbar: { show: false }, fontFamily: 'Outfit, sans-serif' },
        colors: ['#10b981'],
        dataLabels: { enabled: false },
        stroke: { curve: 'smooth', width: 3 },
        fill: {
            type: 'gradient',
            gradient: { shadeIntensity: 1, opacityFrom: 0.45, opacityTo: 0.05, stops: [20, 100] }
        },
        xaxis: { categories: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct'], labels: { show: false } },
        yaxis: { labels: { formatter: (v) => v.toFixed(1) + '%' } },
        grid: { borderColor: '#f1f5f9' },
        tooltip: { theme: 'dark', x: { show: false } }
    };
    new ApexCharts(document.querySelector("#performanceChart"), perfOptions).render();
});
</script>
{% endblock %}
