<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body {
            font-family: Arial;
            color: #0f172a;
        }

        h2 {
            color: #1e3a8a;
            text-align: center;
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th, td {
            border: 1px solid #e5e7eb;
            padding: 10px;
            text-align: center;
        }

        th {
            background: #1e3a8a;
            color: white;
            font-weight: bold;
        }

        tbody tr:nth-child(even) {
            background: #f1f5f9; /* 🔥 zebra clean */
        }

        .income {
            color: #1e3a8a;
            font-weight: 600;
        }

        .outcome {
            color: #374151;
            font-weight: 600;
        }

        .amount {
            font-weight: 500;
        }

    </style>
</head>
<body>

<h2>User {{ userId }} Transactions</h2>

<table>
    <thead>
        <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Montant</th>
            <th>Date</th>
        </tr>
    </thead>

    <tbody>
        {% for t in transactions %}
            <tr>
                <td>{{ t.nomTransaction }}</td>

                <td class="{{ t.type == 'INCOME' ? 'income' : 'outcome' }}">
                    {{ t.type }}
                </td>

                <td class="amount">
                    {{ t.montant }} DT
                </td>

                <td style="color:#64748b;">
                    {{ t.dateTransaction|date('Y-m-d') }}
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>

</body>
</html>