{% extends 'admin/base.html.twig' %}

{% block body %}

<h2>Edit Profile</h2>

{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

    {{ form_errors(form) }}

    <div>
        {{ form_label(form.username) }}
        {{ form_widget(form.username) }}
        {{ form_errors(form.username) }}
    </div>

    <div>
        {{ form_label(form.email) }}
        {{ form_widget(form.email) }}
        {{ form_errors(form.email) }}
    </div>

    <div>
        {{ form_label(form.password) }}
        {{ form_widget(form.password) }}
        {{ form_errors(form.password) }}
    </div>

    <div>
        {{ form_label(form.image) }}
        {{ form_widget(form.image) }}
        {{ form_errors(form.image) }}
    </div>

    {% if app.user.image %}
        <img src="{{ asset('uploads/' ~ app.user.image) }}" width="120">
    {% endif %}

    <div>
        {{ form_label(form.role) }}
        {{ form_widget(form.role) }}
    </div>

    <div>
        {{ form_label(form.phone) }}
        {{ form_widget(form.phone) }}
        {{ form_errors(form.phone) }}
    </div>

    <div>
        {{ form_label(form.address) }}
        {{ form_widget(form.address) }}
        {{ form_errors(form.address) }}
    </div>

    <div>
        {{ form_label(form.date_of_birth) }}
        {{ form_widget(form.date_of_birth) }}
    </div>

    <div>
        {{ form_label(form.isVerified) }}
        {{ form_widget(form.isVerified) }}
    </div>

    <button type="submit" class="btn">Save</button>

{{ form_end(form) }}

<hr>

<h3 class="mt-4">Biometrics Security (Face ID)</h3>
<div class="card mb-4 mt-2 border-0 shadow-sm col-md-8">
    <div class="card-body text-center">
        {% set biometrics = app.user.userBiometrics %}
        {% if biometrics and biometrics.faceEmbedding %}
            <h5 class="text-success mb-3">✅ Face ID is active</h5>
            <button id="btnConfigureFaceId" type="button" class="btn btn-warning">Reconfigure Face ID</button>
        {% else %}
            <h5 class="text-secondary mb-3">❌ Face ID is NOT active</h5>
            <button id="btnConfigureFaceId" type="button" class="btn btn-primary">Configure Face ID</button>
        {% endif %}

        <div id="faceIdSetupArea" style="display:none;" class="mt-4">
            <video id="videoElement" width="400" height="300" autoplay style="border:1px solid #ccc; border-radius:8px;"></video>
            <br>
            <button id="btnCaptureFace" type="button" class="btn btn-success mt-2">Take Photo & Save</button>
            <button id="btnCancelFace" type="button" class="btn btn-secondary mt-2">Cancel</button>
            <canvas id="canvasElement" style="display:none;"></canvas>
            
            <div id="faceIdStatus" class="mt-3 text-info fw-bold"></div>
        </div>
    </div>
</div>

<script>
    const btnConfigureFaceId = document.getElementById('btnConfigureFaceId');
    const faceIdSetupArea = document.getElementById('faceIdSetupArea');
    const video = document.getElementById('videoElement');
    const canvas = document.getElementById('canvasElement');
    const btnCaptureFace = document.getElementById('btnCaptureFace');
    const btnCancelFace = document.getElementById('btnCancelFace');
    const faceIdStatus = document.getElementById('faceIdStatus');
    let stream = null;

    btnConfigureFaceId.addEventListener('click', async (e) => {
        e.preventDefault();
        faceIdSetupArea.style.display = 'block';
        btnConfigureFaceId.style.display = 'none';
        
        try {
            stream = await navigator.mediaDevices.getUserMedia({ video: true });
            video.srcObject = stream;
        } catch (err) {
            console.error("Camera error:", err);
            faceIdStatus.innerHTML = "<span class='text-danger'>Could not access webcam.</span>";
        }
    });

    btnCancelFace.addEventListener('click', (e) => {
        e.preventDefault();
        if (stream) {
            stream.getTracks().forEach(track => track.stop());
        }
        faceIdSetupArea.style.display = 'none';
        btnConfigureFaceId.style.display = 'inline-block';
        faceIdStatus.innerHTML = "";
    });

    btnCaptureFace.addEventListener('click', (e) => {
        e.preventDefault();
        faceIdStatus.innerHTML = "Processing image...";
        
        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        canvas.getContext('2d').drawImage(video, 0, 0, canvas.width, canvas.height);
        
        const base64Image = canvas.toDataURL('image/jpeg');

        fetch("{{ path('app_profile_face_enroll') }}", {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ image: base64Image })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                faceIdStatus.innerHTML = "<span class='text-success'>" + data.message + "</span>";
                if (stream) {
                    stream.getTracks().forEach(track => track.stop());
                }
                setTimeout(() => location.reload(), 2000);
            } else {
                faceIdStatus.innerHTML = "<span class='text-danger'>" + data.message + "</span>";
            }
        })
        .catch(err => {
            console.error(err);
            faceIdStatus.innerHTML = "<span class='text-danger'>Error connecting to server.</span>";
        });
    });
</script>

<a href="{{ path('app_profile') }}" class="btn btn-secondary mt-3 mb-5">Back</a>

{% endblock %}