{% extends 'admin/baseA.html.twig' %}

{% block body %}
        <!-- Title -->
        <div class="row">
            <div class="col-12 mb-3 d-flex justify-content-between align-items-center">
                <h1 class="h3 mb-2 mb-sm-0">Dashboard</h1>
                <a href="{{ path('download_pdf', { search: app.request.get('search') }) }}" class="btn btn-primary mb-0"><i class="bi bi-file-earmark-pdf me-2"></i>Download PDF</a>
            </div>
        </div>

        <!-- Counter boxes START -->
       
        <!-- Counter boxes END -->

        <!-- Chart and Ticket START -->
        <div class="row g-4 mb-4">
            <!-- Chart START (User custom chart) -->
            <div class="col-xxl-8">
                <div class="card shadow h-100">
                    <div class="card-header p-4 border-bottom">
                        <h5 class="card-header-title">Earnings Overview</h5>
                    </div>
                    <div class="card-body">
                        <div class="chart-box big-chart" style="height: 300px;">
                            <canvas id="stackedChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Chart END -->

            <!-- Ticket START -->
           
            <!-- Ticket END -->
        
        <!-- Chart and Ticket END -->

        <!-- Users Table START -->
        <div class="row g-4 mb-4">
            <div class="col-12">
                <div class="card shadow h-100">
                    <div class="card-header border-bottom d-flex justify-content-between align-items-center p-4">
                        <h5 class="card-header-title">Users Configuration</h5>
                        <form method="GET" class="position-relative">
                            <input class="form-control pe-5 bg-secondary bg-opacity-10 border-0" type="search" placeholder="Search User" aria-label="Search User" id="searchUser" value="{{ app.request.get('search') }}">
                        </form>
                    </div>

                    <div class="card-body p-4">
                        <div class="table-responsive">
                            <table class="table table-borderless table-hover align-middle mb-0" id="userTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>Name</th>
                                        <th>Balance</th>
                                        <th>Income</th>
                                        <th>Outcome</th>
                                        <th>Transactions</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for u in users %}
                                        <tr>
                                            <td>{{ u.name }}</td>
                                            <td>{{ u.balance }} DT</td>
                                            <td class="text-success">{{ u.income }}</td>
                                            <td class="text-danger">{{ u.outcome }}</td>
                                            <td>{{ u.count }}</td>
                                            <td>
                                                {% if u.balance > 0 %}
                                                    <span class="badge bg-success bg-opacity-10 text-success">Good</span>
                                                {% else %}
                                                    <span class="badge bg-danger bg-opacity-10 text-danger">Risk</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <a href="{{ path('user_transactions', { id: u.id }) }}" class="btn btn-sm btn-info-soft mb-0">👁 View</a>
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr><td colspan="7">No users found.</td></tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Users Table END -->

        <!-- ========================================== -->
        <!-- Top listed Cards START (From Static HTML) -->
        <!-- ========================================== -->
       
            <!-- Traffic sources END -->

     
        <!-- Top listed Cards END -->

{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
// Chart.js Logic
const usersData = {{ users|json_encode|raw }};

const labels = Object.values(usersData).map(u => u.name);
const incomeData = Object.values(usersData).map(u => u.income);
const outcomeData = Object.values(usersData).map(u => u.outcome);

const ctx = document.getElementById('stackedChart').getContext('2d');

const incomeGradient = ctx.createLinearGradient(0, 0, 0, 300);
incomeGradient.addColorStop(0, '#2563eb');   
incomeGradient.addColorStop(1, '#7c3aed');   

const outcomeGradient = ctx.createLinearGradient(0, 0, 0, 300);
outcomeGradient.addColorStop(0, '#c7d2fe');  
outcomeGradient.addColorStop(1, '#e5e7eb');  

new Chart(ctx, {
    type: 'bar',
    data: {
        labels: labels,
        datasets: [
            {
                label: 'Income',
                data: incomeData,
                backgroundColor: incomeGradient,
                borderRadius: 10,
                barThickness: 40
            },
            {
                label: 'Outcome',
                data: outcomeData,
                backgroundColor: outcomeGradient,
                borderRadius: 10,
                barThickness: 40
            }
        ]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                labels: {
                    color: '#6b7280',
                    font: { size: 12 }
                }
            }
        },
        scales: {
            x: {
                grid: { display: false },
                ticks: { color: '#9ca3af' }
            },
            y: {
                grid: { color: '#f1f5f9' },
                ticks: { color: '#9ca3af' }
            }
        }
    }
});
</script>

<script>
// Search User Functionality (CORRIGÉ : accolade manquante)
const input = document.getElementById('searchUser');

if (input) {
    input.addEventListener('keyup', function () {
        let value = input.value.toLowerCase();
        let userRows = document.querySelectorAll("#userTable tbody tr");

        userRows.forEach(row => {
            let text = row.innerText.toLowerCase();
            row.style.display = text.includes(value) ? "" : "none";
        });

        let transactionRows = document.querySelectorAll("#transactionTable tbody tr");
        if(transactionRows.length > 0) {
            transactionRows.forEach(row => {
                let text = row.innerText.toLowerCase();
                row.style.display = text.includes(value) ? "" : "none";
            });
        }
    }); // <-- Ajout de la parenthèse et accolade manquante ici
}
</script>
{% endblock %}