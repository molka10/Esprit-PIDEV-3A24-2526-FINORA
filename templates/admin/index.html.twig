{% extends 'admin/baseA.html.twig' %}

{% block title %}FINORA - Admin Dashboard{% endblock %}

{% block body %}
<!-- Title and Top Action -->
<div class="row mb-4">
    <div class="col-12 d-sm-flex justify-content-between align-items-center">
        <h1 class="h3 mb-2 mb-sm-0">Dashboard Overview</h1>
        
        <div class="d-flex align-items-center gap-2">
            <!-- Currency Toggle -->
            <div class="btn-group" role="group" aria-label="Currency toggle">
                <a href="{{ path('app_admin', {'currency': 'DT', 'search': app.request.query.get('search')}) }}" class="btn btn-sm btn-{{ currencySymbol == 'DT' ? 'primary' : 'outline-primary' }}">DT</a>
                <a href="{{ path('app_admin', {'currency': 'EUR', 'search': app.request.query.get('search')}) }}" class="btn btn-sm btn-{{ currencySymbol == 'EUR' ? 'primary' : 'outline-primary' }}">EUR</a>
                <a href="{{ path('app_admin', {'currency': 'USD', 'search': app.request.query.get('search')}) }}" class="btn btn-sm btn-{{ currencySymbol == 'USD' ? 'primary' : 'outline-primary' }}">USD</a>
            </div>
            
            <a href="{{ path('download_pdf', {'search': app.request.query.get('search')}) }}" class="btn btn-sm btn-danger mb-0">
                <i class="bi bi-file-earmark-pdf me-2"></i>Export PDF
            </a>
        </div>
    </div>
</div>

<!-- Search Bar -->


<!-- Stat Cards -->
<div class="row g-4 mb-5">
    <!-- Total Income -->
    <div class="col-md-4">
        <div class="card h-100 border-0 p-4 position-relative overflow-hidden" style="background: linear-gradient(135deg, #ffffff, #fcfaff);">
            <div class="position-absolute end-0 top-0 mt-3 me-3 opacity-10">
                <i class="bi bi-graph-up-arrow" style="font-size: 5rem; color: #8b5cf6;"></i>
            </div>
            <div class="d-flex align-items-center mb-3 position-relative z-index-1">
                <div class="icon-md rounded-circle text-white d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; background: linear-gradient(135deg, #10b981, #34d399); box-shadow: 0 4px 10px rgba(16, 185, 129, 0.2);">
                    <i class="bi bi-arrow-down-left fs-4"></i>
                </div>
                <h5 class="mb-0 text-muted fw-normal">Total Income</h5>
            </div>
            <h2 class="mb-0 fw-bold position-relative z-index-1" style="color: #1e1b4b;">{{ totalIncome|number_format(2, '.', ',') }} <span class="fs-6 text-muted">{{ currencySymbol }}</span></h2>
            <div class="mt-3 small position-relative z-index-1" style="color: #10b981;">
                <i class="bi bi-check-circle-fill me-1"></i> Across active portfolios
            </div>
        </div>
    </div>

    <!-- Total Outcome -->
    <div class="col-md-4">
        <div class="card h-100 border-0 p-4 position-relative overflow-hidden" style="background: linear-gradient(135deg, #ffffff, #fcfaff);">
            <div class="position-absolute end-0 top-0 mt-3 me-3 opacity-10">
                <i class="bi bi-graph-down-arrow" style="font-size: 5rem; color: #ef4444;"></i>
            </div>
            <div class="d-flex align-items-center mb-3 position-relative z-index-1">
                <div class="icon-md rounded-circle text-white d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; background: linear-gradient(135deg, #f43f5e, #fb7185); box-shadow: 0 4px 10px rgba(244, 63, 94, 0.2);">
                    <i class="bi bi-arrow-up-right fs-4"></i>
                </div>
                <h5 class="mb-0 text-muted fw-normal">Total Outcome</h5>
            </div>
            <h2 class="mb-0 fw-bold position-relative z-index-1" style="color: #1e1b4b;">{{ totalOutcome|number_format(2, '.', ',') }} <span class="fs-6 text-muted">{{ currencySymbol }}</span></h2>
            <div class="mt-3 small position-relative z-index-1" style="color: #f43f5e;">
                <i class="bi bi-exclamation-circle-fill me-1"></i> Registered expenses
            </div>
        </div>
    </div>

    <!-- Net Balance -->
    <div class="col-md-4">
        <div class="card h-100 border-0 p-4 position-relative overflow-hidden" style="background: linear-gradient(135deg, #7c3aed, #5b21b6); color: white; box-shadow: 0 10px 30px rgba(124, 58, 237, 0.25) !important;">
            <svg class="position-absolute end-0 top-0" style="opacity: 0.1;" width="150" height="150" viewBox="0 0 100 100" fill="white">
                <circle cx="80" cy="20" r="50"></circle>
                <circle cx="10" cy="90" r="20"></circle>
            </svg>
            <div class="d-flex align-items-center mb-3 position-relative z-index-1">
                <div class="icon-md rounded-circle text-primary d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; background: #fff; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
                    <i class="bi bi-wallet2 fs-4" style="color: #7c3aed;"></i>
                </div>
                <h5 class="mb-0 fw-normal text-white-50">Net Balance</h5>
            </div>
            <h2 class="mb-0 fw-bold text-white position-relative z-index-1">{{ totalBalance|number_format(2, '.', ',') }} <span class="fs-6 text-white-50">{{ currencySymbol }}</span></h2>
             <div class="mt-3 small text-white-50 position-relative z-index-1">
                <i class="bi bi-shield-check me-1 text-white"></i> Secured funds
            </div>
        </div>
    </div>
</div>

<!-- Chart Section -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card shadow">
            <div class="card-header border-bottom">
                <h5 class="card-header-title">Transaction Volume Overview</h5>
            </div>
            <div class="card-body">
                <div id="transactionsChart" style="height: 300px;"></div>
            </div>
        </div>
    </div>
</div>

<!-- Users Table -->
<div class="row">
    <div class="col-12">
        <div class="card shadow">
            <div class="card-header border-bottom">
                <h5 class="card-header-title">Users Summary</h5>
            </div>
            <!-- Search Bar -->
<div class="row mb-4">
    <div class="col-12 position-relative">
        <input 
            id="searchInput"
            class="form-control bg-body pe-5"
            type="search"
            placeholder="Search users by name or ID..."
            value="{{ app.request.query.get('search') }}"
        >
        <span class="bg-transparent p-2 position-absolute top-50 end-0 translate-middle-y border-0 text-muted" style="margin-right: 15px;">
            <i class="bi bi-search fs-6"></i>
        </span>
    </div>
</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
                        <thead>
                            <tr>
                                <th scope="col" class="border-0 rounded-start">User</th>
                                <th scope="col" class="border-0">Total Transactions</th>
                                <th scope="col" class="border-0">Income ({{ currencySymbol }})</th>
                                <th scope="col" class="border-0">Outcome ({{ currencySymbol }})</th>
                                <th scope="col" class="border-0">Balance ({{ currencySymbol }})</th>
                                <th scope="col" class="border-0 rounded-end">Action</th>
                            </tr>
                        </thead>
                        <tbody id="usersTableBody">
    {% include 'admin/_table_rows.html.twig' with { users: users } %}
</tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


{% endblock %}

{% block javascripts %}
<script src="{{ asset('assets/vendor/apexcharts/js/apexcharts.min.js') }}"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        var options = {
            series: [{
                name: 'Transaction Volume',
                data: {{ chartData|json_encode|raw }}
            }],
            chart: {
                height: 300,
                type: 'area',
                toolbar: {
                    show: false
                }
            },
            dataLabels: {
                enabled: false
            },
            stroke: {
                curve: 'smooth'
            },
            xaxis: {
                type: 'category',
                categories: {{ chartLabels|json_encode|raw }},
                labels: {
                    style: {
                        colors: '#9ca3af'
                    }
                }
            },
            yaxis: {
                labels: {
                    style: {
                        colors: '#9ca3af'
                    },
                    formatter: function (value) {
                        return value.toFixed(2) + " {{ currencySymbol|raw }}";
                    }
                }
            },
            tooltip: {
                y: {
                    formatter: function (val) {
                        return val.toFixed(2) + " {{ currencySymbol|raw }}"
                    }
                }
            },
            colors: ['#7c3aed'],
            fill: {
                type: 'gradient',
                gradient: {
                    shadeIntensity: 1,
                    opacityFrom: 0.7,
                    opacityTo: 0.1,
                    stops: [0, 90, 100]
                }
            }
        };

        var chart = new ApexCharts(document.querySelector("#transactionsChart"), options);
        chart.render();
    });
</script>
<script>
document.addEventListener("DOMContentLoaded", function () {
    const input = document.getElementById("searchInput");

    input.addEventListener("keyup", function () {
        let query = this.value;
        let urlParams = new URLSearchParams(window.location.search);
        let currency = urlParams.get('currency') || 'DT';

        fetch(`/admin/search-users?search=${encodeURIComponent(query)}&currency=${encodeURIComponent(currency)}`)
            .then(response => response.text())
            .then(data => {
               document.getElementById("usersTableBody").innerHTML = data;
            });
    });
});
</script>
{% endblock %}
