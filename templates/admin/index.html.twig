{% extends 'base.html.twig' %}

{% block content %}

<div class="admin">

    <div class="admin-header">
        <h1>📊 ADMIN DASHBOARD</h1>
       <a href="{{ path('download_pdf', { search: app.request.get('search') }) }}" class="btn-purple"> ⬇ PDF</a>
    </div>

    <form method="GET">
    <input type="text" id="searchUser"
       placeholder="🔍 Search..."
       class="admin-search">
</form>

    <div class="admin-grid">

        <!-- USERS -->
        <div class="box">
            <h3>👥 Users</h3>

            <table id="userTable">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Balance</th>
                        <th>Income</th>
                        <th>Outcome</th>
                        <th>Transactions</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    {% for u in users %}
                        <tr>
                            <td>{{ u.name }}</td>
                            <td>{{ u.balance }} DT</td>
                            <td class="green">{{ u.income }}</td>
                            <td class="red">{{ u.outcome }}</td>
                            <td>{{ u.count }}</td>
                            <td>
                                {% if u.balance > 0 %}
                                    <span class="badge income">Good</span>
                                {% else %}
                                    <span class="badge outcome">Risk</span>
                                {% endif %}
                            </td>
                            <td>
                               <a href="{{ path('user_transactions', { id: u.id }) }}" class="btn-view"> 👁 View</a>
                                
                               
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

      

    </div>

   <div style="width:500px; height:300px; margin:auto;">
    <canvas id="stackedChart"></canvas>
</div>

        


</div>

{% endblock %}

{% block javascripts %}


<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
const ctx = document.getElementById('stackedChart');

new Chart(ctx, {
    type: 'bar',
    data: {
        labels: ['User 1', 'User 6'],
        datasets: [
            {
                label: 'Income',
                data: [4000, 3000],
                backgroundColor: '#00b894'
            },
            {
                label: 'Outcome',
                data: [3145, 2000],
                backgroundColor: '#d63031'
            }
        ]
    },
    options: {
        responsive: true,
        plugins: {
            legend: {
                position: 'top'
            }
        },
        scales: {
            x: {
                stacked: true
            },
            y: {
                stacked: true
            }
        }
    }
});
</script>
<script>
    const usersData = {{ users|json_encode|raw }};
</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

function showUserTransactions(userName) {

    let tbody = document.getElementById("transactionBody");
    tbody.innerHTML = "";

    for (let userId in usersData) {

        let user = usersData[userId];

        if (user.name === userName) {

            if (user.transactions.length === 0) {
                tbody.innerHTML = "<tr><td colspan='4'>No transactions</td></tr>";
                return;
            }

            user.transactions.forEach(t => {

                let color = t.type === "INCOME" ? "green" : "red";

                let row = `
                    <tr>
                        <td>${user.name}</td>
                        <td>${t.type}</td>
                        <td class="${color}">${t.montant} DT</td>
                        <td>${t.dateTransaction.date.split(' ')[0]}</td>
                    </tr>
                `;

                tbody.innerHTML += row;
            });

        }
    }
}




const input = document.getElementById('searchUser');

input.addEventListener('keyup', function () {
    let value = input.value.toLowerCase();

    let userRows = document.querySelectorAll("#userTable tbody tr");

    userRows.forEach(row => {
        let text = row.innerText.toLowerCase();
        row.style.display = text.includes(value) ? "" : "none";
    });

    let transactionRows = document.querySelectorAll("#transactionTable tbody tr");

    transactionRows.forEach(row => {
        let text = row.innerText.toLowerCase();
        row.style.display = text.includes(value) ? "" : "none";
    });
});

</script>

{% endblock %}