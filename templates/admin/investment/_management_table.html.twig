<table class="table align-middle p-4 mb-0 table-hover">
    <thead class="bg-light">
        <tr>
            <th scope="col" class="border-0 p-4">Investisseur</th>
            <th scope="col" class="border-0">Projet d'Investissement</th>
            <th scope="col" class="border-0 text-center">Montant Investi</th>
            <th scope="col" class="border-0 text-center">Quote-part (%)</th>
            <th scope="col" class="border-0 text-center">Status</th>
            <th scope="col" class="border-0 rounded-end text-center">Actions</th>
        </tr>
    </thead>
    <tbody id="management-table-body">
        {% for m in managements %}
        <tr>
            <td class="p-4">
                <div class="d-flex align-items-center">
                    <div class="avatar avatar-sm me-3">
                        <div class="avatar-img rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-bold" style="width: 40px; height: 40px;">
                            {{ m.user and m.user.username ? m.user.username|first|upper : (m.user and m.user.email ? m.user.email|first|upper : '?') }}
                        </div>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold">
                            {% if m.user %}
                                {{ m.user.username ?: m.user.email ?: 'Investisseur Sans Nom' }}
                            {% else %}
                                <span class="text-muted fst-italic">Anonyme #{{ m.id }}</span>
                            {% endif %}
                        </h6>
                        <span class="small text-muted">{{ m.startDate|date('d M Y') }}</span>
                    </div>
                </div>
            </td>
            <td>
                <div class="d-flex align-items-center">
                    <i class="bi bi-link-45deg text-primary me-2"></i>
                    <span class="fw-medium text-dark">{{ m.investment ? m.investment.name : 'Projet inconnu' }}</span>
                </div>
            </td>
            <td class="text-center">
                <div class="h6 mb-0 text-success fw-bold">{{ m.amountInvested|format_currency }}</div>
            </td>
            <td class="text-center">
                <div class="badge bg-light text-dark border fw-normal">{{ m.ownershipPercentage }}%</div>
            </td>
            <td class="text-center">
                {% if m.status == 'ACTIVE' %}
                    <span class="badge bg-success bg-opacity-10 text-success">
                        <i class="bi bi-check-circle-fill me-1"></i>Actif
                    </span>
                {% else %}
                    <span class="badge bg-danger bg-opacity-10 text-danger">
                        <i class="bi bi-x-circle-fill me-1"></i>Clôturé
                    </span>
                {% endif %}
            </td>
            <td class="text-center">
                <button class="btn btn-sm btn-outline-primary shadow-sm mb-1 btn-lifecycle" data-id="{{ m.id }}" data-bs-toggle="modal" data-bs-target="#lifecycleModal">
                    <i class="bi bi-clock-history"></i> Lifecycle
                </button>
                <br>
                <a href="{{ path('app_management_show', {id: m.id}) }}" class="btn btn-sm btn-white border shadow-sm mb-0">
                    <i class="bi bi-eye me-1"></i>Détails
                </a>
            </td>
            </td>
        </tr>
        {% else %}
        <tr>
            <td colspan="6" class="text-center py-5">
                <div class="mb-3 text-muted"><i class="bi bi-clipboard-x display-3"></i></div>
                <h6 class="text-muted">Aucune participation active trouvée</h6>
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>

<div class="d-flex justify-content-center mt-4 p-4">
    {{ knp_pagination_render(managements) }}
</div>
