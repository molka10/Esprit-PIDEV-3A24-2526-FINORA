{% extends 'admin/baseA.html.twig' %}

{% block title %}Audit des Fraudes - Admin{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-danger fw-bold"><i class="bi bi-shield-exclamation me-2"></i>Audit des Fraudes & Anomalies</h1>
            <p class="text-muted mt-2">Surveillance système des transactions à haut risque dépassant {{ threshold }} DT.</p>
        </div>
        <button class="btn btn-outline-danger" onclick="window.print()">
            <i class="bi bi-printer"></i> Imprimer le Rapport
        </button>
    </div>

    <!-- Alert Banner -->
    <div class="alert alert-danger shadow-sm border-0 d-flex align-items-center" role="alert" style="border-radius: 16px;">
        <i class="bi bi-exclamation-triangle-fill fs-3 me-3"></i>
        <div>
            <h5 class="alert-heading mb-1 fw-bold">{{ anomalies|length }} Transactions Suspectes Détectées !</h5>
            <p class="mb-0">Le volume total d'argent impliqué dans ces anomalies est de <strong>{{ totalRiskyVolume|number_format(2, ',', ' ') }} DT</strong>.</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mt-4">
        <div class="card-header bg-white border-bottom py-3">
            <h6 class="m-0 fw-bold text-dark">Logs d'Anomalies Financières</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Utilisateur</th>
                            <th>Nom/Raison</th>
                            <th>Date</th>
                            <th>Type</th>
                            <th class="text-end pe-4">Montant (DT)</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for t in anomalies %}
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar avatar-xs me-2">
                                            <div class="avatar-img rounded-circle bg-danger text-white d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                                <i class="bi bi-person-fill"></i>
                                            </div>
                                        </div>
                                        <span class="fw-semibold">User {{ t.userId }}</span>
                                    </div>
                                </td>
                                <td>{{ t.nomTransaction }}</td>
                                <td>{{ t.dateTransaction|date('Y-m-d H:i') }}</td>
                                <td>
                                    {% if t.type|lower == 'income' or t.type|lower == 'revenu' %}
                                        <span class="badge bg-success-soft text-success"><i class="bi bi-arrow-up-right me-1"></i>Revenu</span>
                                    {% else %}
                                        <span class="badge bg-danger-soft text-danger"><i class="bi bi-arrow-down-right me-1"></i>Dépense</span>
                                    {% endif %}
                                </td>
                                <td class="text-end fw-bold text-danger fs-5 pe-4">
                                    {{ t.montant|abs|number_format(2, ',', ' ') }}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-shield-check text-success fs-1 d-block mb-3"></i>
                                    Aucune anomalie détectée. Le système est sécurisé.
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
