{% extends 'admin/base.html.twig' %}

{% block title %}Bourse Intelligence — Finora Admin{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800 fw-bold">📊 Bourse Intelligence</h1>
            <p class="text-muted mb-0 small">Analyse avancée des marchés et détection d'anomalies.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_bourse_new') }}" class="btn btn-primary shadow-sm rounded-3 px-4 fw-bold">
                <i class="bi bi-plus-lg me-2"></i>Nouveau Marché
            </a>
        </div>
    </div>

    <!-- ROW 1: Intelligence Widgets -->
    <div class="row g-4 mb-4">
        <!-- Main Stats Card -->
        <div class="col-xl-6">
            <div class="card border-0 shadow-sm overflow-hidden h-100" style="border-radius: 20px;">
                <div class="card-body p-0">
                    <div class="row g-0 h-100">
                        <div class="col-md-6 p-4 border-end border-light">
                            <div class="d-flex align-items-center mb-2">
                                <div class="bg-primary bg-opacity-10 p-2 rounded-3 text-primary me-3">
                                    <i class="bi bi-currency-exchange fs-5"></i>
                                </div>
                                <span class="text-muted xsmall fw-bold text-uppercase">Volume Total</span>
                            </div>
                            <h3 class="fw-bold mb-1 text-dark">{{ volumeTotal|number_format(0, '.', ',') }} <small class="h6 text-muted">TND</small></h3>
                            <div class="text-success xsmall"><i class="bi bi-caret-up-fill me-1"></i>Liquidité stable</div>
                        </div>
                        <div class="col-md-6 p-4">
                            <div class="d-flex align-items-center mb-2">
                                <div class="bg-success bg-opacity-10 p-2 rounded-3 text-success me-3">
                                    <i class="bi bi-wallet-fill fs-5"></i>
                                </div>
                                <span class="text-muted xsmall fw-bold text-uppercase">Revenus (Frais)</span>
                            </div>
                            <h3 class="fw-bold mb-1 text-dark">{{ totalCommissions|number_format(2, '.', ',') }} <small class="h6 text-muted">TND</small></h3>
                            <div class="text-muted xsmall">Commissions plateforme</div>
                        </div>
                        <div class="col-md-6 p-4 border-top border-end border-light">
                            <div class="d-flex align-items-center mb-2">
                                <div class="bg-purple bg-opacity-10 p-2 rounded-3 text-purple me-3">
                                    <i class="bi bi-lightning-charge-fill fs-5"></i>
                                </div>
                                <span class="text-muted xsmall fw-bold text-uppercase">Actifs Cotés</span>
                            </div>
                            <h4 class="fw-bold mb-0 text-dark">{{ totalActions }} Titres</h4>
                        </div>
                        <div class="col-md-6 p-4 border-top border-light">
                            <div class="d-flex align-items-center mb-2">
                                <div class="bg-info bg-opacity-10 p-2 rounded-3 text-info me-3">
                                    <i class="bi bi-people-fill fs-5"></i>
                                </div>
                                <span class="text-muted xsmall fw-bold text-uppercase">Investisseurs</span>
                            </div>
                            <h4 class="fw-bold mb-0 text-dark">Actifs</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Market Health Score -->
        <div class="col-xl-3">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 20px;">
                <div class="card-body p-4 text-center">
                    <span class="text-muted xsmall fw-bold text-uppercase mb-3 d-block">Indice de Santé du Marché</span>
                    <div id="healthChart" style="min-height: 180px;"></div>
                    <div class="mt-2">
                        {% if healthScore > 70 %}
                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">Excellent</span>
                        {% elseif healthScore > 40 %}
                            <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3">Stable</span>
                        {% else %}
                            <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3">Risque Élevé</span>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <!-- Sentiment Card -->
        <div class="col-xl-3">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 20px;">
                <div class="card-body p-4 text-center d-flex flex-column justify-content-center">
                    <span class="text-muted xsmall fw-bold text-uppercase mb-3 d-block">Sentiment (Bull/Bear)</span>
                    <div id="sentimentChart" style="min-height: 150px;"></div>
                    <div class="d-flex justify-content-between mt-3 px-3">
                        <div class="text-start">
                            <div class="xsmall text-muted">Acheteurs</div>
                            <div class="fw-bold text-success">{{ ((sentiment.buys / sentiment.total) * 100)|round }}%</div>
                        </div>
                        <div class="text-end">
                            <div class="xsmall text-muted">Vendeurs</div>
                            <div class="fw-bold text-danger">{{ ((sentiment.sells / sentiment.total) * 100)|round }}%</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ROW 2: Activity Heatmap & Anomalies -->
    <div class="row g-4 mb-4">
        <!-- Trading Heatmap -->
        <div class="col-xl-9">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-transparent py-4 border-0 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 fw-bold text-dark"><i class="bi bi-calendar3 me-2 text-primary"></i>Activité Horaire (Punch Card)</h5>
                    <div class="xsmall text-muted">Concentration des transactions par heure/jour</div>
                </div>
                <div class="card-body px-4">
                    <div id="tradingHeatmap" style="min-height: 300px;"></div>
                </div>
            </div>
        </div>

        <!-- Anomaly Alerts -->
        <div class="col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-dark overflow-hidden">
                <div class="card-header bg-transparent py-4 border-0">
                    <h5 class="m-0 fw-bold text-white"><i class="bi bi-shield-exclamation me-2 text-danger"></i>Alertes Anomalies</h5>
                </div>
                <div class="card-body p-4 pt-0">
                    {% for anomaly in anomalies %}
                    <div class="mb-3 p-3 rounded-4 bg-white bg-opacity-10 border-start border-4 border-{{ anomaly.severity == 'High' ? 'danger' : 'warning' }}">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="fw-bold text-white small">{{ anomaly.type }}</span>
                            <span class="text-muted xsmall">{{ anomaly.time }}</span>
                        </div>
                        <p class="xsmall text-light opacity-75 mb-0">Detecté sur <strong>{{ anomaly.action }}</strong> par <strong>{{ anomaly.user }}</strong>.</p>
                    </div>
                    {% else %}
                    <div class="text-center py-5">
                        <i class="bi bi-shield-check text-success fs-1 mb-3 d-block"></i>
                        <p class="text-muted small">Aucune activité suspecte détectée aujourd'hui.</p>
                    </div>
                    {% endfor %}
                </div>
                <div class="card-footer bg-white bg-opacity-5 border-0 p-3 text-center">
                    <a href="#" class="text-decoration-none xsmall text-white opacity-50">Voir le rapport complet</a>
                </div>
            </div>

            <!-- Smart Circuit Breaker Panel -->
            <div class="card border-0 shadow-sm rounded-4 mt-4 bg-primary bg-opacity-10 border border-primary border-opacity-10">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="m-0 fw-bold text-primary"><i class="bi bi-shield-shaded me-2"></i>Smart Circuit Breaker</h6>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="circuitBreakerToggle" checked>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="xsmall text-muted fw-bold text-uppercase d-block mb-1">Seuil Volatilité</label>
                            <select class="form-select form-select-sm rounded-3">
                                <option>-15% en 1h</option>
                                <option selected>-30% en 1h</option>
                                <option>-50% en 1h</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="xsmall text-muted fw-bold text-uppercase d-block mb-1">Action Automatique</label>
                            <select class="form-select form-select-sm rounded-3">
                                <option>Alerte Admin</option>
                                <option selected>Geler le Marché</option>
                            </select>
                        </div>
                    </div>
                    <div class="mt-3 xsmall text-primary opacity-75">
                        <i class="bi bi-info-circle me-1"></i> Système de protection actif.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ROW 3: Whale Watch & Leaderboards -->
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-transparent py-4 border-0 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 fw-bold text-dark"><i class="bi bi-water text-primary me-2"></i>Whale Watch</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light bg-opacity-50">
                                <tr>
                                    <th class="ps-4 border-0 xsmall text-muted text-uppercase fw-bold">Trader</th>
                                    <th class="border-0 xsmall text-muted text-uppercase fw-bold">Symbole</th>
                                    <th class="border-0 xsmall text-muted text-uppercase fw-bold text-center">Type</th>
                                    <th class="border-0 xsmall text-muted text-uppercase fw-bold text-end">Volume</th>
                                    <th class="pe-4 border-0 xsmall text-muted text-uppercase fw-bold text-end">Heure</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for tx in whales %}
                                <tr>
                                    <td class="ps-4"><span class="small fw-bold">{{ tx.user.username }}</span></td>
                                    <td><span class="badge bg-light text-primary border border-primary border-opacity-10">{{ tx.action.symbole }}</span></td>
                                    <td class="text-center">
                                        <span class="badge {{ tx.typeTransaction == 'ACHAT' ? 'bg-success-soft text-success' : 'bg-danger-soft text-danger' }} rounded-pill xsmall">
                                            {{ tx.typeTransaction == 'ACHAT' ? 'Buy' : 'Sell' }}
                                        </span>
                                    </td>
                                    <td class="text-end fw-bold small">{{ tx.montantTotal|number_format(2, '.', ',') }} TND</td>
                                    <td class="pe-4 text-end text-muted xsmall">{{ tx.dateTransaction|date('H:i') }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-transparent py-4 border-0">
                    <h5 class="m-0 fw-bold text-dark"><i class="bi bi-graph-up me-2 text-success"></i>Performance Valeurs</h5>
                </div>
                <div class="card-body p-4 pt-0">
                    {% for action in topActions %}
                    <div class="d-flex align-items-center justify-content-between mb-4 p-2 rounded-3 hover-bg-light transition-all">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3 text-primary fw-bold" style="width: 45px; text-align: center;">{{ action.symbole }}</div>
                            <div class="fw-bold small">{{ action.nomEntreprise }}</div>
                        </div>
                        <div class="text-end fw-bold small">{{ action.totalVolume|number_format(0) }} <small class="xsmall text-muted">TND</small></div>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-success-soft { background: rgba(16, 185, 129, 0.1); }
    .bg-danger-soft { background: rgba(239, 68, 68, 0.1); }
    .text-purple { color: #7c3aed; }
    .xsmall { font-size: 0.7rem; letter-spacing: 0.3px; }
    .hover-bg-light:hover { background-color: #f8f9fa !important; }
    .transition-all { transition: all 0.2s ease; }
    .rounded-4 { border-radius: 1.25rem !important; }
</style>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // 1. Market Health Gauge
        new ApexCharts(document.querySelector("#healthChart"), {
            series: [{{ healthScore }}],
            chart: { height: 220, type: 'radialBar', offsetY: -10 },
            plotOptions: {
                radialBar: {
                    hollow: { size: '70%' },
                    dataLabels: {
                        name: { show: false },
                        value: { offsetY: 10, fontSize: '24px', fontWeight: 'bold', color: '#1e293b' }
                    }
                }
            },
            colors: ['#10b981'],
            labels: ['Health Score']
        }).render();

        // 2. Sentiment Gauge
        new ApexCharts(document.querySelector("#sentimentChart"), {
            series: [{{ ((sentiment.buys / sentiment.total) * 100)|round }}],
            chart: { height: 180, type: 'radialBar', offsetY: -10 },
            plotOptions: {
                radialBar: {
                    startAngle: -110, endAngle: 110,
                    dataLabels: {
                        name: { fontSize: '11px', color: '#94a3b8', offsetY: 60, label: 'Bulls' },
                        value: { offsetY: 25, fontSize: '18px', color: '#1e293b' }
                    }
                }
            },
            colors: ['#6366f1'],
            labels: ['Sentiment']
        }).render();

        // 3. Trading Activity Heatmap
        var heatmapSeries = [];
        var days = ['Dim', 'Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam'];
        {% for d, hours in heatmapData %}
            heatmapSeries.push({
                name: days[{{ d }}],
                data: [
                    {% for h, count in hours %}
                        { x: '{{ h }}h', y: {{ count }} },
                    {% endfor %}
                ]
            });
        {% endfor %}

        new ApexCharts(document.querySelector("#tradingHeatmap"), {
            series: heatmapSeries,
            chart: { height: 300, type: 'heatmap', toolbar: { show: false } },
            dataLabels: { enabled: false },
            colors: ["#6366f1"],
            xaxis: { type: 'category' },
            grid: { padding: { right: 20 } }
        }).render();
    });
</script>
{% endblock %}
