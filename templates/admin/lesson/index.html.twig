{% extends 'admin/base.html.twig' %}

{% block title %}Admin - Gestion des Leçons{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12 mb-4">
        <div class="d-sm-flex justify-content-between align-items-center">
            <h1 class="h3 mb-2 mb-sm-0">Gestion des Leçons</h1>
            <a href="{{ path('app_lesson_new') }}" class="btn btn-primary mb-0">Ajouter une leçon</a>
        </div>
    </div>
</div>

<div class="card bg-transparent border mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 px-0">
            <div class="col-md-4">
                <input type="text" name="titre" value="{{ titre }}" class="form-control" placeholder="Rechercher par titre...">
            </div>
            <div class="col-md-4">
                <select name="formation" class="form-select">
                    <option value="">Toutes les formations</option>
                    {% for f in formations %}
                        <option value="{{ f.id }}" {{ formationSelected == f.id ? 'selected' : '' }}>{{ f.titre }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Filtrer</button>
            </div>
            <div class="col-md-2">
                <a href="{{ path('app_lesson_index') }}" class="btn btn-outline-secondary w-100">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card bg-transparent border">
    <div class="card-body">
        <div class="table-responsive border-0">
            <table class="table table-dark-gradient align-middle p-4 mb-0 table-hover">
                <thead>
                    <tr>
                        <th scope="col" class="border-0 rounded-start">Leçon</th>
                        <th scope="col" class="border-0">Formation</th>
                        <th scope="col" class="border-0">Ordre</th>
                        <th scope="col" class="border-0">Durée</th>
                        <th scope="col" class="border-0 rounded-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for lesson in lessons %}
                    <tr>
                        <td>
                            <h6 class="mb-0">{{ lesson.titre }}</h6>
                        </td>
                        <td>{{ lesson.formation ? lesson.formation.titre : 'N/A' }}</td>
                        <td>{{ lesson.ordre }}</td>
                        <td>{{ lesson.dureeMinutes }} min</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="{{ path('app_lesson_edit', {id: lesson.id}) }}" class="btn btn-success-soft btn-round mb-0" title="Modifier"><i class="bi bi-pencil"></i></a>
                                <a href="{{ path('app_lesson_youtube_manage', {id: lesson.id}) }}" class="btn btn-danger-soft btn-round mb-0" title="YouTube"><i class="bi bi-youtube"></i></a>
                                <form method="post" action="{{ path('app_lesson_delete', {id: lesson.id}) }}" onsubmit="return confirm('Supprimer ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ lesson.id) }}">
                                    <button class="btn btn-secondary-soft btn-round mb-0"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="5" class="text-center">aucune leçon trouvée.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
