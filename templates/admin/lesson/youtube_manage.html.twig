{% extends 'admin/base.html.twig' %}

{% block title %}Admin - YouTube Media Manager{% endblock %}

{% block body %}
<div class="row">
    <div class="col-xl-8 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-1">YouTube Media Manager</h1>
                <p class="mb-0 text-muted">Leçon: <strong>{{ lesson.titre }}</strong></p>
            </div>
            <a href="{{ path('app_lesson_edit', {id: lesson.id}) }}" class="btn btn-outline-secondary btn-sm">Retour</a>
        </div>

        {% if error %}
            <div class="alert alert-danger">{{ error }}</div>
        {% endif %}

        <div class="card border mb-4">
            <div class="card-body">
                <form method="get" class="row g-2">
                    <div class="col-md-9">
                        <input type="text" name="q" value="{{ query }}" class="form-control" placeholder="Rechercher sur YouTube...">
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary w-100">Chercher</button>
                    </div>
                </form>
            </div>
        </div>

        {% if results is not empty %}
            <div class="row g-4">
                {% for item in results %}
                    <div class="col-12">
                        <div class="card border h-100 p-2 shadow-sm">
                            <div class="row g-0 align-items-center">
                                <div class="col-md-4">
                                    <img src="{{ item.thumbnail }}" class="img-fluid rounded" alt="">
                                </div>
                                <div class="col-md-8">
                                    <div class="card-body py-2">
                                        <h6 class="card-title mb-1">{{ item.title|raw }}</h6>
                                        <p class="small text-muted mb-2">{{ item.channelTitle }} • {{ item.publishedAt|date('d/m/Y') }}</p>
                                        
                                        <div class="d-flex gap-2">
                                            <a href="https://www.youtube.com/watch?v={{ item.videoId }}" target="_blank" class="btn btn-sm btn-outline-secondary">Prévisualiser</a>
                                            
                                            <form method="post" action="{{ path('app_lesson_youtube_link', {id: lesson.id}) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('link_youtube_' ~ lesson.id) }}">
                                                <input type="hidden" name="video_url" value="https://www.youtube.com/watch?v={{ item.videoId }}">
                                                <button type="submit" class="btn btn-sm btn-primary">Lier cette vidéo</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
            
            <div class="mt-4">
                {{ knp_pagination_render(results) }}
            </div>
        {% else %}
            <div class="text-center py-5">
                <i class="bi bi-search display-1 text-light"></i>
                <p class="mt-3 text-muted">Effectuez une recherche pour trouver des vidéos pertinentes.</p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
