{% extends 'admin/base.html.twig' %}

{% block title %}Admin - Modifier Leçon{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12 mb-4">
        <div class="d-sm-flex justify-content-between align-items-center">
            <h1 class="h3 mb-2 mb-sm-0">Modifier: {{ lesson.titre }}</h1>
            <div class="d-flex gap-2">
                <a href="{{ path('app_lesson_youtube_manage', {id: lesson.id}) }}" class="btn btn-danger-soft mb-0"><i class="bi bi-youtube me-1"></i>YouTube</a>
                <a href="{{ path('app_lesson_index') }}" class="btn btn-outline-secondary mb-0">Retour</a>
            </div>
        </div>
    </div>
</div>

<div class="card bg-transparent border">
    <div class="card-body">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            <div class="row g-4">
                <div class="col-md-8">
                    <div class="mb-3">
                        {{ form_label(form.titre, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.titre, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.titre) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(form.contenu, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.contenu, {'attr': {'class': 'form-control', 'rows': '15'}}) }}
                        {{ form_errors(form.contenu) }}
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        {{ form_label(form.formation, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.formation, {'attr': {'class': 'form-select'}}) }}
                        {{ form_errors(form.formation) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(form.ordre, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.ordre, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.ordre) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(form.dureeMinutes, null, {'label_attr': {'class': 'form-label'}}) }}
                        <div class="input-group">
                            {{ form_widget(form.dureeMinutes, {'attr': {'class': 'form-control'}}) }}
                            <span class="input-group-text">min</span>
                        </div>
                        {{ form_errors(form.dureeMinutes) }}
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Vidéo associée</label>
                        {% if lesson.videoUrl %}
                            <div class="p-2 border rounded bg-light mb-2 small">
                                <i class="bi bi-file-earmark-play me-2"></i>{{ lesson.videoUrl }}
                            </div>
                        {% endif %}
                        {{ form_label(form.videoFile, "Remplacer la vidéo", {'label_attr': {'class': 'form-label small'}}) }}
                        {{ form_widget(form.videoFile, {'attr': {'class': 'form-control'}}) }}
                    </div>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary">Enregistrer les modifications</button>
                    <a href="{{ path('app_lesson_show', {id: lesson.id}) }}" target="_blank" class="btn btn-link text-primary"><i class="bi bi-eye me-1"></i>Voir le rendu final</a>
                </div>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
