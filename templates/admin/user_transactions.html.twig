{% extends 'admin/baseA.html.twig' %}

{% block body %}

<div class="admin">

    <h1 style="color:#374151;"> User {{ userId }} Transactions</h1>
<div style="display:flex; gap:10px; margin-bottom:20px;">
    <a href="{{ path('app_admin') }}" class="btn-view">⬅ Back</a>

    <a href="{{ path('user_transactions_pdf', { id: userId }) }}" class="btn-purple">
        ⬇ PDF
    </a>

   
</div>
    <div class="box">

        <table>
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Type</th>
                    <th>Montant</th>
                    <th>Date</th>
                </tr>
            </thead>

            <tbody>
                {% for t in transactions %}
                    <tr>
                        <td>{{ t.nomTransaction }}</td>
                        <td>{{ t.type }}</td>

                        <td class="{{ t.type == 'INCOME' ? 'green' : 'red' }}">
                            {{ t.type == 'INCOME' ? '' : '-' }}{{ t.montant }} DT
                        </td>

                        <td>{{ t.dateTransaction|date('Y-m-d') }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3">No transactions</td>
                    </tr>
                {% endfor %}
            </tbody>

        </table>

    </div>
 <div class="chart-container" style="display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-top:28px;">

    <div class="chart-donut" style="height:280px; position:relative;">
        <h3> Overview</h3>
        <canvas id="chartUser"></canvas>
    </div>

    <div class="chart-line" style="height:280px; position:relative;">
        <h3>Transactions</h3>
        <canvas id="lineChartUser"></canvas>
    </div>

</div>
</div>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
// ✅ donut (income vs outcome)
new Chart(document.getElementById('chartUser'), {
    type: 'doughnut',
    data: {
        labels: ['Revenus', 'Dépenses'],
        datasets: [{
            data: [{{ income }}, {{ outcome }}],
            backgroundColor: [
                '#2563eb',  // blue
                '#e5e7eb'   // gray soft (كيف الصورة)
            ],
            borderWidth: 0
        }]
    },
    options: {
        cutout: '75%',
        responsive: true,
        maintainAspectRatio: false
    }
});
// ✅ line chart
const ctx = document.getElementById('lineChartUser').getContext('2d');

// 🎨 gradient
const gradient = ctx.createLinearGradient(0, 0, 0, 300);
gradient.addColorStop(0, 'rgba(37,99,235,0.25)');
gradient.addColorStop(1, 'rgba(124,58,237,0.05)');

new Chart(ctx, {
    type: 'line',
    data: {
        labels: {{ chartLabels|json_encode|raw }},
        datasets: [{
            label: 'Montant',
            data: {{ chartData|json_encode|raw }},
            borderColor: '#2563eb',
            borderWidth: 3,
            tension: 0.4,
            fill: true,
            backgroundColor: gradient,
            pointBackgroundColor: '#2563eb',
            pointBorderColor: '#fff',
            pointBorderWidth: 2,
            pointRadius: 5
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: { display: false }
        },
        scales: {
            x: {
                grid: { display: false },
                ticks: { color: '#9ca3af' }
            },
            y: {
                grid: { color: '#f1f5f9' },
                ticks: { color: '#9ca3af' }
            }
        }
    }
});
</script>
{% endblock %}