{% extends 'admin/base_admin.html.twig' %}

{% block title %}Tableau de Bord - FINORA Premium{% endblock %}

{% block admin_content %}

<style>
/* ── DASHBOARD COMPONENT STYLES ── */
.premium-header {
    background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
    border-radius: 24px;
    color: white;
    position: relative;
    overflow: hidden;
}
.header-overlay {
    position: absolute;
    top: -50px; right: -50px;
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 70%);
}

.stat-card {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}
.stat-card .icon-box {
    width: 52px; height: 52px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 14px;
    font-size: 1.5rem;
    margin-bottom: 1.25rem;
}
.stat-icon-indigo { background: rgba(99, 102, 241, 0.1); color: #6366f1; }
.stat-icon-emerald { background: rgba(16, 185, 129, 0.1); color: #10b981; }
.stat-icon-amber { background: rgba(245, 158, 11, 0.1); color: #f59e0b; }
.stat-icon-rose { background: rgba(244, 63, 94, 0.1); color: #f43f5e; }

.stat-value {
    font-family: var(--fn-font-heading);
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 0.25rem;
}
.stat-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--fn-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.action-card {
    text-decoration: none;
    transition: all 0.3s;
    border: 1px solid var(--fn-border);
}
.action-card:hover {
    border-color: var(--fn-primary);
    background: rgba(99, 102, 241, 0.02);
    transform: translateY(-5px);
}

.nav-tabs-premium {
    border-bottom: 2px solid var(--fn-border);
    gap: 2rem;
}
.nav-tabs-premium .nav-link {
    border: none;
    padding: 1rem 0;
    font-weight: 700;
    color: var(--fn-text-muted);
    position: relative;
    background: none !important;
}
.nav-tabs-premium .nav-link.active {
    color: var(--fn-primary);
}
.nav-tabs-premium .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -2px; left: 0;
    width: 100%; height: 2px;
    background: var(--fn-primary);
}

.table thead th {
    background: #f8fafc;
    color: #64748b;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 1rem;
    border-bottom: 1px solid var(--fn-border);
}
[data-bs-theme="dark"] .table thead th { background: #0f172a; }

.table tbody td {
    padding: 1.25rem 1rem;
    font-weight: 500;
}
</style>

<div class="fade-in-up">

    <!-- 🌟 DASHBOARD HEADER -->
    <div class="card premium-header p-5 mb-5 border-0 shadow-lg">
        <div class="header-overlay"></div>
        <div class="position-relative z-1 d-flex justify-content-between align-items-center">
            <div>
                <div class="badge bg-white bg-opacity-20 text-white rounded-pill px-3 py-2 mb-3 d-inline-flex align-items-center">
                    <span id="status-dot" class="bg-success rounded-circle me-2 pulse-animation" style="width: 8px; height: 8px; box-shadow: 0 0 8px #10b981;"></span>
                    <span class="fw-bold small" id="status-text">SYSTÈME : EN LIGNE (TUNISIE)</span>
                </div>
                <h1 class="display-5 fw-bold text-white mb-2">Centre de Pilotage FINORA</h1>
                <p class="lead opacity-80 mb-0">Gestion centralisée des actifs et performances en temps réel.</p>
            </div>
            <div class="text-end d-none d-lg-block border-start border-white border-opacity-10 ps-5">
                <p class="small fw-bold text-uppercase opacity-60 mb-0" id="live-date">{{ "now"|date("d F Y", "Africa/Tunis") }}</p>
                <h2 class="display-6 fw-bold m-0" id="live-time">{{ "now"|date("H:i", "Africa/Tunis") }}</h2>
            </div>
        </div>
    </div>

    <!-- 📊 STATS GRID -->
    <div class="row g-4 mb-5">
        <div class="col-md-6 col-xl-3">
            <div class="card stat-card h-100 border-0 shadow-sm">
                <div>
                    <div class="icon-box stat-icon-indigo">
                        <i class="bi bi-wallet2"></i>
                    </div>
                    <div class="stat-value text-indigo-600">{{ totalInvestments }}</div>
                    <div class="stat-label">Projets de Financement</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card stat-card h-100 border-0 shadow-sm">
                <div>
                    <div class="icon-box stat-icon-emerald">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                    <div class="stat-value text-emerald-600">{{ activeManagement }}</div>
                    <div class="stat-label">Dossiers Actifs</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card stat-card h-100 border-0 shadow-sm">
                <div>
                    <div class="icon-box stat-icon-amber">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <div class="stat-value text-amber-600">{{ closedManagement }}</div>
                    <div class="stat-label">Dossiers Clôturés</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card stat-card h-100 border-0 shadow-sm" style="background: #eef2ff; border: 1px solid #c7d2fe;">
                <div>
                    <div class="icon-box bg-white text-indigo-600 shadow-sm">
                        <i class="bi bi-cash-stack"></i>
                    </div>
                    <div class="stat-value text-indigo-700">{{ totalValue|format_currency }}</div>
                    <div class="stat-label">Valeur du Portfolio</div>
                </div>
            </div>
        </div>
    </div>

    <!-- 🎯 ANALYTICS & CHARTS -->
    <div class="row g-4 mb-5">
        <div class="col-lg-7">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-header border-0 bg-transparent p-4 pb-0">
                    <h5 class="fw-bold mb-1">Exposition par Secteur</h5>
                    <p class="text-muted small">Répartition analytique des actifs par catégorie.</p>
                </div>
                <div class="card-body p-4 pt-0">
                    <div id="chart-categories" style="min-height: 380px;"></div>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-header border-0 bg-transparent p-4 pb-0">
                    <h5 class="fw-bold mb-1">Analyse des Risques</h5>
                    <p class="text-muted small">Niveaux de volatilité du catalogue.</p>
                </div>
                <div class="card-body p-4 pt-0">
                    <div id="chart-risks" style="min-height: 380px;"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- ⚡ QUICK ACTIONS -->
    <div class="mb-5">
        <h6 class="sidebar-section-title ms-0">Actions Globales</h6>
        <div class="row g-4">
            <div class="col-md-4">
                <a href="javascript:void(0)" onclick="showPanel('invest')" class="card action-card p-4 border-0 shadow-sm d-flex flex-row align-items-center">
                    <div class="icon-box stat-icon-indigo mb-0 me-3 shadow-sm" style="width: 48px; height: 48px;"><i class="bi bi-search" style="font-size: 1.25rem;"></i></div>
                    <div>
                        <div class="fw-bold text-dark">Explorer</div>
                        <div class="small text-muted">Aperçu du catalogue</div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="javascript:void(0)" onclick="showPanel('mng')" class="card action-card p-4 border-0 shadow-sm d-flex flex-row align-items-center">
                    <div class="icon-box stat-icon-emerald mb-0 me-3 shadow-sm" style="width: 48px; height: 48px;"><i class="bi bi-kanban" style="font-size: 1.25rem;"></i></div>
                    <div>
                        <div class="fw-bold text-dark">Gérer</div>
                        <div class="small text-muted">Dossiers de management</div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="{{ path('app_investment_new') }}" class="card action-card p-4 border-0 shadow-sm d-flex flex-row align-items-center">
                    <div class="icon-box stat-icon-amber mb-0 me-3 shadow-sm" style="width: 48px; height: 48px;"><i class="bi bi-plus-lg" style="font-size: 1.25rem;"></i></div>
                    <div>
                        <div class="fw-bold text-dark">Nouveau</div>
                        <div class="small text-muted">Ajouter un actif</div>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <!-- 📋 INTERACTIVE DATA PANELS -->
    <div id="dashboard-data-panels" class="card border-0 shadow-lg d-none">
        <div class="card-header bg-transparent p-4 pb-0 border-0">
            <ul class="nav nav-tabs nav-tabs-premium border-0" id="premiumTabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" id="tab-investments" data-bs-toggle="tab" data-bs-target="#panel-invest">
                        <i class="bi bi-wallet2 me-2"></i>Liste des Investissements
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="tab-management" data-bs-toggle="tab" data-bs-target="#panel-mng">
                        <i class="bi bi-graph-up-arrow me-2"></i>Actifs sous Gestion
                    </button>
                </li>
            </ul>
        </div>
        <div class="card-body p-0">
            <div class="tab-content">
                <!-- PANEL INVEST -->
                <div class="tab-pane fade show active" id="panel-invest">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">Référence</th>
                                    <th>Nom du Projet</th>
                                    <th>Secteur</th>
                                    <th>Valorisation</th>
                                    <th>Risque</th>
                                    <th class="text-end pe-4">Détails</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for inv in invList %}
                                <tr>
                                    <td class="ps-4 text-muted small">#{{ inv.id }}</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="rounded me-3" style="width: 40px; height: 40px; background: #f1f5f9; overflow: hidden;">
                                                {% if investment_image_src(inv) %}
                                                    <img src="{{ investment_image_src(inv) }}" style="width:100%; height:100%; object-fit:cover;">
                                                {% else %}
                                                    <div class="d-flex align-items-center justify-content-center h-100 text-muted"><i class="bi bi-image"></i></div>
                                                {% endif %}
                                            </div>
                                            <span class="fw-bold">{{ inv.name }}</span>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-indigo-50 text-indigo-700 px-3 py-2" style="background: #eef2ff;">{{ inv.category }}</span></td>
                                    <td class="fw-bold">{{ inv.estimatedValue|format_currency }}</td>
                                    <td>
                                        {% if inv.riskLevel == 'LOW' %}<span class="text-success"><i class="bi bi-shield-check me-1"></i>Modéré</span>{% endif %}
                                        {% if inv.riskLevel == 'MEDIUM' %}<span class="text-warning"><i class="bi bi-shield-exclamation me-1"></i>Équilibré</span>{% endif %}
                                        {% if inv.riskLevel == 'HIGH' %}<span class="text-danger"><i class="bi bi-shield-x me-1"></i>Élevé</span>{% endif %}
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="{{ path('app_investment_show', {'id': inv.id}) }}" class="btn btn-sm btn-light border fw-bold px-3">Voir</a>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                <!-- PANEL MNG -->
                <div class="tab-pane fade" id="panel-mng">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">ID Mngt</th>
                                    <th>Actif Associé</th>
                                    <th>Type</th>
                                    <th>Montant Investi</th>
                                    <th>Détention</th>
                                    <th>Status</th>
                                    <th class="text-end pe-4">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for mng in mngList %}
                                <tr>
                                    <td class="ps-4 text-muted small">#{{ mng.managementId }}</td>
                                    <td class="fw-bold">{{ mng.investment ? mng.investment.name : 'N/A' }}</td>
                                    <td>{{ mng.investmentType }}</td>
                                    <td class="fw-bold text-primary">{{ mng.amountInvested|format_currency }}</td>
                                    <td><code class="px-2 py-1 rounded bg-light text-dark fw-bold">{{ mng.ownershipPercentage }}%</code></td>
                                    <td>
                                        {% if mng.status == 'ACTIVE' %}
                                            <span class="badge bg-success rounded-pill px-3">Opérationnel</span>
                                        {% else %}
                                            <span class="badge bg-secondary rounded-pill px-3">Clôturé</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="{{ path('app_management_show', {'id': mng.managementId}) }}" class="btn btn-sm btn-light border fw-bold px-3">Gérer</a>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
    
    // --- APEX CHARTS CONFIG ---
    const isDark = (document.documentElement.getAttribute('data-bs-theme') === 'dark');
    const primaryColor = '#6366f1';
    const secondaryColor = '#8b5cf6';
    const textColor = isDark ? '#94a3b8' : '#64748b';
    const borderColor = isDark ? '#1e293b' : '#e2e8f0';

    // Categories Donut
    new ApexCharts(document.querySelector("#chart-categories"), {
        series: {{ chartCategoryData|raw }},
        labels: {{ chartCategories|raw }},
        chart: { type: 'donut', height: 380, fontFamily: 'inherit' },
        colors: [primaryColor, secondaryColor, '#3b82f6', '#10b981', '#f59e0b', '#f43f5e'],
        stroke: { show: true, width: 4, colors: [isDark ? '#0f172a' : '#fff'] },
        plotOptions: {
            pie: {
                donut: {
                    size: '78%',
                    labels: {
                        show: true,
                        total: { show: true, label: 'TOTAL CAPITAUX', fontSize: '11px', fontWeight: 700, color: textColor },
                        value: { fontSize: '24px', fontWeight: 800, color: isDark ? '#fff' : '#0f172a' }
                    }
                }
            }
        },
        legend: { position: 'bottom', labels: { colors: textColor } },
        dataLabels: { enabled: false }
    }).render();

    // Risk Analysis Bar
    new ApexCharts(document.querySelector("#chart-risks"), {
        series: [{ name: 'Actifs', data: {{ chartRisks|raw }} }],
        chart: { type: 'bar', height: 380, toolbar: { show: false } },
        plotOptions: { bar: { borderRadius: 10, columnWidth: '50%', distributed: true } },
        colors: ['#10b981', '#f59e0b', '#f43f5e'],
        xaxis: {
            categories: ['Modéré', 'Équilibré', 'Élevé'],
            labels: { style: { colors: textColor, fontWeight: 600 } },
            axisBorder: { show: false },
            axisTicks: { show: false }
        },
        yaxis: { labels: { style: { colors: textColor } } },
        grid: { borderColor: borderColor, strokeDashArray: 4 },
        legend: { show: false },
        dataLabels: { enabled: false }
    }).render();

    // --- INTERACTION LOGIC ---
    const dataPanel = document.getElementById('dashboard-data-panels');
    const mainStats = document.getElementById('panel-dashboard');
    const tabInvest = new bootstrap.Tab(document.getElementById('tab-investments'));
    const tabMng = new bootstrap.Tab(document.getElementById('tab-management'));

    window.showPanel = function(type) {
        if (type === 'main') {
            dataPanel.classList.add('d-none');
            mainStats.classList.remove('d-none');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        } else {
            dataPanel.classList.remove('d-none');
            if (type === 'invest') tabInvest.show();
            else tabMng.show();
            dataPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
        
        // Update active state in sidebar
        document.querySelectorAll('.navbar-nav .nav-link').forEach(link => link.classList.remove('active'));
        if (type === 'main') document.getElementById('sidebar-nav-dashboard')?.classList.add('active');
        else if (type === 'invest') document.getElementById('sidebar-nav-invest')?.classList.add('active');
        else if (type === 'mng') document.getElementById('sidebar-nav-management')?.classList.add('active');
    }

    // Sidebar Links Integration
    document.getElementById('sidebar-nav-dashboard')?.addEventListener('click', (e) => { e.preventDefault(); showPanel('main'); });
    document.getElementById('sidebar-nav-invest')?.addEventListener('click', (e) => { e.preventDefault(); showPanel('invest'); });
    document.getElementById('sidebar-nav-management')?.addEventListener('click', (e) => { e.preventDefault(); showPanel('mng'); });

    // --- LIVE STATUS & CLOCK TUNISIA ---
    const statusDot = document.getElementById('status-dot');
    const statusText = document.getElementById('status-text');

    function updateNetworkStatus() {
        if (navigator.onLine) {
            if (statusDot) { statusDot.classList.replace('bg-danger', 'bg-success'); statusDot.style.boxShadow = '0 0 8px #10b981'; }
            if (statusText) statusText.textContent = 'SYSTÈME : EN LIGNE (TUNISIE)';
        } else {
            if (statusDot) { statusDot.classList.replace('bg-success', 'bg-danger'); statusDot.style.boxShadow = '0 0 8px #ef4444'; }
            if (statusText) statusText.textContent = 'SYSTÈME : HORS LIGNE';
        }
    }

    window.addEventListener('online', updateNetworkStatus);
    window.addEventListener('offline', updateNetworkStatus);
    updateNetworkStatus();

    function updateTunisiaTime() {
        const timeZone = 'Africa/Tunis';
        const now = new Date();
        
        // Time
        const timeStr = now.toLocaleTimeString('fr-FR', { timeZone, hour: '2-digit', minute: '2-digit' });
        const timeEl = document.getElementById('live-time');
        if(timeEl) timeEl.textContent = timeStr; 

        // Date
        const dateStr = now.toLocaleDateString('fr-FR', { timeZone, day: '2-digit', month: 'long', year: 'numeric' });
        const dateEl = document.getElementById('live-date');
        if(dateEl) dateEl.textContent = dateStr;
    }
    setInterval(updateTunisiaTime, 10000); 
    updateTunisiaTime();

    // Pulse effect for Online Status
    const syncBadge = document.querySelector('.pulse-animation');
    if (syncBadge) {
        setInterval(() => {
            syncBadge.style.opacity = syncBadge.style.opacity === '0.4' ? '1' : '0.4';
        }, 800);
    }
});
</script>

{% endblock %}
