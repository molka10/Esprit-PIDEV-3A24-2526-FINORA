{% extends 'admin/base_admin.html.twig' %}

{% block title %}FINORA - Dashboard{% endblock %}

{% block admin_content %}

<div class="container-fluid p-4">

    <!-- 🔥 HEADER -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <h2 class="fw-bold text-primary">📊 Dashboard FINORA</h2>
            <p class="text-muted mb-0">
                Gestion des formations, lessons et investissements
            </p>
        </div>
    </div>

    <!-- 📊 STATS GLOBAL -->
    <div class="row g-4 mb-4">

        <div class="col-sm-6 col-lg-3">
            <div class="card card-body shadow-sm border-0 h-100 overflow-hidden position-relative">
                <div class="d-flex align-items-center mb-3">
                    <div class="icon-md bg-primary bg-opacity-10 text-primary rounded-circle me-3">
                        <i class="bi bi-briefcase fs-5"></i>
                    </div>
                    <h6 class="mb-0 text-muted">Total Investissements</h6>
                </div>
                <h3 class="mb-0 fw-bold">{{ totalInvestments }}</h3>
                <!-- Motif d'arrière-plan discret -->
                <div class="position-absolute end-0 bottom-0 opacity-1 mt-n5 me-n3">
                    <i class="bi bi-briefcase" style="font-size: 6rem;"></i>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-lg-3">
            <div class="card card-body shadow-sm border-0 h-100 overflow-hidden position-relative">
                <div class="d-flex align-items-center mb-3">
                    <div class="icon-md bg-success bg-opacity-10 text-success rounded-circle me-3">
                        <i class="bi bi-activity fs-5"></i>
                    </div>
                    <h6 class="mb-0 text-muted">Management Actif</h6>
                </div>
                <h3 class="mb-0 fw-bold">{{ activeManagement }}</h3>
                <div class="position-absolute end-0 bottom-0 opacity-1 mt-n5 me-n3">
                    <i class="bi bi-activity" style="font-size: 6rem;"></i>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-lg-3">
            <div class="card card-body shadow-sm border-0 h-100 overflow-hidden position-relative">
                <div class="d-flex align-items-center mb-3">
                    <div class="icon-md bg-secondary bg-opacity-10 text-secondary rounded-circle me-3">
                        <i class="bi bi-door-closed fs-5"></i>
                    </div>
                    <h6 class="mb-0 text-muted">Dossiers Clôturés</h6>
                </div>
                <h3 class="mb-0 fw-bold">{{ closedManagement }}</h3>
                <div class="position-absolute end-0 bottom-0 opacity-1 mt-n5 me-n3">
                    <i class="bi bi-door-closed" style="font-size: 6rem;"></i>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-lg-3">
            <div class="card card-body shadow-sm border-0 h-100 overflow-hidden position-relative" style="background: linear-gradient(135deg, #2b3044 0%, #171923 100%);">
                <div class="d-flex align-items-center mb-3">
                    <div class="icon-md bg-white bg-opacity-25 text-white rounded-circle me-3">
                        <i class="bi bi-cash-stack fs-5"></i>
                    </div>
                    <h6 class="mb-0 text-white-50">Valeur Totale (Estimée)</h6>
                </div>
                <h3 class="mb-0 fw-bold text-white">{{ totalValue|number_format(0, ',', ' ') }} <span class="fs-6 text-white-50">TND</span></h3>
                <div class="position-absolute end-0 bottom-0 opacity-1 mt-n5 me-n3 text-white">
                    <i class="bi bi-cash-stack" style="font-size: 7rem;"></i>
                </div>
            </div>
        </div>

    </div>

    <!-- 📊 GRAPHIQUES -->
    <div class="row g-4 mb-4">
        
        <!-- Catégories Donut -->
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0">
                    <h5 class="mb-0">Répartition par Catégories</h5>
                    <p class="text-muted small">Distribution de la diversité de votre portfolio</p>
                </div>
                <div class="card-body">
                    <div id="chart-categories" class="d-flex justify-content-center"></div>
                </div>
            </div>
        </div>

        <!-- Risques Bar -->
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0">
                    <h5 class="mb-0">Analyse des Risques</h5>
                    <p class="text-muted small">Niveau d'exposition des investissements actuels</p>
                </div>
                <div class="card-body">
                    <div id="chart-risks"></div>
                </div>
            </div>
        </div>

    </div>

    <!-- 🚀 MODULES RAPIDES -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <h5 class="mb-3">Accès Rapide</h5>
        </div>

        <!-- FORMATIONS -->
        <div class="col-md-3">
            <div class="card shadow-hover border-0 p-3 h-100 bg-white">
                <div class="d-flex align-items-center">
                    <div class="icon-lg bg-info bg-opacity-10 text-info rounded flex-shrink-0">
                        <i class="fas fa-graduation-cap fs-4"></i>
                    </div>
                    <div class="ms-3">
                        <h6 class="mb-1">Formations</h6>
                        <a href="#" class="text-muted small stretched-link">Gérer le contenu <i class="bi bi-arrow-right ms-1"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- LESSONS -->
        <div class="col-md-3">
            <div class="card shadow-hover border-0 p-3 h-100 bg-white">
                <div class="d-flex align-items-center">
                    <div class="icon-lg bg-purple bg-opacity-10 text-purple rounded flex-shrink-0">
                        <i class="fas fa-book-open fs-4"></i>
                    </div>
                    <div class="ms-3">
                        <h6 class="mb-1">Lessons</h6>
                        <a href="#" class="text-muted small stretched-link">Gérer les cours <i class="bi bi-arrow-right ms-1"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- INVESTMENTS -->
        <div class="col-md-3">
            <div class="card shadow-hover border-0 p-3 h-100 bg-white">
                <div class="d-flex align-items-center">
                    <div class="icon-lg bg-success bg-opacity-10 text-success rounded flex-shrink-0">
                        <i class="bi bi-wallet2 fs-4"></i>
                    </div>
                    <div class="ms-3">
                        <h6 class="mb-1">Investissements</h6>
                        <a href="{{ path('app_investment_index') }}" class="text-muted small stretched-link">Consulter le portfolio <i class="bi bi-arrow-right ms-1"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- MANAGEMENT -->
        <div class="col-md-3">
            <div class="card shadow-hover border-0 p-3 h-100 bg-white">
                <div class="d-flex align-items-center">
                    <div class="icon-lg bg-warning bg-opacity-10 text-warning rounded flex-shrink-0">
                        <i class="bi bi-graph-up-arrow fs-4"></i>
                    </div>
                    <div class="ms-3">
                        <h6 class="mb-1">Management</h6>
                        <a href="{{ path('app_management_index') }}" class="text-muted small stretched-link">Suivi des dossiers <i class="bi bi-arrow-right ms-1"></i></a>
                    </div>
                </div>
            </div>
        </div>

    </div>

</div>

<script>
document.addEventListener("DOMContentLoaded", function() {

    // === CHART CATÉGORIES (DONUT) ===
    const catCategories = {{ chartCategories|raw }};
    const catData       = {{ chartCategoryData|raw }};

    if (document.querySelector("#chart-categories") && catData.length > 0) {
        new ApexCharts(document.querySelector("#chart-categories"), {
            series: catData,
            labels: catCategories,
            chart: {
                type: 'donut',
                height: 300,
                fontFamily: 'inherit'
            },
            plotOptions: {
                pie: {
                    donut: {
                        size: '70%',
                        labels: {
                            show: true,
                            name: { show: true },
                            value: { show: true, fontSize: '24px', fontWeight: 'bold' },
                            total: { show: true, label: 'Total', color: '#6b7280' }
                        }
                    }
                }
            },
            dataLabels: { enabled: false },
            legend: { position: 'bottom' },
            colors: ['#4f46e5', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#0ea5e9']
        }).render();
    }

    // === CHART RISQUES (BAR) ===
    const riskData = {{ chartRisks|raw }}; // ex: [LOW, MEDIUM, HIGH]

    if (document.querySelector("#chart-risks") && riskData.length > 0) {
        new ApexCharts(document.querySelector("#chart-risks"), {
            series: [{
                name: 'Quantité',
                data: riskData
            }],
            chart: {
                type: 'bar',
                height: 300,
                toolbar: { show: false },
                fontFamily: 'inherit'
            },
            plotOptions: {
                bar: {
                    borderRadius: 6,
                    columnWidth: '40%',
                    distributed: true
                }
            },
            dataLabels: { enabled: false },
            xaxis: {
                categories: ['Faible', 'Moyen', 'Élevé'],
                axisBorder: { show: false },
                axisTicks: { show: false },
                labels: { style: { fontSize: '13px', fontWeight: 500 } }
            },
            yaxis: {
                labels: { style: { colors: '#6b7280' } }
            },
            grid: {
                borderColor: '#e5e7eb',
                strokeDashArray: 4
            },
            legend: { show: false },
            colors: ['#10b981', '#f59e0b', '#ef4444'], // Vert, Orange, Rouge
            tooltip: {
                theme: 'light',
                y: { formatter: function (val) { return val + " investissements" } }
            }
        }).render();
    }
});
</script>

{% endblock %}