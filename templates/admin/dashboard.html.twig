{% extends 'admin/base_admin.html.twig' %}

{% block title %}FINORA - Premium Dashboard{% endblock %}

{% block admin_content %}

<style>
/* ==================================
   CSS Premium SaaS Dashboard
=================================== */
@keyframes fadeInUp { 
    from { opacity: 0; transform: translateY(20px); } 
    to { opacity: 1; transform: translateY(0); } 
}
.fade-in-up { animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; }
.delay-1 { animation-delay: 0.1s; }
.delay-2 { animation-delay: 0.2s; }
.delay-3 { animation-delay: 0.3s; }
.delay-4 { animation-delay: 0.4s; }

.saas-card {
    border-radius: 20px;
    border: 1px solid rgba(0, 0, 0, 0.05);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    background-color: #fff;
    position: relative;
    overflow: hidden;
}
[data-bs-theme="dark"] .saas-card {
    background-color: #1a1d2d;
    border-color: rgba(255, 255, 255, 0.05);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
}
.saas-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08);
}
[data-bs-theme="dark"] .saas-card:hover {
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
}

.header-gradient {
    background: linear-gradient(135deg, #ffffff 0%, #f4f6f8 100%);
}
[data-bs-theme="dark"] .header-gradient {
    background: linear-gradient(135deg, #2b3044 0%, #1a1d2d 100%);
}
.header-glow {
    position: absolute;
    width: 350px; height: 350px;
    background: radial-gradient(circle, rgba(99,102,241,0.15) 0%, rgba(255,255,255,0) 70%);
    top: -100px; right: -50px;
    border-radius: 50%;
    pointer-events: none;
}

.stat-icon-wrapper {
    width: 54px; height: 54px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 14px;
    font-size: 1.5rem;
}
.icon-glow-primary { background: rgba(79, 70, 229, 0.1); color: #4f46e5; }
.icon-glow-success { background: rgba(16, 185, 129, 0.1); color: #10b981; }
.icon-glow-warning { background: rgba(245, 158, 11, 0.1); color: #f59e0b; }
.icon-glow-purple  { background: rgba(139, 92, 246, 0.1); color: #8b5cf6; }

.value-card {
    background: linear-gradient(135deg, #4f46e5 0%, #312e81 100%);
    border: none;
}
.value-card .header-glow {
    background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0) 70%);
}
.value-card:hover {
    box-shadow: 0 15px 35px rgba(79, 70, 229, 0.4) !important;
}

.module-card {
    border-left: 4px solid transparent;
}
.module-card:hover {
    border-left-color: #6366f1;
}

.bg-watermark {
    position: absolute;
    right: -10px;
    bottom: -20px;
    font-size: 8rem;
    opacity: 0.04;
    transition: opacity 0.3s;
}
.value-card .bg-watermark { opacity: 0.15; color: white; }
.saas-card:hover .bg-watermark { opacity: 0.08; }
.value-card:hover .bg-watermark { opacity: 0.25; }

.apexcharts-tooltip {
    box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
    border-radius: 12px !important;
    border: 0 !important;
}
</style>

<div class="container-fluid p-4">

    <!-- 🔥 HEADER -->
    <div class="saas-card mb-4 header-gradient fade-in-up">
        <div class="header-glow"></div>
        <div class="card-body p-4 d-flex justify-content-between align-items-center position-relative z-1">
            <div>
                <span class="badge bg-success bg-opacity-10 text-success mb-2 px-3 py-2 rounded-pill fw-bold border border-success-subtle">
                    <i class="bi bi-circle-fill small me-1 pulse-animation"></i> Système En Ligne
                </span>
                <h2 class="fw-bold mb-1 text-body">Centre de Contrôle FINORA</h2>
                <p class="text-muted mb-0">Aperçu en temps réel de vos performances financières et administratives.</p>
            </div>
            <div class="d-none d-md-block text-end">
                <p class="text-muted small fw-bold mb-0 text-uppercase">{{ 'now'|date('d F Y') }}</p>
                <div class="d-flex align-items-center justify-content-end">
                    <i class="bi bi-clock text-primary me-2"></i>
                    <h4 class="fw-bold m-0 text-primary">{{ 'now'|date('H:i') }}</h4>
                </div>
            </div>
        </div>
    </div>

    <!-- 📊 STATS GLOBAL -->
    <div class="row g-4 mb-4">

        <div class="col-sm-6 col-lg-3 fade-in-up delay-1">
            <div class="saas-card p-4 h-100">
                <div class="d-flex align-items-center mb-3">
                    <div class="stat-icon-wrapper icon-glow-primary me-3">
                        <i class="bi bi-briefcase-fill"></i>
                    </div>
                    <h6 class="mb-0 text-muted fw-bold">Total Investissements</h6>
                </div>
                <h2 class="mb-0 fw-bold display-6">{{ totalInvestments }}</h2>
                <div class="bg-watermark"><i class="bi bi-briefcase"></i></div>
            </div>
        </div>

        <div class="col-sm-6 col-lg-3 fade-in-up delay-1">
            <div class="saas-card p-4 h-100">
                <div class="d-flex align-items-center mb-3">
                    <div class="stat-icon-wrapper icon-glow-success me-3">
                        <i class="bi bi-activity"></i>
                    </div>
                    <h6 class="mb-0 text-muted fw-bold">Management Actif</h6>
                </div>
                <h2 class="mb-0 fw-bold display-6">{{ activeManagement }}</h2>
                <div class="bg-watermark"><i class="bi bi-activity"></i></div>
            </div>
        </div>

        <div class="col-sm-6 col-lg-3 fade-in-up delay-2">
            <div class="saas-card p-4 h-100">
                <div class="d-flex align-items-center mb-3">
                    <div class="stat-icon-wrapper icon-glow-warning me-3">
                        <i class="bi bi-door-closed-fill"></i>
                    </div>
                    <h6 class="mb-0 text-muted fw-bold">Dossiers Clôturés</h6>
                </div>
                <h2 class="mb-0 fw-bold display-6">{{ closedManagement }}</h2>
                <div class="bg-watermark"><i class="bi bi-door-closed"></i></div>
            </div>
        </div>

        <!-- CARTE PREMIUM VALEUR TOTALE -->
        <div class="col-sm-6 col-lg-3 fade-in-up delay-2">
            <div class="saas-card value-card p-4 h-100 text-white">
                <div class="header-glow"></div>
                <div class="d-flex align-items-center mb-3 position-relative z-1">
                    <div class="stat-icon-wrapper bg-white bg-opacity-25 text-white me-3">
                        <i class="bi bi-cash-stack"></i>
                    </div>
                    <h6 class="mb-0 text-white opacity-75 fw-bold">Valeur Globale Estimée</h6>
                </div>
                <h2 class="mb-0 fw-bold text-white position-relative z-1">{{ totalValue|format_currency }}</h2>
                <div class="bg-watermark"><i class="bi bi-cash-stack"></i></div>
            </div>
        </div>

    </div>

    <!-- 📊 GRAPHIQUES -->
    <div class="row g-4 mb-4">
        
        <!-- Catégories Donut -->
        <div class="col-lg-6 fade-in-up delay-3">
            <div class="saas-card h-100">
                <div class="border-bottom border-secondary border-opacity-10 p-4">
                    <h5 class="fw-bold mb-1">Répartition par Catégories</h5>
                    <p class="text-muted small mb-0">Distribution de l'exposition financière du portfolio</p>
                </div>
                <div class="card-body p-4 d-flex justify-content-center align-items-center">
                    <div id="chart-categories" class="w-100 d-flex justify-content-center"></div>
                </div>
            </div>
        </div>

        <!-- Risques Bar -->
        <div class="col-lg-6 fade-in-up delay-3">
            <div class="saas-card h-100">
                <div class="border-bottom border-secondary border-opacity-10 p-4">
                    <h5 class="fw-bold mb-1">Analyse Analytique des Risques</h5>
                    <p class="text-muted small mb-0">Volatilité et niveau d'exposition des actifs courants</p>
                </div>
                <div class="card-body p-4">
                    <div id="chart-risks"></div>
                </div>
            </div>
        </div>

    </div>

    <!-- 🚀 MODULES RAPIDES -->
    <div class="fade-in-up delay-4">
        <h5 class="mb-3 fw-bold text-body"><i class="bi bi-lightning-charge-fill text-warning me-2"></i>Actions Rapides (CRUD)</h5>
        <div class="row g-4">
            
            <div class="col-md-3">
                <div class="saas-card module-card p-3 h-100">
                    <div class="d-flex align-items-center">
                        <div class="icon-lg icon-glow-primary rounded flex-shrink-0">
                            <i class="fas fa-graduation-cap fs-4"></i>
                        </div>
                        <div class="ms-3">
                            <h6 class="mb-1 fw-bold">Formations</h6>
                            <a href="#" class="text-muted small stretched-link text-decoration-none">Gérer le contenu <i class="bi bi-arrow-right ms-1"></i></a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="saas-card module-card p-3 h-100">
                    <div class="d-flex align-items-center">
                        <div class="icon-lg icon-glow-purple rounded flex-shrink-0">
                            <i class="fas fa-book-open fs-4"></i>
                        </div>
                        <div class="ms-3">
                            <h6 class="mb-1 fw-bold">Lessons</h6>
                            <a href="#" class="text-muted small stretched-link text-decoration-none">Gérer les cours <i class="bi bi-arrow-right ms-1"></i></a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="saas-card module-card p-3 h-100">
                    <div class="d-flex align-items-center">
                        <div class="icon-lg icon-glow-success rounded flex-shrink-0">
                            <i class="bi bi-wallet2 fs-4"></i>
                        </div>
                        <div class="ms-3">
                            <h6 class="mb-1 fw-bold">Investissements</h6>
                            <a href="#data-tables-section" id="btn-tab-invest" class="text-muted small stretched-link text-decoration-none">Afficher la table <i class="bi bi-arrow-down-short ms-1"></i></a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="saas-card module-card p-3 h-100">
                    <div class="d-flex align-items-center">
                        <div class="icon-lg icon-glow-warning rounded flex-shrink-0">
                            <i class="bi bi-graph-up-arrow fs-4"></i>
                        </div>
                        <div class="ms-3">
                            <h6 class="mb-1 fw-bold">Management</h6>
                            <a href="#data-tables-section" id="btn-tab-management" class="text-muted small stretched-link text-decoration-none">Afficher la table <i class="bi bi-arrow-down-short ms-1"></i></a>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- 📋 TABLES SECTION (DASHBOARD INLINE) -->
    <div id="data-tables-section" class="mt-5 fade-in-up delay-4 d-none">
        <div class="saas-card overflow-hidden">
            <div class="card-header bg-transparent border-bottom p-4">
                <ul class="nav nav-tabs nav-tabs-line nav-tabs-line-primary mb-0" id="dashboardDataTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active fw-bold" id="tab-investments" data-bs-toggle="tab" data-bs-target="#pane-investments" type="button" role="tab"><i class="bi bi-wallet2 me-2"></i>Liste des Investissements</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold" id="tab-management" data-bs-toggle="tab" data-bs-target="#pane-management" type="button" role="tab"><i class="bi bi-graph-up-arrow me-2"></i>Liste du Management</button>
                    </li>
                </ul>
            </div>
            <div class="card-body p-0">
                <div class="tab-content" id="dashboardDataTabsContent">
                    
                    <!-- PANE : INVESTMENTS -->
                    <div class="tab-pane fade show active" id="pane-investments" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover table-align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="ps-4">ID</th>
                                        <th>Visuel</th>
                                        <th>Nom du Projet</th>
                                        <th>Catégorie</th>
                                        <th>Valeur Estimée</th>
                                        <th>Risque</th>
                                        <th class="text-end pe-4">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                {% for inv in invList %}
                                    <tr>
                                        <td class="ps-4 text-muted">#{{ inv.id }}</td>
                                        <td>
                                            {% if investment_image_src(inv) %}
                                                <img src="{{ investment_image_src(inv) }}" class="rounded avatar-sm" alt="img" style="width:40px; height:40px; object-fit:cover;">
                                            {% else %}
                                                <div class="avatar-sm bg-secondary bg-opacity-10 text-secondary rounded d-flex align-items-center justify-content-center" style="width:40px; height:40px;"><i class="bi bi-image"></i></div>
                                            {% endif %}
                                        </td>
                                        <td class="fw-bold">{{ inv.name }}</td>
                                        <td><span class="badge bg-primary bg-opacity-10 text-primary">{{ inv.category }}</span></td>
                                        <td class="fw-bold text-success">{{ inv.estimatedValue|format_currency }}</td>
                                        <td>
                                            {% if inv.riskLevel == 'LOW' %}<span class="text-success"><i class="bi bi-shield-check me-1"></i>Faible</span>{% endif %}
                                            {% if inv.riskLevel == 'MEDIUM' %}<span class="text-warning"><i class="bi bi-shield-exclamation me-1"></i>Moyen</span>{% endif %}
                                            {% if inv.riskLevel == 'HIGH' %}<span class="text-danger"><i class="bi bi-shield-x me-1"></i>Élevé</span>{% endif %}
                                        </td>
                                        <td class="text-end pe-4">
                                            <a href="{{ path('app_investment_show', {'id': inv.id}) }}" class="btn btn-sm btn-light mb-0"><i class="bi bi-eye"></i></a>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr><td colspan="7" class="text-center py-4 text-muted">Aucun investissement trouvé.</td></tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- PANE : MANAGEMENT -->
                    <div class="tab-pane fade" id="pane-management" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover table-align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="ps-4">ID Mngt</th>
                                        <th>Projet (Investissement)</th>
                                        <th>Type</th>
                                        <th>Montant Investi</th>
                                        <th>Parts (%)</th>
                                        <th>Statut</th>
                                        <th class="text-end pe-4">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                {% for mng in mngList %}
                                    <tr>
                                        <td class="ps-4 text-muted">#{{ mng.managementId }}</td>
                                        <td class="fw-bold">{{ mng.investment ? mng.investment.name : 'N/A' }}</td>
                                        <td>{{ mng.investmentType }}</td>
                                        <td class="fw-bold text-primary">{{ mng.amountInvested|format_currency }}</td>
                                        <td>{{ mng.ownershipPercentage }} %</td>
                                        <td>
                                            {% if mng.status == 'ACTIVE' %}
                                                <span class="badge bg-success">Actif</span>
                                            {% else %}
                                                <span class="badge bg-secondary">Clôturé</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-end pe-4">
                                            <a href="{{ path('app_management_show', {'id': mng.managementId}) }}" class="btn btn-sm btn-light mb-0"><i class="bi bi-eye"></i></a>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr><td colspan="7" class="text-center py-4 text-muted">Aucun dossier de management trouvé.</td></tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

</div>

<script>
document.addEventListener("DOMContentLoaded", function() {

    const theme = document.documentElement.getAttribute('data-bs-theme');
    const isDark = (theme === 'dark');

    // === CHART CATÉGORIES (DONUT) ===
    const catCategories = {{ chartCategories|raw }};
    const catData       = {{ chartCategoryData|raw }};

    if (document.querySelector("#chart-categories") && catData.length > 0) {
        new ApexCharts(document.querySelector("#chart-categories"), {
            series: catData,
            labels: catCategories,
            chart: {
                type: 'donut',
                height: 320,
                fontFamily: 'inherit',
                animations: { enabled: true, easing: 'easeinout', speed: 800 }
            },
            plotOptions: {
                pie: {
                    donut: {
                        size: '75%',
                        labels: {
                            show: true,
                            name: { show: true, color: isDark ? '#9ca3af' : '#6b7280' },
                            value: { show: true, fontSize: '26px', fontWeight: 'bold', color: isDark ? '#fff' : '#111827' },
                            total: { show: true, label: 'Total', color: isDark ? '#9ca3af' : '#6b7280' }
                        }
                    }
                }
            },
            dataLabels: { enabled: false },
            legend: { position: 'bottom', labels: { colors: isDark ? '#e5e7eb' : '#374151' } },
            stroke: { show: true, colors: isDark ? '#1a1d2d' : '#fff', width: 3 },
            colors: ['#4f46e5', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#0ea5e9']
        }).render();
    }

    // === CHART RISQUES (BAR) ===
    const riskData = {{ chartRisks|raw }}; 

    if (document.querySelector("#chart-risks") && riskData.length > 0) {
        new ApexCharts(document.querySelector("#chart-risks"), {
            series: [{
                name: 'Quantité',
                data: riskData
            }],
            chart: {
                type: 'bar',
                height: 320,
                toolbar: { show: false },
                fontFamily: 'inherit',
                animations: { enabled: true, easing: 'easeinout', speed: 800 }
            },
            plotOptions: {
                bar: {
                    borderRadius: 8,
                    columnWidth: '45%',
                    distributed: true
                }
            },
            dataLabels: { enabled: false },
            xaxis: {
                categories: ['Faible', 'Moyen', 'Élevé'],
                axisBorder: { show: false },
                axisTicks: { show: false },
                labels: { style: { fontSize: '13px', fontWeight: 600, colors: isDark ? '#9ca3af' : '#6b7280' } }
            },
            yaxis: {
                labels: { style: { colors: isDark ? '#9ca3af' : '#6b7280' } }
            },
            grid: {
                borderColor: isDark ? 'rgba(255,255,255,0.05)' : '#f3f4f6',
                strokeDashArray: 5,
                xaxis: { lines: { show: false } },
                yaxis: { lines: { show: true } }
            },
            legend: { show: false },
            colors: ['#10b981', '#f59e0b', '#ef4444'], // Vert, Orange, Rouge
            tooltip: {
                theme: isDark ? 'dark' : 'light',
                y: { formatter: function (val) { return val + " Projets" } }
            }
        }).render();
    }

    // === GESTION DYNAMIQUE DES TABLES ===
    const tblSection = document.getElementById('data-tables-section');
    const btnInvest = document.getElementById('btn-tab-invest');
    const btnManagement = document.getElementById('btn-tab-management');

    if (btnInvest && btnManagement && tblSection) {
        
        btnInvest.addEventListener('click', function(e) {
            // Afficher la section si cachée
            tblSection.classList.remove('d-none');
            // Activer la tab
            const tabEl = document.querySelector('#tab-investments');
            const tab = new bootstrap.Tab(tabEl);
            tab.show();
        });

        btnManagement.addEventListener('click', function(e) {
            tblSection.classList.remove('d-none');
            const tabEl = document.querySelector('#tab-management');
            const tab = new bootstrap.Tab(tabEl);
            tab.show();
        });
    }

});
</script>

{% endblock %}