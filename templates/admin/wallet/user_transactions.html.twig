/* â”€â”€ Calendar toggle + init â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
let userCalInit = false;
const USER_ID   = {{ userId }};

function toggleInlineCalendar() {
    const sec = document.getElementById('calendarSection');
    const btn = document.getElementById('toggleCalBtn');
    const open = sec.style.display === 'block';
    if (open) {
        sec.style.display = 'none';
        btn.innerHTML = '<i class="bi bi-calendar3"></i> Calendrier';
        btn.classList.remove('active');
    } else {
        sec.style.display = 'block';
        btn.innerHTML = '<i class="bi bi-x-lg"></i> Masquer Calendrier';
        btn.classList.add('active');
        if (!userCalInit) initUserCal();
    }
}

async function initUserCal() {
    userCalInit = true;
    let events = [];
    try {
        const res  = await fetch(`/api/user/calendar-events/by-user?userId=${USER_ID}`);
        const json = await res.json();
        if (json.status === 'success') events = json.data;
    } catch(e) { console.error('Calendar API error:', e); }

    let income = 0, outcome = 0;
    events.forEach(ev => {
        const ep = ev.extendedProps || {};
        if (ep.isIncome) income  += ep.amount || 0;
        else             outcome += ep.amount || 0;
    });
    document.getElementById('ucTotal').textContent   = events.length;
    document.getElementById('ucIncome').textContent  = '+' + income.toFixed(2)  + ' DT';
    document.getElementById('ucOutcome').textContent = '-' + outcome.toFixed(2) + ' DT';

    document.getElementById('userCalSkel').style.display = 'none';
    const calEl = document.getElementById('userInlineCal');
    calEl.style.display = 'block';

    const cal = new FullCalendar.Calendar(calEl, {
        initialView: 'dayGridMonth',
        locale: 'fr',
        height: 'auto',
        headerToolbar: {
            left:   'prev,next today',
            center: 'title',
            right:  'dayGridMonth,timeGridWeek,listWeek'
        },
        buttonText: { today:"Aujourd'hui", month:'Mois', week:'Semaine', list:'Liste' },
        events: events,
        dayMaxEvents: 4,
        eventTimeFormat: { hour:'2-digit', minute:'2-digit', meridiem:false },
        eventClick: function(info) {
            const ep   = info.event.extendedProps || {};
            const sign = ep.isIncome ? '+' : '-';
            const amt  = (ep.amount ?? 0).toFixed(2);
            const name = (info.event.title ?? '').replace(/^[+\-][\d.]+ DT - /, '');
            const date = info.event.start
                ? new Date(info.event.start).toLocaleDateString('fr-FR', {weekday:'short',year:'numeric',month:'short',day:'numeric'})
                : '—';
            alert(`${sign}${amt} DT — ${name}\nDate : ${date}\nCatégorie : ${ep.category ?? '—'}`);
        }
    });
    // Defer render so the animation completes
    setTimeout(() => { cal.render(); cal.updateSize(); }, 100);
}
</script>
