{% extends 'admin/base.html.twig' %}

{% block title %}FINORA - Gestion des Cartes Bancaires{% endblock %}

{% block stylesheets %}
<style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap');

    :root {
        --p: #7c3aed;
        --p-light: #f5f3ff;
        --p-dark: #6d28d9;
        --text-main: #1e1b4b;
        --text-muted: #64748b;
        --glass-bg: rgba(255, 255, 255, 0.7);
        --glass-border: rgba(255, 255, 255, 0.4);
    }

    .admin-dashboard {
        padding: 40px;
        background: #fdfcff;
        min-height: 100vh;
        font-family: 'Outfit', sans-serif;
    }

    /* Hero Section with Glassmorphism */
    .admin-hero {
        background: linear-gradient(135deg, #1e1b4b 0%, #4338ca 100%);
        border-radius: 30px;
        padding: 50px;
        margin-bottom: 40px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 25px 60px rgba(30, 27, 75, 0.25);
    }

    .admin-hero::before {
        content: '';
        position: absolute;
        top: -100px;
        right: -100px;
        width: 400px;
        height: 400px;
        background: rgba(124, 58, 237, 0.2);
        filter: blur(80px);
        border-radius: 50%;
        z-index: 1;
    }

    .admin-hero-content {
        position: relative;
        z-index: 2;
    }

    .admin-hero h1 {
        font-weight: 900;
        letter-spacing: -1px;
        color: #fff;
        margin-bottom: 10px;
    }

    .admin-hero p {
        color: rgba(255, 255, 255, 0.7);
        font-weight: 500;
        font-size: 16px;
        max-width: 600px;
    }

    /* Stats inside Hero */
    .hero-stats {
        display: flex;
        gap: 20px;
        margin-top: 30px;
    }

    .mini-stat {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.15);
        padding: 15px 25px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .mini-stat i {
        font-size: 20px;
        color: #ddd6fe;
    }

    .mini-stat-info span {
        display: block;
        font-size: 11px;
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 1px;
        opacity: 0.6;
    }

    .mini-stat-info strong {
        font-size: 18px;
        font-weight: 800;
    }

    /* Table Container */
    .card-list-container {
        background: white;
        border-radius: 32px;
        box-shadow: 0 15px 40px rgba(124, 58, 237, 0.08);
        border: 1px solid rgba(124, 58, 237, 0.05);
        overflow: hidden;
    }

    .table-header {
        padding: 30px 35px;
        background: linear-gradient(to right, #fff, #fafbff);
        border-bottom: 1.5px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .table-header h5 {
        font-weight: 800;
        color: var(--text-main);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 1.2rem;
    }

    .custom-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    .custom-table thead th {
        padding: 20px 35px;
        font-size: 11px;
        font-weight: 800;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1.2px;
        border-bottom: 1.5px solid #f1f5f9;
    }

    .custom-table tbody tr {
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .custom-table tbody tr:hover {
        background-color: #fcfaff;
        transform: scale(1.002);
    }

    .custom-table tbody td {
        padding: 22px 35px;
        vertical-align: middle;
        border-bottom: 1px solid #f8fafc;
    }

    /* User Avatar Style */
    .user-pill {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .avatar-box {
        width: 42px;
        height: 42px;
        background: linear-gradient(135deg, #7c3aed, #4f46e5);
        border-radius: 12px;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 15px;
        box-shadow: 0 4px 10px rgba(124, 58, 237, 0.2);
    }

    /* Visual CC Representation */
    .mini-card-icon {
        width: 48px;
        height: 32px;
        border-radius: 6px;
        background: linear-gradient(135deg, #334155, #1e293b);
        position: relative;
        padding: 4px;
        margin-right: 15px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        display: flex;
        align-items: center;
    }
    
    .mini-card-chip {
        width: 8px;
        height: 8px;
        background: #fbbf24;
        border-radius: 2px;
        position: absolute;
        top: 6px;
        left: 6px;
    }

    .mini-card-lines {
        margin-left: 20px;
        width: 100%;
    }

    .card-line {
        height: 2px;
        background: rgba(255,255,255,0.2);
        margin-bottom: 3px;
        border-radius: 1px;
    }

    /* Status Badges */
    .badge-premium {
        background: #ede9fe;
        color: #7c3aed;
        border: 1.5px solid #ddd6fe;
        padding: 6px 14px;
        border-radius: 12px;
        font-weight: 800;
        font-size: 12px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .badge-secondary {
        background: #f1f5f9;
        color: #64748b;
        padding: 6px 14px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 12px;
    }

    code {
        font-family: 'Courier New', monospace;
        letter-spacing: 2px;
        font-size: 14px;
        color: #7c3aed;
        background: #f5f3ff;
        padding: 4px 10px;
        border-radius: 6px;
    }

    .empty-state {
        text-align: center;
        padding: 80px 0;
    }

    .empty-state i {
        font-size: 3rem;
        color: #e2e8f0;
        margin-bottom: 20px;
        display: block;
    }

    /* Animation */
    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .animated {
        animation: fadeInUp 0.6s ease-out forwards;
    }
</style>
{% endblock %}

{% block body %}
<div class="admin-dashboard">
    <!-- Hero Section -->
    <div class="admin-hero animated">
        <div class="admin-hero-content">
            <h1>Gestion des Cartes</h1>
            <p>Administration centralisée de tous les terminaux de paiement sécurisés liés à la plateforme FINORA.</p>
            
            <div class="hero-stats">
                <div class="mini-stat">
                    <i class="bi bi-layers"></i>
                    <div class="mini-stat-info">
                        <span>Total Cartes</span>
                        <strong>{{ cards|length }}</strong>
                    </div>
                </div>
                <div class="mini-stat">
                    <i class="bi bi-shield-check"></i>
                    <div class="mini-stat-info">
                        <span>Terminal Sécurisé</span>
                        <strong>ACTIF</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="card-list-container animated" style="animation-delay: 0.2s;">
        <div class="table-header">
            <h5><i class="bi bi-credit-card-2-front text-primary"></i> Répertoire des Cartes Utilisateurs</h5>
            <div style="font-size: 12px; color: var(--text-muted); font-weight: 600;">
                <span class="badge bg-light text-dark p-2 border">{{ "now"|date("d/m/Y") }}</span>
            </div>
        </div>

        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Utilisateur</th>
                        <th>Détails Titulaire</th>
                        <th>Numéro de Carte</th>
                        <th>Expiration</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    {% for card in cards %}
                        <tr>
                            <td>
                                <div class="user-pill">
                                    <div class="avatar-box">U{{ card.userId }}</div>
                                    <span style="font-weight: 700; color: var(--text-main);">#ID {{ card.userId }}</span>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="mini-card-icon" style="background: {{ card.isDefault ? 'linear-gradient(135deg, #1e293b, #334155)' : 'linear-gradient(135deg, #64748b, #94a3b8)' }};">
                                        <div class="mini-card-chip"></div>
                                        <div class="mini-card-lines">
                                            <div class="card-line" style="width: 15px;"></div>
                                            <div class="card-line" style="width: 10px;"></div>
                                        </div>
                                    </div>
                                    <span style="font-weight: 800; color: var(--text-main); text-transform: capitalize;">{{ card.cardHolderName|default('Inconnu') }}</span>
                                </div>
                            </td>
                            <td>
                                <code>{{ card.cardNumber|slice(0,4) }} **** {{ card.cardNumber|slice(-4) }}</code>
                            </td>
                            <td>
                                <div style="font-weight: 700; color: var(--text-muted);">
                                    <i class="bi bi-calendar-event me-2"></i>{{ card.expiryDate }}
                                </div>
                            </td>
                            <td>
                                {% if card.isDefault %}
                                    <span class="badge-premium">
                                        <i class="bi bi-shield-fill-check"></i> Principale
                                    </span>
                                {% else %}
                                    <span class="badge-secondary">Secondaire</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    <i class="bi bi-credit-card"></i>
                                    <span style="font-weight: 700; color: #94a3b8;">Aucune carte enregistrée dans le système</span>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
