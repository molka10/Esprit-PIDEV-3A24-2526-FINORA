{% extends 'admin/base.html.twig' %}

{% block title %}Audit des Fraudes — Admin{% endblock %}

{% block stylesheets %}
<style>
/* â”€â”€ Fraud hero â”€â”€ */
.fraud-hero {
    background: linear-gradient(135deg, #7f1d1d 0%, #dc2626 60%, #ef4444 100%);
    border-radius: 20px; padding: 24px 28px;
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 14px;
    box-shadow: 0 16px 40px rgba(220,38,38,0.30);
    position: relative; overflow: hidden; margin-bottom: 24px;
}
.fraud-hero::before {
    content: ''; position: absolute; right: -50px; top: -50px;
    width: 200px; height: 200px; border-radius: 50%; background: rgba(255,255,255,0.06);
}
.fraud-hero h1 { color: #fff !important; font-size: 22px !important; font-weight: 800 !important; margin: 0 !important; position: relative; z-index: 1; }
.fraud-hero p  { color: rgba(255,255,255,0.75) !important; margin: 4px 0 0; font-size: 13px !important; position: relative; z-index: 1; }

/* â”€â”€ Alert banner â”€â”€ */
.fraud-alert-banner {
    background: linear-gradient(135deg, #fff1f2, #fee2e2);
    border: 1px solid #fecaca; border-radius: 16px;
    padding: 18px 24px; margin-bottom: 22px;
    display: flex; align-items: center; gap: 14px;
    box-shadow: 0 4px 16px rgba(220,38,38,0.07);
    animation: fraudIn 0.4s ease both;
}
@keyframes fraudIn { from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);} }
.fraud-alert-icon { color: #dc2626; font-size: 2rem; flex-shrink: 0; }
.fraud-alert-title { font-size: 17px; font-weight: 800; color: #991b1b; margin: 0 0 2px; }
.fraud-alert-sub   { font-size: 13.5px; color: #b91c1c; margin: 0; }

/* â”€â”€ Table card â”€â”€ */
.fraud-table-card {
    background: #fff; border-radius: 20px;
    border: 1px solid rgba(220,38,38,0.08);
    box-shadow: 0 8px 32px -8px rgba(124,58,237,0.10);
    overflow: hidden; animation: fraudIn 0.4s 0.1s ease both;
}
.fraud-table-header {
    padding: 18px 24px; border-bottom: 1px solid rgba(220,38,38,0.08);
    display: flex; align-items: center; justify-content: space-between;
    background: linear-gradient(135deg, #fff1f2, #fff);
}
.fraud-table-header h6 { margin: 0; font-weight: 700; color: #7f1d1d; display: flex; align-items: center; gap: 8px; }

.fraud-table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
.fraud-table thead th {
    padding: 12px 18px; font-size: 10.5px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.5px;
    color: #6b7280; border-bottom: 2px solid #fee2e2; background: #fff8f8;
}
.fraud-table tbody tr { border-bottom: 1px solid rgba(220,38,38,0.04); transition: background 0.15s; }
.fraud-table tbody tr:hover { background: #fff8f8; }
.fraud-table tbody td { padding: 14px 18px; vertical-align: middle; color: #374151; }

/* â”€â”€ User badge â”€â”€ */
.user-avatar-circle {
    width: 36px; height: 36px; border-radius: 10px;
    background: linear-gradient(135deg, #dc2626, #ef4444);
    color: #fff; display: flex; align-items: center; justify-content: center;
    font-size: 14px; flex-shrink: 0;
}

/* â”€â”€ Amount â”€â”€ */
.fraud-amount { font-size: 16px; font-weight: 800; color: #dc2626; }

/* â”€â”€ Print Btn â”€â”€ */
.btn-print {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 8px 18px; border-radius: 11px; font-size: 13px; font-weight: 700;
    background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.2);
    color: #fff; cursor: pointer; transition: all 0.2s; position: relative; z-index: 1;
    text-decoration: none;
}
.btn-print:hover { background: rgba(255,255,255,0.25); color: #fff; }

/* â”€â”€ Empty state â”€â”€ */
.fraud-empty { text-align: center; padding: 60px 40px; color: #9ca3af; }
.fraud-empty i { font-size: 3rem; display: block; margin-bottom: 12px; color: #22c55e; }
</style>
{% endblock %}

{% block body %}
<div class="fraud-hero">
    <div style="position:relative;z-index:1;">
        <h1><i class="bi bi-shield-exclamation me-2"></i>Audit des Fraudes &amp; Anomalies</h1>
        <p>Surveillance système des transactions à haut risque dépassant {{ threshold }} DT</p>
    </div>
    <button class="btn-print" onclick="window.print()">
        <i class="bi bi-printer"></i> Imprimer le Rapport
    </button>
</div>

{# Alert banner #}
{% if anomalies|length > 0 %}
<div class="fraud-alert-banner">
    <i class="bi bi-exclamation-triangle-fill fraud-alert-icon"></i>
    <div>
        <p class="fraud-alert-title">{{ anomalies|length }} Transactions Suspectes Détectées !</p>
        <p class="fraud-alert-sub">
            Le volume total d'argent impliqué est de <strong>{{ totalRiskyVolume|number_format(2, ',', ' ') }} DT</strong>.
        </p>
    </div>
</div>
{% endif %}

{# Table #}
<div class="fraud-table-card">
    <div class="fraud-table-header">
        <h6>
            <i class="bi bi-journal-text text-danger"></i>
            Logs d'Anomalies Financières
        </h6>
        <span style="font-size:12px;color:#9ca3af;font-weight:600;">{{ anomalies|length }} entrée{{ anomalies|length != 1 ? 's' : '' }}</span>
    </div>
    <div style="overflow-x:auto;">
        <table class="fraud-table">
            <thead>
                <tr>
                    <th>Utilisateur</th>
                    <th>Nom / Raison</th>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Statut</th>
                    <th style="text-align:right;">Montant (DT)</th>
                    <th style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for t in anomalies %}
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:10px;">
                                <div class="user-avatar-circle">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                                <span style="font-weight:700;color:#1e1b4b;">{{ userNames[t.userId] ?? 'Utilisateur ' ~ t.userId }}</span>
                            </div>
                        </td>
                        <td style="font-weight:600;color:#1e1b4b;">{{ t.nomTransaction }}</td>
                        <td style="color:#6b7280;">{{ t.dateTransaction|date('Y-m-d H:i') }}</td>
                        <td>
                            {% if t.type|lower == 'income' or t.type|lower == 'revenu' %}
                                <span style="display:inline-flex;align-items:center;gap:4px;padding:4px 11px;border-radius:20px;font-size:11px;font-weight:700;background:#dcfce7;color:#16a34a;">
                                    <i class="bi bi-arrow-up-right"></i> Revenu
                                </span>
                            {% else %}
                                <span style="display:inline-flex;align-items:center;gap:4px;padding:4px 11px;border-radius:20px;font-size:11px;font-weight:700;background:#fee2e2;color:#dc2626;">
                                    <i class="bi bi-arrow-down-right"></i> Dépense
                                </span>
                            {% endif %}
                        </td>
                        <td>
                            {% if t.status == 'PENDING' %}
                                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill"><i class="bi bi-clock-history me-1"></i> EN ATTENTE</span>
                            {% elseif t.status == 'ACCEPTED' %}
                                <span class="badge bg-success px-3 py-2 rounded-pill"><i class="bi bi-check-circle me-1"></i> ACCEPTÉ</span>
                            {% else %}
                                <span class="badge bg-danger px-3 py-2 rounded-pill"><i class="bi bi-x-circle me-1"></i> REJETÉ</span>
                            {% endif %}
                        </td>
                        <td style="text-align:right;" class="fraud-amount">
                            {{ t.montant|abs|number_format(2, ',', ' ') }}
                        </td>
                        <td style="text-align:right;">
                            <div class="btn-group">
                                <a href="{{ path('wallet_admin_approve', {id: t.id}) }}" class="btn btn-sm btn-success rounded-pill px-3 me-1">
                                    <i class="bi bi-check-lg"></i> Accepter
                                </a>
                                <a href="{{ path('wallet_admin_reject', {id: t.id}) }}" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                    <i class="bi bi-x-lg"></i> Rejeter
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7">
                            <div class="fraud-empty">
                                <i class="bi bi-shield-check"></i>
                                Aucune transaction en attente de validation. Le système est sécurisé.
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

