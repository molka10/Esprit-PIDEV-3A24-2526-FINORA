{% extends 'admin/base_admin.html.twig' %}

{% block title %}FINORA - Centres de Formation{% endblock %}

{% block admin_content %}
<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <span class="badge bg-primary bg-opacity-10 text-primary mb-2">Back Office</span>
            <h2 class="mb-0">Centres de formation</h2>
        </div>
        <a href="{{ path('admin_centres_new') }}" class="btn btn-primary shadow-sm rounded-pill px-4">
            <i class="fas fa-plus me-2"></i> Ajouter un centre
        </a>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show border-0 shadow-sm rounded-4" role="alert">
                <i class="fas fa-info-circle me-2"></i> {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background-color: #faf5ff;">
                    <tr>
                        <th class="ps-4">Nom du centre</th>
                        <th>Ville</th>
                        <th>Coordonnées</th>
                        <th>Statut</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    {% for centre in centres %}
                        <tr>
                            <td class="ps-4">
                                <p class="fw-bold mb-0">{{ centre.nom }}</p>
                                <small class="text-muted"><i class="fas fa-map-marker-alt text-primary opacity-75 me-1"></i> {{ centre.adresse }}</small>
                            </td>
                            <td><span class="badge bg-light text-dark border">{{ centre.ville }}</span></td>
                            <td>
                                <small class="text-muted d-block">Lat: {{ centre.latitude|number_format(4, '.', '') }}</small>
                                <small class="text-muted d-block">Lng: {{ centre.longitude|number_format(4, '.', '') }}</small>
                            </td>
                            <td>
                                {% if centre.isActive %}
                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3"><i class="fas fa-check-circle me-1"></i> Actif</span>
                                {% else %}
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3"><i class="fas fa-eye-slash me-1"></i> Masqué</span>
                                {% endif %}
                            </td>
                            <td class="text-end pe-4">
                                <a href="{{ path('admin_centres_edit', {'id': centre.id}) }}" class="btn btn-sm btn-light text-primary rounded-circle me-1" data-bs-toggle="tooltip" title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post" action="{{ path('admin_centres_delete', {'id': centre.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce centre ?');" style="display: inline-block">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_centre_' ~ centre.id) }}">
                                    <button class="btn btn-sm btn-light text-danger rounded-circle" data-bs-toggle="tooltip" title="Supprimer">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="text-muted">
                                    <i class="fas fa-map-marker-alt fa-3x mb-3 opacity-25"></i>
                                    <p class="mb-0">Aucun centre de formation n'a été ajouté.</p>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
