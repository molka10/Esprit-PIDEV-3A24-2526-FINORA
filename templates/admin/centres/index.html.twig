{% extends 'admin/base.html.twig' %}

{% block title %}Admin - Centres de Formation{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12 mb-4">
        <div class="d-sm-flex justify-content-between align-items-center">
            <h1 class="h3 mb-2 mb-sm-0">Gestion des Centres de Formation</h1>
            <a href="{{ path('admin_centres_new') }}" class="btn btn-primary mb-0">Ajouter un centre</a>
        </div>
    </div>
</div>

<div class="card bg-transparent border">
    <div class="card-body">
        <div class="table-responsive border-0">
            <table class="table table-dark-gradient align-middle p-4 mb-0 table-hover">
                <thead>
                    <tr>
                        <th scope="col" class="border-0 rounded-start">Nom du Centre</th>
                        <th scope="col" class="border-0">Ville</th>
                        <th scope="col" class="border-0">Contact</th>
                        <th scope="col" class="border-0">Status</th>
                        <th scope="col" class="border-0 rounded-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for centre in centres %}
                    <tr>
                        <td>
                            <h6 class="mb-0">{{ centre.nom }}</h6>
                            <span class="small text-muted">{{ centre.adresse }}</span>
                        </td>
                        <td>{{ centre.ville }}</td>
                        <td>
                            <div class="small">
                                <i class="bi bi-telephone me-1"></i>{{ centre.telephone|default('N/A') }}<br>
                                <i class="bi bi-envelope me-1"></i>{{ centre.email|default('N/A') }}
                            </div>
                        </td>
                        <td>
                            {% if centre.isActive %}
                                <span class="badge bg-success">Actif</span>
                            {% else %}
                                <span class="badge bg-secondary">Inactif</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="{{ path('admin_centres_edit', {id: centre.id}) }}" class="btn btn-success-soft btn-round mb-0"><i class="bi bi-pencil"></i></a>
                                <form method="post" action="{{ path('admin_centres_delete', {id: centre.id}) }}" onsubmit="return confirm('Supprimer ce centre ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_centre_' ~ centre.id) }}">
                                    <button class="btn btn-danger-soft btn-round mb-0"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="5" class="text-center">Aucun centre trouvé.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
