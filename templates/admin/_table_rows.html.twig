{% for u in users %}
<tr style="border-bottom: 1px solid rgba(124,58,237,0.05); transition: background 0.15s;">
    <td style="padding: 14px 16px;">
        <div style="display:flex;align-items:center;gap:10px;">
            <div style="
                width: 40px; height: 40px; border-radius: 12px; flex-shrink: 0;
                background: linear-gradient(135deg, #7c3aed, #8b5cf6);
                color: #fff; font-size: 15px; font-weight: 800;
                display: flex; align-items: center; justify-content: center;
                box-shadow: 0 4px 10px rgba(124,58,237,0.25);
            ">{{ u.name|first|upper }}</div>
            <div>
                <div style="font-weight:700;color:#1e1b4b;font-size:14px;">{{ u.name }}</div>
                <div style="font-size:11px;color:#9ca3af;">ID #{{ u.id }}</div>
            </div>
        </div>
    </td>

    <td style="padding: 14px 16px;">
        <span style="
            display:inline-flex;align-items:center;gap:4px;
            background:#ede9fe;color:#7c3aed;
            padding:4px 11px;border-radius:20px;
            font-size:11px;font-weight:700;
        ">
            <i class="bi bi-lightning-fill"></i> {{ u.count ?? 0 }}
        </span>
    </td>

    <td style="padding: 14px 16px; font-weight:700; color:#16a34a; font-size:14px;">
        +{{ (u.income ?? 0)|number_format(2, '.', ',') }}
    </td>

    <td style="padding: 14px 16px; font-weight:700; color:#dc2626; font-size:14px;">
        -{{ (u.outcome ?? 0)|number_format(2, '.', ',') }}
    </td>

    <td style="padding: 14px 16px;">
        <span style="
            font-weight:800; font-size:15px;
            color: {{ (u.balance ?? 0) >= 0 ? '#1d4ed8' : '#dc2626' }};
        ">
            {{ (u.balance ?? 0)|number_format(2, '.', ',') }}
        </span>
    </td>

    <td style="padding: 14px 16px;">
        <div style="display:flex;gap:6px;flex-wrap:wrap;">
            <a href="{{ path('user_transactions', {'id': u.id}) }}"
               style="display:inline-flex;align-items:center;gap:5px;padding:6px 12px;
                      border-radius:9px;font-size:12px;font-weight:700;text-decoration:none;
                      background:#ede9fe;color:#7c3aed;border:none;transition:all 0.15s;">
                <i class="bi bi-eye-fill"></i> Historique
            </a>

            <a href="{{ path('user_transactions_pdf', {'id': u.id}) }}"
               style="display:inline-flex;align-items:center;gap:5px;padding:6px 12px;
                      border-radius:9px;font-size:12px;font-weight:700;text-decoration:none;
                      background:#fee2e2;color:#dc2626;border:none;transition:all 0.15s;">
                <i class="bi bi-file-earmark-pdf-fill"></i> PDF
            </a>

            <button
                style="display:inline-flex;align-items:center;gap:5px;padding:6px 12px;
                       border-radius:9px;font-size:12px;font-weight:700;cursor:pointer;border:none;
                       background:linear-gradient(135deg,#7c3aed,#8b5cf6);color:#fff;
                       box-shadow:0 3px 10px rgba(124,58,237,0.28);transition:all 0.15s;"
                onclick="openUserCalendarModal({{ u.id }}, '{{ u.name }}')"
                title="Voir calendrier {{ u.name }}"
            >
                <i class="bi bi-calendar3"></i> Calendrier
            </button>
        </div>
    </td>
</tr>

{% else %}
<tr>
    <td colspan="6" style="padding: 60px; text-align:center;">
        <div style="display:flex;flex-direction:column;align-items:center;opacity:.6;">
            <i class="bi bi-people" style="font-size: 3rem; color: #a78bfa; margin-bottom:12px;"></i>
            <span style="font-weight:700;color:#6b7280;font-size:14px;">Aucun utilisateur trouvé.</span>
            <span style="color:#9ca3af;font-size:12px;margin-top:4px;">Essayez une autre recherche.</span>
        </div>
    </td>
</tr>
{% endfor %}