<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>{% block title %}Finora{% endblock %}</title>

    <!-- Dark mode script (Eduport style) -->
    <script>
        const storedTheme = localStorage.getItem('theme')
        const getPreferredTheme = () => storedTheme ? storedTheme : 'light'
        const setTheme = function (theme) {
            document.documentElement.setAttribute('data-bs-theme', theme === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : theme)
        }
        setTheme(getPreferredTheme())
    </script>

    <!-- Google Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap">

    <!-- Bootstrap -->
    <link rel="stylesheet" href="{{ asset('assets/vendor/bootstrap/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Custom style -->
    <link rel="stylesheet" href="{{ asset('assets/css/style.css') }}">

    <style>
        /* ===== EDUPORT BASE STYLES ===== */
        :root {
            --bs-primary: #0d6efd;
            --edu-orange: #fd7e14;
            --edu-dark: #1a1f2e;
        }

        body {
            font-family: 'Roboto', sans-serif;
            background-color: #f8f9fa;
        }

        /* ===== HEADER / NAVBAR ===== */
        .eduport-header {
            background: #fff;
            box-shadow: 0 2px 12px rgba(0,0,0,.07);
            position: sticky;
            top: 0;
            z-index: 1030;
        }

        .eduport-nav-top {
            padding: 0;
        }

        .eduport-nav-top .container {
            display: flex;
            align-items: center;
            gap: 16px;
            padding-top: 10px;
            padding-bottom: 10px;
        }

        .eduport-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            font-family: 'Heebo', sans-serif;
            font-weight: 700;
            font-size: 1.5rem;
            color: var(--edu-dark);
            flex-shrink: 0;
        }

        .eduport-brand .brand-icon {
            width: 38px;
            height: 38px;
            background: linear-gradient(135deg, #0d6efd, #0a58ca);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 1.1rem;
        }

        .eduport-brand span {
            background: linear-gradient(135deg, #0d6efd, #6610f2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Search bar */
        .edu-search {
            flex: 1;
            max-width: 420px;
        }

        .edu-search .input-group {
            border: 1.5px solid #e0e4ef;
            border-radius: 50px;
            overflow: hidden;
            background: #f5f7fb;
        }

        .edu-search input {
            border: none;
            background: transparent;
            padding: 8px 16px;
            font-size: .9rem;
        }

        .edu-search input:focus {
            box-shadow: none;
            outline: none;
        }

        .edu-search .search-btn {
            background: transparent;
            border: none;
            padding: 0 14px;
            color: #0d6efd;
        }

        /* Nav actions */
        .edu-nav-actions {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-left: auto;
        }

        .edu-icon-btn {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: #f1f3f8;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #444;
            font-size: 1rem;
            text-decoration: none;
            transition: background .2s;
        }

        .edu-icon-btn:hover {
            background: #e0e4ef;
            color: #0d6efd;
        }

        /* Notification badge */
        .edu-notif-wrap {
            position: relative;
        }

        .edu-notif-dot {
            position: absolute;
            top: 4px;
            right: 4px;
            width: 8px;
            height: 8px;
            background: #dc3545;
            border-radius: 50%;
            border: 1.5px solid #fff;
        }

        /* Avatar */
        .edu-avatar {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: linear-gradient(135deg, #0d6efd, #6610f2);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 700;
            font-size: .9rem;
            cursor: pointer;
            text-decoration: none;
        }

        /* Dropdown */
        .edu-dropdown {
            position: relative;
        }

        .edu-dropdown-menu {
            display: none;
            position: absolute;
            right: 0;
            top: calc(100% + 10px);
            min-width: 220px;
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 8px 30px rgba(0,0,0,.12);
            padding: 12px 0;
            z-index: 999;
        }

        .edu-dropdown:hover .edu-dropdown-menu,
        .edu-dropdown.open .edu-dropdown-menu {
            display: block;
        }

        .edu-dropdown-menu a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 18px;
            color: #333;
            text-decoration: none;
            font-size: .88rem;
            transition: background .15s;
        }

        .edu-dropdown-menu a:hover {
            background: #f5f7fb;
            color: #0d6efd;
        }

        .edu-dropdown-divider {
            border: none;
            border-top: 1px solid #f0f0f0;
            margin: 6px 0;
        }

        /* ===== CATEGORY NAV ===== */
        .edu-cat-nav {
            background: #fff;
            border-top: 1px solid #f0f2f5;
        }

        .edu-cat-nav .container {
            display: flex;
            gap: 0;
            overflow-x: auto;
            scrollbar-width: none;
        }

        .edu-cat-nav .container::-webkit-scrollbar {
            display: none;
        }

        .edu-cat-link {
            white-space: nowrap;
            padding: 10px 18px;
            color: #555;
            text-decoration: none;
            font-size: .88rem;
            font-weight: 500;
            border-bottom: 2px solid transparent;
            transition: all .2s;
        }

        .edu-cat-link:hover,
        .edu-cat-link.active {
            color: #0d6efd;
            border-bottom-color: #0d6efd;
        }

        /* ===== MAIN CONTENT ===== */
        .edu-main {
            min-height: calc(100vh - 200px);
            padding: 30px 0 50px;
        }

        /* ===== FOOTER ===== */
        .edu-footer {
            background: var(--edu-dark);
            color: #9aa0b0;
            padding: 50px 0 0;
        }

        .edu-footer h5 {
            color: #fff;
            font-family: 'Heebo', sans-serif;
            font-weight: 600;
            margin-bottom: 18px;
            font-size: 1rem;
        }

        .edu-footer-brand p {
            font-size: .88rem;
            line-height: 1.7;
            max-width: 240px;
        }

        .edu-footer-links {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .edu-footer-links li {
            margin-bottom: 8px;
        }

        .edu-footer-links a {
            color: #9aa0b0;
            text-decoration: none;
            font-size: .88rem;
            transition: color .2s;
        }

        .edu-footer-links a:hover {
            color: #fff;
        }

        .edu-footer-social {
            display: flex;
            gap: 8px;
            margin-top: 16px;
        }

        .edu-social-btn {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            background: rgba(255,255,255,.08);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ccc;
            text-decoration: none;
            font-size: .85rem;
            transition: background .2s, color .2s;
        }

        .edu-social-btn:hover {
            background: #0d6efd;
            color: #fff;
        }

        .edu-footer-bottom {
            border-top: 1px solid rgba(255,255,255,.08);
            padding: 18px 0;
            margin-top: 40px;
        }

        .edu-footer-bottom .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 10px;
        }

        .edu-footer-bottom span,
        .edu-footer-bottom a {
            font-size: .82rem;
            color: #6c757d;
        }

        .edu-footer-bottom a {
            text-decoration: none;
            margin-left: 16px;
        }

        .edu-footer-bottom a:hover {
            color: #fff;
        }

        /* ===== CONTACT INFO ===== */
        .edu-contact-item {
            font-size: .88rem;
            margin-bottom: 8px;
        }

        .edu-contact-item strong {
            color: #fff;
        }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            .edu-search {
                display: none;
            }

            .eduport-brand span {
                display: none;
            }
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>

<body>

<!-- ===== HEADER START ===== -->
<header class="eduport-header">

    <!-- Top nav -->
    <nav class="eduport-nav-top">
        <div class="container">

            <!-- Logo -->
            <a class="eduport-brand" href="{{ path('dashboard') }}">
                <div class="brand-icon">
