                </a>

                <!-- Notification -->
                <div class="edu-notif-wrap">
                    <a href="#" class="edu-icon-btn" title="Notifications">
                        <i class="bi bi-bell"></i>
                    </a>
                    <span class="edu-notif-dot"></span>
                </div>

                <!-- Profile dropdown -->
                <div class="edu-dropdown">
                    <a class="edu-avatar" href="#">F</a>

                    <div class="edu-dropdown-menu">
                        <a href="{{ path('dashboard') }}">
                            <i class="bi bi-grid"></i> Dashboard
                        </a>
                        <hr class="edu-dropdown-divider">
                        <a href="{{ path('app_admin') }}">
                            <i class="bi bi-shield-check"></i> Admin
                        </a>
                        <a href="#">
                            <i class="bi bi-person"></i> Mon compte
                        </a>
                        <a href="#">
                            <i class="bi bi-gear"></i> Paramètres
                        </a>
                        <hr class="edu-dropdown-divider">
                        <a href="#" style="color:#dc3545;">
                            <i class="bi bi-power"></i> Déconnexion
                        </a>
