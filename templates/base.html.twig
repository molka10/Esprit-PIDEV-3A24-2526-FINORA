<script>
document.addEventListener('DOMContentLoaded', function() {
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            (function() {
                const msg = `{{ message|raw }}`;
                const label = `{{ label }}`;
                
                if (msg.includes('Solde insuffisant') || msg.includes('portefeuille')) {
                    Swal.fire({
                        title: '<strong>Solde Insuffisant</strong>',
                        icon: 'warning',
                        html: msg,
                        showCloseButton: true,
                        showCancelButton: true,
                        focusConfirm: false,
                        confirmButtonText: '<i class="bi bi-wallet2"></i> Recharger mon Wallet',
                        confirmButtonColor: '#7c3aed',
                        cancelButtonText: 'Fermer',
                        background: '#fff',
                        customClass: {
                            popup: 'animated fadeInDown'
                        }
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = "{{ path('dashboard') }}";
                        }
                    });
                } 
                else if (label === 'success') {
                    Swal.fire({
                        title: 'Succès !',
                        text: msg.replace(/<[^>]*>?/gm, ''),
                        icon: 'success',
                        timer: 3000,
                        showConfirmButton: false,
                        toast: true,
                        position: 'top-end'
                    });
                }
                else if (label === 'danger' || label === 'error') {
                   Swal.fire({
                        title: 'Attention',
                        html: msg,
                        icon: 'error',
                        confirmButtonColor: '#7c3aed'
                    });
                }
                else if (label === 'success') {
                   Swal.fire({
                        title: 'Succès',
                        html: msg,
                        icon: 'success',
                        confirmButtonColor: '#7c3aed'
                    });
                }
            })();
        {% endfor %}
    {% endfor %}
});
</script>


<!-- Unified Notification Bell JS -->
{% if app.user %}
<script>
(function() {
    function loadNotifications() {
        // Fetch from both APIs
        const boursePromise = fetch('/api/bourse/notifications', { headers: { 'X-Requested-With': 'XMLHttpRequest' } }).then(r => r.json()).catch(() => ({count:0, notifications:[]}));
        const investPromise = fetch('/api/investment/notifications', { headers: { 'X-Requested-With': 'XMLHttpRequest' } }).then(r => r.json()).catch(() => ({count:0, notifications:[]}));

        Promise.all([boursePromise, investPromise]).then(([bourseData, investData]) => {
            const badge   = document.getElementById('notifBadge');
            const countEl = document.getElementById('notifCount');
            const list    = document.getElementById('notifList');
            const emptyEl = document.getElementById('notifEmpty');
            if (!badge || !list) return;

            const totalUnread = (bourseData.count || 0) + (investData.count || 0);
            badge.textContent = totalUnread > 9 ? '9+' : totalUnread;
            badge.style.display = totalUnread > 0 ? '' : 'none';

            if (countEl) {
                countEl.textContent = totalUnread > 0 ? totalUnread + ' non lues' : 'À jour';
                countEl.className = totalUnread > 0
                    ? 'badge bg-danger bg-opacity-10 text-danger'
                    : 'badge bg-success bg-opacity-10 text-success';
            }

            // Merge and sort by time (approximate since we don't have absolute timestamps in the API JSON yet, 
            // but we can assume order of fetch if they were sorted on server)
            const allNotifs = [
                ...(bourseData.notifications || []).map(n => ({...n, module: 'bourse'})),
                ...(investData.notifications || []).map(n => ({...n, module: 'invest'}))
            ];

            // Clean list (keep empty placeholder if needed)
            list.querySelectorAll('.notif-item').forEach(el => el.remove());

            if (allNotifs.length === 0) {
                if (emptyEl) emptyEl.style.display = '';
                return;
            }
            if (emptyEl) emptyEl.style.display = 'none';

            allNotifs.forEach(n => {
                const bg = n.isRead ? '' : 'style="background:rgba(124,58,237,0.04);"';
                const dot = !n.isRead ? '<span class="ms-2 mt-1 flex-shrink-0"><span style="width:7px;height:7px;background:#7c3aed;border-radius:50%;display:inline-block;"></span></span>' : '';
                const sym = n.symbol ? ` · <span class="badge bg-secondary bg-opacity-10 text-secondary fw-bold" style="font-size:10px;">${n.symbol}</span>` : '';
                const link = n.module === 'invest' ? `/investments/${n.investmentId}` : '#';
                
                list.insertAdjacentHTML('beforeend', `
                <li class="notif-item">
                    <a href="${link}" class="list-group-item-action border-0 border-bottom d-flex p-3 text-decoration-none" ${bg}>
                        <div class="me-3 mt-1"><i class="${n.icon} fs-5"></i></div>
                        <div class="flex-grow-1 overflow-hidden">
                            <h6 class="mb-1 fw-semibold text-dark" style="font-size:13px;">${n.titre}</h6>
                            <p class="small text-muted m-0" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${n.message}</p>
                            <small class="text-muted" style="font-size:11px;">${n.timeAgo}${sym}</small>
                        </div>${dot}
                    </a>
                </li>`);
            });
        });
    }

    window.markAllNotifsRead = function() {
        // Call both "read" endpoints
        fetch('/api/bourse/notifications/read', { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        fetch('/api/investment/notifications/read', { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        
        const badge = document.getElementById('notifBadge');
        if (badge) badge.style.display = 'none';
        const countEl = document.getElementById('notifCount');
        if (countEl) { countEl.textContent = 'À jour'; countEl.className = 'badge bg-success bg-opacity-10 text-success'; }
    };

    document.addEventListener('DOMContentLoaded', function() {
        loadNotifications();
        setInterval(loadNotifications, 30000);
    });
})();
</script>
{% endif %}

</body>
</html>
