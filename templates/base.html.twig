                            <li><a class="dropdown-item py-2 fw-semibold" href="{{ path('app_lessons') }}"><i class="fas fa-book-open me-2" style="color:var(--finora-purple);"></i>Toutes les Leçons</a></li>
                            <li><a class="dropdown-item py-2 fw-semibold" href="{{ path('app_my_certificates') }}"><i class="fas fa-certificate me-2" style="color:var(--finora-purple);"></i>Mes Certificats</a></li>
                             <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item py-2 fw-semibold text-primary" href="{{ path('public_centres_map') }}"><i class="fas fa-map-marker-alt me-2"></i>Centres de Formations</a></li>
                        </ul>
                    </li>

                    <li class="nav-item ms-lg-3"><a class="btn btn-primary d-none d-xl-block" style="padding: 8px 20px; border-radius: 99px;" href="{{ path('admin_dashboard') }}">Admin</a></li>
                    <li class="nav-item d-xl-none mt-2"><a class="nav-link fw-bold text-primary" href="{{ path('admin_dashboard') }}">Admin</a></li>
