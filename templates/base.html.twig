            <ul class="dropdown-menu shadow-lg border-0 mb-3" aria-labelledby="floatingCurrencyBtn" style="border-radius: 15px; min-width: 200px;">
                <li><span class="dropdown-item-text small text-muted text-uppercase fw-bold pb-2 border-bottom mb-2 text-center d-block">Devise de la plateforme</span></li>
                <li><a class="dropdown-item py-2 d-flex align-items-center {{ app.session.get('currency', 'TND') == 'TND' ? 'bg-light fw-bold' : '' }}" href="{{ path('app_switch_currency', {currency: 'TND'}) }}">
                    <span class="me-2">🇹🇳</span> TND (Dinar Tunisien)
                </a></li>
                <li><a class="dropdown-item py-2 d-flex align-items-center {{ app.session.get('currency') == 'EUR' ? 'bg-light fw-bold' : '' }}" href="{{ path('app_switch_currency', {currency: 'EUR'}) }}">
