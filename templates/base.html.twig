}

.dash-card:hover {
    transform: translateY(-5px);
}

/* BIG CARD */
.dash-card.big {
    grid-column: span 2;
}

/* TEXT */
.dash-card span {
    display: block;
    color: #636e72;
    margin-bottom: 10px;
}

.dash-card h2 {
    font-size: 28px;
