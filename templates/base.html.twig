<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}FINORA{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <script>
        const storedTheme = localStorage.getItem('theme');

        const getPreferredTheme = () => {
            if (storedTheme) {
                return storedTheme;
            }
            return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'light';
        };

        const setTheme = function (theme) {
            if (theme === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-bs-theme', 'dark');
            } else {
                document.documentElement.setAttribute('data-bs-theme', theme);
            }
        };

        setTheme(getPreferredTheme());

        window.addEventListener('DOMContentLoaded', () => {
            const el = document.querySelector('.theme-icon-active');
            if (el !== undefined && el !== null) {
                const showActiveTheme = theme => {
                    const activeThemeIcon = document.querySelector('.theme-icon-active use');
                    const btnToActive = document.querySelector(`[data-bs-theme-value="${theme}"]`);
                    if (!btnToActive || !activeThemeIcon) return;

                    const svgOfActiveBtn = btnToActive.querySelector('.mode-switch use')?.getAttribute('href');

                    document.querySelectorAll('[data-bs-theme-value]').forEach(element => {
                        element.classList.remove('active');
                    });

                    btnToActive.classList.add('active');
                    if (svgOfActiveBtn) {
                        activeThemeIcon.setAttribute('href', svgOfActiveBtn);
                    }
                };

                window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
                    if (storedTheme !== 'light' || storedTheme !== 'dark') {
                        setTheme(getPreferredTheme());
                    }
                });

                showActiveTheme(getPreferredTheme());

                document.querySelectorAll('[data-bs-theme-value]').forEach(toggle => {
                    toggle.addEventListener('click', () => {
                        const theme = toggle.getAttribute('data-bs-theme-value');
                        localStorage.setItem('theme', theme);
                        setTheme(theme);
                        showActiveTheme(theme);
                    });
                });
            }
        });
    </script>

    <link rel="shortcut icon" href="{{ asset('assets/images/favicon.ico') }}">

    <link rel="preconnect" href="https://fonts.googleapis.com/">
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap">

    {% block stylesheets %}
        <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/font-awesome/css/all.min.css') }}">
        <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}">
        <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/tiny-slider/tiny-slider.css') }}">
        <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/glightbox/css/glightbox.css') }}">
        <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/aos/aos.css') }}">
        <link rel="stylesheet" type="text/css" href="{{ asset('assets/css/style.css') }}">

        <style>
            :root{
                --finora-purple:#7c3aed;
                --finora-purple-dark:#5b21b6;
                --finora-purple-soft:#f3e8ff;
                --finora-lavender:#faf5ff;
                --finora-border:#eadcff;
                --finora-text:#24103d;
            }

            body{
                background: linear-gradient(180deg, #fcfaff 0%, #f8f4ff 100%);
                color: var(--finora-text);
            }

            .navbar-light{
                background: rgba(255,255,255,0.92);
                backdrop-filter: blur(10px);
            }

            .navbar .nav-link{
                font-weight: 600;
                color: #5b4b73 !important;
                transition: 0.2s ease;
            }

            .navbar .nav-link:hover,
            .navbar .nav-link.active{
                color: var(--finora-purple) !important;
            }

            @media (min-width: 992px) {
                .navbar .nav-item.dropdown:hover .dropdown-menu {
                    display: block;
                    animation: fadeDown 0.2s ease-out forwards;
                }
            }

            @keyframes fadeDown {
                from { opacity: 0; transform: translateY(-10px); }
                to { opacity: 1; transform: translateY(0); }
            }

            .btn-primary{
                background: linear-gradient(135deg, var(--finora-purple) 0%, #9333ea 100%);
                border: none;
                box-shadow: 0 8px 20px rgba(124, 58, 237, 0.22);
            }

            .btn-primary:hover{
                background: linear-gradient(135deg, var(--finora-purple-dark) 0%, #7e22ce 100%);
            }

            .btn-outline-primary{
                border-color: var(--finora-purple);
                color: var(--finora-purple);
            }

            .btn-outline-primary:hover{
                background: var(--finora-purple);
                border-color: var(--finora-purple);
            }

            .badge.bg-primary,
            .bg-primary{
                background-color: var(--finora-purple) !important;
            }

            .text-primary{
                color: var(--finora-purple) !important;
            }

            .bg-primary.bg-opacity-10,
            .badge.bg-primary.bg-opacity-10{
                background-color: var(--finora-purple-soft) !important;
                color: var(--finora-purple) !important;
            }

            .card{
                border-radius: 18px !important;
                border: 1px solid var(--finora-border) !important;
                box-shadow: 0 10px 30px rgba(89, 30, 130, 0.08) !important;
            }

            .card-img-top{
                border-top-left-radius: 18px;
                border-top-right-radius: 18px;
            }

            .nav-category{
                background: transparent;
            }

            .nav-category .nav-link{
                background: white;
                border: 1px solid var(--finora-border);
                border-radius: 999px;
                margin: 0 4px;
                padding: 8px 14px !important;
            }

            .nav-category .nav-link:hover{
                background: var(--finora-purple-soft);
            }

            .form-control,
            .form-select{
                border-radius: 12px !important;
                border: 1px solid #e9d5ff !important;
                box-shadow: none !important;
            }

            .form-control:focus,
            .form-select:focus{
                border-color: var(--finora-purple) !important;
                box-shadow: 0 0 0 0.2rem rgba(124,58,237,.15) !important;
            }

            .shadow-sm{
                box-shadow: 0 10px 28px rgba(76, 29, 149, 0.08) !important;
            }

            .purple-chip{
                background: var(--finora-purple-soft);
                color: var(--finora-purple);
                border-radius: 999px;
                padding: 6px 12px;
                font-size: 12px;
                font-weight: 700;
            }

            .purple-section{
                background: linear-gradient(135deg, #faf5ff 0%, #f3e8ff 100%);
                border: 1px solid var(--finora-border);
                border-radius: 24px;
            }

            .finora-title{
                color: var(--finora-text);
            }

            /* Udemy Style Cards */
            .udemy-card {
                background: #fff;
                border: 1px solid #d1d7dc; /* subtle gray border */
                border-radius: 0; /* square edges like udemy or maybe slightly rounded */
                transition: transform 0.2s, box-shadow 0.2s;
                overflow: hidden;
                display: flex;
                flex-direction: column;
            }
            .udemy-card:hover {
                box-shadow: 0 10px 20px rgba(0,0,0,0.08); /* no upward transform */
                border-color: #d1d7dc;
            }
            .udemy-card .card-img-top {
                border-radius: 0;
                height: 160px;
                object-fit: cover;
                width: 100%;
            }
            .udemy-card-body {
                padding: 16px;
                display: flex;
                flex-direction: column;
                flex-grow: 1;
            }
            .udemy-card-title {
                font-size: 16px;
                font-weight: 700;
                color: #1c1d1f;
                line-height: 1.2;
                margin-bottom: 4px;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }
            .udemy-instructor {
                font-size: 12px;
                color: #6a6f73;
                margin-bottom: 4px;
            }
            .udemy-rating {
                display: flex;
                align-items: center;
                gap: 4px;
                font-size: 14px;
                margin-bottom: 8px;
            }
            .udemy-rating-num {
                font-weight: 700;
                color: #b4690e;
            }
            .udemy-stars {
                color: #e59819;
                font-size: 12px;
            }
            .udemy-reviews {
                color: #6a6f73;
                font-size: 12px;
            }
            .udemy-price {
                font-size: 16px;
                font-weight: 700;
                color: #1c1d1f;
                margin-bottom: 8px;
            }
            .udemy-tags {
                margin-bottom: 8px;
            }
            .udemy-tag {
                background: #eceff1;
                color: #1c1d1f;
                font-size: 12px;
                font-weight: 700;
                padding: 4px 8px;
            }
        </style>
    {% endblock %}
</head>
<body>

<header class="navbar-light navbar-sticky" style="box-shadow: 0 4px 25px rgba(109, 40, 217, 0.05); position: sticky; top: 0; z-index: 1020;">
    <nav class="navbar navbar-expand-xl z-index-9">
