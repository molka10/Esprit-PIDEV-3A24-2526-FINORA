<!DOCTYPE html>
<html lang="en">
<head>
	<title>{% block title %}FINORA - Gestion Financière & Investissement{% endblock %}</title>

	<!-- Meta Tags -->
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
	<meta name="author" content="Finora">
	<meta name="description" content="FINORA - Plateforme unifiée de gestion d'investissements et de formations financières.">

	<!-- Dark mode -->
	<script>
		const storedTheme = localStorage.getItem('theme')
 
		const getPreferredTheme = () => {
			if (storedTheme) {
				return storedTheme
			}
			return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'light'
		}

		const setTheme = function (theme) {
			if (theme === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches) {
				document.documentElement.setAttribute('data-bs-theme', 'dark')
			} else {
				document.documentElement.setAttribute('data-bs-theme', theme)
			}
		}

		setTheme(getPreferredTheme())

		window.addEventListener('DOMContentLoaded', () => {
		    var el = document.querySelector('.theme-icon-active');
			if(el != 'undefined' && el != null) {
				const showActiveTheme = theme => {
				const activeThemeIcon = document.querySelector('.theme-icon-active use')
				const btnToActive = document.querySelector(`[data-bs-theme-value="${theme}"]`)
				const svgOfActiveBtn = btnToActive.querySelector('.mode-switch use').getAttribute('href')

				document.querySelectorAll('[data-bs-theme-value]').forEach(element => {
					element.classList.remove('active')
				})

				btnToActive.classList.add('active')
				activeThemeIcon.setAttribute('href', svgOfActiveBtn)
			}

			window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
				if (storedTheme !== 'light' || storedTheme !== 'dark') {
					setTheme(getPreferredTheme())
				}
			})

			showActiveTheme(getPreferredTheme())

			document.querySelectorAll('[data-bs-theme-value]')
				.forEach(toggle => {
					toggle.addEventListener('click', () => {
						const theme = toggle.getAttribute('data-bs-theme-value')
						localStorage.setItem('theme', theme)
						setTheme(theme)
						showActiveTheme(theme)
					})
				})

			}
		})
		
	</script>

	<!-- Favicon -->
	<link rel="shortcut icon" href="{{ asset('assets/images/favicon.ico') }}">

	<!-- Google Font -->
	<link rel="preconnect" href="https://fonts.googleapis.com/">
	<link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin>
	<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;700&amp;family=Roboto:wght@400;500;700&amp;display=swap">

	<!-- Plugins CSS -->
	<link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/font-awesome/css/all.min.css') }}">
	<link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}">
	<link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/tiny-slider/tiny-slider.css') }}">
	<link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/glightbox/css/glightbox.css') }}">
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/aos/aos.css') }}">

	<!-- Theme CSS -->
	<link rel="stylesheet" type="text/css" href="{{ asset('assets/css/style.css') }}">

    <style>
        :root {
            --finora-purple: #7c3aed;
            --finora-dark: #1e1b4b;
            --finora-gradient: linear-gradient(135deg, #7c3aed 0%, #3b1278 100%);
        }
        .btn-primary { background: var(--finora-gradient); border: none; }
        .btn-primary:hover { background: linear-gradient(135deg, #6d28d9 0%, #2e1065 100%); transform: translateY(-1px); transition: all 0.2s; }
        .nav-category .nav-link:hover { color: var(--finora-purple) !important; }
        .card-hover:hover { transform: translateY(-5px); transition: all 0.3s ease; box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important; }
        .bg-primary-soft { background-color: rgba(124, 58, 237, 0.1) !important; }
        .text-primary { color: var(--finora-purple) !important; }

        /* Dropdown hover for desktop */
        @media (min-width: 992px) {
            .navbar .nav-item.dropdown:hover .dropdown-menu {
                display: block;
                animation: fadeDown 0.2s ease-out forwards;
            }
        }
        /* --- Header & Module Navigation --- */
        .nav-link-module {
            color: #4b5563 !important;
            font-size: 0.8rem !important;
            letter-spacing: 0.05rem;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
        }
        .nav-link-module:hover {
            color: #7c3aed !important;
            transform: translateY(-1px);
        }
        .nav-link-module i {
            font-size: 1.1rem;
            opacity: 0.8;
        }
        .header-search-input {
            background: #f1f5f9 !important;
            border: 1px solid transparent !important;
            transition: all 0.2s ease;
        }
        .header-search-input:focus {
            background: #fff !important;
            border-color: #7c3aed !important;
            box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1) !important;
        }
        body.no-sidebar .header-search-container {
            display: none !important;
        }
        .btn-round-light {
            background: #f1f5f9;
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            transition: all 0.2s ease;
        }
        .btn-round-light:hover {
            background: #e2e8f0;
            color: #7c3aed;
        }

        /* --- Layout & Utilities --- */
        body {
            padding-top: 140px; /* Adjusted for two-row header */
            background: #f8fafc;
            overflow-x: hidden;
            scroll-behavior: smooth;
        }
        /* Constrain containers on ultra-wide screens */
        @media (min-width: 1400px) {
            .container {
                max-width: 1240px !important;
            }
            .container-fluid {
                max-width: 1600px !important;
                margin-left: auto !important;
                margin-right: auto !important;
            }
        }
        .dropdown-item {
            padding: 0.5rem 1.5rem !important;
            font-size: 0.85rem !important;
            font-weight: 500 !important;
            color: #475569 !important;
            transition: all 0.2s ease;
            position: relative;
            line-height: 1.5 !important;
        }
        .dropdown-item:hover {
            background-color: rgba(124, 58, 237, 0.08) !important;
            color: var(--finora-purple) !important;
            padding-left: 1.75rem !important;
        }
        .dropdown-item::before {
            content: "";
            position: absolute;
            left: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            width: 4px;
            height: 4px;
            border-radius: 50%;
            background-color: var(--finora-purple);
            opacity: 0;
            transition: all 0.2s ease;
        }
        .dropdown-item:hover::before {
            opacity: 1;
        }
        .dropdown-item i {
            display: none !important;
        }
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

        .btn-round {
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            padding: 0 !important;
        }
        .text-gradient {
            background: linear-gradient(135deg, #7c3aed 0%, #3b1278 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .pro-hero {
            background: linear-gradient(rgba(30, 27, 75, 0.85), rgba(30, 27, 75, 0.75)), url('{{ asset('assets/images/finora_hero_bg.png') }}');
            background-size: cover;
            background-position: center;
            min-height: 85vh;
            display: flex;
            align-items: center;
            position: relative;
            z-index: 1;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 20px;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .glass-card:hover {
            transform: translateY(-8px);
            background: rgba(255, 255, 255, 0.9);
            border-color: var(--finora-purple);
            box-shadow: 0 20px 40px rgba(124, 58, 237, 0.15);
        }
        
        /* Premium Buttons */
        .btn-premium {
            background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%);
            color: white;
            border: none;
            box-shadow: 0 4px 15px rgba(124, 58, 237, 0.3);
            transition: all 0.3s ease;
        }
        .btn-premium:hover {
            transform: scale(1.03);
            box-shadow: 0 8px 25px rgba(124, 58, 237, 0.4);
            color: white;
        }
        .explore-icon {
            width: 70px;
            height: 70px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 20px;
            margin-bottom: 1.5rem;
            font-size: 2rem;
            background: rgba(124, 58, 237, 0.15);
            color: #a78bfa;
        }
        .animate-float {
            animation: float 6s ease-in-out infinite;
        }
        @keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
            100% { transform: translateY(0px); }
        }
        .btn-premium {
            background: white;
            color: var(--finora-purple);
            border: none;
            padding: 1rem 2.5rem;
            font-weight: 700;
            border-radius: 50px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
        }
        .btn-premium:hover {
            transform: scale(1.05) translateY(-2px);
            background: #f3f4f6;
            box-shadow: 0 15px 30px rgba(124, 58, 237, 0.3);
        }
    	/* Global Anchor Fix for Sticky Navbars */
	[id] {
		scroll-margin-top: 160px; /* Offset for dual navbars */
	}

    /* Sidebar Variables */
    :root {
        --sidebar-width: 260px; /* Slightly narrower for better fit */
        --sidebar-bg: rgba(255, 255, 255, 0.9);
        --sidebar-blur: 25px;
        --sidebar-transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    [data-bs-theme='dark'] {
        --sidebar-bg: rgba(15, 23, 42, 0.85);
    }

    /* Sidebar Structure */
    .sidebar-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        height: 100vh;
        width: var(--sidebar-width);
        background: var(--sidebar-bg);
        backdrop-filter: blur(var(--sidebar-blur));
        -webkit-backdrop-filter: blur(var(--sidebar-blur));
        z-index: 2000;
        transform: translateX(-105%); /* Ensure it's fully hidden */
        transition: var(--sidebar-transition);
        border-right: 1px solid rgba(124, 58, 237, 0.1);
        display: flex;
        flex-direction: column;
        box-shadow: 20px 0 60px rgba(0, 0, 0, 0.1);
    }

    body.sidebar-open .sidebar-wrapper {
        transform: translateX(0);
    }

    .sidebar-header {
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(124, 58, 237, 0.03);
    }

    .sidebar-content {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    /* Sidebar Nav Links */
    .sidebar-nav-link {
        display: flex;
        align-items: center;
        padding: 0.85rem 1.25rem;
        margin-bottom: 0.4rem;
        border-radius: 14px;
        color: inherit;
        text-decoration: none;
        font-weight: 500;
        transition: all 0.25s ease;
        gap: 15px;
        font-size: 0.95rem;
    }

    .sidebar-nav-link i {
        font-size: 1.3rem;
        color: var(--finora-purple);
        opacity: 0.85;
    }

    .sidebar-nav-link:hover {
        background: rgba(124, 58, 237, 0.08);
        color: var(--finora-purple);
        transform: translateX(8px);
    }

    .sidebar-nav-link.active {
        background: var(--finora-gradient);
        color: white !important;
        box-shadow: 0 4px 15px rgba(124, 58, 237, 0.3);
    }
    .sidebar-nav-link.active i { color: white; opacity: 1; }

    /* Accordion Customization */
    .sidebar-content .collapse {
        transition: all 0.3s ease;
    }

    /* Overlay */
    .sidebar-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.3);
        backdrop-filter: blur(4px);
        z-index: 1999;
        opacity: 0;
        visibility: hidden;
        transition: var(--sidebar-transition);
    }

    body.sidebar-open .sidebar-overlay {
        opacity: 1;
        visibility: visible;
    }

    /* Desktop Push Logic */
    @media (min-width: 1200px) {
        body.sidebar-open:not(.no-sidebar) {
            padding-left: var(--sidebar-width);
            transition: padding-left 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }
        body.sidebar-open:not(.no-sidebar) .fixed-top {
            width: calc(100% - var(--sidebar-width));
            left: var(--sidebar-width);
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }
        /* When open, remove overlay on desktop for 'dont block view' */
        body.sidebar-open:not(.no-sidebar) .sidebar-overlay {
            display: none;
        }
    }
    
    /* Strictly contain the width for a premium centered look */
    .container {
        max-width: 1240px !important; 
        margin-left: auto !important;
        margin-right: auto !important;
    }
    
    /* Animation Tokens */
    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-in {
        animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .sidebar-toggle-btn {
        background: rgba(124, 58, 237, 0.05);
        border: 1px solid rgba(124, 58, 237, 0.1);
        font-size: 1.4rem;
        padding: 0.5rem;
        margin-right: 1.25rem;
        border-radius: 12px;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        color: var(--finora-purple);
    }

    .sidebar-toggle-btn:hover {
        background: rgba(124, 58, 237, 0.15);
        transform: scale(1.05);
    }
</style>

