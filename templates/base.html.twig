<!DOCTYPE html>

<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}FINORA{% endblock %}</title>

```
<!-- Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<!-- Eduport CSS -->
<link rel="stylesheet" href="{{ asset('assets/css/style.css') }}">
<link rel="stylesheet" href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}">
<link rel="stylesheet" href="{{ asset('assets/vendor/apexcharts/css/apexcharts.css') }}">
```

</head>

<body>

<main>

<!-- SIDEBAR -->

<nav class="navbar sidebar navbar-expand-xl navbar-dark bg-dark">
    <div class="d-flex align-items-center p-3">
        <a class="navbar-brand text-white" href="{{ path('app_home') }}">
            💰 FINORA
        </a>
    </div>

```
<div class="offcanvas offcanvas-start flex-row h-100 show">
    <div class="offcanvas-body d-flex flex-column bg-dark">

        <ul class="navbar-nav flex-column">

            <li class="nav-item">
                <a class="nav-link {{ app.request.get('_route') == 'app_home' ? 'active' : '' }}" href="{{ path('app_home') }}">
                    <i class="bi bi-house me-2"></i> Dashboard
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="{{ path('app_bourse_index') }}">
                    <i class="fas fa-chart-bar me-2"></i> Bourses
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="{{ path('app_action_index') }}">
                    <i class="fas fa-chart-line me-2"></i> Actions
                </a>
            </li>

        </ul>

    </div>
</div>
```

</nav>

<!-- PAGE -->

<div class="page-content">

```
<!-- TOPBAR -->
<nav class="navbar top-bar navbar-light border-bottom px-4 py-3">
    <h5 class="mb-0">{% block page_title %}Dashboard{% endblock %}</h5>
</nav>

<!-- CONTENT -->
<div class="page-content-wrapper border p-4">
    {% block body %}{% endblock %}
</div>
```

</div>

</main>

<!-- JS -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script src="{{ asset('assets/vendor/apexcharts/js/apexcharts.min.js') }}"></script>

<script src="{{ asset('assets/js/functions.js') }}"></script>

{% block javascripts %}{% endblock %}

</body>
</html>
