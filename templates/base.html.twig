<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}FINORA{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="author" content="FINORA">
    <meta name="description" content="{% block meta_description %}FINORA — Votre plateforme de gestion d'investissements{% endblock %}">

    <!-- ======================= FAVICON ======================= -->
    <link rel="shortcut icon" href="{{ asset('assets/images/favicon.ico') }}">

    <!-- ======================= DARK MODE SCRIPT ======================= -->
    <script>
        const storedTheme = localStorage.getItem('theme');
        const getPreferredTheme = () => {
            if (storedTheme) return storedTheme;
            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        };

        const setTheme = function (theme) {
            document.documentElement.setAttribute('data-bs-theme', theme);
        };
        
        setTheme(getPreferredTheme());

        window.addEventListener('DOMContentLoaded', () => {
            const toggle = document.getElementById('darkModeToggle');
            if (toggle) {
                document.querySelectorAll('[data-bs-theme-value]').forEach(button => {
                    button.addEventListener('click', () => {
                        const next = button.getAttribute('data-bs-theme-value');
                        localStorage.setItem('theme', next);
                        setTheme(next);
                        
                        const mainIcon = document.getElementById('mainThemeIcon');
                        if (next === 'dark') {
                            mainIcon.className = 'bi bi-moon-stars-fill text-white fs-5';
                        } else {
                            mainIcon.className = 'bi bi-sun-fill text-warning fs-5';
                        }
                    });
                });
            }
        });
    </script>

    {% block stylesheets %}

        <!-- ======================= VENDOR CSS ======================= -->
        <link rel="stylesheet" href="{{ asset('assets/vendor/font-awesome/css/all.min.css') }}">
        <link rel="stylesheet" href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}">
        <link rel="stylesheet" href="{{ asset('assets/vendor/tiny-slider/tiny-slider.css') }}">
        <link rel="stylesheet" href="{{ asset('assets/vendor/glightbox/css/glightbox.css') }}">
        <link rel="stylesheet" href="{{ asset('assets/vendor/aos/aos.css') }}">
        <link rel="stylesheet" href="{{ asset('assets/vendor/choices/css/choices.min.css') }}">

        <!-- ======================= GOOGLE FONTS ======================= -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">

        <!-- ======================= TEMPLATE CSS ======================= -->
        <link rel="stylesheet" href="{{ asset('assets/css/style.css') }}">

        <!-- ======================= FINORA CUSTOM THEME ======================= -->
        <style>
            /* ── CSS Variables ── */
            :root {
                --finora-purple:      #7c3aed;
                --finora-purple-dark: #5b21b6;
                --finora-purple-soft: #f3e8ff;
                --finora-border:      #eadcff;
                --finora-text:        #24103d;
            }

            /* ── Base ── */
            body {
                background: linear-gradient(180deg, #fcfaff 0%, #f8f4ff 100%);
                color: var(--finora-text);
                font-family: 'Heebo', sans-serif;
            }

            /* ── Bootstrap overrides ── */
            .text-primary  { color: var(--finora-purple) !important; }
            .bg-primary    { background-color: var(--finora-purple) !important; }

            .btn-primary {
                background: linear-gradient(135deg, var(--finora-purple), #9333ea);
                border: none;
            }
            .btn-primary:hover,
            .btn-primary:focus {
                background: linear-gradient(135deg, var(--finora-purple-dark), var(--finora-purple));
                border: none;
            }

            .btn-outline-primary {
                border-color: var(--finora-purple);
                color: var(--finora-purple);
            }
            .btn-outline-primary:hover {
                background: var(--finora-purple);
                color: white;
            }

            /* ── Cards ── */
            .card {
                border-radius: 18px;
                border: 1px solid var(--finora-border);
                box-shadow: 0 10px 30px rgba(89, 30, 130, 0.08);
                transition: box-shadow 0.25s ease, transform 0.25s ease;
            }
            .card:hover,
            .shadow-hover:hover {
                box-shadow: 0 20px 50px rgba(89, 30, 130, 0.15) !important;
                transform: translateY(-3px);
            }

            /* ── Forms ── */
            .form-control,
            .form-select {
                border-radius: 12px;
                border: 1px solid #e9d5ff;
            }
            .form-control:focus,
            .form-select:focus {
                border-color: var(--finora-purple);
                box-shadow: 0 0 0 0.2rem rgba(124, 58, 237, 0.15);
            }

            /* ── Navbar ── */
            .navbar-light .navbar-nav .nav-link.active,
            .navbar-light .navbar-nav .nav-link:hover {
                color: var(--finora-purple) !important;
            }

            /* ── Pagination ── */
            .pagination-primary-soft .page-item.active .page-link {
                background-color: var(--finora-purple);
                border-color: var(--finora-purple);
            }
            .pagination-primary-soft .page-link:hover {
                color: var(--finora-purple);
            }

            /* ── Badge primary ── */
            .text-bg-primary,
            .badge.bg-primary {
                background-color: var(--finora-purple) !important;
            }

            /* ── Progress bar ── */
            .progress-bar.bg-primary {
                background-color: var(--finora-purple) !important;
            }

            /* ── bg-primary soft ── */
            .bg-primary.bg-opacity-10 {
                background-color: var(--finora-purple-soft) !important;
            }

            /* ── Smooth page transition ── */
            main {
                animation: fadeInPage 0.35s ease;
            }
            @keyframes fadeInPage {
                from { opacity: 0; transform: translateY(8px); }
                to   { opacity: 1; transform: translateY(0);   }
            }

            /* ── DARK MODE OVERRIDES ── */
            [data-bs-theme="dark"] body {
                background: linear-gradient(180deg, #130f1c 0%, #1a1625 100%) !important;
                color: #e2e8f0;
            }
            [data-bs-theme="dark"] .bg-light,
            [data-bs-theme="dark"] .nav-light {
                background-color: #1f1b2d !important;
            }
            [data-bs-theme="dark"] .card, 
            [data-bs-theme="dark"] .dropdown-menu {
                background-color: #1e1a2f;
                border-color: #372f4f;
                color: #e2e8f0;
            }
            [data-bs-theme="dark"] .card-header,
            [data-bs-theme="dark"] .card-footer {
                border-color: #372f4f;
            }
            [data-bs-theme="dark"] .text-muted {
                color: #9ca3af !important;
            }
            [data-bs-theme="dark"] h1, [data-bs-theme="dark"] h2, 
            [data-bs-theme="dark"] h3, [data-bs-theme="dark"] h4, 
            [data-bs-theme="dark"] h5, [data-bs-theme="dark"] h6 {
                color: #f8fafc;
            }
            [data-bs-theme="dark"] .form-control,
            [data-bs-theme="dark"] .form-select,
            [data-bs-theme="dark"] .input-group-text {
                background-color: #161324 !important;
                border-color: #372f4f;
                color: #e2e8f0;
            }
            [data-bs-theme="dark"] .form-control:focus,
            [data-bs-theme="dark"] .form-select:focus {
                background-color: #161324 !important;
                border-color: var(--finora-purple);
                color: white;
            }
            [data-bs-theme="dark"] .navbar-light {
                background-color: #130f1c !important;
                border-bottom: 1px solid #372f4f;
            }
            [data-bs-theme="dark"] .table {
                --bs-table-bg: transparent;
                --bs-table-color: #e2e8f0;
                border-color: #372f4f;
            }
            [data-bs-theme="dark"] .table-light,
            [data-bs-theme="dark"] .table-hover>tbody>tr:hover>* {
                background-color: #1f1b2d !important;
                color: white;
            }
            [data-bs-theme="dark"] .page-content-wrapper {
                background: linear-gradient(180deg, #130f1c 0%, #1a1625 100%) !important;
            }
        </style>

    {% endblock %}
</head>

<body>

{% block body %}{% endblock %}

{% block javascripts %}

    <!-- ======================= BOOTSTRAP ======================= -->
    <script src="{{ asset('assets/vendor/bootstrap/dist/js/bootstrap.bundle.min.js') }}"></script>

    <!-- ======================= VENDOR JS ======================= -->
    <script src="{{ asset('assets/vendor/tiny-slider/tiny-slider.js') }}"></script>
    <script src="{{ asset('assets/vendor/glightbox/js/glightbox.js') }}"></script>
    <script src="{{ asset('assets/vendor/purecounterjs/dist/purecounter_vanilla.js') }}"></script>
    <script src="{{ asset('assets/vendor/aos/aos.js') }}"></script>
    <script src="{{ asset('assets/vendor/choices/js/choices.min.js') }}"></script>

    <!-- ======================= TEMPLATE JS ======================= -->
    <script src="{{ asset('assets/js/functions.js') }}"></script>

    <!-- ======================= CHART.JS ======================= -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

{% endblock %}

<!-- ======================= QUICK ACTIONS TOGGLES ======================= -->
<div class="position-fixed d-flex gap-2" style="bottom: 20px; left: 20px; z-index: 1050;">
    
    <!-- DARK MODE TOGGLE -->
    <div class="dropdown dropup">
        <button id="darkModeToggle" class="btn btn-dark shadow rounded-circle d-flex align-items-center justify-content-center" 
                type="button" data-bs-toggle="dropdown" aria-expanded="false"
                style="width: 50px; height: 50px; border: 2px solid #5b21b6;">
            <i id="mainThemeIcon" class="bi bi-circle-half text-white fs-5"></i>
        </button>
        <ul class="dropdown-menu dropdown-menu-start shadow mb-2 rounded-3 border-0 py-2" aria-labelledby="darkModeToggle">
            <li>
                <button type="button" class="dropdown-item d-flex align-items-center gap-2 fw-bold" data-bs-theme-value="light">
                    <i class="bi bi-sun-fill text-warning"></i> Light Mode
                </button>
            </li>
            <li>
                <button type="button" class="dropdown-item d-flex align-items-center gap-2 fw-bold" data-bs-theme-value="dark">
                    <i class="bi bi-moon-stars-fill text-dark"></i> Dark Mode
                </button>
            </li>
        </ul>
    </div>

</div>
<script>
    // Initialize correct icon on load
    window.addEventListener('DOMContentLoaded', () => {
        const theme = document.documentElement.getAttribute('data-bs-theme');
        const mainIcon = document.getElementById('mainThemeIcon');
        if(theme === 'dark') {
            mainIcon.className = 'bi bi-moon-stars-fill text-white fs-5';
        } else {
            mainIcon.className = 'bi bi-sun-fill text-warning fs-5';
        }
    });
</script>

<!-- ======================= BACK TO TOP ======================= -->
<div class="back-top">
    <i class="bi bi-arrow-up-short position-absolute top-50 start-50 translate-middle"></i>
</div>

</body>
</html>
