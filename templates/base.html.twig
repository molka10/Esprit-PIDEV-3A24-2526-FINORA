    <style>
        :root {
            --finora-purple: #7c3aed;
            --finora-dark: #1e1b4b;
            --finora-gradient: linear-gradient(135deg, #7c3aed 0%, #3b1278 100%);
        }
        .btn-primary { background: var(--finora-gradient); border: none; }
        .btn-primary:hover { background: linear-gradient(135deg, #6d28d9 0%, #2e1065 100%); transform: translateY(-1px); transition: all 0.2s; }
        .nav-category .nav-link:hover { color: var(--finora-purple) !important; }
        .card-hover:hover { transform: translateY(-5px); transition: all 0.3s ease; box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important; }
        .bg-primary-soft { background-color: rgba(124, 58, 237, 0.1) !important; }
        .text-primary { color: var(--finora-purple) !important; }

        /* Dropdown hover for desktop */
        @media (min-width: 992px) {
            .navbar .nav-item.dropdown:hover .dropdown-menu {
                display: block;
                animation: fadeDown 0.2s ease-out forwards;
            }
        }
        @keyframes fadeDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>

{% block stylesheets %}{% endblock %}</head>


