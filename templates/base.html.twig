            </div>
        </div>
    </nav>

    <hr style="margin:0; border-color:#f0f2f5;">

    <!-- Category nav -->
    <nav class="edu-cat-nav">
        <div class="container">
            <a href="{{ path('dashboard') }}" class="edu-cat-link active">
                <i class="bi bi-speedometer2 me-1"></i>Dashboard
            </a>
            <a href="{{ path('transactions') }}" class="edu-cat-link">
                <i class="bi bi-arrow-left-right me-1"></i>Transactions
            </a>
            <a href="{{ path('wishlist') }}" class="edu-cat-link">
                <i class="bi bi-heart me-1"></i>Wishlist
            </a>
            <a href="{{ path('app_admin') }}" class="edu-cat-link">
                <i class="bi bi-shield me-1"></i>Admin
            </a>
        </div>
    </nav>

</header>
<!-- ===== HEADER END ===== -->

<!-- ===== MAIN CONTENT ===== -->
<main class="edu-main">
    <div class="container">
        {% block content %}{% endblock %}
    </div>
</main>
<!-- ===== MAIN CONTENT END ===== -->

<!-- ===== FOOTER START ===== -->
<footer class="edu-footer">
    <div class="container">
        <div class="row g-4">

            <!-- Brand -->
            <div class="col-lg-3 edu-footer-brand">
                <h5>FINORA</h5>
                <p>Plateforme de trading et d'investissement dédiée aux marchés financiers tunisiens.</p>
                <div class="edu-footer-social">
                    <a href="#" class="edu-social-btn"><i class="fab fa-facebook-f"></i></a>
                    <a href="#" class="edu-social-btn"><i class="fab fa-instagram"></i></a>
                    <a href="#" class="edu-social-btn"><i class="fab fa-twitter"></i></a>
                    <a href="#" class="edu-social-btn"><i class="fab fa-linkedin-in"></i></a>
                </div>
            </div>

            <!-- Links col 1 -->
            <div class="col-6 col-lg-2">
                <h5>FINORA</h5>
                <ul class="edu-footer-links">
                    <li><a href="#">Marché</a></li>
                    <li><a href="#">Historique</a></li>
                    <li><a href="{{ path('dashboard') }}">Dashboard</a></li>
                </ul>
            </div>

            <!-- Links col 2 -->
            <div class="col-6 col-lg-2">
                <h5>Communauté</h5>
                <ul class="edu-footer-links">
                    <li><a href="#">FAQ</a></li>
                    <li><a href="#">Forum</a></li>
                    <li><a href="#">Documentation</a></li>
                </ul>
            </div>

            <!-- Links col 3 -->
            <div class="col-6 col-lg-2">
                <h5>Compte</h5>
                <ul class="edu-footer-links">
                    <li><a href="#">Mon profil</a></li>
                    <li><a href="#">Paramètres</a></li>
                    <li><a href="#" style="color:#ef4444;">Déconnexion</a></li>
                </ul>
            </div>

            <!-- Contact -->
            <div class="col-lg-3">
                <h5>Contact</h5>
                <p class="edu-contact-item">
                    Email: <strong>contact@finora.tn</strong>
                </p>
                <p class="edu-contact-item">
                    Tél: <strong>+216 XX XXX XXX</strong>
                </p>
                <p class="edu-contact-item" style="font-size:.82rem; margin-top:6px;">
                    Lun – Ven · 9h à 18h
                </p>
            </div>

        </div>
    </div>

    <!-- Footer bottom -->
    <div class="edu-footer-bottom">
        <div class="container">
            <span>© 2026 FINORA — Tous droits réservés</span>
            <div>
                <a href="#">Confidentialité</a>
                <a href="#">Conditions</a>
                <a href="#">Mentions légales</a>
            </div>
        </div>
    </div>
</footer>
<!-- ===== FOOTER END ===== -->

<!-- Bootstrap JS -->
<script src="{{ asset('assets/vendor/bootstrap/bootstrap.bundle.min.js') }}"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js" defer></script>

<script>
    // Dropdown toggle on click (mobile friendly)
    document.querySelectorAll('.edu-dropdown').forEach(function(el) {
        el.querySelector('.edu-avatar')?.addEventListener('click', function(e) {
            e.preventDefault();
            el.classList.toggle('open');
        });
    });

    document.addEventListener('click', function(e) {
        document.querySelectorAll('.edu-dropdown').forEach(function(el) {
            if (!el.contains(e.target)) el.classList.remove('open');
        });
    });

    // Active nav link highlight
    const currentPath = window.location.pathname;
    document.querySelectorAll('.edu-cat-link').forEach(function(link) {
        link.classList.remove('active');
        if (link.getAttribute('href') && currentPath.startsWith(link.getAttribute('href')) && link.getAttribute('href') !== '/') {
            link.classList.add('active');
        }
    });
</script>

{% block javascripts %}{% endblock %}
</body>
</html>