<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>{% block title %}FINORA Admin{% endblock %}</title>

    <script>
        const storedTheme = localStorage.getItem('theme')
        const getPreferredTheme = () => storedTheme ? storedTheme : 'light'
        const setTheme = function (theme) {
            document.documentElement.setAttribute('data-bs-theme', theme === 'auto' ? 'light' : theme)
        }
        setTheme(getPreferredTheme())
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com/">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap">
    <link rel="stylesheet" href="/assets/vendor/font-awesome/css/all.min.css">
    <link rel="stylesheet" href="/assets/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/assets/vendor/apexcharts/css/apexcharts.css">
    <link rel="stylesheet" href="/assets/css/style.css">

    <style>
        :root {
            --finora-dark:   #1e0a3c;
            --finora-mid:    #2d1155;
            --finora-accent: #3b1278;
            --finora-purple: #7c3aed;
            --finora-light:  #a855f7;
            --finora-pale:   #f5f3ff;
        }
        .sidebar .nav-link.active,
        .sidebar .nav-link:hover {
            background: rgba(168,85,247,0.15) !important;
            color: #a855f7 !important;
        }
        .sidebar .nav-link { color: #94a3b8; }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>
<main>

<!-- SIDEBAR -->
<nav class="navbar sidebar navbar-expand-xl navbar-dark bg-dark">
    <div class="d-flex align-items-center p-3">
        <a class="navbar-brand fw-bold fs-5 text-decoration-none" href="{{ path('app_home') }}">
            💰 <span style="color:var(--finora-light);">FINORA</span>
        </a>
    </div>

    <div class="offcanvas offcanvas-start flex-row h-100" data-bs-backdrop="true" tabindex="-1" id="offcanvasSidebar">
        <div class="offcanvas-body sidebar-content d-flex flex-column bg-dark">
            <ul class="navbar-nav flex-column" id="navbar-sidebar">

                <li class="nav-item">
                    <a class="nav-link {{ app.request.get('_route') == 'app_home' ? 'active' : '' }}"
                       href="{{ path('app_home') }}">
                        <i class="bi bi-speedometer2 fa-fw me-2"></i> Dashboard
                    </a>
                </li>

                <li class="nav-item ms-2 my-2" style="color:#4b5563; font-size:11px; text-transform:uppercase; letter-spacing:1px;">
                    Gestion
                </li>

                <li class="nav-item">
                    <a class="nav-link {{ app.request.get('_route') starts with 'app_bourse' ? 'active' : '' }}"
                       href="{{ path('app_bourse_index') }}">
                        <i class="fas fa-chart-bar fa-fw me-2"></i> Bourses
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link {{ app.request.get('_route') starts with 'app_action' ? 'active' : '' }}"
                       href="{{ path('app_action_index') }}">
                        <i class="fas fa-chart-line fa-fw me-2"></i> Actions
                    </a>
                </li>

                <li class="nav-item ms-2 my-2" style="color:#4b5563; font-size:11px; text-transform:uppercase; letter-spacing:1px;">
                    Utilisateurs
                </li>

                <li class="nav-item">
                    <a class="nav-link {{ app.request.get('_route') starts with 'app_market' ? 'active' : '' }}"
                       href="{{ path('app_market') }}">
                        <i class="bi bi-globe fa-fw me-2"></i> Voir le Marché
                    </a>
                </li>

            </ul>

            <div class="px-3 mt-auto pt-3 pb-3">
                <div class="d-flex align-items-center justify-content-between text-primary-hover">
                    <a class="h5 mb-0 text-body" href="{{ path('app_home') }}" title="Dashboard">
                        <i class="bi bi-speedometer2"></i>
                    </a>
                    <a class="h5 mb-0 text-body" href="{{ path('app_market') }}" title="Marché">
                        <i class="bi bi-globe"></i>
                    </a>
                    <a class="h5 mb-0 text-body" href="#" title="Déconnexion">
                        <i class="bi bi-power"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</nav>

<!-- PAGE CONTENT -->
<div class="page-content">

    <!-- TOP BAR -->
    <nav class="navbar top-bar navbar-light border-bottom py-0 py-xl-3">
        <div class="container-fluid p-0">
            <div class="d-flex align-items-center w-100 px-3">

                <div class="navbar-expand-xl sidebar-offcanvas-menu">
                    <button class="navbar-toggler me-3" type="button"
                            data-bs-toggle="offcanvas" data-bs-target="#offcanvasSidebar">
                        <i class="bi bi-text-right fa-fw h2 lh-0 mb-0"></i>
                    </button>
                </div>

                <h5 class="mb-0">{% block page_title %}Dashboard{% endblock %}</h5>

                <div class="ms-auto">
                    <ul class="navbar-nav flex-row align-items-center">
                        <li class="nav-item ms-3 dropdown">
                            <a class="btn btn-light btn-round mb-0" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-bell fa-fw"></i>
                            </a>
                            <span class="notif-badge animation-blink"></span>
                            <div class="dropdown-menu dropdown-animation dropdown-menu-end dropdown-menu-size-md p-0 shadow-lg border-0">
                                <div class="card bg-transparent">
                                    <div class="card-header bg-transparent border-bottom py-3 d-flex justify-content-between">
                                        <h6 class="m-0">Notifications</h6>
                                        <a class="small" href="#">Tout effacer</a>
                                    </div>
                                    <div class="card-footer bg-transparent border-0 py-3 text-center">
                                        <a href="#">Voir toutes les activités</a>
                                    </div>
                                </div>
                            </div>
                        </li>
                        <li class="nav-item ms-3 dropdown">
                            <a class="avatar avatar-sm p-0" href="#" data-bs-toggle="dropdown">
                                <img class="avatar-img rounded-circle" src="/assets/images/avatar/01.jpg" alt="avatar">
                            </a>
                            <ul class="dropdown-menu dropdown-animation dropdown-menu-end shadow pt-3">
                                <li class="px-3 mb-3">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar me-3">
                                            <img class="avatar-img rounded-circle shadow" src="/assets/images/avatar/01.jpg" alt="avatar">
                                        </div>
                                        <div>
                                            <a class="h6" href="#">Admin FINORA</a>
                                            <p class="small m-0">admin@finora.tn</p>
                                        </div>
                                    </div>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item bg-danger-soft-hover" href="#"><i class="bi bi-power fa-fw me-2"></i>Déconnexion</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show m-3">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="page-content-wrapper border">
        {% block body %}{% endblock %}
    </div>

</div>
</main>

<div class="back-top"><i class="bi bi-arrow-up-short position-absolute top-50 start-50 translate-middle"></i></div>

<script src="/assets/vendor/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="/assets/vendor/purecounterjs/dist/purecounter_vanilla.js"></script>
<script src="/assets/vendor/apexcharts/js/apexcharts.min.js"></script>
<script src="/assets/js/functions.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>