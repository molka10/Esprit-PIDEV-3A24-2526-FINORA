<!-- Notification API Script -->
<script>
document.addEventListener("DOMContentLoaded", async () => {
    try {
        const res = await fetch('/api/user/notifications');
        const data = await res.json();
        
        if (data.status === 'success') {
            const notifList = document.getElementById('notif-list');
            const notifBadge = document.getElementById('notif-badge');
            const notifCount = document.getElementById('notif-count');
            
            if (data.data.length > 0) {
                // Show red dot
                notifBadge.classList.remove('d-none');
                notifCount.innerText = data.summary.unreadCount;
                
                notifList.innerHTML = data.data.map(notif => `
                    <li class="list-group-item p-3 border-0 bg-light bg-opacity-50">
                        <div class="d-flex w-100 justify-content-between">
                            <h6 class="mb-1 text-danger"><i class="bi bi-exclamation-triangle-fill me-1"></i> ${notif.title}</h6>
                            <small class="text-muted"><i class="bi bi-clock"></i> Just now</small>
                        </div>
                        <p class="mb-1 small text-dark">${notif.message}</p>
                    </li>
                `).join('');
                
            } else {
                notifList.innerHTML = '<li class="list-group-item p-3 text-center text-muted small border-0">No new notifications</li>';
            }
        }
    } catch(e) {
        console.error('Failed to load notifications', e);
    }
});
</script>

