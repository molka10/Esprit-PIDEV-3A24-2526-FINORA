<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Finora{% endblock %}</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="{{ asset('assets/vendor/bootstrap/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}">

    <!-- STYLE -->
    <link rel="stylesheet" href="{{ asset('assets/css/style.css') }}">
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar">
    <div class="navbar-brand">
        <img src="{{ asset('assets/images/logo.svg') }}">
        FINORA
    </div>

    <div class="ms-auto">
        <a href="{{ path('dashboard') }}">📊 Dashboard</a>
        <a href="{{ path('app_admin') }}" class="btn btn-primary">Admin</a>
    </div>
</nav>

<!-- CONTENT -->
<div class="container">
    {% block content %}{% endblock %}
</div>

<!-- FOOTER -->
<footer class="site-footer">
    <div class="footer-inner">

        <div class="footer-brand">
            <h3>FINORA</h3>
            <p>
                Plateforme de trading et d’investissement dédiée aux marchés financiers tunisiens.
            </p>
        </div>

        <div class="footer-col">
            <h4>FINORA</h4>
            <a href="#">Marché</a>
            <a href="#">Historique</a>
        </div>

        <div class="footer-col">
            <h4>Support</h4>
            <a href="#">FAQ</a>
            <a href="#">Contact</a>
        </div>

        <div class="footer-col">
            <h4>Compte</h4>
            <a href="#">Déconnexion</a>
        </div>

        <div class="footer-col">
            <h4>Contact</h4>
            <p>Email: contact@finora.tn</p>
            <p>Tél: +216 XX XXX XXX</p>
        </div>

    </div>

    <hr class="footer-divider">

    <div class="footer-bottom">
        <span>© 2026 FINORA</span>
        <div class="footer-bottom-links">
            <a href="#">Confidentialité</a>
            <a href="#">Conditions</a>
        </div>
    </div>
</footer>

<script src="{{ asset('assets/vendor/bootstrap/bootstrap.bundle.min.js') }}"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

{% block javascripts %}{% endblock %}

</body>
</html>