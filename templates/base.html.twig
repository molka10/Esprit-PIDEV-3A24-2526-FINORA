{% block javascripts %}{% endblock %}

<script>
document.addEventListener('DOMContentLoaded', function() {
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            (function() {
                const msg = `{{ message|raw }}`;
                const label = `{{ label }}`;
                
                if (msg.includes('Solde insuffisant') || msg.includes('portefeuille')) {
                    Swal.fire({
                        title: '<strong>Solde Insuffisant</strong>',
                        icon: 'warning',
                        html: msg,
                        showCloseButton: true,
                        showCancelButton: true,
                        focusConfirm: false,
                        confirmButtonText: '<i class="bi bi-wallet2"></i> Recharger mon Wallet',
                        confirmButtonColor: '#7c3aed',
                        cancelButtonText: 'Fermer',
                        background: '#fff',
                        customClass: {
                            popup: 'animated fadeInDown'
                        }
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = "{{ path('dashboard') }}";
                        }
                    });
                } 
                else if (label === 'success') {
                    Swal.fire({
                        title: 'Succès !',
                        text: msg.replace(/<[^>]*>?/gm, ''),
                        icon: 'success',
                        timer: 3000,
                        showConfirmButton: false,
                        toast: true,
                        position: 'top-end'
                    });
                }
                else if (label === 'danger' || label === 'error') {
                   Swal.fire({
                        title: 'Attention',
                        html: msg,
                        icon: 'error',
                        confirmButtonColor: '#7c3aed'
                    });
                }
                else if (label === 'success') {
                   Swal.fire({
                        title: 'Succès',
                        html: msg,
                        icon: 'success',
                        confirmButtonColor: '#7c3aed'
                    });
                }
            })();
        {% endfor %}
    {% endfor %}
});
</script>

    <!-- Floating Currency Switcher START -->
    {% if app.request.attributes.get('_route') != 'dashboard' %}
