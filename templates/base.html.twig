<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Finora{% endblock %}</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        body {
            background-color: #f4f6f9;
        }

        .navbar {
            background-color: #343a40;
        }

        .navbar a {
            color: white !important;
        }

        .main-layout {
            display: flex;
        }

        .sidebar {
            width: 250px;
            min-height: 100vh;
            background: #212529;
            padding: 20px;
        }

        .sidebar h5 {
            color: white;
            margin-bottom: 20px;
        }

        .sidebar a {
            display: block;
            color: white;
            padding: 10px;
            margin-bottom: 10px;
            border-radius: 5px;
            text-decoration: none;
            transition: 0.3s;
        }

        .sidebar a:hover {
            background: #0d6efd;
        }

        .content {
            flex: 1;
            padding: 20px;
            width: 100%;
        }

        .card {
            border: none;
            border-radius: 12px;
        }
    </style>
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg">
    <div class="container-fluid">

        <a class="navbar-brand text-white" href="{{ path('app_home') }}">
            Finora
        </a>

        <ul class="navbar-nav ms-auto">

            <li class="nav-item">
                <a class="nav-link" href="{{ path('app_home') }}">Home</a>
            </li>

            {% if app.user %}
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_profile') }}">
                        👤 {{ app.user.firstname }}
                    </a>
                </li>

                {% if is_granted('ROLE_ADMIN') %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('admin_dashboard') }}">
                            Admin
                        </a>
                    </li>
                {% endif %}

                <li class="nav-item">
                    <a class="nav-link text-danger" href="{{ path('app_logout') }}">
                        Logout
                    </a>
                </li>
            {% else %}
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_login') }}">Login</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_register') }}">Register</a>
                </li>
            {% endif %}

        </ul>
    </div>
</nav>

<div class="main-layout">

    {% if app.user %}
    <div class="sidebar">
        <h5>🚀 Services</h5>
        <a href="/bourse">📈 Bourse</a>
        <a href="/wallet">💰 Wallet</a>
        <a href="/appel-offre">📢 Appel d'offre</a>
        <a href="/formation">🎓 Formation</a>
        <a href="/investissement">🚀 Investissement</a>
    </div>
    {% endif %}

    <div class="content">

        {# ✅ FLASH MESSAGES #}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}

        {% block body %}{% endblock %}
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="{{ asset('js/validation.js') }}"></script>
{% block javascripts %}{% endblock %}

</body>
</html>