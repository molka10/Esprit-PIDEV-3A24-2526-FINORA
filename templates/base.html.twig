    padding: 30px;
    border-radius: 20px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    text-align: center;
}

.chart-card canvas {
    max-width: 350px;
    margin: auto;
}

/* RESPONSIVE */
@media (max-width: 900px) {
    .dashboard-grid {
        grid-template-columns: 1fr;
    }

    .dash-card.big {
        grid-column: span 1;
    }
}
/* HEADER */
.dash-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
}

/* BUTTON */
.btn-main {
    background: #2d3436;
}

/* STATS */
.stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 15px;
}

.stat {
    background: white;
    padding: 20px;
    border-radius: 12px;
    border: 1px solid #eee;
}

.stat span {
    font-size: 14px;
    color: #777;
}

.stat h2 {
    margin: 10px 0 0;
}

/* EXPORT */
.export-row {
    margin: 25px 0;
    display: flex;
    gap: 10px;
}

.btn-outline {
    padding: 8px 15px;
    border: 1px solid #ccc;
    border-radius: 8px;
    text-decoration: none;
    color: black;
}

