{% extends 'base.html.twig' %}

{% block title %}Modifier Suivi - FINORA{% endblock %}

{% block body %}
    <section class="py-5" style="background: #f8fafc;">
        <div class="container py-5">
            <div class="row justify-content-center">
                <div class="col-lg-7">
                    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                        <div class="card-header bg-warning text-dark p-4">
                            <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Modifier le Suivi</h4>
                            <p class="mb-0 small text-dark-50">Mettez à jour les informations de votre participation.</p>
                        </div>
                        <div class="card-body p-4 p-md-5 bg-white">
                            {{ include('investment_management/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
                            
                            <hr class="my-4">
                            
                            <div class="d-flex justify-content-between align-items-center">
                                <a href="{{ path('app_management_index') }}" class="text-muted text-decoration-none small">
                                    <i class="bi bi-arrow-left me-1"></i>Retour
                                </a>
                                <form method="post" action="{{ path('app_management_delete', {'id': item.id}) }}" onsubmit="return confirm('Souhaitez-vous vraiment supprimer cet enregistrement ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                                    <button class="btn btn-link btn-sm text-danger text-decoration-none small p-0">
                                        <i class="bi bi-trash me-1"></i>Supprimer ce suivi
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
