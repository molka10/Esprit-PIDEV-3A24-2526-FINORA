            'class': 'form-control ' ~ (form_errors(form.amountInvested) ? 'is-invalid' : '')
        }
    }) }}
    <div class="invalid-feedback d-block">
        {{ form_errors(form.amountInvested) }}
    </div>
</div>

<!-- PERCENTAGE -->
<div class="mb-3">
