{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

<!-- INVESTMENT -->
<div class="mb-3">
    {{ form_label(form.investment) }}
    {{ form_widget(form.investment, {
        'attr': {
            'class': 'form-control ' ~ (form_errors(form.investment) ? 'is-invalid' : '')
        }
    }) }}
    <div class="invalid-feedback d-block">
        {{ form_errors(form.investment) }}
    </div>
</div>

<!-- TYPE -->
<div class="mb-3">
    {{ form_label(form.investmentType) }}
    {{ form_widget(form.investmentType, {
        'attr': {
            'class': 'form-control ' ~ (form_errors(form.investmentType) ? 'is-invalid' : '')
        }
    }) }}
    <div class="invalid-feedback d-block">
        {{ form_errors(form.investmentType) }}
    </div>
</div>

<!-- AMOUNT -->
<div class="mb-3">
    {{ form_label(form.amountInvested) }}
