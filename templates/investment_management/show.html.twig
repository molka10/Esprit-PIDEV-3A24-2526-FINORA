{% extends 'base.html.twig' %}

{% block title %}FINORA - Détails Investissement{% endblock %}

{% block body %}

<!-- HEADER -->
<header class="navbar-light navbar-sticky">
    <nav class="navbar navbar-expand-xl z-index-9">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}">
                <img class="light-mode-item navbar-brand-item" src="{{ asset('assets/images/logo.svg') }}" alt="FINORA" style="height:40px;">
                <img class="dark-mode-item navbar-brand-item" src="{{ asset('assets/images/logo-light.svg') }}" alt="FINORA" style="height:40px;">
            </a>
            <div class="navbar-collapse w-100 collapse" id="navbarCollapse">
                <ul class="navbar-nav navbar-nav-scroll mx-auto">
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}"><i class="bi bi-house me-1"></i>Accueil</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_investment_index') }}"><i class="bi bi-graph-up-arrow me-1"></i>Investissements</a></li>
                    <li class="nav-item"><a class="nav-link active" href="{{ path('app_management_index') }}"><i class="bi bi-briefcase me-1"></i>Management</a></li>
                </ul>
            </div>
            <div class="ms-1 ms-lg-0">
                <a class="avatar avatar-sm p-0" href="#">
                    <img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/01.jpg') }}" alt="avatar">
                </a>
            </div>
        </div>
    </nav>
</header>

<main>

    <!-- Banner -->
    <section class="align-items-center d-flex position-relative overflow-hidden"
             style="background: linear-gradient(135deg, #4b0082 0%, #7c3aed 50%, #8b5cf6 100%); min-height: 160px;">
        <div class="container position-relative z-index-1">
            <div class="row">
                <div class="col-12">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb breadcrumb-dark breadcrumb-dots mb-2">
                            <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                            <li class="breadcrumb-item"><a href="{{ path('app_management_index') }}">Portefeuille</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Détails</li>
                        </ol>
                    </nav>
                    <h1 class="text-white fw-bold mb-0">Détails de l'Investissement</h1>
                </div>
            </div>
        </div>
    </section>

    <!-- Content -->
    <section class="py-5">
        <div class="container">
            <div class="row g-4">

                <!-- Left: Investment Info -->
                <div class="col-xl-8">

                    <!-- Project header card -->
                    <div class="card border-0 shadow-sm mb-4" style="border-radius: 20px; overflow: hidden;">
                        {% if item.investment %}
                        <div class="position-relative">
                            <img src="{{ investment_image_src(item.investment) ?: asset('assets/images/courses/4by3/06.jpg') }}"
                                 class="card-img-top object-fit-cover" style="height: 280px;" alt="{{ item.investment.name }}">
                            <div class="card-img-overlay d-flex align-items-end p-4" style="background: linear-gradient(0deg, rgba(30,27,75,0.85) 0%, transparent 60%);">
                                <div>
                                    <span class="badge rounded-pill px-3 py-2 text-white mb-2" style="background: linear-gradient(90deg, #7c3aed, #8b5cf6);">{{ item.investmentType }}</span>
                                    <h2 class="text-white fw-bold mb-0">{{ item.investment.name }}</h2>
                                    <p class="text-white text-opacity-75 mb-0 small">
                                        <i class="bi bi-geo-alt me-1"></i>{{ item.investment.location ?? 'Non spécifiée' }}
                                    </p>
                                </div>
                            </div>
                        </div>
                        {% endif %}
                    </div>

                    <!-- Details Grid -->
                    <div class="card border-0 shadow-sm mb-4" style="border-radius: 20px;">
                        <div class="card-body p-4 p-sm-5">
                            <h5 class="fw-bold mb-4"><i class="bi bi-clipboard-data me-2" style="color: #7c3aed;"></i>Informations de l'Investissement</h5>

                            <div class="row g-4">
                                <div class="col-sm-6">
                                    <div class="d-flex align-items-center p-3 rounded-3" style="background: #faf5ff; border: 1px solid #ede9fe;">
                                        <div class="d-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, #7c3aed, #8b5cf6);">
                                            <i class="bi bi-cash-stack text-white fs-5"></i>
                                        </div>
                                        <div class="ms-3">
                                            <small class="text-muted d-block">Montant Investi</small>
                                            <strong class="fs-5" style="color: #7c3aed;">{{ (item.amountInvested ?? 0)|number_format(2, ',', ' ') }} TND</strong>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-sm-6">
                                    <div class="d-flex align-items-center p-3 rounded-3" style="background: #ecfdf5; border: 1px solid #d1fae5;">
                                        <div class="d-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, #10b981, #34d399);">
                                            <i class="bi bi-pie-chart text-white fs-5"></i>
                                        </div>
                                        <div class="ms-3">
                                            <small class="text-muted d-block">Part Détenue</small>
                                            <strong class="fs-5" style="color: #059669;">{{ item.ownershipPercentage ?? 0 }}%</strong>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-sm-6">
                                    <div class="d-flex align-items-center p-3 rounded-3" style="background: #eff6ff; border: 1px solid #dbeafe;">
                                        <div class="d-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, #3b82f6, #60a5fa);">
                                            <i class="bi bi-calendar-event text-white fs-5"></i>
                                        </div>
                                        <div class="ms-3">
                                            <small class="text-muted d-block">Date de Début</small>
                                            <strong>{{ item.startDate ? item.startDate|date('d/m/Y') : 'Non définie' }}</strong>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-sm-6">
                                    <div class="d-flex align-items-center p-3 rounded-3" style="background: {{ item.status == 'ACTIVE' ? '#ecfdf5' : '#fef2f2' }}; border: 1px solid {{ item.status == 'ACTIVE' ? '#d1fae5' : '#fecaca' }};">
                                        <div class="d-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, {{ item.status == 'ACTIVE' ? '#10b981, #34d399' : '#ef4444, #f87171' }});">
                                            <i class="bi {{ item.status == 'ACTIVE' ? 'bi-check-circle' : 'bi-x-circle' }} text-white fs-5"></i>
                                        </div>
                                        <div class="ms-3">
                                            <small class="text-muted d-block">Statut</small>
                                            {% if item.status == 'ACTIVE' %}
                                                <span class="badge rounded-pill px-3 py-1" style="background: linear-gradient(90deg, #10b981, #059669); color: white;">Actif</span>
                                            {% else %}
                                                <span class="badge rounded-pill px-3 py-1" style="background: linear-gradient(90deg, #ef4444, #dc2626); color: white;">Clôturé</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Right Sidebar -->
                <div class="col-xl-4">
                    <div style="position: sticky; top: 100px;">

                        <!-- Rendement Card -->
                        <div class="card border-0 shadow-sm mb-4" style="border-radius: 20px; overflow: hidden;">
                            <div class="text-center py-4" style="background: linear-gradient(135deg, #7c3aed 0%, #8b5cf6 100%);">
                                <small class="text-white text-opacity-75 text-uppercase fw-bold" style="letter-spacing: 1px; font-size: 0.7rem;">Rendement Estimé</small>
                                {% if item.investment %}
                                    <h2 class="text-white fw-bold display-6 mb-0">{{ item.investment.annualReturn }}%</h2>
                                {% else %}
                                    <h2 class="text-white fw-bold display-6 mb-0">9.5%</h2>
                                {% endif %}
                                <small class="text-white text-opacity-75">par an</small>
                            </div>
                            <div class="card-body p-4">
                                <div class="p-3 rounded-3 text-center mb-3" style="background: linear-gradient(135deg, #ecfdf5, #d1fae5); border: 1px solid #a7f3d0;">
                                    <small class="text-muted d-block">Rendement annuel estimé</small>
                                    {% set rate = item.investment ? item.investment.annualReturn : 9.5 %}
                                    <h4 class="fw-bold mb-0" style="color: #059669;">
                                        {{ ((item.amountInvested ?? 0) * rate / 100)|number_format(2, ',', ' ') }} TND / an
                                    </h4>
                                    <small class="text-muted">≈ {{ (((item.amountInvested ?? 0) * rate / 100) / 12)|number_format(2, ',', ' ') }} TND / mois</small>
                                </div>

                                <div class="row g-2 mb-3">
                                    <div class="col-6">
                                        <div class="text-center p-3 rounded-3" style="background: #faf5ff;">
                                            <i class="bi bi-clock fs-4 d-block mb-1" style="color: #7c3aed;"></i>
                                            <strong class="d-block">{{ item.investment ? item.investment.durationMonths : 24 }} mois</strong>
                                            <small class="text-muted">Durée</small>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="text-center p-3 rounded-3" style="background: #faf5ff;">
                                            <i class="bi bi-tag fs-4 d-block mb-1" style="color: #7c3aed;"></i>
                                            <strong class="d-block">{{ item.investmentType }}</strong>
                                            <small class="text-muted">Type</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Actions Card -->
                        <div class="card border-0 shadow-sm" style="border-radius: 20px;">
                            <div class="card-body p-4">
                                <h6 class="fw-bold mb-3"><i class="bi bi-gear me-1" style="color: #7c3aed;"></i>Actions</h6>
                                <div class="d-grid gap-2">
                                    <a href="{{ path('app_management_index') }}" class="btn btn-outline-secondary rounded-pill">
                                        <i class="bi bi-arrow-left me-1"></i>Retour au portefeuille
                                    </a>
                                    <a href="{{ path('app_management_edit', {'id': item.id}) }}" class="btn rounded-pill text-white" style="background: linear-gradient(135deg, #f59e0b, #d97706); border: none;">
                                        <i class="bi bi-pencil me-1"></i>Modifier
                                    </a>

                                    <form method="post" action="{{ path('app_management_delete', {'id': item.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet investissement ?');" class="d-grid">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                                        <button class="btn btn-outline-danger rounded-pill"><i class="bi bi-trash me-1"></i>Supprimer</button>
                                    </form>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </section>

</main>

{% endblock %}