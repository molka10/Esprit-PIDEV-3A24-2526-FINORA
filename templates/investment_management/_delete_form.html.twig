<form method="post"
      action="{{ path('app_management_delete', {'managementId': item.managementId}) }}"
      onsubmit="return confirm('⚠️ Delete this investment?');"
      class="d-inline">

    <input type="hidden"
           name="_token"
           value="{{ csrf_token('delete' ~ item.managementId) }}">

    <button class="btn btn-danger btn-sm">
        🗑
    </button>

</form>