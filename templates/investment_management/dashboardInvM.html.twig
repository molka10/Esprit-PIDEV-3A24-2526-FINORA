{% extends 'base.html.twig' %}

{% block title %}Management Dashboard{% endblock %}

{% block body %}

<div class="container mt-5">

    <h1 class="mb-4">⚙️ Investment Management Dashboard</h1>

    <!-- 🔥 STATS -->
    <div class="row">

        <div class="col-md-3">
            <div class="card text-center shadow p-3 bg-light">
                <h6>Total Management</h6>
                <h2>{{ total }}</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center shadow p-3 bg-light">
                <h6>Total Amount Invested</h6>
                <h2>{{ totalAmount|default(0) }} DT</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center shadow p-3 bg-light">
                <h6>Active</h6>
                <h2>{{ active }}</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center shadow p-3 bg-light">
                <h6>Closed</h6>
                <h2>{{ closed }}</h2>
            </div>
        </div>

    </div>

    <!-- 🔥 AVERAGE -->
    <div class="card mt-4 text-center shadow p-3">
        <h6>Average Investment</h6>
        <h2>{{ average|default(0)|number_format(2) }} DT</h2>
    </div>

    <!-- 📊 GRAPH STATUS -->
    <div class="card mt-5 shadow p-4">
        <h4 class="text-center mb-3">📊 Investment Status</h4>
        <div style="height:350px;">
            <canvas id="statusChart"></canvas>
        </div>
    </div>

    <!-- 📈 GRAPH AMOUNT -->
    <div class="card mt-5 shadow p-4">
        <h4 class="text-center mb-3">💰 Investment Overview</h4>
        <div style="height:350px;">
            <canvas id="amountChart"></canvas>
        </div>
    </div>

    <!-- 🔥 TABLE -->
    <div class="card mt-5 shadow p-3">
        <h4 class="mb-3">📋 Investment Management</h4>

        <table class="table table-bordered align-middle text-center">
            <thead>
                <tr>
                    <th>Investment</th>
                    <th>Amount</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                {% for item in items %}
                    <tr>

                        <!-- ✅ ID + NAME -->
                        <td class="text-start">
                            <span class="badge bg-dark mb-1">
                                #{{ item.managementId }}
                            </span><br>

                            {% if item.investment %}
                                <strong class="text-primary">
                                    {{ item.investment.name }}
                                </strong>
                            {% else %}
                                <span class="text-muted">N/A</span>
                            {% endif %}
                        </td>

                        <!-- AMOUNT -->
                        <td class="fw-semibold text-primary">
                            {{ item.amountInvested }} DT
                        </td>

                        <!-- STATUS -->
                        <td>
                            {% if item.status == 'ACTIVE' %}
                                <span class="badge bg-success px-3 py-2">Active</span>
                            {% else %}
                                <span class="badge bg-danger px-3 py-2">Closed</span>
                            {% endif %}
                        </td>

                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3">No data</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

</div>

{% endblock %}

{% block javascripts %}
<script>
document.addEventListener("DOMContentLoaded", function () {

    const active = {{ active|default(0) }};
    const closed = {{ closed|default(0) }};
    const totalAmount = {{ totalAmount|default(0) }};
    const average = {{ average|default(0) }};

    // 📊 STATUS
    new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: {
            labels: ['Active', 'Closed'],
            datasets: [{
                data: [active, closed],
                backgroundColor: ['#28a745', '#dc3545']
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false
        }
    });

    // 📈 AMOUNT
    new Chart(document.getElementById('amountChart'), {
        type: 'bar',
        data: {
            labels: ['Total', 'Average'],
            datasets: [{
                label: 'TND',
                data: [totalAmount, average],
                backgroundColor: ['#007bff', '#ffc107']
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false
        }
    });

});
</script>
{% endblock %}