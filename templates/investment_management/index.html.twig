{% extends 'base.html.twig' %}

{% block title %}Investment Management{% endblock %}

{% block body %}

<h1>Investment Management</h1>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
                <th>ManagementId</th>
                <th>InvestmentType</th>
                <th>AmountInvested</th>
                <th>OwnershipPercentage</th>
                <th>StartDate</th>
                <th>Status</th>
                <th>actions</th>
        </tr>
    </thead>

    <tbody>
    {% for item in items %}
        <tr>
            <td>{{ item.managementId }}</td>

            <!-- 🔥 RELATION -->
            <td>{{ item.investment.name }}</td>

            <td>{{ item.investmentType }}</td>
            <td>{{ item.amountInvested }}</td>
            <td>{{ item.ownershipPercentage }}%</td>

            <td>
                {{ item.startDate ? item.startDate|date('Y-m-d') : '' }}
            </td>

            <td>
                {% if item.status == 'ACTIVE' %}
                    <span class="badge bg-success">Active</span>
                {% else %}
                    <span class="badge bg-danger">Closed</span>
                {% endif %}
            </td>

            <td>
                <a class="btn btn-sm btn-info"
                   href="{{ path('app_management_show', {'managementId': item.managementId}) }}">
                   Show
                </a>

                <a class="btn btn-sm btn-warning"
                   href="{{ path('app_management_edit', {'managementId': item.managementId}) }}">
                   Edit
                </a>
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="8">No records found</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

<a class="btn btn-primary" href="{{ path('app_management_new') }}">
    ➕ Create new
</a>

{% endblock %}
