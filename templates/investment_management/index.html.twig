{% extends 'base.html.twig' %}

{% block title %}Investment Management{% endblock %}

{% block body %}

<div class="container mt-4">

    <h1 class="mb-4">📊 Investment Management</h1>

    <!-- 🔍 SEARCH + FILTER -->
    <form method="get" class="row g-2 mb-3">

        <div class="col-md-6">
            <input type="text" name="search" class="form-control"
                   placeholder="🔍 Search investment..."
                   value="{{ app.request.get('search') }}">
        </div>

        <div class="col-md-3">
            <select name="status" class="form-select">
                <option value="ALL">All</option>
                <option value="ACTIVE"
                    {{ app.request.get('status') == 'ACTIVE' ? 'selected' }}>
                    Active
                </option>
                <option value="CLOSED"
                    {{ app.request.get('status') == 'CLOSED' ? 'selected' }}>
                    Closed
                </option>
            </select>
        </div>

        <div class="col-md-3 d-flex gap-2">
            <button class="btn btn-primary w-100">Search</button>

            <a href="{{ path('app_management_index') }}"
               class="btn btn-secondary w-100">
               Reset
            </a>
        </div>

    </form>

    <!-- ACTIONS -->
    <div class="d-flex justify-content-between mb-3">

        <a class="btn btn-success" href="{{ path('app_management_new') }}">
            ➕ New Investment
        </a>

        <a class="btn btn-dark" href="{{ path('app_management_dashboard') }}">
            📊 Dashboard
        </a>

    </div>

    <div class="card shadow p-3">

        <table class="table table-hover align-middle">

            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Investment</th>
                    <th>Type</th>
                    <th>Amount</th>
                    <th>%</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
            {% for item in items %}
                <tr>

                    <td>{{ item.managementId }}</td>

                    <td>
                        <strong>{{ item.investment.name }}</strong>
                    </td>

                    <td>{{ item.investmentType }}</td>

                    <td>💰 {{ item.amountInvested }} TND</td>

                    <td>{{ item.ownershipPercentage }}%</td>

                    <td>
                        {{ item.startDate ? item.startDate|date('d M Y') : '' }}
                    </td>

                    <td>
                        {% if item.status == 'ACTIVE' %}
                            <span class="badge bg-success">Active</span>
                        {% else %}
                            <span class="badge bg-danger">Closed</span>
                        {% endif %}
                    </td>

                    <td class="d-flex gap-2">

                        <a class="btn btn-sm btn-info"
                           href="{{ path('app_management_show', {'managementId': item.managementId}) }}">
                           👁
                        </a>

                        <a class="btn btn-sm btn-warning"
                           href="{{ path('app_management_edit', {'managementId': item.managementId}) }}">
                           ✏️
                        </a>

                        {{ include('investment_management/_delete_form.html.twig', {'item': item}) }}

                    </td>

                </tr>
            {% else %}
                <tr>
                    <td colspan="8" class="text-center text-muted">
                        🚫 No records found
                    </td>
                </tr>
            {% endfor %}
            </tbody>

        </table>

    </div>

</div>

{% endblock %}