{% extends 'base.html.twig' %}

{% block title %}Investment Management{% endblock %}

{% block body %}

<div class="container mt-4">

    <h1 class="mb-4 fw-bold text-primary">📊 Investment Management</h1>

    {% set role = app.session.get('role') %}

    <!-- FILTER -->
    <form method="get" class="row g-2 mb-4">

        <div class="col-md-6">
            <input type="text" name="search" class="form-control"
                   placeholder="Search..."
                   value="{{ app.request.get('search') }}">
        </div>

        <div class="col-md-3">
            <select name="status" class="form-select">
                <option value="">All</option>
                <option value="ACTIVE" {{ app.request.get('status') == 'ACTIVE' ? 'selected' }}>Active</option>
                <option value="CLOSED" {{ app.request.get('status') == 'CLOSED' ? 'selected' }}>Closed</option>
            </select>
        </div>

        <div class="col-md-3 d-flex gap-2">
            <button class="btn btn-primary w-100">Search</button>
            <a href="{{ path('app_management_index') }}" class="btn btn-outline-secondary w-100">Reset</a>
        </div>

    </form>

    <!-- ACTIONS -->
    <div class="d-flex justify-content-between mb-3">

        <div class="d-flex gap-2">

            <a href="{{ path('app_investment_index') }}" class="btn btn-outline-primary">
                💼 Investments
            </a>

            {% if role == 'investisseur' %}
                <a href="{{ path('app_management_new') }}" class="btn btn-success">
                    ➕ New
                </a>
            {% endif %}

        </div>

        <a href="{{ path('admin_dashboard') }}" class="btn btn-dark">
            📊 Dashboard
        </a>

    </div>

    <!-- TABLE -->
    <div class="card shadow-sm p-3">

        <table class="table table-hover text-center align-middle">

            <thead class="table-dark">
                <tr>
                    <th>Investment</th>
                    <th>Type</th>
                    <th>Amount</th>
                    <th>%</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

            {% for item in investment_managements %}
                <tr>

                    <td>
                        <strong>{{ item.investment ? item.investment.name : 'N/A' }}</strong>
                    </td>

                    <td>{{ item.investmentType ?? '-' }}</td>

                    <td class="text-success fw-bold">
                        {{ item.amountInvested ?? 0 }} TND
                    </td>

                    <td>{{ item.ownershipPercentage ?? 0 }}%</td>

                    <td>
                        {{ item.startDate ? item.startDate|date('Y-m-d') : '-' }}
                    </td>

                    <td>
                        {% if item.status == 'ACTIVE' %}
                            <span class="badge bg-success">Active</span>
                        {% else %}
                            <span class="badge bg-danger">Closed</span>
                        {% endif %}
                    </td>

                    <td class="d-flex justify-content-center gap-2">

                        <!-- VIEW -->
                        <a href="{{ path('app_management_show', {'id': item.id}) }}"
                           class="btn btn-sm btn-primary">👁️</a>

                        {% if role == 'investisseur' %}

                            <!-- EDIT -->
                            <a href="{{ path('app_management_edit', {'id': item.id}) }}"
                               class="btn btn-sm btn-warning">✏️</a>

                            <!-- DELETE -->
                            <form method="post"
                                  action="{{ path('app_management_delete', {'id': item.id}) }}"
                                  onsubmit="return confirm('Delete?');">

                                <input type="hidden"
                                       name="_token"
                                       value="{{ csrf_token('delete' ~ item.id) }}">

                                <button class="btn btn-sm btn-danger">🗑</button>
                            </form>

                        {% endif %}

                    </td>

                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="text-muted text-center">No data</td>
                </tr>
            {% endfor %}

            </tbody>

        </table>

    </div>

</div>

{% endblock %}