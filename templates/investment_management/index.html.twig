{% extends 'base.html.twig' %}

{% block title %}Investment Management{% endblock %}

{% block body %}

<div class="container mt-4">

    <h1 class="mb-4 fw-bold">Investment Management</h1>

    <!-- 🔍 SEARCH + FILTER -->
    <form method="get" class="row g-2 mb-4">

        <div class="col-md-6">
            <input type="text" name="search" class="form-control"
                   placeholder="Search investment..."
                   value="{{ app.request.get('search') }}">
        </div>

        <div class="col-md-3">
            <select name="status" class="form-select">
                <option value="ALL">All</option>
                <option value="ACTIVE" {{ app.request.get('status') == 'ACTIVE' ? 'selected' }}>Active</option>
                <option value="CLOSED" {{ app.request.get('status') == 'CLOSED' ? 'selected' }}>Closed</option>
            </select>
        </div>

        <div class="col-md-3 d-flex gap-2">
            <button class="btn btn-primary w-100">Search</button>
            <a href="{{ path('app_management_index') }}" class="btn btn-outline-secondary w-100">Reset</a>
        </div>

    </form>

    <!-- ACTIONS -->
    <div class="d-flex justify-content-between mb-3">

        <a href="{{ path('app_management_new') }}" class="btn btn-success">
            New Investment
        </a>

        <a href="{{ path('app_management_dashboard') }}" class="btn btn-dark">
            Dashboard
        </a>

    </div>

    <div class="card shadow-sm border-0 p-3">

        <table class="table table-hover align-middle">

            <thead class="table-dark text-center">
                <tr>
                    <th>Investment</th>
                    <th>Type</th>
                    <th>Amount</th>
                    <th>%</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody class="text-center">
            {% for item in items %}
                <tr>

                    <!-- ✅ ID + NAME -->
                    <td class="text-start">
                        <span class="badge bg-dark mb-1">
                            #{{ item.managementId }}
                        </span><br>

                        {% if item.investment %}
                            <strong class="text-primary">
                                {{ item.investment.name }}
                            </strong>
                        {% else %}
                            <span class="text-muted">N/A</span>
                        {% endif %}
                    </td>

                    <!-- TYPE -->
                    <td>{{ item.investmentType }}</td>

                    <!-- AMOUNT -->
                    <td class="fw-semibold text-primary">
                        {{ item.amountInvested }} TND
                    </td>

                    <!-- PERCENT -->
                    <td>{{ item.ownershipPercentage }}%</td>

                    <!-- DATE -->
                    <td>
                        {{ item.startDate ? item.startDate|date('d M Y') : '' }}
                    </td>

                    <!-- STATUS -->
                    <td>
                        {% if item.status == 'ACTIVE' %}
                            <span class="badge bg-success px-3 py-2">Active</span>
                        {% else %}
                            <span class="badge bg-danger px-3 py-2">Closed</span>
                        {% endif %}
                    </td>

                    <!-- ACTIONS -->
                    <td class="d-flex justify-content-center gap-2">

                        <a class="btn btn-sm btn-info text-white"
                           href="{{ path('app_management_show', {'managementId': item.managementId}) }}">
                           View
                        </a>

                        <a class="btn btn-sm btn-warning text-white"
                           href="{{ path('app_management_edit', {'managementId': item.managementId}) }}">
                           Edit
                        </a>

                        {{ include('investment_management/_delete_form.html.twig', {'item': item}) }}

                    </td>

                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="text-center text-muted">
                        No records found
                    </td>
                </tr>
            {% endfor %}
            </tbody>

        </table>

    </div>

</div>

{% endblock %}