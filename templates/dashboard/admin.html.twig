{% extends 'admin/base.html.twig' %}

{% block title %}Tableau de Bord - Appels d'Offres{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold text-dark">Tableau de Bord des Appels d'Offres</h1>
            <p class="text-muted mb-0">Gestion centralisée des opportunités et des candidatures.</p>
        </div>
        <div class="text-end">
            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill">
                <i class="bi bi-shield-check me-1 small"></i> Mode Administration
            </span>
        </div>
    </div>

    <!-- ROW 1: Quick Stats -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-3" style="border-radius: 15px;">
                <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-3 text-primary me-3">
                        <i class="bi bi-file-earmark-text fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold">Appels d'Offre</div>
                        <div class="h4 fw-bold mb-0">{{ totalAppels }}</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-3" style="border-radius: 15px;">
                <div class="d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 p-3 rounded-3 text-success me-3">
                        <i class="bi bi-people fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold">Candidatures</div>
                        <div class="h4 fw-bold mb-0">{{ totalCandidatures }}</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-3" style="border-radius: 15px;">
                <div class="d-flex align-items-center">
                    <div class="bg-info bg-opacity-10 p-3 rounded-3 text-info me-3">
                        <i class="bi bi-tags fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold">Catégories</div>
                        <div class="h4 fw-bold mb-0">{{ totalCategories }}</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-3" style="border-radius: 15px;">
                <div class="d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 p-3 rounded-3 text-warning me-3">
                        <i class="bi bi-person-check fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold">Utilisateurs</div>
                        <div class="h4 fw-bold mb-0">{{ totalUsers }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ROW 2: Insights (The Pies) -->
    <div class="row g-4 mb-4">
        <!-- Category Distribution Pie -->
        <div class="col-xl-12">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 20px;">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-uppercase text-muted small mb-4 text-center">Répartition des Appels d'Offres par Catégorie</h6>
                    <div id="categoryPieChart" style="min-height: 350px;"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- ROW 3: Business & Opportunities -->
    <div class="row g-4">
        <!-- Appels d'Offres -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm" style="border-radius: 20px;">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">Appels d'Offre</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3 mb-4 text-center">
                        <div class="col-4">
                            <div class="p-3 bg-light rounded-4">
                                <div class="h4 fw-bold mb-0">{{ totalAppels }}</div>
                                <div class="xsmall text-muted">Total</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-3 bg-success-soft rounded-4">
                                <div class="h4 fw-bold text-success mb-0">{{ appelPublies }}</div>
                                <div class="xsmall text-success">En cours</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-3 bg-danger-soft rounded-4">
                                <div class="h4 fw-bold text-danger mb-0">{{ appelClotures }}</div>
                                <div class="xsmall text-danger">Clôturés</div>
                            </div>
                        </div>
                    </div>
                    <div class="list-group list-group-flush">
                        {% for appel in derniersAppels %}
                        <a href="{{ path('app_appel_offre_show', {'id': appel.id, 'role': 'admin'}) }}" class="list-group-item list-group-item-action border-0 px-0 d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-bold small">{{ appel.titre }}</div>
                                <div class="xsmall text-muted">{{ appel.createdAt|date('d M Y') }}</div>
                            </div>
                            <i class="bi bi-chevron-right text-muted"></i>
                        </a>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        <!-- Candidatures -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm" style="border-radius: 20px;">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">Candidatures</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3 mb-4 text-center">
                        <div class="col-4">
                            <div class="p-3 bg-light rounded-4">
                                <div class="h4 fw-bold mb-0">{{ totalCandidatures }}</div>
                                <div class="xsmall text-muted">Total</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-3 bg-warning-soft rounded-4">
                                <div class="h4 fw-bold text-warning mb-0">{{ candidaturesEnAttente }}</div>
                                <div class="xsmall text-warning">Pending</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-3 bg-success-soft rounded-4">
                                <div class="h4 fw-bold text-success mb-0">{{ candidaturesAcceptees }}</div>
                                <div class="xsmall text-success">Success</div>
                            </div>
                        </div>
                    </div>
                    <div class="list-group list-group-flush">
                        {% for candidature in dernieresCandidatures %}
                        <a href="{{ path('app_candidature_show', {'id': candidature.id, 'role': 'admin'}) }}" class="list-group-item list-group-item-action border-0 px-0 d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 35px; height: 35px;">
                                    <i class="bi bi-person small"></i>
                                </div>
                                <div>
                                    <div class="fw-bold small">{{ (candidature.user and candidature.user is defined) ? candidature.user.username : 'Anonyme' }}</div>
                                    <div class="xsmall text-muted">Postulé le {{ candidature.createdAt|date('d/m/Y') }}</div>
                                </div>
                            </div>
                            <span class="badge {{ candidature.statut == 'accepted' ? 'bg-success' : (candidature.statut == 'rejected' ? 'bg-danger' : 'bg-warning text-dark') }} rounded-pill xsmall">
                                {{ candidature.statut|capitalize }}
                            </span>
                        </a>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-success-soft { background: rgba(16, 185, 129, 0.1); }
    .bg-danger-soft { background: rgba(239, 68, 68, 0.1); }
    .bg-warning-soft { background: rgba(245, 158, 11, 0.1); }
    .bg-primary-soft { background: rgba(99, 102, 241, 0.1); }
    .xsmall { font-size: 0.75rem; }
    .hover-bg-light:hover { background-color: #f8f9fa !important; }
    .transition-all { transition: all 0.3s ease; }
    .avatar-sm { width: 40px; height: 40px; }
</style>

{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // 1. Category Pie Chart
        var catOptions = {
            series: [{% for stat in categoryStats %}{{ stat.count }}{{ not loop.last ? ',' : '' }}{% endfor %}],
            chart: {
                type: 'donut',
                height: 250
            },
            labels: [{% for stat in categoryStats %}"{{ stat.name }}"{{ not loop.last ? ',' : '' }}{% endfor %}],
            colors: ['#6366f1', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899'],
            legend: {
                position: 'bottom'
            },
            plotOptions: {
                pie: {
                    donut: {
                        size: '70%'
                    }
                }
            },
            dataLabels: {
                enabled: false
            }
        };
        var catChart = new ApexCharts(document.querySelector("#categoryPieChart"), catOptions);
        catChart.render();
    });
</script>
{% endblock %}
