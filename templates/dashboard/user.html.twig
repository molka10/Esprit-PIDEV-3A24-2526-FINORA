{% extends 'base.html.twig' %}

{% block title %}Tableau de Bord — FINORA{% endblock %}

{% block breadcrumb %}Tableau de Bord{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <!-- Welcome Section -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-lg p-4 p-md-5 text-white position-relative overflow-hidden" 
                 style="background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); border-radius: 24px;">
                <!-- Decorative Circle -->
                <div class="position-absolute top-0 end-0 mt-n5 me-n5 bg-white bg-opacity-10 rounded-circle" style="width: 200px; height: 200px;"></div>
                
                <div class="row align-items-center position-relative">
                    <div class="col-md-8">
                        <span class="badge bg-white bg-opacity-20 text-white mb-3 px-3 py-2 rounded-pill">Aperçu Quotidien</span>
                        <h1 class="text-white display-5 fw-bold mb-2">Bon retour, {{ app.user.username }} ! 👋</h1>
                        <p class="lead mb-0 opacity-80">Votre écosystème financier est sous contrôle. Voici vos performances actuelles.</p>
                    </div>
                    <div class="col-md-4 text-md-end mt-4 mt-md-0">
                        <div class="d-flex gap-3 justify-content-md-end">
                            <a href="{{ path('app_gamification') }}" class="btn btn-glass btn-lg px-4" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.3); color: white; border-radius: 14px;">
                                <i class="bi bi-trophy-fill me-2"></i>Badges
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Smart Learning Recommendations (CONTEXTUAL CAROUSEL) -->
    {% if recommendations is defined and recommendations|length > 0 %}
    <div class="row mb-4">
        <div class="col-12">
            <div id="smartRecCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner" style="border-radius: 24px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
                    {% for rec in recommendations %}
                    <div class="carousel-item {{ loop.first ? 'active' : '' }}">
                        <div class="card border-0 position-relative" style="background: white; border-radius: 24px;">
                            <div class="card-body p-0">
                                <div class="row g-0 align-items-center">
                                    <div class="col-md-auto p-4 d-flex align-items-center justify-content-center" style="background: rgba(99, 102, 241, 0.05); min-width: 100px;">
                                        <div class="icon-circle bg-primary text-white fs-2 shadow-sm" style="width: 60px; height: 60px; display: flex; align-items:center; justify-content:center; border-radius: 18px;">
                                            <i class="bi {{ rec.icon }}"></i>
                                        </div>
                                    </div>
                                    <div class="col-md p-4">
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            <span class="badge bg-warning bg-opacity-10 text-warning xsmall fw-bold px-2 py-1 rounded-pill">
                                                <i class="bi bi-stars me-1"></i>RECOMMANDATION SMART {{ recommendations|length > 1 ? '#' ~ loop.index : '' }}
                                            </span>
                                        </div>
                                        <h5 class="fw-bold text-dark mb-1">{{ rec.title }}</h5>
                                        <p class="text-muted small mb-0">{{ rec.reason }}</p>
                                    </div>
                                    <div class="col-md-auto p-4">
                                        {% if rec.formation %}
                                            <a href="{{ path('app_formation_show', {id: rec.formation.id}) }}" class="btn btn-primary rounded-pill px-4 fw-bold">
                                                Apprendre & Agir <i class="bi bi-arrow-right ms-2"></i>
                                            </a>
                                        {% else %}
                                            <a href="{{ path('app_formations', {categorie: rec.category_slug}) }}" class="btn btn-outline-primary rounded-pill px-4 fw-bold">
                                                Explorer {{ rec.category_slug }}
                                            </a>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <!-- Subtle side accent -->
                            <div class="position-absolute top-0 bottom-0 start-0" style="width: 4px; background: #6366f1;"></div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
                {% if recommendations|length > 1 %}
                <button class="carousel-control-prev" type="button" data-bs-target="#smartRecCarousel" data-bs-slide="prev" style="width: 5%;">
                    <span class="carousel-control-prev-icon bg-dark rounded-circle" aria-hidden="true" style="width: 30px; height: 30px;"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#smartRecCarousel" data-bs-slide="next" style="width: 5%;">
                    <span class="carousel-control-next-icon bg-dark rounded-circle" aria-hidden="true" style="width: 30px; height: 30px;"></span>
                </button>
                {% endif %}
            </div>
        </div>
    </div>
    {% endif %}

    <!-- Stats Grid -->
    <div class="row g-4 mb-4">
        <!-- Solde Bourse (Volume) -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm p-4 h-100 transition-up" style="border-radius: 20px;">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-4">
                        <i class="bi bi-graph-up-arrow fs-4"></i>
                    </div>
                    <span class="badge bg-success-soft text-success">+12%</span>
                </div>
                <h6 class="text-muted small text-uppercase fw-bold mb-1">Volume Bourse Total</h6>
                <h3 class="fw-bold mb-0">{{ convert_currency(stats.bourseVolume, current_currency())|format_currency(current_currency()) }}</h3>
            </div>
        </div>

        <!-- Wallet Transactions -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm p-4 h-100 transition-up" style="border-radius: 20px;">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="bg-info bg-opacity-10 text-info p-3 rounded-4">
                        <i class="bi bi-wallet2 fs-4"></i>
                    </div>
                    <span class="text-muted small">Mois en cours</span>
                </div>
                <h6 class="text-muted small text-uppercase fw-bold mb-1">Transactions Wallet</h6>
                <h3 class="fw-bold mb-0">{{ stats.walletTransactions }} <span class="fs-6 fw-normal">Actions</span></h3>
            </div>
        </div>

        <!-- Investissements Actifs -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm p-4 h-100 transition-up" style="border-radius: 20px;">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="bg-success bg-opacity-10 text-success p-3 rounded-4">
                        <i class="bi bi-cash-stack fs-4"></i>
                    </div>
                    <span class="badge bg-primary-soft text-primary">Actifs</span>
                </div>
                <h6 class="text-muted small text-uppercase fw-bold mb-1">Investissements</h6>
                <h3 class="fw-bold mb-0">{{ stats.investmentsCount }} <span class="fs-6 fw-normal">Projets</span></h3>
            </div>
        </div>

        <!-- Candidatures -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm p-4 h-100 transition-up" style="border-radius: 20px;">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="bg-warning bg-opacity-10 text-warning p-3 rounded-4">
                        <i class="bi bi-megaphone fs-4"></i>
                    </div>
                </div>
                <h6 class="text-muted small text-uppercase fw-bold mb-1">Appels d'Offres</h6>
                <h3 class="fw-bold mb-0">{{ stats.candidaturesCount }} <span class="fs-6 fw-normal">Soumis</span></h3>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Recent Bourse Activity -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm" style="border-radius: 20px;">
                <div class="card-header bg-transparent border-0 p-4 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">Dernières Activités Bourse</h5>
                    <a href="{{ path('app_history') }}" class="btn btn-sm btn-light rounded-pill px-3">Tout voir</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light bg-opacity-50">
                                <tr>
                                    <th class="border-0 ps-4 py-3">Action</th>
                                    <th class="border-0 py-3">Type</th>
                                    <th class="border-0 py-3">Montant</th>
                                    <th class="border-0 py-3">Date</th>
                                    <th class="border-0 py-3">Statut</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for transaction in recentTransactions %}
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <span class="fw-semibold">{{ transaction.action.symbole }}</span>
                                            <span class="small text-muted ms-2">{{ transaction.action.nomEntreprise }}</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge {{ transaction.typeTransaction == 'ACHAT' ? 'bg-success-soft text-success' : 'bg-danger-soft text-danger' }} rounded-pill px-3">
                                            {{ transaction.typeTransaction == 'ACHAT' ? 'Achat' : 'Vente' }}
                                        </span>
                                    </td>
                                    <td><span class="fw-bold">{{ transaction.montantTotal|format_currency }}</span></td>
                                    <td class="text-muted small">{{ transaction.dateTransaction|date('d M Y, H:i') }}</td>
                                    <td><i class="bi bi-check-circle-fill text-success me-1"></i> Confirmé</td>
                                </tr>
                                {% else %}
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <i class="bi bi-inbox fs-2 d-block mb-2 opacity-50"></i>
                                        Aucune transaction récente
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 20px;">
                <div class="card-header bg-transparent border-0 p-4 pb-0">
                    <h5 class="mb-0 fw-bold">Actions Rapides</h5>
                </div>
                <div class="card-body p-4">
                    <div class="d-grid gap-3">
                        <a href="{{ path('app_market') }}" class="btn btn-primary w-100 py-3 rounded-4 d-flex align-items-center justify-content-between px-4 group">
                            <div class="text-start">
                                <div class="fw-bold">Bourse Live</div>
                                <div class="small opacity-80">Marché en direct</div>
                            </div>
                            <i class="bi bi-arrow-right fs-4"></i>
                        </a>
                        <a href="{{ path('dashboard') }}" class="btn btn-info w-100 py-3 text-white rounded-4 d-flex align-items-center justify-content-between px-4">
                            <div class="text-start">
                                <div class="fw-bold">Gestion Wallet</div>
                                <div class="small opacity-80">Suivre vos flux</div>
                            </div>
                            <i class="bi bi-arrow-right fs-4"></i>
                        </a>
                        <a href="{{ path('app_investment_index') }}" class="btn btn-success w-100 py-3 rounded-4 d-flex align-items-center justify-content-between px-4">
                            <div class="text-start">
                                <div class="fw-bold">Opportunités</div>
                                <div class="small opacity-80">Nouvelles offres</div>
                            </div>
                            <i class="bi bi-arrow-right fs-4"></i>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Trophies Preview -->
            <div class="card border-0 shadow-sm" style="border-radius: 20px; background: rgba(255,255,255,0.7); backdrop-filter: blur(10px);">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3"><i class="bi bi-award text-warning me-2"></i>Badges récents</h6>
                    <div class="d-flex gap-2">
                        {% set unlocked_count = 0 %}
                        {% for badge in badges %}
                            {% if badge.unlocked %}
                                {% set unlocked_count = unlocked_count + 1 %}
                                <div class="avatar avatar-md bg-white shadow-sm d-flex align-items-center justify-content-center rounded-circle border border-2" 
                                     style="border-color: {{ badge.color }} !important; width: 45px; height: 45px; font-size: 1.5rem;"
                                     data-bs-toggle="tooltip" title="{{ badge.name }}: {{ badge.description }}">
                                    {{ badge.icon }}
                                </div>
                            {% endif %}
                        {% endfor %}

                        {% if unlocked_count == 0 %}
                            <p class="small text-muted mb-0">Continuez à utiliser Finora pour gagner des badges !</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-primary-soft { background: rgba(99, 102, 241, 0.1); }
    .bg-success-soft { background: rgba(16, 185, 129, 0.1); }
    .bg-info-soft { background: rgba(6, 182, 212, 0.1); }
    .bg-warning-soft { background: rgba(245, 158, 11, 0.1); }
    .bg-danger-soft { background: rgba(239, 68, 68, 0.1); }
    
    .transition-up { transition: transform 0.3s ease; }
    .transition-up:hover { transform: translateY(-5px); }
    
    .btn-glass:hover { background: rgba(255,255,255,0.3) !important; }
</style>
{% endblock %}