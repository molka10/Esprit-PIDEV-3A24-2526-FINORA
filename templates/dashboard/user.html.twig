{% extends 'base.html.twig' %}


{% block title %}Tableau de Bord — FINORA{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row g-4 mb-4">
    <!-- Welcome Section -->
    <div class="col-12">
        <div class="card border-0 shadow-sm p-4 text-white" style="background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%); border-radius: 20px;">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h2 class="text-white mb-1">Bienvenue, {{ app.user.username }} ! 👋</h2>
                    <p class="mb-0 opacity-80">Ravi de vous revoir. Voici un aperçu de vos activités et du marché boursier aujourd'hui.</p>
                </div>
                <div class="col-md-4 text-md-end mt-3 mt-md-0">
                    <a href="{{ path('app_profile') }}" class="btn btn-white btn-sm text-primary px-4 py-2" style="border-radius: 10px; font-weight: 600;">Mon Profil</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Stats Widgets -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 16px;">
            <div class="d-flex align-items-center mb-3">
                <div class="icon-md bg-primary-soft text-primary rounded-3 me-3">
                    <i class="bi bi-wallet2 fs-4"></i>
                </div>
                <h6 class="mb-0">Solde Cash</h6>
            </div>
            <h3 class="mb-1">2,450.00 <span class="fs-6 text-muted">TND</span></h3>
            <p class="text-success mb-0 small"><i class="bi bi-arrow-up me-1"></i>+12.5% depuis le mois dernier</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 16px;">
            <div class="d-flex align-items-center mb-3">
                <div class="icon-md bg-success-soft text-success rounded-3 me-3">
                    <i class="bi bi-graph-up-arrow fs-4"></i>
                </div>
                <h6 class="mb-0">Valeur Portefeuille</h6>
            </div>
            <h3 class="mb-1">15,840.50 <span class="fs-6 text-muted">TND</span></h3>
            <p class="text-success mb-0 small"><i class="bi bi-arrow-up me-1"></i>+5.2% cette semaine</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 16px;">
            <div class="d-flex align-items-center mb-3">
                <div class="icon-md bg-info-soft text-info rounded-3 me-3">
                    <i class="bi bi-clock-history fs-4"></i>
                </div>
                <h6 class="mb-0">Transactions</h6>
            </div>
            <h3 class="mb-1">42</h3>
            <p class="text-muted mb-0 small">Effectuées ce mois-ci</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 16px;">
            <div class="d-flex align-items-center mb-3">
                <div class="icon-md bg-warning-soft text-warning rounded-3 me-3">
                    <i class="bi bi-star fs-4"></i>
                </div>
                <h6 class="mb-0">Liste de suivi</h6>
            </div>
            <h3 class="mb-1">8</h3>
            <p class="text-muted mb-0 small">Actions surveillées</p>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Main Content Grid -->
                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                        <div class="card-header bg-transparent border-0 p-4 pb-0">
                            <h5 class="mb-0">Aperçu du Marché</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="row g-3">
                                <!-- Card Bourse -->
                                <div class="col-md-4">
                                    <div class="card border-0 shadow-sm p-4 text-center h-100 card-hover" style="border-radius: 16px;">
                                        <div class="icon-lg bg-primary-soft text-primary mx-auto mb-3">
                                            <i class="bi bi-graph-up-arrow fs-3"></i>
                                        </div>
                                        <h6 class="mb-1">Bourse</h6>
                                        <p class="small text-muted mb-0">Track market trends</p>
                                    </div>
                                </div>
                                <!-- Card Wallet -->
                                <div class="col-md-4">
                                    <div class="card border-0 shadow-sm p-4 text-center h-100 card-hover" style="border-radius: 16px;">
                                        <div class="icon-lg bg-info-soft text-info mx-auto mb-3">
                                            <i class="bi bi-wallet2 fs-3"></i>
                                        </div>
                                        <h6 class="mb-1">Wallet</h6>
                                        <p class="small text-muted mb-0">Manage your funds</p>
                                    </div>
                                </div>
                                <!-- Card Invest -->
                                <div class="col-md-4">
                                    <div class="card border-0 shadow-sm p-4 text-center h-100 card-hover" style="border-radius: 16px;">
                                        <div class="icon-lg bg-success-soft text-success mx-auto mb-3">
                                            <i class="bi bi-cash-stack fs-3"></i>
                                        </div>
                                        <h6 class="mb-1">Invest</h6>
                                        <p class="small text-muted mb-0">Grow your money</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>


    <!-- Quick Actions / Sidebar in Dashboard -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
            <div class="card-header bg-transparent border-0 p-4 pb-0">
                <h5 class="mb-0">Actions Rapides</h5>
            </div>
            <div class="card-body p-4">
                <div class="d-grid gap-3">
                    <a href="{{ path('app_market') }}" class="btn btn-primary-soft w-100 p-3 text-start d-flex align-items-center">
                        <i class="bi bi-shop fs-4 me-3"></i>
                        <div>
                            <div class="fw-bold">Acheter des actions</div>
                            <div class="small opacity-70">Explorer le marché live</div>
                        </div>
                    </a>
                    <a href="{{ path('app_history') }}" class="btn btn-info-soft w-100 p-3 text-start d-flex align-items-center">
                        <i class="bi bi-receipt fs-4 me-3"></i>
                        <div>
                            <div class="fw-bold">Mes Transactions</div>
                            <div class="small opacity-70">Voir l'historique complet</div>
                        </div>
                    </a>
                    <a href="#" class="btn btn-success-soft w-100 p-3 text-start d-flex align-items-center">
                        <i class="bi bi-plus-circle fs-4 me-3"></i>
                        <div>
                            <div class="fw-bold">Déposer des fonds</div>
                            <div class="small opacity-70">Alimenter votre compte</div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}