{% extends 'base.html.twig' %}

{% block title %}Espace Entreprise — FINORA{% endblock %}

{% block body %}
<div class="container py-5">
<div class="row g-4 mb-4">

    <!-- Welcome Section -->
    <div class="col-12">
        <div class="card border-0 shadow-sm p-5 text-white position-relative overflow-hidden" style="background: linear-gradient(135deg, #1e1b4b 0%, #3b1278 100%); border-radius: 24px;">
            <!-- Abstract background shape -->
            <div class="position-absolute top-0 end-0 mt-n5 me-n5 opacity-10">
                <i class="bi bi-briefcase" style="font-size: 200px;"></i>
            </div>
            
            <div class="row align-items-center position-relative">
                <div class="col-lg-8">
                    <h1 class="text-white mb-2 display-6 fw-bold">Espace Entreprise : {{ app.user.username }} ! 🏢</h1>
                    <p class="mb-0 fs-5 opacity-80 fw-light">Gérez vos appels d'offres, vos investissements et suivez vos performances financières avec précision.</p>
                </div>
                <div class="col-lg-4 text-lg-end mt-4 mt-lg-0 d-flex gap-3 justify-content-lg-end">
                    <a href="{{ path('app_gamification') }}" class="btn btn-warning btn-lg text-dark px-4" style="border-radius: 12px; font-weight: 700; transition: all 0.3s ease;">
                        <i class="bi bi-award-fill me-2"></i>Trophées
                    </a>
                    <a href="{{ path('app_profile') }}" class="btn btn-white btn-lg text-primary px-4" style="border-radius: 12px; font-weight: 700; transition: all 0.3s ease;">
                        Profil Entreprise
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>



<div class="row g-4 mb-4">
    <!-- Stats Widgets for Entreprise -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4 h-100 card-hover" style="border-radius: 18px; border-bottom: 4px solid #7c3aed !important;">
            <div class="d-flex align-items-center mb-3">
                <div class="icon-lg bg-primary-soft text-primary rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                    <i class="bi bi-briefcase fs-4"></i>
                </div>
                <h6 class="mb-0 fw-bold text-secondary">Appels d'offres</h6>
            </div>
            <h3 class="mb-1 fw-bold">{{ appelPublies }}</h3>
            <p class="text-success mb-0 small fw-semibold"><i class="bi bi-plus-circle me-1"></i>Projets actifs</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4 h-100 card-hover" style="border-radius: 18px; border-bottom: 4px solid #10b981 !important;">
            <div class="d-flex align-items-center mb-3">
                <div class="icon-lg bg-success-soft text-success rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                    <i class="bi bi-cash-stack fs-4"></i>
                </div>
                <h6 class="mb-0 fw-bold text-secondary">Budget Engagé</h6>
            </div>
            <h3 class="mb-1 fw-bold">45,000 <span class="fs-6 text-muted">TND</span></h3>
            <p class="text-muted mb-0 small fw-semibold">Sur les projets actifs</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4 h-100 card-hover" style="border-radius: 18px; border-bottom: 4px solid #0ea5e9 !important;">
            <div class="d-flex align-items-center mb-3">
                <div class="icon-lg bg-info-soft text-info rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                    <i class="bi bi-people fs-4"></i>
                </div>
                <h6 class="mb-0 fw-bold text-secondary">Candidatures</h6>
            </div>
            <h3 class="mb-1 fw-bold">{{ totalCandidatures }}</h3>
            <p class="text-muted mb-0 small fw-semibold">{{ candidaturesEnAttente }} en attente</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4 h-100 card-hover" style="border-radius: 18px; border-bottom: 4px solid #f59e0b !important;">
            <div class="d-flex align-items-center mb-3">
                <div class="icon-lg bg-warning-soft text-warning rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                    <i class="bi bi-graph-up fs-4"></i>
                </div>
                <h6 class="mb-0 fw-bold text-secondary">Score Crédit</h6>
            </div>
            <h3 class="mb-1 fw-bold">A+</h3>
            <p class="text-success mb-0 small fw-semibold">Excellent</p>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Main Content Grid -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm" style="border-radius: 16px;">
            <div class="card-header bg-transparent border-0 p-4 pb-0">
                <h5 class="mb-0">Activités Récentes</h5>
            </div>
            <div class="card-body p-4">
                <div class="text-center py-5">
                    <img src="https://illustrations.popsy.co/purple/business-analysis.svg" alt="Illustration" style="height: 150px;" class="mb-3">
                    <p class="text-muted">Vos statistiques de marché et appels d'offres apparaîtront ici.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
            <div class="card-header bg-transparent border-0 p-4 pb-0">
                <h5 class="mb-0">Actions Entreprise</h5>
            </div>
            <div class="card-body p-4">
                <div class="d-grid gap-3">
                    <a href="{{ path('app_market') }}" class="btn btn-info-soft w-100 p-3 text-start d-flex align-items-center">
                        <i class="bi bi-graph-up-arrow fs-4 me-3"></i>
                        <div>
                            <div class="fw-bold">Investir en Bourse</div>
                            <div class="small opacity-70">Gérer l'excédent de trésorerie</div>
                        </div>
                    </a>
                    <a href="#" class="btn btn-success-soft w-100 p-3 text-start d-flex align-items-center">
                        <i class="bi bi-file-earmark-bar-graph fs-4 me-3"></i>
                        <div>
                            <div class="fw-bold">Rapports Financiers</div>
                            <div class="small opacity-70">Export PDF & Excel</div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
</div>
{% endblock %}