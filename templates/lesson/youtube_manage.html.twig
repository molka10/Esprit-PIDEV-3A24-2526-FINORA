{% extends 'admin/base.html.twig' %}

{% block title %}Gérer la vidéo YouTube{% endblock %}

{% block body %}
<div class="container py-4">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert {% if label == 'success' %}alert-success{% elseif label == 'danger' %}alert-danger{% else %}alert-info{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
                <div>
                    <h1 class="h3 mb-1">Gérer la vidéo YouTube</h1>
                    <p class="text-muted mb-0">
                        Lesson : <strong>{{ lesson.titre }}</strong>
                    </p>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <a href="{{ path('app_lesson_edit', {'id': lesson.id}) }}" class="btn btn-outline-secondary">
                        Retour à la modification
                    </a>
                </div>
            </div>

            {% if lesson.videoUrl %}
                <div class="alert alert-info">
                    <strong>Vidéo actuellement liée :</strong> {{ lesson.videoUrl }}
                </div>
            {% endif %}

            <form method="get" action="{{ path('app_lesson_youtube_manage', {'id': lesson.id}) }}" class="row g-3 align-items-end">
                <div class="col-lg-7">
                    <label class="form-label">Recherche</label>
                    <input
                        type="text"
                        name="q"
                        class="form-control"
                        value="{{ query }}"
                        placeholder="Chercher une vidéo YouTube"
                    >
                </div>

                <div class="col-lg-3">
                    <label class="form-label">Tri</label>
                    <select name="sort" class="form-select">
                        <option value="relevance" {{ sort == 'relevance' ? 'selected' : '' }}>Pertinence</option>
                        <option value="date" {{ sort == 'date' ? 'selected' : '' }}>Date</option>
                        <option value="viewCount" {{ sort == 'viewCount' ? 'selected' : '' }}>Vues</option>
                        <option value="rating" {{ sort == 'rating' ? 'selected' : '' }}>Note</option>
                        <option value="title" {{ sort == 'title' ? 'selected' : '' }}>Titre</option>
                    </select>
                </div>

                <div class="col-lg-2">
                    <button class="btn btn-primary w-100" type="submit">Rechercher</button>
                </div>
            </form>

            {% if lesson.youTubeVideoId %}
                <div class="mt-4">
                    <form method="post" action="{{ path('app_lesson_youtube_remove', {'id': lesson.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('remove_youtube_' ~ lesson.id) }}">
                        <button type="submit" class="btn btn-outline-danger">
                            Supprimer la vidéo YouTube actuelle
                        </button>
                    </form>
                </div>
            {% endif %}
        </div>
    </div>

    {% if error %}
        <div class="alert alert-danger">{{ error }}</div>
    {% endif %}

    {% if query is not empty and results is empty and not error %}
        <div class="alert alert-warning">
            Aucun résultat trouvé pour cette recherche.
        </div>
    {% endif %}

    <div class="row g-4">
        {% for video in results %}
            <div class="col-md-6 col-xl-4">
                <div class="card h-100 border-0 shadow-sm">
                    {% if video.thumbnailUrl %}
                        <img
                            src="{{ video.thumbnailUrl }}"
                            class="card-img-top"
                            alt="{{ video.title }}"
                            style="height: 220px; object-fit: cover;"
                        >
                    {% endif %}

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">{{ video.title }}</h5>
                        <p class="text-muted small mb-3">
                            {{ video.channelTitle ?: 'Chaîne inconnue' }}
                        </p>

                        <div class="mt-auto d-flex gap-2 flex-wrap">
                            <a href="{{ video.url }}" target="_blank" class="btn btn-outline-primary btn-sm">
                                Ouvrir
                            </a>

                            <form method="post" action="{{ path('app_lesson_youtube_link', {'id': lesson.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('link_youtube_' ~ lesson.id) }}">
                                <input type="hidden" name="video_url" value="{{ video.url }}">
                                <button type="submit" class="btn btn-warning btn-sm">
                                    Associer à la lesson
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    <!-- Pagination controls -->
    <div class="d-flex justify-content-center mt-5">
        {{ knp_pagination_render(results) }}
    </div>
</div>
{% endblock %}
