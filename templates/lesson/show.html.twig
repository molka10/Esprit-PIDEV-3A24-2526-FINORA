{% extends 'base.html.twig' %}

{% block title %}{{ lesson.titre }} - FINORA{% endblock %}

{% block body %}
<header class="navbar-light navbar-sticky">
    <nav class="navbar navbar-expand-xl z-index-9">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}">
                <img class="light-mode-item navbar-brand-item" src="{{ asset('assets/images/logo.svg') }}" alt="logo">
                <img class="dark-mode-item navbar-brand-item" src="{{ asset('assets/images/logo-light.svg') }}" alt="logo">
            </a>

            <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                <span class="navbar-toggler-animation">
                    <span></span><span></span><span></span>
                </span>
            </button>

            <div class="navbar-collapse collapse" id="navbarCollapse">
                <ul class="navbar-nav navbar-nav-scroll ms-auto">
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}">Accueil</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_formations') }}">Formations</a></li>
                    <li class="nav-item"><a class="nav-link active" href="{{ path('app_lessons') }}">Lessons</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('admin_dashboard') }}">Dashboard</a></li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<main>
    <section class="py-5">
        <div class="container">
            <div class="mx-auto" style="max-width: 1200px;">

                <div class="card border-0 shadow-sm overflow-hidden mb-4">
                    <div class="p-4 p-md-5" style="background: linear-gradient(135deg, #ede9fe 0%, #f5f3ff 100%);">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                            <div>
                                <div class="small text-uppercase fw-bold mb-2" style="letter-spacing: 1px; color: #6d28d9;">
                                    Leçon {{ '%02d'|format(lesson.ordre) }}
                                </div>
                                <h1 class="h2 mb-3 fw-bold text-dark">{{ lesson.titre }}</h1>

                                <div class="d-flex gap-2 flex-wrap">
                                    <span class="badge rounded-pill px-3 py-2 bg-primary bg-opacity-10 text-primary">
                                        {{ lesson.formation ? lesson.formation.titre : 'Formation inconnue' }}
                                    </span>

                                    <span class="badge rounded-pill px-3 py-2 bg-success bg-opacity-10 text-success">
                                        {{ lesson.dureeMinutes }} min
                                    </span>

                                    {% if lesson.videoUrl %}
                                        <span class="badge rounded-pill px-3 py-2 bg-warning bg-opacity-10 text-warning">
                                            Vidéo disponible
                                        </span>
                                    {% endif %}
                                </div>
                            </div>

                            <div class="d-flex gap-2 flex-wrap">
                                <a href="{{ path('app_lessons') }}" class="btn btn-light border">
                                    Retour
                                </a>

                                <a href="{{ path('app_lesson_pdf', {'id': lesson.id}) }}" class="btn btn-outline-primary">
                                    Exporter PDF
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-lg-8">
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body p-4 p-md-5">
                                {% if lesson.videoUrl %}
                                    <h3 class="h5 mb-3 fw-bold">Vidéo de la leçon</h3>

                                    {% set isYoutube = lesson.youTubeVideoId is not null %}

                                    {% if isYoutube %}
                                        <div class="mb-4">
                                            <iframe
                                                width="100%"
                                                height="420"
                                                src="https://www.youtube.com/embed/{{ lesson.youTubeVideoId }}"
                                                title="YouTube video player"
                                                frameborder="0"
                                                allowfullscreen
                                                style="border-radius: 16px;">
                                            </iframe>
                                        </div>
                                    {% elseif lesson.isUploadedVideo %}
                                        <div class="mb-4">
                                            <video controls style="width: 100%; border-radius: 16px;">
                                                <source src="{{ asset('uploads/lessons/videos/' ~ lesson.videoUrl) }}">
                                                Votre navigateur ne supporte pas la lecture vidéo.
                                            </video>
                                        </div>
                                    {% else %}
                                        <div class="mb-4">
                                            <a href="{{ lesson.videoUrl }}" target="_blank" class="btn btn-warning">
                                                Ouvrir la vidéo
                                            </a>
                                        </div>
                                    {% endif %}
                                {% endif %}

                                <h3 class="h5 mb-3 fw-bold">Contenu</h3>
                                <div class="fs-6 text-secondary" style="white-space: pre-line; line-height: 1.9;">
                                    {{ lesson.contenu ?: 'Aucun contenu disponible.' }}
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="card border-0 shadow-sm" style="position: sticky; top: 100px;">
                            <div class="card-body p-4">
                                <h3 class="h5 fw-bold mb-3">Actions</h3>

                                <div class="d-grid gap-2">
                                    <a href="{{ path('app_lessons') }}" class="btn btn-secondary">
                                        Retour aux lessons
                                    </a>

                                    {% if lesson.formation %}
                                        <a href="{{ path('app_lessons', {'formation': lesson.formation.id}) }}" class="btn btn-primary">
                                            Voir les lessons de cette formation
                                        </a>
                                    {% endif %}

                                    <a href="{{ path('app_lesson_pdf', {'id': lesson.id}) }}" class="btn btn-outline-primary">
                                        Exporter en PDF
                                    </a>

                                    <a href="{{ path('app_lesson_related_videos', {'id': lesson.id}) }}" class="btn btn-warning">
                                        🎥 Vidéos recommandées
                                    </a>
                                </div>

                                <hr class="my-4">

                                <div>
                                    <h4 class="h6 fw-bold mb-3">Informations</h4>

                                    <div class="mb-3">
                                        <div class="small text-muted">Formation</div>
                                        <div class="fw-semibold">
                                            {{ lesson.formation ? lesson.formation.titre : 'Formation inconnue' }}
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="small text-muted">Ordre</div>
                                        <div class="fw-semibold">Leçon {{ '%02d'|format(lesson.ordre) }}</div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="small text-muted">Durée</div>
                                        <div class="fw-semibold">{{ lesson.dureeMinutes }} minutes</div>
                                    </div>

                                    <div>
                                        <div class="small text-muted">Vidéo</div>
                                        <div class="fw-semibold">
                                            {% if lesson.videoUrl %}
                                                Disponible
                                            {% else %}
                                                Non disponible
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>
</main>
{% endblock %}