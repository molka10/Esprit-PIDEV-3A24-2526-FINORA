{% extends 'base.html.twig' %}

{% block title %}{{ lesson.titre }} - FINORA{% endblock %}

{% block body %}
<header class="navbar-light navbar-sticky">
    <nav class="navbar navbar-expand-xl z-index-9">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}">
                <img class="light-mode-item navbar-brand-item" src="{{ asset('assets/images/logo.svg') }}" alt="logo">
                <img class="dark-mode-item navbar-brand-item" src="{{ asset('assets/images/logo-light.svg') }}" alt="logo">
            </a>

            <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                <span class="navbar-toggler-animation">
                    <span></span><span></span><span></span>
                </span>
            </button>

            <div class="navbar-collapse collapse" id="navbarCollapse">
                <ul class="navbar-nav navbar-nav-scroll ms-auto">
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}">Accueil</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_formations') }}">Formations</a></li>
                    <li class="nav-item"><a class="nav-link active" href="{{ path('app_lessons') }}">Lessons</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('admin_dashboard') }}">Dashboard</a></li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<main>
    <section class="py-5" style="background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);">
        <div class="container">
            <div class="mx-auto" style="max-width: 1240px;">

                <div class="card border-0 shadow-sm overflow-hidden mb-4">
                    <div class="p-4 p-md-5" style="background: linear-gradient(135deg, #ede9fe 0%, #f5f3ff 55%, #ffffff 100%);">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-4">
                            <div style="max-width: 760px;">
                                <div class="d-flex gap-2 flex-wrap mb-3">
                                    <span class="badge rounded-pill px-3 py-2" style="background:#ffffff; color:#6d28d9; font-weight:700;">
                                        Leçon {{ '%02d'|format(lesson.ordre) }}
                                    </span>

                                    <span class="badge rounded-pill px-3 py-2 bg-primary bg-opacity-10 text-primary">
                                        {{ lesson.formation ? lesson.formation.titre : 'Formation inconnue' }}
                                    </span>

                                    <span class="badge rounded-pill px-3 py-2 bg-success bg-opacity-10 text-success">
                                        {{ lesson.dureeMinutes }} min
                                    </span>

                                    {% if lesson.videoUrl %}
                                        <span class="badge rounded-pill px-3 py-2 bg-warning bg-opacity-10 text-warning">
                                            Vidéo disponible
                                        </span>
                                    {% else %}
                                        <span class="badge rounded-pill px-3 py-2 bg-secondary bg-opacity-10 text-secondary">
                                            Sans vidéo
                                        </span>
                                    {% endif %}
                                </div>

                                <h1 class="display-6 fw-bold mb-3 text-dark">{{ lesson.titre }}</h1>

                                <p class="mb-0 text-muted" style="max-width: 700px; line-height: 1.8;">
                                    Découvrez cette leçon dans un format plus clair et plus agréable, avec son contenu principal,
                                    sa vidéo associée et des ressources recommandées pour aller plus loin.
                                </p>
                            </div>

                            <div class="d-flex flex-column gap-2" style="min-width: 220px;">
                                <a href="{{ path('app_lessons') }}" class="btn btn-light border">
                                    Retour aux lessons
                                </a>

                                <a href="{{ path('app_lesson_pdf', {'id': lesson.id}) }}" class="btn btn-outline-primary">
                                    Exporter en PDF
                                </a>

                                <a href="{{ path('app_lesson_related_videos', {'id': lesson.id}) }}" class="btn btn-warning">
                                    🎥 Vidéos recommandées
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-lg-8">

                        {% if lesson.videoUrl %}
                            <div class="card border-0 shadow-sm mb-4 overflow-hidden">
                                <div class="card-header border-0 bg-white pt-4 px-4 px-md-5">
                                    <h2 class="h4 fw-bold mb-1">Vidéo de la leçon</h2>
                                    <p class="text-muted mb-0">Visionnez la ressource principale associée à cette leçon.</p>
                                </div>

                                <div class="card-body p-4 p-md-5 pt-3">
                                    {% set isYoutube = lesson.youTubeVideoId is not null %}

                                    {% if isYoutube %}
                                        <div class="ratio ratio-16x9 rounded-4 overflow-hidden shadow-sm">
                                            <iframe
                                                src="https://www.youtube.com/embed/{{ lesson.youTubeVideoId }}"
                                                title="YouTube video player"
                                                frameborder="0"
                                                allowfullscreen>
                                            </iframe>
                                        </div>
                                    {% elseif lesson.isUploadedVideo %}
                                        <div class="rounded-4 overflow-hidden shadow-sm">
                                            <video controls style="width:100%; display:block;">
                                                <source src="{{ asset('uploads/lessons/videos/' ~ lesson.videoUrl) }}">
                                                Votre navigateur ne supporte pas la lecture vidéo.
                                            </video>
                                        </div>
                                    {% else %}
                                        <div class="p-4 rounded-4" style="background:#fff7ed; border:1px solid #fed7aa;">
                                            <p class="mb-3 text-dark">
                                                Cette leçon contient une vidéo externe.
                                            </p>
                                            <a href="{{ lesson.videoUrl }}" target="_blank" class="btn btn-warning">
                                                Ouvrir la vidéo
                                            </a>
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endif %}

                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-header border-0 bg-white pt-4 px-4 px-md-5">
                                <h2 class="h4 fw-bold mb-1">Contenu de la leçon</h2>
                                <p class="text-muted mb-0">Prenez le temps de lire et comprendre les points clés.</p>
                            </div>

                            <div class="card-body p-4 p-md-5 pt-3">
                                <div
                                    class="fs-6 text-secondary"
                                    style="
                                        white-space: pre-line;
                                        line-height: 2;
                                        font-size: 1.02rem;
                                    "
                                >
                                    {{ lesson.contenu ?: 'Aucun contenu disponible.' }}
                                </div>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body p-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
                                <div>
                                    {% if previousLesson %}
                                        <a href="{{ path('app_lesson_show', {'id': previousLesson.id}) }}" class="btn btn-outline-secondary">
                                            ⬅️ {{ previousLesson.titre|length > 30 ? previousLesson.titre|slice(0, 30) ~ '...' : previousLesson.titre }}
                                        </a>
                                    {% else %}
                                        <span class="text-muted small">Première leçon</span>
                                    {% endif %}
                                </div>

                                <div>
                                    {% if nextLesson %}
                                        <a href="{{ path('app_lesson_show', {'id': nextLesson.id}) }}" class="btn btn-primary">
                                            {{ nextLesson.titre|length > 30 ? nextLesson.titre|slice(0, 30) ~ '...' : nextLesson.titre }} ➡️
                                        </a>
                                    {% else %}
                                        <span class="text-muted small">Dernière leçon</span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm">
                            <div class="card-body p-4 p-md-5">
                                <h3 class="h5 fw-bold mb-3">Pourquoi continuer ?</h3>
                                <p class="text-muted mb-0" style="line-height: 1.9;">
                                    Après cette leçon, vous pouvez consulter les autres leçons de la même formation
                                    ou explorer les vidéos recommandées pour approfondir vos connaissances.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div style="position: sticky; top: 100px;">
                            <div class="card border-0 shadow-sm mb-4">
                                <div class="card-body p-4">
                                    <h3 class="h5 fw-bold mb-3">Actions rapides</h3>

                                    <div class="d-grid gap-2">
                                        <a href="{{ path('app_lessons') }}" class="btn btn-secondary">
                                            Retour aux lessons
                                        </a>

                                        {% if lesson.formation %}
                                            <a href="{{ path('app_lessons', {'formation': lesson.formation.id}) }}" class="btn btn-primary">
                                                Voir cette formation
                                            </a>
                                        {% endif %}

                                        <a href="{{ path('app_lesson_pdf', {'id': lesson.id}) }}" class="btn btn-outline-primary">
                                            Exporter en PDF
                                        </a>

                                        <a href="{{ path('app_lesson_related_videos', {'id': lesson.id}) }}" class="btn btn-warning">
                                            🎥 Vidéos recommandées
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm mb-4">
                                <div class="card-body p-4">
                                    <h3 class="h5 fw-bold mb-4">Résumé</h3>

                                    <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                                        <span class="text-muted">Titre</span>
                                        <span class="fw-semibold text-end ms-3">{{ lesson.titre }}</span>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                                        <span class="text-muted">Formation</span>
                                        <span class="fw-semibold text-end ms-3">
                                            {{ lesson.formation ? lesson.formation.titre : 'Formation inconnue' }}
                                        </span>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                                        <span class="text-muted">Ordre</span>
                                        <span class="fw-semibold">Leçon {{ '%02d'|format(lesson.ordre) }}</span>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                                        <span class="text-muted">Durée</span>
                                        <span class="fw-semibold">{{ lesson.dureeMinutes }} min</span>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="text-muted">Vidéo</span>
                                        <span class="fw-semibold">
                                            {% if lesson.videoUrl %}
                                                Disponible
                                            {% else %}
                                                Non disponible
                                            {% endif %}
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-4">
                                    <h3 class="h5 fw-bold mb-3">Conseil</h3>
                                    <p class="text-muted mb-0" style="line-height: 1.8;">
                                        Regardez la vidéo, lisez le contenu attentivement, puis explorez les vidéos recommandées
                                        pour renforcer votre compréhension du sujet.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>
</main>
{% endblock %}