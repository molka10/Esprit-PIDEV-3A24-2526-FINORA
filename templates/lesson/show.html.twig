{% extends 'base.html.twig' %}

{% block title %}{{ lesson.titre }} - FINORA{% endblock %}

{% block body %}
<header class="navbar-light navbar-sticky">
    <nav class="navbar navbar-expand-xl z-index-9">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}">
                <img class="light-mode-item navbar-brand-item" src="{{ asset('assets/images/logo.svg') }}" alt="logo">
                <img class="dark-mode-item navbar-brand-item" src="{{ asset('assets/images/logo-light.svg') }}" alt="logo">
            </a>

            <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                <span class="navbar-toggler-animation">
                    <span></span><span></span><span></span>
                </span>
            </button>

            <div class="navbar-collapse collapse" id="navbarCollapse">
                <ul class="navbar-nav navbar-nav-scroll ms-auto">
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}">Accueil</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_formations') }}">Formations</a></li>
                    <li class="nav-item"><a class="nav-link active" href="{{ path('app_lessons') }}">Lessons</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('admin_dashboard') }}">Dashboard</a></li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<main>
    <section class="py-5">
        <div class="container">
            <div class="mx-auto" style="max-width: 1000px;">
                <div class="card border-0 shadow-sm overflow-hidden">
                    <div class="p-4" style="background:#ede9fe;">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                            <div>
                                <div class="small text-muted fw-bold mb-2">
                                    LEÇON {{ '%02d'|format(lesson.ordre) }}
                                </div>
                                <h1 class="h2 mb-0">{{ lesson.titre }}</h1>
                            </div>

                            <div class="d-flex gap-2 flex-wrap">
                                <span class="badge bg-primary bg-opacity-10 text-primary">
                                    {{ lesson.formation ? lesson.formation.titre : 'Formation inconnue' }}
                                </span>
                                <span class="badge bg-success bg-opacity-10 text-success">
                                    {{ lesson.dureeMinutes }} min
                                </span>
                                {% if lesson.videoUrl %}
                                    <span class="badge bg-warning bg-opacity-10 text-warning">
                                        Vidéo disponible
                                    </span>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <div class="card-body p-4">
                        <h3 class="h5 mb-3">Contenu</h3>
                        <div class="mb-4" style="white-space: pre-line; line-height: 1.8;">
                            {{ lesson.contenu ?: 'Aucun contenu disponible.' }}
                        </div>

                        {% if lesson.videoUrl %}
                            <h3 class="h5 mb-3">Vidéo</h3>

                            {% set isYoutube = lesson.youTubeVideoId is not null %}
                            {% set isMp4 = lesson.videoUrl ends with '.mp4' %}

                            {% if isYoutube %}
                                <div class="mb-4">
                                    <iframe
                                        width="100%"
                                        height="420"
                                        src="https://www.youtube.com/embed/{{ lesson.youTubeVideoId }}"
                                        title="YouTube video player"
                                        frameborder="0"
                                        allowfullscreen
                                        style="border-radius:12px;">
                                    </iframe>
                                </div>
                            {% elseif isMp4 %}
                                <div class="mb-4">
                                    <video controls style="width:100%; border-radius:12px;">
                                        <source src="{{ lesson.videoUrl }}" type="video/mp4">
                                        Votre navigateur ne supporte pas la lecture vidéo.
                                    </video>
                                </div>
                            {% else %}
                                <div class="mb-4">
                                    <a href="{{ lesson.videoUrl }}" target="_blank" class="btn btn-warning">
                                        Ouvrir la vidéo
                                    </a>
                                </div>
                            {% endif %}
                        {% endif %}

                        <div class="d-flex gap-2 flex-wrap mt-4">
                            <a href="{{ path('app_lessons') }}" class="btn btn-secondary">
                                Retour aux lessons
                            </a>

                            {% if lesson.formation %}
                                <a href="{{ path('app_lessons', {'formation': lesson.formation.id}) }}" class="btn btn-primary">
                                    Voir les lessons de cette formation
                                </a>
                            {% endif %}

                            {% if lesson.videoUrl %}
                                <a href="{{ lesson.videoUrl }}" target="_blank" class="btn btn-outline-primary">
                                    Ouvrir dans un nouvel onglet
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>
{% endblock %}