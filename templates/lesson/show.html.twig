{% extends 'base.html.twig' %}

{% block title %}{{ lesson.titre }} - FINORA{% endblock %}

{% block body %}

<style>
/* =========================================
   LESSON BOOK STYLES
   ========================================= */

.lesson-hero {
    background: linear-gradient(135deg, #ede9fe 0%, #f5f3ff 55%, #ffffff 100%);
    border-radius: 20px;
    padding: 2.5rem;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(124,58,237,0.08);
}

/* --- Book Container --- */
.book-container {
    background: #fffcf5;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06), inset 0 0 0 1px rgba(0,0,0,0.04);
    overflow: hidden;
    margin-bottom: 1.5rem;
    position: relative;
}

.book-top-bar {
    background: linear-gradient(90deg, #7c3aed, #8b5cf6);
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
}

.book-title-bar {
    color: white;
    font-size: 0.85rem;
    font-weight: 600;
    opacity: 0.9;
    letter-spacing: 0.02em;
}

.book-progress-wrap {
    flex: 1;
    max-width: 260px;
}

.book-progress-bar {
    height: 6px;
    background: rgba(255,255,255,0.25);
    border-radius: 99px;
    overflow: hidden;
}

.book-progress-fill {
    height: 100%;
    background: #fff;
    border-radius: 99px;
    transition: width 0.3s ease;
}

.book-page-label {
    color: white;
    font-size: 0.78rem;
    font-weight: 700;
    white-space: nowrap;
    opacity: 0.9;
}

/* --- Page Content --- */
.book-page {
    padding: 2.5rem 3rem;
    min-height: 380px;
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: 1.05rem;
    line-height: 1.95;
    color: #2d2d2d;
}

@media (max-width: 768px) {
    .book-page { padding: 1.5rem; }
}

.book-page p {
    margin-bottom: 1.4rem;
    text-align: justify;
    hyphens: auto;
}

.book-page p:first-child::first-letter {
    font-size: 3rem;
    font-weight: 700;
    float: left;
    line-height: 0.85;
    margin-right: 0.1em;
    margin-top: 0.08em;
    color: #7c3aed;
    font-family: 'Georgia', serif;
}

.book-page .translation-badge {
    display: inline-block;
    font-size: 0.72rem;
    background: #ede9fe;
    color: #6d28d9;
    border-radius: 999px;
    padding: 0.1rem 0.6rem;
    font-family: 'Inter', sans-serif;
    margin-bottom: 0.5rem;
    font-weight: 600;
    letter-spacing: 0.03em;
}

/* --- Book Nav --- */
.book-nav {
    padding: 1rem 1.5rem;
    border-top: 1px solid #f0ebe0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    background: #faf7f0;
}

.book-nav-btn {
    background: white;
    border: 1.5px solid #e0d6f5;
    color: #6d28d9;
    border-radius: 10px;
    padding: 0.4rem 1.2rem;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.18s ease;
    display: flex;
    align-items: center;
    gap: 0.4rem;
}

.book-nav-btn:hover:not(:disabled) {
    background: #7c3aed;
    color: white;
    border-color: #7c3aed;
}

.book-nav-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
}

/* --- Translation Panel --- */
.translation-panel {
    background: white;
    border-radius: 14px;
    border: 1.5px solid #ede9fe;
    overflow: hidden;
    margin-bottom: 1rem;
}

.translation-panel-header {
    background: linear-gradient(90deg, #ede9fe, #f5f3ff);
    padding: 0.85rem 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid #e9e1fb;
}

.translation-panel-header h3 {
    font-size: 0.88rem;
    font-weight: 700;
    color: #5b21b6;
    margin: 0;
}

.translation-panel-body {
    padding: 1rem 1.2rem;
}

.translation-panel select {
    border: 1.5px solid #e0d6f5;
    border-radius: 8px;
    font-size: 0.85rem;
    color: #374151;
    padding: 0.4rem 0.6rem;
    width: 100%;
    margin-bottom: 0.75rem;
    background: #faf5ff;
}

.btn-translate {
    width: 100%;
    background: linear-gradient(135deg, #7c3aed, #8b5cf6);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s;
    margin-bottom: 0.5rem;
}

.btn-translate:hover { opacity: 0.9; }
.btn-translate:disabled { opacity: 0.5; cursor: not-allowed; }

.btn-toggle-lang {
    width: 100%;
    background: transparent;
    border: 1.5px solid #c4b5fd;
    color: #7c3aed;
    border-radius: 8px;
    padding: 0.45rem 1rem;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.18s;
}

.btn-toggle-lang:hover {
    background: #ede9fe;
}

.tts-controls {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
}

.tts-controls .btn {
    flex: 1;
    min-width: 60px;
    font-size: 0.78rem;
    padding: 0.35rem 0.5rem;
}

/* --- Sidebar card shared --- */
.sidebar-card {
    background: white;
    border: 1px solid rgba(124,58,237,0.1);
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 1rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.sidebar-card-header {
    background: #faf5ff;
    border-bottom: 1px solid #ede9fe;
    padding: 0.8rem 1.2rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: #5b21b6;
    text-transform: uppercase;
    letter-spacing: 0.06em;
}

.sidebar-card-body {
    padding: 1rem 1.2rem;
}

.meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid #f3f4f6;
    font-size: 0.85rem;
}
.meta-row:last-child { border-bottom: none; }
.meta-row .label { color: #9ca3af; }
.meta-row .value { font-weight: 600; color: #111; text-align: right; max-width: 60%; }

.spinner {
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 2px solid rgba(255,255,255,0.5);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    vertical-align: middle;
    margin-right: 4px;
}

@keyframes spin { to { transform: rotate(360deg); } }
</style>

<main>
    <section class="py-5" style="background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);">
        <div class="container">
            <div class="mx-auto" style="max-width: 1240px;">

                {# ====== HERO HEADER ====== #}
                <div class="lesson-hero mb-4">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-4">
                        <div style="max-width: 720px;">
                            <div class="d-flex gap-2 flex-wrap mb-3">
                                <span class="badge rounded-pill px-3 py-2" style="background:#fff; color:#6d28d9; font-weight:700; border:1.5px solid #c4b5fd;">
                                    Leçon {{ '%02d'|format(lesson.ordre) }}
                                </span>
                                <span class="badge rounded-pill px-3 py-2 bg-primary bg-opacity-10 text-primary">
                                    {{ lesson.formation ? lesson.formation.titre : 'Formation inconnue' }}
                                </span>
                                <span class="badge rounded-pill px-3 py-2 bg-success bg-opacity-10 text-success">
                                    {{ lesson.dureeMinutes }} min
                                </span>
                                {% if lesson.videoUrl %}
                                    <span class="badge rounded-pill px-3 py-2 bg-warning bg-opacity-10 text-warning">
                                        Vidéo disponible
                                    </span>
                                {% endif %}
                            </div>
                            <h1 class="display-6 fw-bold mb-2 text-dark">{{ lesson.titre }}</h1>
                            <p class="text-muted mb-0" style="line-height:1.7;">
                                Lisez le contenu de cette leçon à votre rythme, page par page.
                                Utilisez le panneau de traduction pour lire dans votre langue.
                            </p>
                        </div>
                        <div class="d-flex flex-column gap-2" style="min-width: 200px;">
                            <a href="{{ path('app_lessons') }}" class="btn btn-light border">
                                ← Toutes les leçons
                            </a>
                            <a href="{{ path('app_lesson_pdf', {'id': lesson.id}) }}" class="btn btn-outline-primary">
                                Exporter en PDF
                            </a>
                            <a href="{{ path('app_lesson_related_videos', {'id': lesson.id}) }}" class="btn btn-warning">
                                🎥 Vidéos recommandées
                            </a>
                            <a href="{{ path('app_quiz_take', {'id': lesson.id}) }}" class="btn btn-primary">
                                🧠 Passer le quiz
                            </a>
                        </div>
                    </div>
                </div>

                <div class="row g-4">

                    {# ====== MAIN COLUMN ====== #}
                    <div class="col-lg-8">

                        {# --- Video --- #}
                        {% if lesson.videoUrl %}
                            <div class="sidebar-card mb-4">
                                <div class="sidebar-card-header">🎬 Vidéo de la leçon</div>
                                <div class="sidebar-card-body">
                                    {% set isYoutube = lesson.youTubeVideoId is not null %}
                                    {% if isYoutube %}
                                        <div class="ratio ratio-16x9 rounded-3 overflow-hidden shadow-sm">
                                            <iframe
                                                src="https://www.youtube.com/embed/{{ lesson.youTubeVideoId }}"
                                                title="YouTube video player"
                                                frameborder="0"
                                                allowfullscreen>
                                            </iframe>
                                        </div>
                                    {% elseif lesson.isUploadedVideo %}
                                        <div class="rounded-3 overflow-hidden shadow-sm">
                                            <video controls style="width:100%; display:block;">
                                                <source src="{{ asset('uploads/lessons/videos/' ~ lesson.videoUrl) }}">
                                                Votre navigateur ne supporte pas la lecture vidéo.
                                            </video>
                                        </div>
                                    {% else %}
                                        <div class="p-3 rounded-3" style="background:#fff7ed; border:1px solid #fed7aa;">
                                            <p class="mb-2 text-dark">Cette leçon contient une vidéo externe.</p>
                                            <a href="{{ lesson.videoUrl }}" target="_blank" class="btn btn-warning btn-sm">Ouvrir la vidéo</a>
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endif %}

                        {# --- BOOK CONTENT AREA --- #}
                        <div class="book-container" id="book-wrapper">

                            <div class="book-top-bar">
                                <span class="book-title-bar">📖 {{ lesson.titre|length > 40 ? lesson.titre|slice(0, 40) ~ '…' : lesson.titre }}</span>
                                <div class="book-progress-wrap">
                                    <div class="book-progress-bar">
                                        <div class="book-progress-fill" id="progress-fill" style="width: 0%"></div>
                                    </div>
                                </div>
                                <span class="book-page-label" id="page-label">Page 1 / 1</span>
                            </div>

                            <div class="book-page" id="book-page-content">
                                {# Content injected by JS #}
                                <p class="text-muted">Chargement du contenu…</p>
                            </div>

                            <div class="book-nav">
                                <button class="book-nav-btn" id="btn-prev-page" disabled>
                                    ← Précédent
                                </button>
                                <span id="book-lang-indicator" class="badge bg-light text-muted fw-normal px-3 py-2 border" style="font-size:0.75rem;"></span>
                                <button class="book-nav-btn" id="btn-next-page" disabled>
                                    Suivant →
                                </button>
                            </div>
                        </div>

                        {# --- TTS controls (now minimal, below content) --- #}
                        <div class="sidebar-card mb-4">
                            <div class="sidebar-card-header">🔊 Lecture audio (TTS)</div>
                            <div class="sidebar-card-body">
                                <div class="tts-controls mb-2">
                                    <button id="play-btn" class="btn btn-primary btn-sm">▶ Lire</button>
                                    <button id="pause-btn" class="btn btn-outline-secondary btn-sm">⏸ Pause</button>
                                    <button id="stop-btn" class="btn btn-outline-danger btn-sm">⏹ Stop</button>
                                </div>
                                <audio id="audio-player" controls style="width:100%; height:36px;"></audio>
                                <div id="tts-status" class="small text-muted mt-1"></div>
                            </div>
                        </div>

                        {# --- Prev / Next lesson --- #}
                        <div class="sidebar-card mb-4">
                            <div class="sidebar-card-body d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <div>
                                    {% if previousLesson %}
                                        <a href="{{ path('app_lesson_show', {'id': previousLesson.id}) }}" class="btn btn-outline-secondary btn-sm">
                                            ⬅️ {{ previousLesson.titre|length > 28 ? previousLesson.titre|slice(0, 28) ~ '...' : previousLesson.titre }}
                                        </a>
                                    {% else %}
                                        <span class="text-muted small">Première leçon</span>
                                    {% endif %}
                                </div>
                                <div>
                                    {% if nextLesson %}
                                        <a href="{{ path('app_lesson_show', {'id': nextLesson.id}) }}" class="btn btn-primary btn-sm">
                                            {{ nextLesson.titre|length > 28 ? nextLesson.titre|slice(0, 28) ~ '...' : nextLesson.titre }} ➡️
                                        </a>
                                    {% else %}
                                        <span class="text-muted small">Dernière leçon</span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                    </div>{# end col-lg-8 #}

                    {# ====== SIDEBAR ====== #}
                    <div class="col-lg-4">
                        <div style="position: sticky; top: 90px;">

                            {# --- Translation Panel --- #}
                            <div class="translation-panel mb-3">
                                <div class="translation-panel-header">
                                    <span style="font-size:1.1rem;">🌐</span>
                                    <h3>Traduction</h3>
                                </div>
                                <div class="translation-panel-body">
                                    <label class="form-label" style="font-size:0.8rem; font-weight:600; color:#6b7280; margin-bottom:0.4rem;">Langue cible</label>
                                    <select id="lang-select">
                                        <option value="">— Choisir une langue —</option>
                                        <option value="en">🇬🇧 Anglais</option>
                                        <option value="ar">🇸🇦 Arabe</option>
                                        <option value="es">🇪🇸 Espagnol</option>
                                        <option value="de">🇩🇪 Allemand</option>
                                        <option value="it">🇮🇹 Italien</option>
                                        <option value="zh">🇨🇳 Chinois</option>
                                        <option value="tr">🇹🇷 Turc</option>
                                        <option value="pt">🇵🇹 Portugais</option>
                                        <option value="ru">🇷🇺 Russe</option>
                                        <option value="ja">🇯🇵 Japonais</option>
                                    </select>
                                    <button class="btn-translate" id="btn-translate">
                                        Traduire cette page
                                    </button>
                                    <button class="btn-toggle-lang d-none" id="btn-toggle-lang">
                                        Voir l'original
                                    </button>
                                    <div id="translate-status" class="small text-muted mt-2" style="min-height:18px;"></div>
                                </div>
                            </div>

                            {# --- Quick Actions --- #}
                            <div class="sidebar-card">
                                <div class="sidebar-card-header">⚡ Actions rapides</div>
                                <div class="sidebar-card-body d-grid gap-2">
                                    {% if lesson.formation %}
                                        <a href="{{ path('app_lessons', {'formation': lesson.formation.id}) }}" class="btn btn-primary btn-sm">
                                            Voir cette formation
                                        </a>
                                    {% endif %}
                                    <a href="{{ path('app_lesson_pdf', {'id': lesson.id}) }}" class="btn btn-outline-primary btn-sm">
                                        Exporter en PDF
                                    </a>
                                    <a href="{{ path('app_lesson_related_videos', {'id': lesson.id}) }}" class="btn btn-warning btn-sm">
                                        🎥 Vidéos liées
                                    </a>
                                    <a href="{{ path('app_quiz_take', {'id': lesson.id}) }}" class="btn btn-primary btn-sm">
                                        🧠 Quiz
                                    </a>
                                </div>
                            </div>

                            {# --- Meta sidebar --- #}
                            <div class="sidebar-card mt-3">
                                <div class="sidebar-card-header">📋 Informations</div>
                                <div class="sidebar-card-body">
                                    <div class="meta-row">
                                        <span class="label">Formation</span>
                                        <span class="value">{{ lesson.formation ? lesson.formation.titre : '—' }}</span>
                                    </div>
                                    <div class="meta-row">
                                        <span class="label">Ordre</span>
                                        <span class="value">Leçon {{ '%02d'|format(lesson.ordre) }}</span>
                                    </div>
                                    <div class="meta-row">
                                        <span class="label">Durée estimée</span>
                                        <span class="value">{{ lesson.dureeMinutes }} min</span>
                                    </div>
                                    <div class="meta-row">
                                        <span class="label">Vidéo</span>
                                        <span class="value">{{ lesson.videoUrl ? '✅ Disponible' : '❌ Non disponible' }}</span>
                                    </div>
                                </div>
                            </div>

                            {# --- Tip card --- #}
                            <div class="sidebar-card mt-3" style="background: linear-gradient(135deg,#ede9fe,#f5f3ff);">
                                <div class="sidebar-card-body">
                                    <p class="mb-0 text-muted small" style="line-height:1.7;">
                                        💡 <strong>Conseil :</strong> Lisez page par page, regardez la vidéo, puis explorez les
                                        vidéos recommandées pour renforcer votre compréhension.
                                    </p>
                                </div>
                            </div>

                        </div>
                    </div>{# end col-lg-4 #}

                </div>{# end row #}
            </div>
        </div>
    </section>
</main>

<script>
(function() {
    /* ================================================================
       FINORA Lesson Book Engine
       Auth-agnostic: keyed by lessonId only.
       Future: store currentPage & activeLang server-side per userId.
    ================================================================ */

    const LESSON_ID = {{ lesson.id }};
    const RAW_CONTENT = {{ lesson.contenu is not null ? lesson.contenu|json_encode|raw : '""' }};
    const STORAGE_PAGE_KEY = 'finora_lesson_' + LESSON_ID + '_page';
    const STORAGE_LANG_KEY = 'finora_lesson_' + LESSON_ID + '_lang';

    // --- Split content into pages (by double newline or ~600 char chunks) ---
    function splitIntoPages(text) {
        if (!text || text.trim() === '') return ['Aucun contenu disponible pour cette leçon.'];

        // Split by double newlines first
        let blocks = text.split(/\n\s*\n/).map(b => b.trim()).filter(b => b.length > 0);

        // If no double newlines found, split by single newlines
        if (blocks.length <= 1) {
            blocks = text.split(/\n/).map(b => b.trim()).filter(b => b.length > 0);
        }

        // Group into pages of ~3 blocks each (to avoid 1 paragraph per page on dense content)
        const BLOCKS_PER_PAGE = 3;
        const pages = [];
        for (let i = 0; i < blocks.length; i += BLOCKS_PER_PAGE) {
            pages.push(blocks.slice(i, i + BLOCKS_PER_PAGE).join('\n\n'));
        }
        return pages.length > 0 ? pages : [text];
    }

    const originalPages = splitIntoPages(RAW_CONTENT);
    // Cache: { 'en': ['page1 translated', 'page2 translated', ...], 'ar': [...] }
    const translationCache = {};

    let currentPage = 0;
    let activeLang = null; // null = original French
    let isShowingTranslation = false;

    // Restore saved state
    const savedPage = parseInt(sessionStorage.getItem(STORAGE_PAGE_KEY) || '0', 10);
    const savedLang = localStorage.getItem(STORAGE_LANG_KEY);
    if (!isNaN(savedPage) && savedPage < originalPages.length) currentPage = savedPage;

    // DOM refs
    const pageContent  = document.getElementById('book-page-content');
    const pageLabel    = document.getElementById('page-label');
    const progressFill = document.getElementById('progress-fill');
    const btnPrev      = document.getElementById('btn-prev-page');
    const btnNext      = document.getElementById('btn-next-page');
    const langIndicator= document.getElementById('book-lang-indicator');
    const langSelect   = document.getElementById('lang-select');
    const btnTranslate = document.getElementById('btn-translate');
    const btnToggle    = document.getElementById('btn-toggle-lang');
    const translateStatus = document.getElementById('translate-status');

    // Restore saved language in select
    if (savedLang) {
        langSelect.value = savedLang;
    }

    const LANG_NAMES = {
        en: 'Anglais', ar: 'Arabe', es: 'Espagnol', de: 'Allemand',
        it: 'Italien', zh: 'Chinois', tr: 'Turc', pt: 'Portugais',
        ru: 'Russe', ja: 'Japonais'
    };

    /* ----------- RENDER PAGE ----------- */
    function renderPage() {
        const totalPages = originalPages.length;
        const pct = totalPages > 1 ? ((currentPage + 1) / totalPages * 100) : 100;
        progressFill.style.width = pct + '%';
        pageLabel.textContent = 'Page ' + (currentPage + 1) + ' / ' + totalPages;
        btnPrev.disabled = currentPage === 0;
        btnNext.disabled = currentPage === totalPages - 1;

        // Pick which content to show
        let textToShow = originalPages[currentPage];
        let isTranslated = false;

        if (isShowingTranslation && activeLang && translationCache[activeLang] && translationCache[activeLang][currentPage]) {
            textToShow = translationCache[activeLang][currentPage];
            isTranslated = true;
        }

        // Build HTML
        const paragraphs = textToShow.split('\n\n').map(p => p.trim()).filter(p => p);
        let html = '';
        if (isTranslated) {
            html += '<div class="translation-badge">🌐 Traduction — ' + (LANG_NAMES[activeLang] || activeLang) + '</div>';
        }
        paragraphs.forEach(p => {
            html += '<p>' + escapeHtml(p).replace(/\n/g, '<br>') + '</p>';
        });

        pageContent.innerHTML = html || '<p class="text-muted">Aucun contenu.</p>';

        // Update lang indicator
        if (isTranslated) {
            langIndicator.textContent = '🌐 ' + (LANG_NAMES[activeLang] || activeLang);
            langIndicator.className = 'badge bg-purple text-white px-3 py-2 border';
            langIndicator.style.background = '#7c3aed';
            langIndicator.style.color = 'white';
        } else {
            langIndicator.textContent = '🇫🇷 Français (original)';
            langIndicator.className = 'badge bg-light text-muted px-3 py-2 border';
            langIndicator.style.background = '';
            langIndicator.style.color = '';
        }

        // Save progress
        sessionStorage.setItem(STORAGE_PAGE_KEY, currentPage);
    }

    function escapeHtml(str) {
        return str
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }

    /* ----------- TRANSLATE CURRENT PAGE ----------- */
    async function translateCurrentPage(lang) {
        const text = originalPages[currentPage];
        if (!text) return;

        // Already cached
        if (translationCache[lang] && translationCache[lang][currentPage] !== undefined) {
            return;
        }

        translateStatus.innerHTML = '<span class="spinner"></span> Traduction en cours…';
        btnTranslate.disabled = true;

        try {
            const encoded = encodeURIComponent(text);
            const url = `https://api.mymemory.translated.net/get?q=${encoded}&langpair=fr|${lang}`;
            const res = await fetch(url);
            const data = await res.json();

            if (data.responseStatus === 200 && data.responseData && data.responseData.translatedText) {
                if (!translationCache[lang]) translationCache[lang] = {};
                translationCache[lang][currentPage] = data.responseData.translatedText;
                translateStatus.textContent = '✅ Traduction terminée.';
            } else {
                translateStatus.textContent = '⚠️ Traduction non disponible pour cette page.';
            }
        } catch (err) {
            translateStatus.textContent = '❌ Erreur réseau. Vérifiez votre connexion.';
            console.error('Translation error:', err);
        } finally {
            btnTranslate.disabled = false;
        }
    }

    /* ----------- EVENTS ----------- */
    btnPrev.addEventListener('click', () => {
        if (currentPage > 0) {
            currentPage--;
            renderPage();
            // Auto-translate if we were in translation mode
            if (isShowingTranslation && activeLang) {
                autoTranslatePage();
            }
            window.scrollTo({ top: document.getElementById('book-wrapper').offsetTop - 80, behavior: 'smooth' });
        }
    });

    btnNext.addEventListener('click', () => {
        if (currentPage < originalPages.length - 1) {
            currentPage++;
            renderPage();
            if (isShowingTranslation && activeLang) {
                autoTranslatePage();
            }
            window.scrollTo({ top: document.getElementById('book-wrapper').offsetTop - 80, behavior: 'smooth' });
        }
    });

    async function autoTranslatePage() {
        await translateCurrentPage(activeLang);
        renderPage();
    }

    btnTranslate.addEventListener('click', async () => {
        const lang = langSelect.value;
        if (!lang) {
            translateStatus.textContent = '⚠️ Veuillez choisir une langue.';
            return;
        }
        activeLang = lang;
        localStorage.setItem(STORAGE_LANG_KEY, lang);
        await translateCurrentPage(lang);
        isShowingTranslation = true;
        btnToggle.classList.remove('d-none');
        btnToggle.textContent = 'Voir l\'original';
        renderPage();
    });

    btnToggle.addEventListener('click', () => {
        isShowingTranslation = !isShowingTranslation;
        btnToggle.textContent = isShowingTranslation ? 'Voir l\'original' : 'Voir la traduction';
        renderPage();
    });

    // Initial render
    renderPage();

    /* =========================================
       TTS AUDIO PLAYER (unchanged logic)
    ========================================= */
    const audio     = document.getElementById('audio-player');
    const playBtn   = document.getElementById('play-btn');
    const pauseBtn  = document.getElementById('pause-btn');
    const stopBtn   = document.getElementById('stop-btn');
    const ttsStatus = document.getElementById('tts-status');
    const baseTtsUrl = "{{ path('app_tts', {'id': lesson.id}) }}";

    let isStopped = true;

    playBtn.addEventListener('click', async function () {
        try {
            if (audio.paused && audio.src && !isStopped) {
                await audio.play();
                ttsStatus.textContent = 'Lecture en cours.';
                return;
            }
            isStopped = false;
            audio.pause();
            audio.currentTime = 0;
            audio.src = baseTtsUrl + '?v=' + Date.now();
            ttsStatus.textContent = 'Chargement audio…';
            const onCanPlay = async () => {
                audio.removeEventListener('canplaythrough', onCanPlay);
                if (isStopped) return;
                try {
                    await audio.play();
                    ttsStatus.textContent = 'Lecture en cours.';
                } catch (e) {
                    ttsStatus.textContent = 'Impossible de lancer la lecture.';
                }
            };
            audio.addEventListener('canplaythrough', onCanPlay, { once: true });
            audio.load();
        } catch (error) {
            ttsStatus.textContent = 'Impossible de charger l\'audio.';
        }
    });

    pauseBtn.addEventListener('click', function () {
        if (!audio.src) return;
        audio.pause();
        isStopped = false;
        ttsStatus.textContent = 'Lecture en pause.';
    });

    stopBtn.addEventListener('click', function () {
        isStopped = true;
        audio.pause();
        audio.currentTime = 0;
        audio.removeAttribute('src');
        audio.load();
        ttsStatus.textContent = 'Lecture arrêtée.';
    });

    audio.addEventListener('ended', () => { isStopped = true; ttsStatus.textContent = 'Lecture terminée.'; });
    audio.addEventListener('error', () => { isStopped = true; ttsStatus.textContent = 'Erreur de chargement audio.'; });

})();
</script>

{% endblock %}