{% extends 'base.html.twig' %}

{% block title %}Vidéos recommandées{% endblock %}

{% block body %}
<div class="container py-5">

    <h2 class="mb-4">🎥 Vidéos recommandées pour "{{ lesson.titre }}"</h2>

    {% if error %}
        <div class="alert alert-danger">{{ error }}</div>
    {% endif %}

    <div class="row g-4">
        {% for video in results %}
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm h-100">

                    {% if video.thumbnailUrl %}
                        <img src="{{ video.thumbnailUrl }}" class="card-img-top">
                    {% endif %}

                    <div class="card-body d-flex flex-column">
                        <h5>{{ video.title }}</h5>
                        <p class="text-muted small">{{ video.channelTitle }}</p>

                        <div class="mt-auto d-flex gap-2">
                            <a href="{{ video.url }}" target="_blank" class="btn btn-outline-primary btn-sm">
                                Ouvrir
                            </a>

                            <a href="https://www.youtube.com/embed/{{ video.videoId }}"
                               target="_blank"
                               class="btn btn-primary btn-sm">
                                Regarder
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        {% endfor %}
    </div>

    <!-- Pagination controls -->
    <div class="d-flex justify-content-center mt-5">
        {{ knp_pagination_render(results) }}
    </div>

</div>
{% endblock %}