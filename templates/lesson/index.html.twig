{% extends 'base.html.twig' %}

{% block title %}Lessons{% endblock %}

{% block body %}
<div style="padding: 30px; font-family: Arial;">
    <h1>Lessons</h1>

    <form method="get" action="{{ path('app_lesson_index') }}" style="margin-bottom: 25px; padding: 15px; border: 1px solid #ddd; border-radius: 10px;">
        <div style="display: flex; flex-wrap: wrap; gap: 15px; align-items: end;">
            <div>
                <label for="titre">Titre</label><br>
                <input type="text" id="titre" name="titre" value="{{ titre }}" placeholder="Rechercher par titre">
            </div>

            <div>
                <label for="formation">Formation</label><br>
                <select id="formation" name="formation">
                    <option value="">Toutes</option>
                    {% for formation in formations %}
                        <option value="{{ formation.id }}" {{ formationSelected == formation.id ? 'selected' : '' }}>
                            {{ formation.titre }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div>
                <label for="tri">Trier par</label><br>
                <select id="tri" name="tri">
                    <option value="id" {{ tri == 'id' ? 'selected' : '' }}>ID</option>
                    <option value="titre" {{ tri == 'titre' ? 'selected' : '' }}>Titre</option>
                    <option value="ordre" {{ tri == 'ordre' ? 'selected' : '' }}>Ordre</option>
                    <option value="duree_minutes" {{ tri == 'duree_minutes' ? 'selected' : '' }}>Durée</option>
                </select>
            </div>

            <div>
                <label for="ordre">Ordre</label><br>
                <select id="ordre" name="ordre">
                    <option value="asc" {{ ordre == 'asc' ? 'selected' : '' }}>Ascendant</option>
                    <option value="desc" {{ ordre == 'desc' ? 'selected' : '' }}>Descendant</option>
                </select>
            </div>

            <div>
                <button type="submit" style="padding: 8px 14px; background: #7C3AED; color: white; border: none; border-radius: 6px;">
                    Rechercher
                </button>
            </div>

            <div>
                <a href="{{ path('app_lesson_index') }}" style="padding: 8px 14px; background: #6b7280; color: white; text-decoration: none; border-radius: 6px;">
                    Réinitialiser
                </a>
            </div>
        </div>
    </form>

    <a href="{{ path('app_lesson_new') }}"
       style="display:inline-block; margin-bottom:20px; padding:10px 15px; background:#7C3AED; color:white; border-radius:8px; text-decoration:none;">
        Add Lesson
    </a>

    <div style="display:flex; flex-wrap:wrap; gap:20px;">
        {% for lesson in lessons %}
            <div style="width:300px; padding:15px; border-radius:10px; box-shadow:0 2px 8px rgba(0,0,0,0.1);">
                <h3>{{ lesson.titre }}</h3>

                <p style="font-size:14px;">
                    {{ lesson.contenu ? lesson.contenu|slice(0, 100) ~ '...' : 'Pas de contenu' }}
                </p>

                <p><strong>Formation:</strong> {{ lesson.formation ? lesson.formation.titre : 'Non liée' }}</p>
                <p><strong>Ordre:</strong> {{ lesson.ordre }}</p>
                <p><strong>Duration:</strong> {{ lesson.dureeMinutes ?? 'Non définie' }} min</p>

                <div style="margin-top:10px;">
                    <a href="{{ path('app_lesson_show', {'id': lesson.id}) }}"
                       style="padding:6px 10px; background:#16a34a; color:white; border-radius:5px; text-decoration:none;">
                        Show
                    </a>

                    <a href="{{ path('app_lesson_edit', {'id': lesson.id}) }}"
                       style="padding:6px 10px; background:#2563eb; color:white; border-radius:5px; text-decoration:none;">
                        Edit
                    </a>

                    <form method="post"
                          action="{{ path('app_lesson_delete', {'id': lesson.id}) }}"
                          style="display:inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ lesson.id) }}">
                        <button style="padding:6px 10px; background:#dc2626; color:white; border:none; border-radius:5px;">
                            Delete
                        </button>
                    </form>
                </div>
            </div>
        {% else %}
            <p>Aucune lesson trouvée.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}