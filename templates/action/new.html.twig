{% extends 'base.html.twig' %}

{% block title %}Nouvelle Action{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="card shadow p-4" style="max-width:650px; margin:auto; border-radius:15px;">

        <h3 class="mb-4 text-center">➕ Nouvelle Action</h3>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

        <div class="mb-3">
            {{ form_label(form.bourse) }}
            {{ form_widget(form.bourse) }}
            <div class="text-danger small mt-1">{{ form_errors(form.bourse) }}</div>
        </div>

        <div class="mb-3">
            {{ form_label(form.symbole) }}
            {{ form_widget(form.symbole) }}
            <div class="text-danger small mt-1">{{ form_errors(form.symbole) }}</div>
        </div>

        <div class="mb-3">
            {{ form_label(form.nomEntreprise) }}
            {{ form_widget(form.nomEntreprise) }}
            <div class="text-danger small mt-1">{{ form_errors(form.nomEntreprise) }}</div>
        </div>

        <div class="mb-3">
            {{ form_label(form.secteur) }}
            {{ form_widget(form.secteur) }}
            <div class="text-danger small mt-1">{{ form_errors(form.secteur) }}</div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                {{ form_label(form.prixUnitaire) }}
                {{ form_widget(form.prixUnitaire) }}
                <div class="text-danger small mt-1">{{ form_errors(form.prixUnitaire) }}</div>
            </div>
            <div class="col-md-6 mb-3">
                {{ form_label(form.quantiteDisponible) }}
                {{ form_widget(form.quantiteDisponible) }}
                <div class="text-danger small mt-1">{{ form_errors(form.quantiteDisponible) }}</div>
            </div>
        </div>

        <div class="mb-3">
            {{ form_label(form.statut) }}
            {{ form_widget(form.statut) }}
        </div>

        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-success w-100">💾 Créer</button>
            <a href="{{ path('app_action_index') }}" class="btn btn-secondary w-100">⬅ Retour</a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}