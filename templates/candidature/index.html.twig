{% extends app.request.query.get('role') == 'admin' ? 'admin_base.html.twig' : 'base.html.twig' %}

{% block title %}Candidatures{% endblock %}

{% block body %}

{# HERO #}
<div class="py-4 mb-4" style="background: linear-gradient(135deg, #1a1a2e, #16213e); border-radius: 10px;">
    <div class="container text-center py-3">
        <h1 class="display-5 font-weight-bold" style="color: #ffffff !important;">
            <i class="fas fa-file-alt mr-2" style="color: #f0a500;"></i>Candidatures
        </h1>
        {% if app.session.get('role') == 'admin' %}
            <p class="lead" style="color: #d0d8e8 !important;">Gérez toutes les candidatures soumises</p>
        {% else %}
            <p class="lead" style="color: #d0d8e8 !important;">Vos candidatures soumises</p>
        {% endif %}
        {% if app.session.get('role') == 'entreprise' %}
            <a href="{{ path('app_candidature_new', {'role': app.request.query.get('role')}) }}" class="btn btn-warning btn-lg mt-2">
                <i class="fas fa-plus"></i> Nouvelle Candidature
            </a>
        {% endif %}
    </div>
</div>

{# STATS #}
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-white mb-3" style="background:#1a1a2e;">
            <div class="card-body text-center">
                <i class="fas fa-users fa-2x mb-2"></i>
                <h4>{{ candidatures|length }}</h4>
                <p class="mb-0">Total Candidatures</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white mb-3" style="background:#28a745;">
            <div class="card-body text-center">
                <i class="fas fa-check-circle fa-2x mb-2"></i>
                <h4>{{ candidatures|filter(c => c.statut == 'accepted')|length }}</h4>
                <p class="mb-0">Acceptées</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white mb-3" style="background:#ffc107;">
            <div class="card-body text-center">
                <i class="fas fa-hourglass-half fa-2x mb-2"></i>
                <h4>{{ candidatures|filter(c => c.statut == 'submitted')|length }}</h4>
                <p class="mb-0">En Attente</p>
            </div>
        </div>
    </div>
</div>

{# TABLE #}
<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center" style="background:#1a1a2e;">
        <h5 class="mb-0 text-white"><i class="fas fa-list text-white"></i> Liste des Candidatures</h5>
        {% if app.session.get('role') == 'entreprise' %}
        <a href="{{ path('app_candidature_new', {'role': app.request.query.get('role')}) }}" class="btn btn-warning btn-sm">
            <i class="fas fa-plus"></i> Nouvelle
        </a>
        {% endif %}
    </div>
    <div class="card-body bg-transparent p-0">
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        {% for candidature in candidatures %}
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <!-- Header -->
                    <div class="card-header border-0 pb-0 d-flex justify-content-between align-items-center" style="background:transparent;">
                        <span class="small text-muted"><i class="fas fa-calendar-day me-1"></i> {{ candidature.createdAt|date('d/m/Y') }}</span>
                        {% if candidature.statut == 'accepted' %}
                            <span class="badge bg-success text-white">Acceptée</span>
                        {% elseif candidature.statut == 'rejected' %}
                            <span class="badge bg-danger text-white">Rejetée</span>
                        {% else %}
                            <span class="badge bg-warning text-dark">En attente</span>
                        {% endif %}
                    </div>

                    <!-- Body -->
                    <div class="card-body">
                        <h6 class="text-muted small mb-1">Appel d'Offre:</h6>
                        <h5 class="card-title mb-3">
                            {{ candidature.appelOffre ? candidature.appelOffre.titre : 'N/A' }}
                        </h5>
                        
                        <div class="d-flex align-items-center mb-3">
                            <div class="avatar avatar-xs me-2">
                                <i class="fas fa-user-circle fa-2x text-secondary"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 small">{{ candidature.user ? candidature.user.nom : 'Anonyme' }}</h6>
                                <span class="text-muted tiny">Candidat</span>
                            </div>
                        </div>

                        <div class="p-2 bg-light rounded-2 d-flex justify-content-between align-items-center">
                            <span class="small text-muted">Montant Proposé:</span>
                            <span class="fw-bold text-success">
                                {% if candidature.montantPropose %}
                                    {{ candidature.montantPropose|number_format(0, '.', ' ') }} TND
                                {% else %}
                                    N/A
                                {% endif %}
                            </span>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="card-footer bg-white border-0 pt-0 d-flex justify-content-end">
                        <div class="btn-group">
                            <a href="{{ path('app_candidature_show', {'id': candidature.id, 'role': app.request.query.get('role')}) }}" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-eye me-1"></i> Voir
                            </a>
                            {% if app.session.get('role') == 'admin' or app.session.get('role') == 'entreprise' %}
                                <a href="{{ path('app_candidature_edit', {'id': candidature.id, 'role': app.request.query.get('role')}) }}" class="btn btn-sm btn-outline-warning">
                                    <i class="fas fa-edit me-1"></i> Modifier
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <i class="fas fa-inbox fa-3x mb-3 text-muted"></i>
                <p class="text-muted">Aucune candidature pour le moment</p>
            </div>
        {% endfor %}
        </div>
    </div>

    {# PAGINATION #}
    {% if total_pages > 1 %}
    <div class="card-footer bg-white py-3 border-top">
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center mb-0">
                {# PREVIOUS #}
                <li class="page-item {{ current_page <= 1 ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_candidature_index', app.request.query.all|merge({'page': current_page - 1})) }}">
                        <i class="fas fa-chevron-left"></i> Précédent
                    </a>
                </li>

                {# PAGES #}
                {% for i in 1..total_pages %}
                    <li class="page-item {{ i == current_page ? 'active' : '' }}">
                        <a class="page-link" href="{{ path('app_candidature_index', app.request.query.all|merge({'page': i})) }}">
                            {{ i }}
                        </a>
                    </li>
                {% endfor %}

                {# NEXT #}
                <li class="page-item {{ current_page >= total_pages ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_candidature_index', app.request.query.all|merge({'page': current_page + 1})) }}">
                        Suivant <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
        <div class="text-center mt-2 small text-muted">
            Page {{ current_page }} sur {{ total_pages }} ({{ total_items }} résultats au total)
        </div>
    </div>
    {% endif %}
</div>

{% endblock %}
