<form method="post" action="{{ path('app_candidature_delete', {'id': candidature.id, 'role': app.request.query.get('role')}) }}">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ candidature.id) }}">
    <button type="submit" class="btn btn-danger"
        onclick="return confirm('Êtes-vous sûr de vouloir supprimer cette candidature ?')">
        <i class="fas fa-trash"></i> Supprimer
    </button>
</form>