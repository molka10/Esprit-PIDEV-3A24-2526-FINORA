{% extends 'base.html.twig' %}

{% block body %}

<h2>User Details</h2>

<ul class="list-group">
    <li class="list-group-item"><b>Email:</b> {{ user.email }}</li>
    <li class="list-group-item"><b>Firstname:</b> {{ user.firstname }}</li>
    <li class="list-group-item"><b>Role:</b> {{ user.roleType }}</li>
</ul>

<a href="{{ path('app_user_index') }}" class="btn btn-primary mt-3">Back</a>

{% endblock %}