{% extends app.request.query.get('role') == 'admin' ? 'admin_base.html.twig' : 'base.html.twig' %}

{% block title %}Utilisateurs{% endblock %}

{% block body %}

{# HERO #}
<div class="py-4 mb-4" style="background: linear-gradient(135deg, #1a1a2e, #16213e); border-radius: 10px;">
    <div class="container text-center py-3">
        <h1 class="display-5 font-weight-bold" style="color: #ffffff !important;">
            <i class="fas fa-users mr-2" style="color: #f0a500;"></i>Utilisateurs
        </h1>
        <p class="lead" style="color: #d0d8e8 !important;">Gérez les utilisateurs de l'application</p>
        <a href="{{ path('app_user_new', {'role': app.request.query.get('role')}) }}" class="btn btn-warning btn-lg mt-2">
            <i class="fas fa-plus"></i> Nouvel Utilisateur
        </a>
    </div>
</div>

{# TABLE #}
<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center" style="background:#1a1a2e;">
        <h5 class="mb-0 text-white"><i class="fas fa-users text-white"></i> Liste des Utilisateurs</h5>
        <a href="{{ path('app_user_new', {'role': app.request.query.get('role')}) }}" class="btn btn-warning btn-sm">
            <i class="fas fa-plus"></i> Nouveau
        </a>
    </div>
    <div class="card-body bg-transparent p-0">
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        {% for user in users %}
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <!-- Header -->
                    <div class="card-header border-0 pb-0 d-flex justify-content-center pt-4" style="background:transparent;">
                        <div class="avatar avatar-xl">
                            <img class="avatar-img rounded-circle border border-3 border-white shadow" 
                                 src="{{ asset('assets/images/avatar/01.jpg') }}" 
                                 alt="avatar" 
                                 style="width: 80px; height: 80px; object-fit: cover;">
                        </div>
                    </div>

                    <!-- Body -->
                    <div class="card-body text-center">
                        <h5 class="card-title mb-1">{{ user.username }}</h5>
                        <p class="text-muted small mb-2"><i class="fas fa-envelope me-1"></i> {{ user.email }}</p>
                        
                        <div class="mb-3">
                            {% for role in user.roles %}
                                {% if role == 'ROLE_ADMIN' %}
                                    <span class="badge bg-danger text-white"><i class="fas fa-crown me-1"></i>Admin</span>
                                {% elseif role == 'ROLE_ENTREPRISE' %}
                                    <span class="badge bg-info text-dark"><i class="fas fa-building me-1"></i>Entreprise</span>
                                {% elseif role == 'ROLE_USER' %}
                                    <span class="badge bg-secondary text-white"><i class="fas fa-user me-1"></i>Utilisateur</span>
                                {% endif %}
                            {% endfor %}
                        </div>

                        <div class="p-2 bg-light rounded-2 small text-muted">
                            <i class="fas fa-phone me-1"></i> {{ user.telephone ?? 'Non renseigné' }}
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="card-footer bg-white border-0 pt-0 d-flex justify-content-center pb-4">
                        <div class="btn-group w-100">
                            <a href="{{ path('app_user_show', {'id': user.id, 'role': app.request.query.get('role')}) }}" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-eye me-1"></i> Profil
                            </a>
                            <a href="{{ path('app_user_edit', {'id': user.id, 'role': app.request.query.get('role')}) }}" class="btn btn-sm btn-outline-warning">
                                <i class="fas fa-edit me-1"></i> Modifier
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <i class="fas fa-users-slash fa-3x mb-3 text-muted"></i>
                <p class="text-muted">Aucun utilisateur trouvé</p>
            </div>
        {% endfor %}
        </div>
    </div>
</div>

{% endblock %}