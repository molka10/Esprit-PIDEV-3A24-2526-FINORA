<!-- MODAL DELETE -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-3 shadow">

            <div class="modal-header border-0">
                <h5 class="modal-title text-danger fw-bold">
                    ⚠ Confirmation
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center">
                <p>Supprimer cette action ?</p>
                <h5 class="fw-bold">{{ nom.bourse }}</h5>
            </div>

            <div class="modal-footer border-0 justify-content-center gap-3">

                <button class="btn-annuler" data-bs-dismiss="modal">
                    Annuler
                </button>

                <form method="POST" action="{{ path('app_action_delete', {id: action.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ action.id) }}">
                    <button class="btn-supprimer">
                        Supprimer
                    </button>
                </form>

            </div>

        </div>
    </div>
</div>