{% extends 'base.html.twig' %}

{% block title %}Gestion des Bourses{% endblock %}

{% block body %}
<!-- Titre principal -->
<div style="padding: 30px;">
    <h1 style="font-size: 2.5rem; font-weight: 700; color: #1a1a1a; margin-bottom: 30px;">
        🏛️ Gestion des Bourses
    </h1>

    <!-- Bouton Ajouter -->
    <a href="{{ path('app_bourse_new') }}" style="color: #007bff; text-decoration: none; font-size: 1rem; margin-bottom: 20px; display: inline-block;">
        <i class="fas fa-plus-circle"></i> Ajouter une Bourse
    </a>

    <!-- Tableau -->
    <table style="width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden;">
        <thead>
            <tr style="background: #f8f9fa; border-bottom: 2px solid #dee2e6;">
                <th style="padding: 15px; text-align: left; font-weight: 600; color: #495057;">Nom</th>
                <th style="padding: 15px; text-align: left; font-weight: 600; color: #495057;">Pays</th>
                <th style="padding: 15px; text-align: left; font-weight: 600; color: #495057;">Devise</th>
                <th style="padding: 15px; text-align: left; font-weight: 600; color: #495057;">Statut</th>
                <th style="padding: 15px; text-align: left; font-weight: 600; color: #495057;">Actions</th>
                <th style="padding: 15px; text-align: left; font-weight: 600; color: #495057;">Date Création</th>
                <th style="padding: 15px; text-align: left; font-weight: 600; color: #495057;">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for data in boursesData %}
             {% set bourse = data[0] %}
                {% set nbActions = data.nbActions %}
                
                <tr style="border-bottom: 1px solid #e9ecef; {{ nbActions == 0 ? 'background: #fff3cd;' : 'background: white;' }}">
                    <!-- Nom -->
                    <td style="padding: 15px;">
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <strong>{{ bourse.nomBourse }}</strong>
                            {% if nbActions == 0 %}
                                <span style="background: #ffc107; color: #212529; padding: 4px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600; display: inline-flex; align-items: center; gap: 4px;">
                                    <i class="fas fa-exclamation-triangle"></i> Aucune action
                                </span>
                            {% endif %}
                        </div>
                    </td>

                    <!-- Pays -->
                    <td style="padding: 15px; color: #6c757d;">{{ bourse.pays }}</td>

                    <!-- Devise -->
                    <td style="padding: 15px;">
                        <span style="background: #17a2b8; color: white; padding: 6px 14px; border-radius: 16px; font-size: 0.85rem; font-weight: 600;">
                            {{ bourse.devise }}
                        </span>
                    </td>

                    <!-- Statut -->
                    <td style="padding: 15px;">
                        {% if bourse.statut == 'ACTIVE' %}
                            <span style="background: #28a745; color: white; padding: 6px 14px; border-radius: 16px; font-size: 0.85rem; font-weight: 600;">
                                Actif
                            </span>
                        {% else %}
                            <span style="background: #6c757d; color: white; padding: 6px 14px; border-radius: 16px; font-size: 0.85rem; font-weight: 600;">
                                Inactif
                            </span>
                        {% endif %}
                    </td>

                    <!-- Colonne Actions (nombre) -->
                    <td style="padding: 15px;">
                        {% if nbActions > 0 %}
                            <a href="{{ path('app_action_index') }}?bourse={{ bourse.id }}" 
                               style="color: #007bff; text-decoration: none; display: inline-flex; align-items: center; gap: 6px;">
                                <i class="fas fa-chart-line"></i> {{ nbActions }} action(s)
                            </a>
                        {% else %}
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <span style="color: #ff9800; display: inline-flex; align-items: center; gap: 6px;">
                                    <i class="fas fa-info-circle"></i> Aucune action
                                </span>
                                <a href="{{ path('app_action_new') }}?bourse={{ bourse.id }}" 
                                   style="background: #28a745; color: white; padding: 6px 12px; border-radius: 4px; text-decoration: none; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 4px;">
                                    <i class="fas fa-plus"></i> Ajouter
                                </a>
                            </div>
                        {% endif %}
                    </td>

                    <!-- Date Création -->
                    <td style="padding: 15px; color: #6c757d;">
                        {{ bourse.dateCreation|date('d/m/Y H:i') }}
                    </td>

                    <!-- Actions (boutons) -->
                    <td style="padding: 15px;">
                        <div style="display: flex; gap: 8px;">
                            <a href="{{ path('app_bourse_show', {id: bourse.id}) }}" 
                               style="color: #007bff; text-decoration: none; font-size: 0.9rem;">
                                Voir
                            </a>
                            <a href="{{ path('app_bourse_edit', {id: bourse.id}) }}" 
                               style="color: #007bff; text-decoration: none; font-size: 0.9rem;">
                                Éditer
                            </a>
                            
                            {% if nbActions == 0 %}
                                <form method="post" 
                                      action="{{ path('app_bourse_delete', {id: bourse.id}) }}" 
                                      style="display: inline;" 
                                      onsubmit="return confirm('Supprimer cette bourse ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ bourse.id) }}">
                                    <button type="submit" 
                                            style="background: none; border: none; color: #dc3545; cursor: pointer; padding: 0; font-size: 0.9rem; text-decoration: underline;">
                                        Supprimer
                                    </button>
                                </form>
                            {% else %}
                                <span style="color: #6c757d; font-size: 0.9rem; cursor: not-allowed;" 
                                      title="Supprimez d'abord les {{ nbActions }} action(s)">
                                    Supprimer
                                </span>
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <!-- Cartes résumé en bas -->
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 40px;">
        <!-- Total Bourses -->
        <div style="background: white; padding: 30px; border-radius: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); display: flex; align-items: center; gap: 20px;">
            <div style="width: 70px; height: 70px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 16px; display: flex; align-items: center; justify-content: center; color: white; font-size: 2rem;">
                <i class="fas fa-building"></i>
            </div>
            <div>
                <div style="font-size: 0.9rem; color: #6c757d; margin-bottom: 5px;">Total Bourses</div>
                <div style="font-size: 2.5rem; font-weight: 700; color: #1a1a1a;">{{ boursesData|length }}</div>
            </div>
        </div>

        <!-- Avec Actions -->
        <div style="background: white; padding: 30px; border-radius: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); display: flex; align-items: center; gap: 20px;">
            <div style="width: 70px; height: 70px; background: linear-gradient(135deg, #28a745 0%, #20c997 100%); border-radius: 16px; display: flex; align-items: center; justify-content: center; color: white; font-size: 2rem;">
                <i class="fas fa-check-circle"></i>
            </div>
            <div>
                <div style="font-size: 0.9rem; color: #6c757d; margin-bottom: 5px;">Avec Actions</div>
                <div style="font-size: 2.5rem; font-weight: 700; color: #1a1a1a;">
                    {% set withActions = 0 %}
                    {% for data in boursesData %}
                        {% if data.nbActions > 0 %}
                            {% set withActions = withActions + 1 %}
                        {% endif %}
                    {% endfor %}
                    {{ withActions }}
                </div>
            </div>
        </div>

        <!-- Sans Actions -->
        <div style="background: white; padding: 30px; border-radius: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); display: flex; align-items: center; gap: 20px;">
            <div style="width: 70px; height: 70px; background: linear-gradient(135deg, #ff9800 0%, #ffc107 100%); border-radius: 16px; display: flex; align-items: center; justify-content: center; color: white; font-size: 2rem;">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <div>
                <div style="font-size: 0.9rem; color: #6c757d; margin-bottom: 5px;">Sans Actions</div>
                <div style="font-size: 2.5rem; font-weight: 700; color: #1a1a1a;">
                    {% set withoutActions = 0 %}
                    {% for data in boursesData %}
                        {% if data.nbActions == 0 %}
                            {% set withoutActions = withoutActions + 1 %}
                        {% endif %}
                    {% endfor %}
                    {{ withoutActions }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
