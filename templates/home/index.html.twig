{% extends 'base.html.twig' %}

{% block title %}FINORA - Accueil{% endblock %}

{% block body %}
{% block subheader %}
    <hr class="my-0">
    <nav class="navbar navbar-expand-xl nav-category">
        <div class="container px-0">
            <ul class="navbar-nav mx-auto">
                <li class="nav-item"><a class="nav-link" href="{{ path('app_formations', {'categorie':'Bourse'}) }}">Bourse</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_formations', {'categorie':'Trading'}) }}">Trading</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_formations', {'categorie':'Investissement'}) }}">Investissement</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_formations', {'categorie':'Crypto'}) }}">Crypto</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_formations', {'categorie':'Analyse technique'}) }}">Analyse technique</a></li>
            </ul>
        </div>
    </nav>
{% endblock %}

<main>
    <section class="position-relative overflow-hidden pb-0 pb-sm-5">
        <div class="container">
            <div class="row align-items-center g-4 purple-section p-4 p-lg-5">

                <div class="col-lg-7">
                    <h6 class="mb-3 bg-primary bg-opacity-10 text-primary py-2 px-4 rounded-2 d-inline-block">
                        Bienvenue sur FINORA
                    </h6>

                    <h1 class="mb-4 display-5 finora-title">
                        Développez vos compétences en
                        <span class="text-primary">finance</span>
                    </h1>

                    <p class="mb-3">
                        Découvrez les formations et progressez dans le monde de la finance, du trading et de l’investissement.
                    </p>

                    <form method="get" action="{{ path('app_formations') }}" class="border rounded p-2 mb-4 bg-white">
                        <div class="input-group">
                            <input name="titre" class="form-control border-0 me-1" type="search" placeholder="Trouver une formation">
                            <button type="submit" class="btn btn-primary rounded">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </form>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <div class="icon-lg text-primary bg-primary bg-opacity-10 rounded">
                                        <i class="bi bi-book-half"></i>
                                    </div>
                                    <div class="ms-3">
                                        <h4 class="fw-bold mb-0">{{ formations|length }}</h4>
                                        <div>Formations</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <div class="icon-lg text-primary bg-primary bg-opacity-10 rounded">
                                        <i class="fas fa-graduation-cap"></i>
                                    </div>
                                    <div class="ms-3">
                                        <h4 class="fw-bold mb-0">{{ lessons|length }}</h4>
                                        <div>Lessons</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5 text-center">
                    <img src="{{ asset('assets/images/element/06.png') }}" class="img-fluid" alt="hero image">
                </div>

            </div>
        </div>
    </section>

    <section class="pt-5" style="background:#faf5ff;">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="finora-title"><i class="bi bi-star-fill text-warning me-2"></i>Formations Bestsellers</h2>
            </div>
            <div class="tiny-slider arrow-round arrow-hover arrow-dark">
                <div class="tiny-slider-inner" data-autoplay="true" data-arrow="true" data-dots="false" data-items="3" data-items-lg="3" data-items-md="2" data-items-sm="1" data-items-xs="1">
                    {% for formation in formations|slice(0, 5) %}
                        <div class="item pb-4">
                            <div class="card shadow-sm h-100 mx-2" style="border-radius:18px; border:1px solid rgba(124,58,237,0.1);">
                                {% if formation.imageUrl %}
                                    <img src="{{ asset('uploads/formations/' ~ formation.imageUrl) }}" class="card-img-top" style="height:200px; object-fit:cover; border-radius:18px 18px 0 0;" alt="{{ formation.titre }}">
                                {% else %}
                                    <img src="{{ asset('assets/images/courses/4by3/16.jpg') }}" class="card-img-top" style="height:200px; object-fit:cover; border-radius:18px 18px 0 0;" alt="{{ formation.titre }}">
                                {% endif %}
                                <div class="card-body">
                                    <div class="mb-2 d-flex flex-wrap gap-2">
                                        <span class="badge bg-primary bg-opacity-10 text-primary">{{ formation.niveau }}</span>
                                        <span class="badge bg-danger bg-opacity-10 text-danger"><i class="bi bi-fire"></i> Best-seller</span>
                                    </div>
                                    <h5 class="fw-bold text-dark">{{ formation.titre }}</h5>
                                    <p class="text-muted small">{{ formation.description ? formation.description|slice(0, 80) ~ '...' : 'Pas de description' }}</p>
                                    <div class="d-flex gap-2 mt-3">
                                        <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn btn-primary w-100 fw-bold" style="border-radius:12px;">Découvrir</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <div class="item"><div class="alert alert-info">Aucune formation disponible.</div></div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>

    <section class="pt-5 pb-5">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="finora-title">Toutes nos formations</h2>
                <a href="{{ path('app_formations') }}" class="btn btn-outline-primary" style="border-radius:12px; font-weight:700;">
                    Voir toutes <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div class="row g-4">
                {% for formation in formations|slice(5, 6) %}
                    <div class="col-md-6 col-xl-4">
                        <div class="card shadow-sm h-100" style="border-radius:18px; border:1px solid rgba(124,58,237,0.08);">
                            {% if formation.imageUrl %}
                                <img src="{{ asset('uploads/formations/' ~ formation.imageUrl) }}" class="card-img-top" style="height:200px; object-fit:cover; border-radius:18px 18px 0 0;" alt="{{ formation.titre }}">
                            {% else %}
                                <img src="{{ asset('assets/images/courses/4by3/16.jpg') }}" class="card-img-top" style="height:200px; object-fit:cover; border-radius:18px 18px 0 0;" alt="{{ formation.titre }}">
                            {% endif %}
                            <div class="card-body">
                                <span class="badge bg-primary bg-opacity-10 text-primary mb-2">{{ formation.niveau }}</span>
                                <h5 class="fw-bold">{{ formation.titre }}</h5>
                                <div class="mt-3">
                                    <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn btn-outline-primary btn-sm w-100" style="border-radius:8px;">
                                        Voir la formation
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12"><p class="text-muted">Explorez nos bestsellers.</p></div>
                {% endfor %}
            </div>
        </div>
    </section>
</main>
{% endblock %}