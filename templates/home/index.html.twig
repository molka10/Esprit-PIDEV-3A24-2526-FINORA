{% extends 'base.html.twig' %}

{% block title %}FINORA - Gérez vos investissements{% endblock %}

{% block body %}

<!-- ======================= HEADER START ======================= -->
<header class="navbar-light navbar-sticky">
    <nav class="navbar navbar-expand-xl z-index-9">
        <div class="container">

            <!-- Logo -->
            <a class="navbar-brand" href="{{ path('app_home') }}">
                <img class="light-mode-item navbar-brand-item" src="{{ asset('assets/images/logo.svg') }}" alt="FINORA" style="height:40px;">
                <img class="dark-mode-item navbar-brand-item" src="{{ asset('assets/images/logo-light.svg') }}" alt="FINORA" style="height:40px;">
            </a>

            <!-- Mobile toggler -->
            <button class="navbar-toggler ms-auto" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarCollapse"
                    aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-animation">
                    <span></span><span></span><span></span>
                </span>
            </button>

            <!-- Main navbar -->
            <div class="navbar-collapse collapse" id="navbarCollapse">

                <!-- Search bar -->
                <div class="col-xxl-6">
                    <div class="nav my-3 my-xl-0 px-4 flex-nowrap align-items-center">
                        <div class="nav-item w-100">
                            <form method="get" action="{{ path('app_investment_index') }}" class="rounded position-relative">
                                <input class="form-control pe-5 bg-secondary bg-opacity-10 border-0"
                                       name="search" type="search"
                                       placeholder="Rechercher un investissement" aria-label="Search">
                                <button class="btn btn-link bg-transparent px-2 py-0 position-absolute top-50 end-0 translate-middle-y" type="submit">
                                    <i class="fas fa-search fs-6 text-primary"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Nav links -->
                <ul class="navbar-nav navbar-nav-scroll ms-auto">
                    {% set current_nav_role = app.session.get('role') %}
                    {% if current_nav_role == 'admin' %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('admin_dashboard') }}">
                            <i class="bi bi-speedometer2 me-1"></i>Dashboard
                        </a>
                    </li>
                    {% endif %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_investment_index') }}">
                            <i class="bi bi-graph-up-arrow me-1"></i>Investments
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_management_index') }}">
                            <i class="bi bi-briefcase me-1"></i>Management
                        </a>
                    </li>
                </ul>

            </div>

            <!-- Profile & notifications -->
            <ul class="nav flex-row align-items-center list-unstyled ms-xl-auto">

                <!-- Wishlist -->
                <li class="nav-item ms-0 ms-sm-2 d-none d-sm-block">
                    <a class="btn btn-light btn-round mb-0" href="#">
                        <i class="bi bi-heart fa-fw"></i>
                    </a>
                </li>

                <!-- Notifications -->
                <li class="nav-item ms-2 ms-sm-3 dropdown">
                    <a class="btn btn-light btn-round mb-0" href="#"
                       role="button" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside">
                        <i class="bi bi-bell fa-fw"></i>
                    </a>
                    <span class="notif-badge animation-blink"></span>

                    <div class="dropdown-menu dropdown-animation dropdown-menu-end dropdown-menu-size-md p-0 shadow-lg border-0">
                        <div class="card bg-transparent">
                            <div class="card-header bg-transparent border-bottom py-4 d-flex justify-content-between align-items-center">
                                <h6 class="m-0">Notifications <span class="badge bg-danger bg-opacity-10 text-danger ms-2">2 new</span></h6>
                                <a class="small" href="#">Tout effacer</a>
                            </div>
                            <div class="card-body p-0">
                                <ul class="list-group list-unstyled list-group-flush">
                                    <li>
                                        <a href="#" class="list-group-item-action border-0 border-bottom d-flex p-3">
                                            <div class="me-3">
                                                <div class="avatar avatar-md">
                                                    <img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/03.jpg') }}" alt="avatar">
                                                </div>
                                            </div>
                                            <div>
                                                <h6 class="mb-1">Nouveau rapport disponible</h6>
                                                <p class="small text-body m-0">Votre rapport mensuel est prêt</p>
                                                <small class="text-body">5 min ago</small>
                                            </div>
                                        </a>
                                    </li>
                                </ul>
                            </div>
                            <div class="card-footer bg-transparent border-0 py-3 text-center position-relative">
                                <a href="#" class="stretched-link">Voir toute l'activité</a>
                            </div>
                        </div>
                    </div>
                </li>

                <!-- Profile dropdown / Sign In -->
                <li class="nav-item ms-3 dropdown">
                    {% set current_role = app.session.get('role') %}
                    {% if current_role %}
                        <a class="avatar avatar-sm p-0" href="#" id="profileDropdown" role="button" data-bs-auto-close="outside" data-bs-display="static" data-bs-toggle="dropdown" aria-expanded="false">
                            <img class="avatar-img rounded-circle border border-2 border-primary" src="{{ asset('assets/images/avatar/01.jpg') }}" alt="avatar">
                        </a>

                        <ul class="dropdown-menu dropdown-animation dropdown-menu-end shadow pt-3" aria-labelledby="profileDropdown">
                            <li class="px-3 mb-3">
                                <div class="d-flex align-items-center">
                                    <div class="avatar me-3">
                                        <img class="avatar-img rounded-circle shadow" src="{{ asset('assets/images/avatar/01.jpg') }}" alt="avatar">
                                    </div>
                                    <div>
                                        <a class="h6" href="#">Profil Actif</a>
                                        <p class="small m-0 text-primary fw-bold">{{ current_role|upper }}</p>
                                    </div>
                                </div>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            {% if current_role == 'investisseur' %}
                            <li><a class="dropdown-item" href="{{ path('app_investor_profile') }}"><i class="bi bi-person fa-fw me-2"></i>Mon Profil</a></li>
                            {% endif %}
                            {% if current_role == 'admin' %}
                            <li><a class="dropdown-item" href="{{ path('admin_dashboard') }}"><i class="bi bi-speedometer2 fa-fw me-2"></i>Dashboard</a></li>
                            {% endif %}
                            <li><a class="dropdown-item bg-danger-soft-hover" href="{{ path('logout_role') }}"><i class="bi bi-power fa-fw me-2 text-danger"></i>Se déconnecter</a></li>
                        </ul>
                    {% else %}
                        <a href="{{ path('choose_role') }}" class="btn btn-primary btn-sm mb-0">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Sign In
                        </a>
                    {% endif %}
                </li>

            </ul>

        </div>
    </nav>

    <hr class="my-0">

    <!-- Category navbar -->
    <nav class="navbar navbar-expand-xl nav-category">
        <div class="container px-0">
            <button class="navbar-toggler m-auto w-100" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarCollapse2"
                    aria-controls="navbarCollapse2" aria-expanded="false">
                <i class="bi bi-grid-fill"></i> Catégories
            </button>

            <div class="navbar-collapse w-100 collapse" id="navbarCollapse2">
                <ul class="navbar-nav navbar-nav-scroll mx-auto">

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle active" href="#"
                           data-bs-toggle="dropdown" aria-expanded="false">Investissements</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="#">Actions & Bourse</a></li>
                            <li><a class="dropdown-item" href="#">Immobilier</a></li>
                            <li><a class="dropdown-item" href="#">Cryptomonnaies</a></li>
                            <li><a class="dropdown-item" href="#">Obligations</a></li>
                            <li><a class="dropdown-item" href="#">Fonds communs</a></li>
                        </ul>
                    </li>

                    <li class="nav-item"><a class="nav-link" href="{{ path('app_management_index') }}">Finance & Gestion</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Développement</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">IT & Logiciels</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Développement personnel</a></li>

                </ul>
            </div>
        </div>
    </nav>
</header>
<!-- ======================= HEADER END ======================= -->


