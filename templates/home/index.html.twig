{% extends 'base.html.twig' %}

{% block title %}FINORA - Accueil{% endblock %}

{% block body %}
{% block subheader %}
    <hr class="my-0">
    <nav class="navbar navbar-expand-xl nav-category">
        <div class="container px-0">
            <ul class="navbar-nav mx-auto">
                <li class="nav-item"><a class="nav-link" href="{{ path('app_formations', {'categorie':'Bourse'}) }}">Bourse</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_formations', {'categorie':'Trading'}) }}">Trading</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_formations', {'categorie':'Investissement'}) }}">Investissement</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_formations', {'categorie':'Crypto'}) }}">Crypto</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_formations', {'categorie':'Analyse technique'}) }}">Analyse technique</a></li>
            </ul>
        </div>
    </nav>
{% endblock %}

<main>
    <section class="position-relative overflow-hidden pb-0 pb-sm-5">
        <div class="container">
            <div class="row align-items-center g-4 purple-section p-4 p-lg-5">

                <div class="col-lg-7">
                    <h6 class="mb-3 bg-primary bg-opacity-10 text-primary py-2 px-4 rounded-2 d-inline-block">
                        Bienvenue sur FINORA
                    </h6>

                    <h1 class="mb-4 display-5 finora-title">
                        Développez vos compétences en
                        <span class="text-primary">finance</span>
                    </h1>

                    <p class="mb-3">
                        Découvrez les formations et progressez dans le monde de la finance, du trading et de l’investissement.
                    </p>

                    <form method="get" action="{{ path('app_formations') }}" class="border rounded p-2 mb-4 bg-white">
                        <div class="input-group">
                            <input name="titre" class="form-control border-0 me-1" type="search" placeholder="Trouver une formation">
                            <button type="submit" class="btn btn-primary rounded">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </form>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <div class="icon-lg text-primary bg-primary bg-opacity-10 rounded">
                                        <i class="bi bi-book-half"></i>
                                    </div>
                                    <div class="ms-3">
                                        <h4 class="fw-bold mb-0">{{ formations|length }}</h4>
                                        <div>Formations</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <div class="icon-lg text-primary bg-primary bg-opacity-10 rounded">
                                        <i class="fas fa-graduation-cap"></i>
                                    </div>
                                    <div class="ms-3">
                                        <h4 class="fw-bold mb-0">{{ lessons|length }}</h4>
                                        <div>Lessons</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5 text-center">
                    <img src="{{ asset('assets/images/element/06.png') }}" class="img-fluid" alt="hero image">
                </div>

            </div>
        </div>
    </section>

    <section class="pt-5">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="finora-title">Nos formations</h2>
                <a href="{{ path('app_formations') }}" class="btn btn-primary">
                    Voir toutes →
                </a>
            </div>

            <div class="row g-4">
                {% for formation in formations|slice(0, 3) %}
                    <div class="col-md-6 col-xl-4">
                        <div class="card shadow-sm h-100">

                            {% if formation.imageUrl %}
                                <img src="{{ asset('uploads/formations/' ~ formation.imageUrl) }}" class="card-img-top" alt="{{ formation.titre }}">
                            {% else %}
                                <img src="{{ asset('assets/images/courses/4by3/16.jpg') }}" class="card-img-top" alt="{{ formation.titre }}">
                            {% endif %}

                            <div class="card-body">
                                <div class="mb-2 d-flex flex-wrap gap-2">
                                    <span class="badge bg-primary">{{ formation.niveau }}</span>

                                    {% for tag in formation.categorie ? formation.categorie|split(',') : [] %}
                                        {% if tag|trim != '' %}
                                            <span class="purple-chip">{{ tag|trim }}</span>
                                        {% endif %}
                                    {% endfor %}
                                </div>

                                <h5>{{ formation.titre }}</h5>
                                <p>{{ formation.description ?: 'Pas de description' }}</p>

                                <div class="d-flex gap-2 flex-wrap">
                                    <a href="{{ path('app_formations') }}" class="btn btn-outline-primary">
                                        Explorer
                                    </a>
                                    <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn btn-primary">
                                        Voir formation
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12">
                        <p>Aucune formation disponible.</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>
</main>
{% endblock %}