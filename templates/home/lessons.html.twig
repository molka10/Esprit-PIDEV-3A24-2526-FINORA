{% extends 'base.html.twig' %}

{% block title %}FINORA - Lessons{% endblock %}

{% block body %}
<header class="navbar-light navbar-sticky">
    <nav class="navbar navbar-expand-xl z-index-9">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}">
                <img class="light-mode-item navbar-brand-item" src="{{ asset('assets/images/logo.svg') }}" alt="logo">
                <img class="dark-mode-item navbar-brand-item" src="{{ asset('assets/images/logo-light.svg') }}" alt="logo">
            </a>

            <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-animation">
                    <span></span>
                    <span></span>
                    <span></span>
                </span>
            </button>

            <div class="navbar-collapse collapse" id="navbarCollapse">
                <ul class="navbar-nav navbar-nav-scroll ms-auto">
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}">Accueil</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_formations') }}">Formations</a></li>
                    <li class="nav-item"><a class="nav-link active" href="{{ path('app_lessons') }}">Lessons</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('admin_dashboard') }}">Dashboard</a></li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<main>
    <section class="pt-5 pb-0">
        <div class="container">
            <div class="row align-items-center g-4 purple-section p-4 p-lg-5">
                <div class="col-lg-6">
                    <span class="badge bg-primary bg-opacity-10 text-primary mb-3">Catalogue Lessons</span>
                    <h1 class="display-5 mb-3 finora-title">Explorez les lessons FINORA</h1>
                    <p class="mb-4">
                        Parcourez les lessons disponibles, filtrez par formation et trouvez rapidement le contenu qui vous intéresse.
                    </p>

                    <form method="get" action="{{ path('app_lessons') }}" class="border rounded p-2 mb-4 bg-white" id="hero-lesson-search-form">
                        <div class="input-group">
                            <input
                                type="text"
                                name="titre"
                                class="form-control border-0 me-1"
                                placeholder="Trouver une lesson"
                                value="{{ titre }}"
                            >
                            <button class="btn btn-primary rounded" type="submit">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </form>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <div class="icon-lg fs-4 text-primary bg-primary bg-opacity-10 rounded">
                                        <i class="bi bi-play-btn"></i>
                                    </div>
                                    <div class="ms-3">
                                        <div class="d-flex">
                                            <h4 class="fw-bold mb-0">{{ lessons.getTotalItemCount }}</h4>
                                            <span class="h4 mb-0">+</span>
                                        </div>
                                        <div>Lessons disponibles</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <div class="icon-lg fs-4 text-primary bg-primary bg-opacity-10 rounded">
                                        <i class="fas fa-book-open"></i>
                                    </div>
                                    <div class="ms-3">
                                        <div class="d-flex">
                                            <h4 class="fw-bold mb-0">{{ formations|length }}</h4>
                                        </div>
                                        <div>Formations liées</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6 text-center">
                    <img src="{{ asset('assets/images/element/06.png') }}" class="img-fluid" style="max-height: 380px;" alt="hero image">
                </div>
            </div>
        </div>
    </section>

    <section class="py-5">
        <div class="container">

            <div class="mb-4">
                <h4 class="mb-3 finora-title">Filtrer par formation</h4>
                <div class="d-flex flex-wrap gap-2">
                    <a href="{{ path('app_lessons') }}"
                       class="btn btn-sm {{ formationSelected == '' ? 'btn-primary' : 'btn-outline-primary' }}">
                        Toutes
                    </a>

                    {% for formation in formations %}
                        <a href="{{ path('app_lessons', {'formation': formation.id}) }}"
                           class="btn btn-sm {{ formationSelected == formation.id ? 'btn-primary' : 'btn-outline-primary' }}">
                            {{ formation.titre }}
                        </a>
                    {% endfor %}
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <form method="get" action="{{ path('app_lessons') }}" id="fo-lesson-filter-form">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <input
                                    type="text"
                                    name="titre"
                                    id="fo-lesson-search"
                                    class="form-control"
                                    placeholder="Rechercher par titre ou contenu"
                                    value="{{ titre }}"
                                >
                            </div>

                            <div class="col-md-3">
                                <select name="formation" class="form-select">
                                    <option value="">Toutes les formations</option>
                                    {% for formation in formations %}
                                        <option value="{{ formation.id }}" {{ formationSelected == formation.id ? 'selected' : '' }}>
                                            {{ formation.titre }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="col-md-2">
                                <select name="tri" class="form-select">
                                    <option value="ordre" {{ tri == 'ordre' ? 'selected' : '' }}>Ordre</option>
                                    <option value="id" {{ tri == 'id' ? 'selected' : '' }}>ID</option>
                                    <option value="titre" {{ tri == 'titre' ? 'selected' : '' }}>Titre</option>
                                    <option value="dureeMinutes" {{ tri == 'dureeMinutes' ? 'selected' : '' }}>Durée</option>
                                </select>
                            </div>

                            <div class="col-md-1">
                                <select name="ordre" class="form-select">
                                    <option value="asc" {{ ordre == 'asc' ? 'selected' : '' }}>ASC</option>
                                    <option value="desc" {{ ordre == 'desc' ? 'selected' : '' }}>DESC</option>
                                </select>
                            </div>

                            <div class="col-md-2 d-flex gap-2">
                                <button type="submit" class="btn btn-primary w-100">Filtrer</button>
                                <a href="{{ path('app_lessons') }}" class="btn btn-outline-secondary w-100">Reset</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            {% if lessons|length > 0 %}
                <div class="row g-4">
                    {% for lesson in lessons %}
                        <div class="col-md-6 col-xl-4">
                            <div class="card border-0 shadow-sm h-100 overflow-hidden">
                                <div class="card-body">
                                    <div class="d-flex flex-wrap gap-2 mb-3">
                                        <span class="badge bg-primary bg-opacity-10 text-primary">
                                            Ordre {{ lesson.ordre }}
                                        </span>

                                        <span class="purple-chip">
                                            {{ lesson.formation ? lesson.formation.titre : 'Formation inconnue' }}
                                        </span>

                                        <span class="badge bg-success bg-opacity-10 text-success">
                                            {{ lesson.dureeMinutes }} min
                                        </span>

                                        {% if lesson.videoUrl %}
                                            <span class="badge bg-warning bg-opacity-10 text-warning">Vidéo</span>
                                        {% endif %}
                                    </div>

                                    <h5 class="card-title">{{ lesson.titre }}</h5>

                                    <p class="card-text">
                                        {{ lesson.contenu ? lesson.contenu|slice(0, 120) ~ '...' : 'Pas de contenu' }}
                                    </p>

                                    <div class="d-flex gap-2 flex-wrap mt-3">
                                        <a href="{{ path('app_lesson_show', {'id': lesson.id}) }}" class="btn btn-sm btn-primary">
                                            Voir
                                        </a>

                                        {% if lesson.videoUrl %}
                                            {% if lesson.isUploadedVideo %}
                                                <a href="{{ asset('uploads/lessons/videos/' ~ lesson.videoUrl) }}" target="_blank" class="btn btn-sm btn-outline-primary">
                                                    Ouvrir vidéo
                                                </a>
                                            {% else %}
                                                <a href="{{ lesson.videoUrl }}" target="_blank" class="btn btn-sm btn-outline-primary">
                                                    Ouvrir vidéo
                                                </a>
                                            {% endif %}
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                <div class="d-flex justify-content-center mt-5">
                    {{ knp_pagination_render(lessons) }}
                </div>
            {% else %}
                <div class="alert alert-info">
                    Aucune lesson trouvée.
                </div>
            {% endif %}
        </div>
    </section>
</main>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('fo-lesson-filter-form');
    const titreInput = document.getElementById('fo-lesson-search');

    let timeout = null;

    if (titreInput) {
        titreInput.addEventListener('keyup', function () {
            clearTimeout(timeout);
            timeout = setTimeout(() => {
                form.submit();
            }, 500);
        });
    }

    document.querySelectorAll('#fo-lesson-filter-form select').forEach(select => {
        select.addEventListener('change', function () {
            form.submit();
        });
    });
});
</script>
{% endblock %}