{% extends 'base.html.twig' %}

{% block title %}{{ formation.titre }} - FINORA{% endblock %}

{% block body %}
<header class="navbar-light navbar-sticky">
    <nav class="navbar navbar-expand-xl z-index-9">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}">
                <img class="light-mode-item navbar-brand-item" src="{{ asset('assets/images/logo.svg') }}" alt="logo">
                <img class="dark-mode-item navbar-brand-item" src="{{ asset('assets/images/logo-light.svg') }}" alt="logo">
            </a>

            <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                <span class="navbar-toggler-animation">
                    <span></span><span></span><span></span>
                </span>
            </button>

            <div class="navbar-collapse collapse" id="navbarCollapse">
                <ul class="navbar-nav navbar-nav-scroll ms-auto">
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}">Accueil</a></li>
                    <li class="nav-item"><a class="nav-link active" href="{{ path('app_formations') }}">Formations</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_lessons') }}">Lessons</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('admin_dashboard') }}">Dashboard</a></li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<main>
    <section class="py-5">
        <div class="container">

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}

            <div class="card formation-hero-card border-0 shadow-sm overflow-hidden mb-5">
                <div class="row g-0 align-items-stretch">
                    <div class="col-lg-5">
                        <div class="formation-hero-media-wrapper">
                            {% if formation.imageUrl %}
                                <img
                                    src="{{ asset('uploads/formations/' ~ formation.imageUrl) }}"
                                    alt="{{ formation.titre }}"
                                    class="formation-hero-media"
                                >
                            {% else %}
                                <img
                                    src="{{ asset('assets/images/courses/4by3/16.jpg') }}"
                                    alt="{{ formation.titre }}"
                                    class="formation-hero-media"
                                >
                            {% endif %}
                            <div class="formation-hero-overlay"></div>
                        </div>
                    </div>

                    <div class="col-lg-7">
                        <div class="card-body p-4 p-lg-5 h-100 d-flex flex-column justify-content-center">
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <span class="hero-level-badge">{{ formation.niveau }}</span>

                                {% for tag in formation.categorie ? formation.categorie|split(',') : [] %}
                                    {% if tag|trim != '' %}
                                        <span class="purple-chip">{{ tag|trim }}</span>
                                    {% endif %}
                                {% endfor %}

                                {% if formation.isPublished %}
                                    <span class="hero-status-badge published">Publié</span>
                                {% else %}
                                    <span class="hero-status-badge draft">Non publié</span>
                                {% endif %}
                            </div>

                            <h1 class="h2 mb-3 formation-hero-title">{{ formation.titre }}</h1>

                            <p class="formation-hero-text mb-4">
                                {{ formation.description ?: 'Pas de description disponible.' }}
                            </p>

                            <div class="d-flex gap-2 flex-wrap">
                                <a href="{{ path('app_formation_inscription', {'id': formation.id}) }}" class="btn formation-main-btn">
                                    S'inscrire
                                </a>
                                <a href="{{ path('app_lessons', {'formation': formation.id}) }}" class="btn formation-outline-btn">
                                    Voir uniquement ces lessons
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
                <div>
                    <h2 class="h3 mb-1 formation-section-title">Lessons de cette formation</h2>
                    <p class="text-muted mb-0">Découvrez les lessons incluses dans ce parcours.</p>
                </div>
                <span class="lesson-count-badge">{{ lessons|length }} lesson(s)</span>
            </div>

            {% if lessons|length > 0 %}
                <div class="row g-4">
                    {% for lesson in lessons %}
                        <div class="col-md-6 col-xl-4">
                            <div class="card lesson-card border-0 h-100">

                                <div class="thumb">
                                    {% if lesson.videoUrl and lesson.youTubeVideoId %}
                                        <img src="https://img.youtube.com/vi/{{ lesson.youTubeVideoId }}/hqdefault.jpg" alt="{{ lesson.titre }}">
                                        <div class="thumb-overlay"></div>
                                        <div class="play-badge">▶</div>
                                    {% elseif lesson.videoUrl and lesson.isUploadedVideo %}
                                        <div class="fallback with-video">▶ Vidéo</div>
                                        <div class="thumb-overlay"></div>
                                        <div class="play-badge">▶</div>
                                    {% else %}
                                        <div class="fallback">FINORA</div>
                                        <div class="thumb-overlay soft"></div>
                                    {% endif %}

                                    <div class="badge-order">
                                        Leçon {{ '%02d'|format(lesson.ordre) }}
                                    </div>

                                    {% if lesson.videoUrl %}
                                        <div class="badge-video">Vidéo</div>
                                    {% endif %}
                                </div>

                                <div class="card-body d-flex flex-column">
                                    <div class="mb-2 d-flex flex-wrap gap-2">
                                        <span class="mini-chip duration-chip">⏱ {{ lesson.dureeMinutes }} min</span>

                                        {% if lesson.videoUrl %}
                                            <span class="mini-chip video-chip">Avec vidéo</span>
                                        {% else %}
                                            <span class="mini-chip neutral-chip">Contenu texte</span>
                                        {% endif %}
                                    </div>

                                    <h5 class="fw-bold lesson-title">{{ lesson.titre }}</h5>

                                    <p class="text-muted small flex-grow-1 lesson-text">
                                        {{ lesson.contenu ? lesson.contenu|slice(0, 120) ~ '...' : 'Pas de contenu' }}
                                    </p>

                                    <div class="d-flex justify-content-between align-items-center mt-3">
                                        <span class="duration-label">Ordre {{ lesson.ordre }}</span>

                                        <a href="{{ path('app_lesson_show', {'id': lesson.id}) }}" class="btn btn-sm btn-primary lesson-btn">
                                            Voir lesson
                                        </a>
                                    </div>
                                </div>

                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="alert alert-info">
                    Cette formation ne contient encore aucune lesson.
                </div>
            {% endif %}
        </div>
    </section>
</main>

<style>
.formation-hero-card {
    border-radius: 26px;
    background: #ffffff;
    border: 1px solid rgba(124, 58, 237, 0.08);
    box-shadow: 0 14px 40px rgba(109, 40, 217, 0.08);
}

.formation-hero-media-wrapper {
    position: relative;
    height: 100%;
    min-height: 360px;
    overflow: hidden;
    background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 50%, #c4b5fd 100%);
}

.formation-hero-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.formation-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(46, 16, 101, 0.28), rgba(46, 16, 101, 0.04));
    pointer-events: none;
}

.formation-hero-title {
    color: #1f1147;
    font-weight: 800;
    line-height: 1.25;
}

.formation-hero-text {
    color: #6b7280;
    line-height: 1.85;
    font-size: 1rem;
}

.hero-level-badge {
    background: rgba(124, 58, 237, 0.1);
    color: #6d28d9;
    padding: 7px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 800;
}

.hero-status-badge {
    padding: 7px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
}

.hero-status-badge.published {
    background: rgba(220, 252, 231, 0.95);
    color: #166534;
}

.hero-status-badge.draft {
    background: rgba(254, 243, 199, 0.95);
    color: #92400e;
}

.purple-chip {
    background: #f3e8ff;
    color: #6d28d9;
    padding: 7px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    border: 1px solid rgba(124, 58, 237, 0.12);
}

.formation-main-btn {
    background: linear-gradient(135deg, #7c3aed 0%, #8b5cf6 100%);
    color: #ffffff;
    border: none;
    border-radius: 12px;
    padding: 10px 16px;
    font-weight: 700;
    box-shadow: 0 8px 18px rgba(124, 58, 237, 0.22);
}

.formation-main-btn:hover {
    color: #ffffff;
    background: linear-gradient(135deg, #6d28d9 0%, #7c3aed 100%);
}

.formation-outline-btn {
    border-radius: 12px;
    padding: 10px 16px;
    font-weight: 700;
    border: 1px solid rgba(124, 58, 237, 0.24);
    color: #6d28d9;
    background: #faf5ff;
}

.formation-outline-btn:hover {
    background: #f3e8ff;
    color: #5b21b6;
    border-color: rgba(124, 58, 237, 0.35);
}

.formation-section-title {
    color: #1f1147;
    font-weight: 800;
}

.lesson-count-badge {
    background: linear-gradient(135deg, #ede9fe, #f5f3ff);
    color: #6d28d9;
    border: 1px solid rgba(124, 58, 237, 0.12);
    padding: 8px 14px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 800;
}

.lesson-card {
    border-radius: 20px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(124, 58, 237, 0.08);
}

.lesson-card:hover {
    transform: translateY(-7px);
    box-shadow: 0 18px 40px rgba(124, 58, 237, 0.18);
}

.thumb {
    height: 190px;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #7c3aed, #a78bfa);
}

.thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
}

.lesson-card:hover .thumb img {
    transform: scale(1.06);
}

.fallback {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 800;
    letter-spacing: 0.5px;
    font-size: 18px;
    background: linear-gradient(135deg, #7c3aed, #a78bfa);
}

.fallback.with-video {
    font-size: 20px;
}

.thumb-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(46, 16, 101, 0.55), rgba(46, 16, 101, 0.08));
    pointer-events: none;
}

.thumb-overlay.soft {
    background: linear-gradient(to top, rgba(46, 16, 101, 0.35), rgba(46, 16, 101, 0.05));
}

.play-badge {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(1);
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.92);
    color: #6d28d9;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 20px;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
    transition: transform 0.28s ease, background 0.28s ease;
}

.lesson-card:hover .play-badge {
    transform: translate(-50%, -50%) scale(1.08);
    background: #ffffff;
}

.badge-order {
    position: absolute;
    bottom: 12px;
    left: 12px;
    background: white;
    color: #6d28d9;
    padding: 5px 11px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    z-index: 2;
}

.badge-video {
    position: absolute;
    top: 12px;
    right: 12px;
    background: #fde68a;
    color: #92400e;
    padding: 5px 11px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    z-index: 2;
}

.lesson-title {
    color: #1f1147;
    line-height: 1.35;
}

.lesson-text {
    line-height: 1.7;
}

.mini-chip {
    padding: 5px 10px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 700;
}

.video-chip {
    background: #fef3c7;
    color: #92400e;
}

.neutral-chip {
    background: #f3f4f6;
    color: #4b5563;
}

.duration-chip {
    background: #dcfce7;
    color: #166534;
}

.duration-label {
    font-size: 13px;
    color: #666;
    font-weight: 600;
}

.lesson-btn {
    border-radius: 10px;
    padding-inline: 14px;
    font-weight: 700;
}
</style>
{% endblock %}