{% extends 'base.html.twig' %}

{% block title %}FINORA - Formations{% endblock %}

{% block body %}


<main>
    <section class="pt-5 pb-0">
        <div class="container">
            <div class="row align-items-center g-4 purple-section p-4 p-lg-5">
                <div class="col-lg-6">
                    <span class="badge bg-primary bg-opacity-10 text-primary mb-3">Bienvenue sur FINORA</span>
                    <h1 class="display-5 mb-3 finora-title">Explorez les formations FINORA</h1>
                    <p class="mb-4">
                        Découvrez des formations en finance, investissement, trading et analyse des marchés.
                        Recherchez, filtrez et trouvez rapidement le contenu qui correspond à votre niveau.
                    </p>

                    <form method="get" action="{{ path('app_formations') }}" class="border rounded p-2 mb-4 bg-white" id="hero-search-form">
                        <div class="input-group">
                            <input
                                type="text"
                                name="titre"
                                id="voice-search-input"
                                class="form-control border-0 me-1"
                                placeholder="Trouver une formation"
                                value="{{ titre }}"
                            >
                            <button type="button" id="voice-btn" class="btn btn-warning">
                                🎤
                            </button>
                            <button class="btn btn-primary rounded" type="submit">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                        <div id="voice-status" class="small text-muted mt-2"></div>
                    </form>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <div class="icon-lg fs-4 text-primary bg-primary bg-opacity-10 rounded">
                                        <i class="bi bi-book-half"></i>
                                    </div>
                                    <div class="ms-3">
                                        <div class="d-flex">
                                            <h4 class="fw-bold mb-0">{{ formations.getTotalItemCount }}</h4>
                                            <span class="h4 mb-0">+</span>
                                        </div>
                                        <div>Formations disponibles</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <div class="icon-lg fs-4 text-primary bg-primary bg-opacity-10 rounded">
                                        <i class="fas fa-layer-group"></i>
                                    </div>
                                    <div class="ms-3">
                                        <div class="d-flex">
                                            <h4 class="fw-bold mb-0">{{ categories|length }}</h4>
                                        </div>
                                        <div>Catégories</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6 text-center">
                    <img src="{{ asset('assets/images/element/06.png') }}" class="img-fluid" style="max-height: 380px;" alt="hero image">
                </div>
            </div>
        </div>
    </section>

    <section class="py-5">
        <div class="container">

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}

            <div class="mb-4">
                <h4 class="mb-3 finora-title">Catégories populaires</h4>
                <div class="d-flex flex-wrap gap-2">
                    <a href="{{ path('app_formations') }}"
                       class="btn btn-sm {{ categorie == '' ? 'btn-primary' : 'btn-outline-primary' }}">
                        Toutes
                    </a>

                    {% for cat in categories %}
                        <a href="{{ path('app_formations', {'categorie': cat}) }}"
                           class="btn btn-sm {{ categorie == cat ? 'btn-primary' : 'btn-outline-primary' }}">
                            {{ cat }}
                        </a>
                    {% endfor %}
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <form method="get" action="{{ path('app_formations') }}" id="fo-formation-filter-form">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <input
                                    type="text"
                                    name="titre"
                                    id="fo-titre-search"
                                    class="form-control"
                                    placeholder="Rechercher par titre"
                                    value="{{ titre }}"
                                >
                            </div>

                            <div class="col-md-2">
                                <select name="categorie" class="form-select">
                                    <option value="">Toutes catégories</option>
                                    {% for cat in categories %}
                                        <option value="{{ cat }}" {{ categorie == cat ? 'selected' : '' }}>
                                            {{ cat }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="col-md-2">
                                <select name="niveau" class="form-select">
                                    <option value="">Tous niveaux</option>
                                    <option value="Débutant" {{ niveau == 'Débutant' ? 'selected' : '' }}>Débutant</option>
                                    <option value="Intermédiaire" {{ niveau == 'Intermédiaire' ? 'selected' : '' }}>Intermédiaire</option>
                                    <option value="Avancé" {{ niveau == 'Avancé' ? 'selected' : '' }}>Avancé</option>
                                </select>
                            </div>

                            <div class="col-md-2">
                                <select name="tri" class="form-select">
                                    <option value="id" {{ tri == 'id' ? 'selected' : '' }}>Trier par ID</option>
                                    <option value="titre" {{ tri == 'titre' ? 'selected' : '' }}>Titre</option>
                                    <option value="categorie" {{ tri == 'categorie' ? 'selected' : '' }}>Catégorie</option>
                                    <option value="niveau" {{ tri == 'niveau' ? 'selected' : '' }}>Niveau</option>
                                </select>
                            </div>

                            <div class="col-md-1">
                                <select name="ordre" class="form-select">
                                    <option value="asc" {{ ordre == 'asc' ? 'selected' : '' }}>ASC</option>
                                    <option value="desc" {{ ordre == 'desc' ? 'selected' : '' }}>DESC</option>
                                </select>
                            </div>

                            <div class="col-md-2 d-flex gap-2">
                                <button type="submit" class="btn btn-primary w-100">Filtrer</button>
                                <a href="{{ path('app_formations') }}" class="btn btn-outline-secondary w-100">Reset</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            {% if formations|length > 0 %}
                <div class="row g-4">
                    {% for formation in formations %}
                        <div class="col-md-6 col-xl-4">
                            <div class="card formation-card border-0 h-100 overflow-hidden">

                                <div class="formation-card-top">
                                    {% if formation.imageUrl %}
                                        <img
                                            src="{{ asset('uploads/formations/' ~ formation.imageUrl) }}"
                                            class="formation-card-media"
                                            alt="{{ formation.titre }}"
                                        >
                                    {% else %}
                                        <img
                                            src="{{ asset('assets/images/courses/4by3/16.jpg') }}"
                                            class="formation-card-media"
                                            alt="{{ formation.titre }}"
                                        >
                                    {% endif %}

                                    <div class="formation-card-overlay"></div>

                                    <div class="formation-card-badges">
                                        <span class="formation-level-badge">
                                            {{ formation.niveau }}
                                        </span>

                                        {% if formation.isPublished %}
                                            <span class="formation-status-badge published">
                                                Publié
                                            </span>
                                        {% else %}
                                            <span class="formation-status-badge draft">
                                                Non publié
                                            </span>
                                        {% endif %}
                                    </div>
                                </div>

                                <div class="card-body d-flex flex-column p-4">
                                    <div class="d-flex flex-wrap gap-2 mb-3">
                                        {% for tag in formation.categorie ? formation.categorie|split(',') : [] %}
                                            {% if tag|trim != '' %}
                                                <span class="purple-chip">{{ tag|trim }}</span>
                                            {% endif %}
                                        {% endfor %}
                                    </div>

                                    <h5 class="card-title formation-card-title">{{ formation.titre }}</h5>

                                    <p class="card-text formation-card-text flex-grow-1">
                                        {{ formation.description ? formation.description|slice(0, 120) ~ '...' : 'Pas de description' }}
                                    </p>

                                    <div class="formation-card-footer d-flex gap-2 flex-wrap mt-3">
                                        <button type="button" class="btn btn-sm formation-outline-btn" data-bs-toggle="modal" data-bs-target="#purchaseModal{{ formation.id }}">
                                            Acheter
                                        </button>
                                        <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn btn-sm formation-main-btn">
                                            Voir formation
                                        </a>
                                    </div>
                                </div>

                            </div>
                        </div>

                        <!-- Purchase Modal for Formation {{ formation.id }} -->
                        <div class="modal fade" id="purchaseModal{{ formation.id }}" tabindex="-1" aria-labelledby="purchaseModalLabel{{ formation.id }}" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content border-0" style="border-radius: 18px; box-shadow: 0 15px 35px rgba(0,0,0,0.15);">
                                    <div class="modal-header border-bottom-0 pb-0">
                                        <h5 class="modal-title fw-bold text-primary" id="purchaseModalLabel{{ formation.id }}">Acheter la formation</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                                    </div>
                                    <div class="modal-body">
                                        <h6 class="fw-bold mb-3">{{ formation.titre }}</h6>
                                        
                                        <div class="bg-primary bg-opacity-10 p-3 rounded-3 mb-4">
                                            <p class="mb-2 fw-semibold text-primary"><i class="bi bi-info-circle me-1"></i> Qu'allez-vous apprendre ?</p>
                                            <p class="small mb-0 text-dark">
                                                En rejoignant cette formation, vous maîtriserez les concepts clés, découvrirez des stratégies pratiques et acquerrez les compétences nécessaires pour progresser à votre rythme.
                                            </p>
                                        </div>

                                        <form action="{{ path('app_formation_inscription', {'id': formation.id}) }}" method="post">
                                            <div class="mb-3">
                                                <label class="form-label small fw-bold">Nom complet</label>
                                                <input type="text" class="form-control" required placeholder="Ex: Jean Dupont">
                                            </div>
                                            <div class="mb-4">
                                                <label class="form-label small fw-bold">Méthode de paiement</label>
                                                <select class="form-select">
                                                    <option>Carte Bancaire</option>
                                                    <option>PayPal</option>
                                                    <option>Virement</option>
                                                </select>
                                            </div>
                                            <div class="d-grid">
                                                <button type="submit" class="btn btn-primary py-2 fw-bold" style="border-radius: 12px; background: linear-gradient(135deg, #7c3aed, #8b5cf6); border: none;">
                                                    Confirmer l'achat
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                    {% endfor %}
                </div>

                <div class="d-flex justify-content-center mt-5">
                    {{ knp_pagination_render(formations) }}
                </div>
            {% else %}
                <div class="alert alert-info">
                    Aucune formation trouvée.
                </div>
            {% endif %}
        </div>
    </section>
</main>

<style>
.formation-card {
    border-radius: 22px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(109, 40, 217, 0.08);
    transition: transform 0.28s ease, box-shadow 0.28s ease;
    border: 1px solid rgba(124, 58, 237, 0.08);
}

.formation-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 18px 40px rgba(109, 40, 217, 0.16);
}

.formation-card-top {
    position: relative;
    height: 230px;
    overflow: hidden;
    background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 50%, #c4b5fd 100%);
}

.formation-card-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
}

.formation-card:hover .formation-card-media {
    transform: scale(1.05);
}

.formation-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(46, 16, 101, 0.55) 0%, rgba(46, 16, 101, 0.12) 45%, rgba(255,255,255,0) 100%);
    pointer-events: none;
}

.formation-card-badges {
    position: absolute;
    inset: auto 16px 16px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    z-index: 2;
}

.formation-level-badge {
    background: rgba(255, 255, 255, 0.95);
    color: #6d28d9;
    padding: 7px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 800;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
}

.formation-status-badge {
    padding: 7px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
}

.formation-status-badge.published {
    background: rgba(220, 252, 231, 0.96);
    color: #166534;
}

.formation-status-badge.draft {
    background: rgba(254, 243, 199, 0.96);
    color: #92400e;
}

.formation-card-title {
    color: #1f1147;
    font-weight: 800;
    margin-bottom: 12px;
    line-height: 1.35;
}

.formation-card-text {
    color: #6b7280;
    line-height: 1.75;
    min-height: 85px;
}

.purple-chip {
    background: #f3e8ff;
    color: #6d28d9;
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    border: 1px solid rgba(124, 58, 237, 0.12);
}

.formation-card-footer {
    padding-top: 4px;
}

.formation-main-btn {
    background: linear-gradient(135deg, #7c3aed 0%, #8b5cf6 100%);
    color: #ffffff;
    border: none;
    border-radius: 12px;
    padding: 9px 14px;
    font-weight: 700;
    box-shadow: 0 8px 18px rgba(124, 58, 237, 0.22);
}

.formation-main-btn:hover {
    color: #ffffff;
    background: linear-gradient(135deg, #6d28d9 0%, #7c3aed 100%);
}

.formation-outline-btn {
    border-radius: 12px;
    padding: 9px 14px;
    font-weight: 700;
    border: 1px solid rgba(124, 58, 237, 0.24);
    color: #6d28d9;
    background: #faf5ff;
}

.formation-outline-btn:hover {
    background: #f3e8ff;
    color: #5b21b6;
    border-color: rgba(124, 58, 237, 0.35);
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('fo-formation-filter-form');
    const titreInput = document.getElementById('fo-titre-search');
    const voiceBtn = document.getElementById('voice-btn');
    const voiceSearchInput = document.getElementById('voice-search-input');
    const voiceStatus = document.getElementById('voice-status');

    let timeout = null;
    let mediaRecorder = null;
    let audioChunks = [];

    if (titreInput) {
        titreInput.addEventListener('keyup', function () {
            clearTimeout(timeout);
            timeout = setTimeout(() => {
                form.submit();
            }, 500);
        });
    }

    document.querySelectorAll('#fo-formation-filter-form select').forEach(select => {
        select.addEventListener('change', function () {
            form.submit();
        });
    });

    if (voiceBtn && voiceSearchInput) {
        voiceBtn.addEventListener('click', async () => {
            try {
                if (mediaRecorder && mediaRecorder.state === 'recording') {
                    mediaRecorder.stop();
                    voiceBtn.innerText = '🎤';
                    if (voiceStatus) {
                        voiceStatus.textContent = 'Analyse en cours...';
                    }
                    return;
                }

                if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                    if (voiceStatus) {
                        voiceStatus.textContent = 'Le microphone n’est pas supporté sur ce navigateur.';
                    }
                    return;
                }

                if (!window.MediaRecorder) {
                    if (voiceStatus) {
                        voiceStatus.textContent = 'MediaRecorder n’est pas disponible sur ce navigateur.';
                    }
                    return;
                }

                const stream = await navigator.mediaDevices.getUserMedia({ audio: true });

                let mimeType = 'audio/webm';
                if (MediaRecorder.isTypeSupported('audio/webm;codecs=opus')) {
                    mimeType = 'audio/webm;codecs=opus';
                } else if (MediaRecorder.isTypeSupported('audio/webm')) {
                    mimeType = 'audio/webm';
                } else if (MediaRecorder.isTypeSupported('audio/mp4')) {
                    mimeType = 'audio/mp4';
                }

                mediaRecorder = new MediaRecorder(stream, { mimeType });
                audioChunks = [];

                mediaRecorder.ondataavailable = event => {
                    if (event.data && event.data.size > 0) {
                        audioChunks.push(event.data);
                    }
                };

                mediaRecorder.onstop = async () => {
                    try {
                        const blob = new Blob(audioChunks, { type: mimeType });

                        if (blob.size === 0) {
                            if (voiceStatus) {
                                voiceStatus.textContent = 'Aucun son détecté.';
                            }
                            return;
                        }

                        const response = await fetch('{{ path('api_stt') }}', {
                            method: 'POST',
                            headers: {
                                'Content-Type': mimeType,
                                'Accept': 'application/json'
                            },
                            body: blob
                        });

                        const rawText = await response.text();
                        let data = null;

                        try {
                            data = JSON.parse(rawText);
                        } catch (jsonError) {
                            if (voiceStatus) {
                                voiceStatus.textContent = 'Réponse serveur invalide: ' + rawText.substring(0, 120);
                            }
                            return;
                        }

                        if (data.success && data.text) {
                            voiceSearchInput.value = data.text;

                            const filterSearch = document.getElementById('fo-titre-search');
                            if (filterSearch) {
                                filterSearch.value = data.text;
                            }

                            if (voiceStatus) {
                                voiceStatus.textContent = 'Texte reconnu : ' + data.text;
                            }

                            document.getElementById('hero-search-form').submit();
                        } else {
                            if (voiceStatus) {
                                voiceStatus.textContent = data.error
                                    ? 'Erreur serveur: ' + data.error
                                    : 'Aucun texte reconnu.';
                            }
                        }
                    } catch (error) {
                        console.error('Erreur STT:', error);
                        if (voiceStatus) {
                            voiceStatus.textContent = error.message
                                ? 'Erreur: ' + error.message
                                : 'Erreur lors de la transcription.';
                        }
                    } finally {
                        voiceBtn.innerText = '🎤';
                        stream.getTracks().forEach(track => track.stop());
                    }
                };

                mediaRecorder.start();
                voiceBtn.innerText = '⏹';
                if (voiceStatus) {
                    voiceStatus.textContent = 'Enregistrement... Parlez maintenant.';
                }

                setTimeout(() => {
                    if (mediaRecorder && mediaRecorder.state === 'recording') {
                        mediaRecorder.stop();
                    }
                }, 6000);

            } catch (error) {
                console.error('Erreur micro:', error);
                if (voiceStatus) {
                    voiceStatus.textContent = error.message
                        ? 'Erreur micro: ' + error.message
                        : 'Impossible d’accéder au microphone.';
                }
                voiceBtn.innerText = '🎤';
            }
        });
    }
});
</script>
{% endblock %}