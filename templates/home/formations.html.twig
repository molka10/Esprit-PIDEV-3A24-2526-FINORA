{% extends 'base.html.twig' %}

{% block title %}FINORA - Formations{% endblock %}

{% block body %}


<main>
    <section class="pt-5 pb-0">
        <div class="container">
            <div class="row align-items-center g-4 purple-section p-4 p-lg-5">
                <div class="col-lg-6">
                    <span class="badge bg-primary bg-opacity-10 text-primary mb-3">Bienvenue sur FINORA</span>
                    <h1 class="display-5 mb-3 finora-title">Explorez les formations FINORA</h1>
                    <p class="mb-4">
                        Découvrez des formations en finance, investissement, trading et analyse des marchés.
                        Recherchez, filtrez et trouvez rapidement le contenu qui correspond à votre niveau.
                    </p>
                    <div class="mb-4">
                        {% include 'home/_badges.html.twig' %}
                    </div>

                    <form method="get" action="{{ path('app_formations') }}" class="border rounded p-2 mb-4 bg-white" id="hero-search-form">
                        <div class="input-group">
                            <input
                                type="text"
                                name="titre"
                                id="voice-search-input"
                                class="form-control border-0 me-1"
                                placeholder="Trouver une formation"
                                value="{{ titre }}"
                            >
                            <button type="button" id="voice-btn" class="btn btn-warning">
                                🎤
                            </button>
                            <button class="btn btn-primary rounded" type="submit">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                        <div id="voice-status" class="small text-muted mt-2"></div>
                    </form>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <div class="icon-lg fs-4 text-primary bg-primary bg-opacity-10 rounded">
                                        <i class="bi bi-book-half"></i>
                                    </div>
                                    <div class="ms-3">
                                        <div class="d-flex">
                                            <h4 class="fw-bold mb-0">{{ formations.getTotalItemCount }}</h4>
                                            <span class="h4 mb-0">+</span>
                                        </div>
                                        <div>Formations disponibles</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <div class="icon-lg fs-4 text-primary bg-primary bg-opacity-10 rounded">
                                        <i class="fas fa-layer-group"></i>
                                    </div>
                                    <div class="ms-3">
                                        <div class="d-flex">
                                            <h4 class="fw-bold mb-0">{{ categories|length }}</h4>
                                        </div>
                                        <div>Catégories</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6 text-center">
                    <img src="{{ asset('assets/images/element/06.png') }}" class="img-fluid" style="max-height: 380px;" alt="hero image">
                </div>
            </div>
        </div>
    </section>

    <section class="py-5">
        <div class="container">

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}

            <div id="main-formations-wrapper" style="transition: opacity 0.3s ease;">

            <!-- =======================
            Bestseller Carousel START -->
            {% if bestsellers|length > 0 %}
            <div class="row mb-5">
                <div class="col-12">
                    <div id="bestsellerCarousel" class="carousel slide carousel-fade shadow-lg" data-bs-ride="carousel" style="border-radius: 25px; overflow: hidden;">
                        <div class="carousel-indicators">
                            {% for best in bestsellers %}
                                <button type="button" data-bs-target="#bestsellerCarousel" data-bs-slide-to="{{ loop.index0 }}" class="{{ loop.first ? 'active' : '' }}" aria-current="{{ loop.first ? 'true' : '' }}"></button>
                            {% endfor %}
                        </div>
                        <div class="carousel-inner">
                            {% for best in bestsellers %}
                                <div class="carousel-item {{ loop.first ? 'active' : '' }}" data-bs-interval="5000">
                                    <div class="position-relative h-400px h-md-500px bg-dark">
                                        {% if best.imageUrl %}
                                            <img src="{{ asset('uploads/formations/' ~ best.imageUrl) }}" class="d-block w-100 h-100 transition-all" style="object-fit: cover; opacity: 0.6; filter: brightness(0.7);" alt="{{ best.titre }}">
                                        {% else %}
                                            <img src="{{ asset('assets/images/courses/4by3/16.jpg') }}" class="d-block w-100 h-100 transition-all" style="object-fit: cover; opacity: 0.6; filter: brightness(0.7);" alt="{{ best.titre }}">
                                        {% endif %}
                                        
                                        <div class="carousel-caption d-none d-md-block text-start" style="left: 10%; bottom: 15%; max-width: 600px;">
                                            <span class="badge bg-warning text-dark mb-3 px-3 py-2 fw-bold" style="border-radius: 50px;">
                                                <i class="bi bi-fire me-1"></i> BESTSELLER #{{ loop.index }}
                                            </span>
                                            <h2 class="display-4 fw-bold text-white mb-3" style="text-shadow: 0 2px 10px rgba(0,0,0,0.5);">{{ best.titre }}</h2>
                                            <p class="fs-5 text-white-50 mb-4">{{ best.description|slice(0, 150) }}...</p>
                                            <div class="d-flex gap-3 align-items-center">
                                                <a href="{{ path('app_formation_show', {'id': best.id}) }}" class="btn btn-primary btn-lg px-5 py-3 fw-bold rounded-pill" style="background: linear-gradient(135deg, #7c3aed, #a855f7); border: none;">Explorer</a>
                                                <div class="d-flex align-items-center">
                                                    <div class="text-warning fs-5 me-2">
                                                        {% set stars = best.rating|round(0, 'floor') %}
                                                        {% for i in 1..5 %}
                                                            <i class="bi {{ i <= stars ? 'bi-star-fill' : 'bi-star' }}"></i>
                                                        {% endfor %}
                                                    </div>
                                                    <span class="text-white fw-bold">{{ best.rating|number_format(1) }} ({{ best.purchasedBy|length }} inscrits)</span>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Big Price on Right Middle -->
                                        <div class="position-absolute d-none d-lg-flex align-items-center justify-content-center" 
                                             style="right: 8%; top: 50%; transform: translateY(-50%); z-index: 10;">
                                            <div class="price-bubble-premium p-4 text-center" 
                                                 style="background: rgba(255,255,255,0.1); backdrop-filter: blur(15px); border: 1px solid rgba(255,255,255,0.2); border-radius: 30px; box-shadow: 0 25px 50px rgba(0,0,0,0.3); min-width: 240px;">
                                                <div class="small text-white-50 text-uppercase fw-bold mb-1" style="letter-spacing: 2px;">Investissez sur vous</div>
                                                <div class="display-3 fw-bold text-white mb-0" style="text-shadow: 0 4px 20px rgba(124, 58, 237, 0.4);">
                                                    {{ best.prix|format_currency }}
                                                </div>
                                                {% if best.prix %}
                                                    <div class="text-white-50 text-decoration-line-through small">{{ (best.prix * 1.4)|format_currency }}</div>
                                                {% endif %}
                                                <div class="badge bg-primary mt-3 px-3 py-1 rounded-pill small">Meilleur Prix</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#bestsellerCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon p-3 bg-dark bg-opacity-25 rounded-circle" aria-hidden="true"></span>
                            <span class="visually-hidden">Précédent</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#bestsellerCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon p-3 bg-dark bg-opacity-25 rounded-circle" aria-hidden="true"></span>
                            <span class="visually-hidden">Suivant</span>
                        </button>
                    </div>
                </div>
            </div>
            {% endif %}

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="mb-0 finora-title">Catégories populaires</h4>
                </div>
                
                <div class="category-wrapper">
                    <div class="d-flex flex-wrap gap-2" id="category-list">
                        <a href="{{ path('app_formations') }}"
                           class="btn btn-sm cat-pill {{ (categorie == '' and not mesFormations) ? 'btn-primary' : 'btn-outline-primary' }}">
                            Toutes
                        </a>

                        {% if app.user %}
                            <a href="{{ path('app_formations', {'mes_formations': 1}) }}"
                               class="btn btn-sm cat-pill {{ mesFormations ? 'btn-primary' : 'btn-outline-primary' }}"
                               style="border-color: #7c3aed; color: {{ mesFormations ? '#fff' : '#7c3aed' }}; background: {{ mesFormations ? '#7c3aed' : 'transparent' }};">
                                <i class="bi bi-journal-bookmark-fill me-1"></i> Mes Formations
                            </a>
                        {% endif %}

                        {% for cat in categories %}
                            <a href="{{ path('app_formations', {'categorie': cat}) }}"
                               class="btn btn-sm cat-pill category-item {{ categorie == cat ? 'btn-primary' : 'btn-outline-primary' }}"
                               {% if loop.index > 5 %}style="display: none;"{% endif %}>
                                {{ cat }}
                            </a>
                        {% endfor %}
                        
                        {% if categories|length > 5 %}
                            <button class="btn btn-sm btn-link text-primary p-0 ms-2" id="toggle-categories-btn">
                                <i class="bi bi-chevron-down"></i> Voir plus
                            </button>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- Currency Switcher START -->
            <div class="d-flex justify-content-end mb-4 px-2">
                <div class="currency-switcher-premium d-flex align-items-center gap-2 p-1" style="background: rgba(255,255,255,0.7); backdrop-filter: blur(10px); border-radius: 50px; border: 1px solid rgba(124, 58, 237, 0.2); box-shadow: 0 8px 32px rgba(31, 38, 135, 0.07);">
                    <div class="switcher-icon ms-2 me-1 text-primary">
                        <i class="bi bi-cash-stack fs-6"></i>
                    </div>
                    {% set currentCurr = app.session.get('app_currency', 'TND') %}
                    <div class="d-flex gap-1" id="currency-switcher-list">
                        {% for curr in ['TND', 'USD', 'EUR'] %}
                            <a href="{{ path('app_switch_currency', {'currency': curr}) }}" 
                               class="btn btn-xs curr-pill rounded-pill px-4 py-2 fw-bold transition-all {{ currentCurr == curr ? 'active-curr' : 'text-muted' }}"
                               style="font-size: 0.75rem; border: none; letter-spacing: 0.5px; transition: all 0.3s ease;">
                                {{ curr }}
                            </a>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <style>
                .active-curr {
                    background: linear-gradient(135deg, #7c3aed, #a855f7) !important;
                    color: white !important;
                    box-shadow: 0 4px 15px rgba(124, 58, 237, 0.3) !important;
                }
                .curr-pill:hover:not(.active-curr) {
                    background: rgba(124, 58, 237, 0.05);
                    color: #7c3aed !important;
                }
                .currency-switcher-premium {
                    transform: translateY(0);
                    transition: all 0.3s ease;
                }
                .currency-switcher-premium:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 12px 40px rgba(31, 38, 135, 0.12) !important;
                }
            </style>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <form method="get" action="{{ path('app_formations') }}" id="fo-formation-filter-form">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <input
                                    type="text"
                                    name="titre"
                                    id="fo-titre-search"
                                    class="form-control"
                                    placeholder="Rechercher par titre"
                                    value="{{ titre }}"
                                >
                            </div>

                            <div class="col-md-2">
                                <select name="categorie" class="form-select">
                                    <option value="">Toutes catégories</option>
                                    {% for cat in categories %}
                                        <option value="{{ cat }}" {{ categorie == cat ? 'selected' : '' }}>
                                            {{ cat }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="col-md-2">
                                <select name="niveau" class="form-select">
                                    <option value="">Tous niveaux</option>
                                    <option value="Débutant" {{ niveau == 'Débutant' ? 'selected' : '' }}>Débutant</option>
                                    <option value="Intermédiaire" {{ niveau == 'Intermédiaire' ? 'selected' : '' }}>Intermédiaire</option>
                                    <option value="Avancé" {{ niveau == 'Avancé' ? 'selected' : '' }}>Avancé</option>
                                </select>
                            </div>

                            <div class="col-md-2">
                                <select name="tri" class="form-select">
                                    <option value="id" {{ tri == 'id' ? 'selected' : '' }}>Trier par ID</option>
                                    <option value="titre" {{ tri == 'titre' ? 'selected' : '' }}>Titre</option>
                                    <option value="categorie" {{ tri == 'categorie' ? 'selected' : '' }}>Catégorie</option>
                                    <option value="niveau" {{ tri == 'niveau' ? 'selected' : '' }}>Niveau</option>
                                </select>
                            </div>

                            <div class="col-md-1">
                                <select name="ordre" class="form-select">
                                    <option value="asc" {{ ordre == 'asc' ? 'selected' : '' }}>ASC</option>
                                    <option value="desc" {{ ordre == 'desc' ? 'selected' : '' }}>DESC</option>
                                </select>
                            </div>

                            <div class="col-md-2 d-flex gap-2">
                                <button type="submit" class="btn btn-primary w-100">Filtrer</button>
                                <a href="{{ path('app_formations') }}" class="btn btn-outline-secondary w-100">Reset</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div id="results-container" style="transition: opacity 0.2s ease;">
                {% if formations|length > 0 %}
                    <div class="row g-4" id="formations-grid-row">
                    {% for formation in formations %}
                        <div class="col-md-6 col-xl-4">
                            <div class="card formation-card border-0 h-100 overflow-hidden">

                                <div class="formation-card-top">
                                    {% if formation.imageUrl %}
                                        <img
                                            src="{{ asset('uploads/formations/' ~ formation.imageUrl) }}"
                                            class="formation-card-media"
                                            alt="{{ formation.titre }}"
                                        >
                                    {% else %}
                                        <img
                                            src="{{ asset('assets/images/courses/4by3/16.jpg') }}"
                                            class="formation-card-media"
                                            alt="{{ formation.titre }}"
                                        >
                                    {% endif %}

                                    <div class="formation-card-overlay"></div>

                                    <div class="formation-card-badges">
                                        <div class="d-flex gap-2">
                                            <span class="formation-level-badge">
                                                {{ formation.niveau }}
                                            </span>
                                            {% if app.user and formation.id not in purchasedIds %}
                                                {% set isFavorited = app.user.wishlist.contains(formation) %}
                                                <button class="wishlist-toggle-btn p-0 border-0 bg-white rounded-circle d-flex align-items-center justify-content-center" 
                                                        style="width: 32px; height: 32px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); cursor: pointer; transition: all 0.2s;"
                                                        data-id="{{ formation.id }}"
                                                        title="{{ isFavorited ? 'Retirer des favoris' : 'Ajouter aux favoris' }}">
                                                    <i class="bi {{ isFavorited ? 'bi-heart-fill text-danger' : 'bi-heart text-secondary' }} fs-6"></i>
                                                </button>
                                            {% endif %}
                                            {% if formation.id in purchasedIds %}
                                                <span class="badge bg-success shadow-sm rounded-pill px-3 py-2">
                                                    <i class="bi bi-patch-check-fill me-1"></i> Inscrit
                                                </span>
                                            {% endif %}
                                            
                                            {% if progressMap[formation.id] is defined and progressMap[formation.id].isCompleted %}
                                                <span class="badge bg-warning text-dark shadow-sm rounded-pill px-3 py-2">
                                                    <i class="bi bi-trophy-fill me-1"></i> Complétée
                                                </span>
                                            {% endif %}
                                        </div>

                                        <div class="d-flex flex-wrap gap-2">
                                            <span class="formation-rating-badge text-dark">
                                                <i class="bi bi-star-fill text-warning me-1"></i> 
                                                <span id="rating-val-{{ formation.id }}">{{ formation.rating|default(0)|number_format(1) }}</span>
                                                <small class="text-muted">(<span id="rating-count-{{ formation.id }}">{{ formation.ratingCount|default(0) }}</span>)</small>
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <div class="card-body d-flex flex-column p-4">
                                    <div class="d-flex flex-wrap gap-2 mb-3">
                                        {% for tag in formation.categorie ? formation.categorie|split(',') : [] %}
                                            {% if tag|trim != '' %}
                                                <span class="purple-chip">{{ tag|trim }}</span>
                                            {% endif %}
                                        {% endfor %}
                                    </div>

                                    <h5 class="card-title formation-card-title">{{ formation.titre }}</h5>

                                    {% if progressMap[formation.id] is defined %}
                                        <div class="mb-3">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <small class="text-muted fw-bold">{{ progressMap[formation.id].passed }}/{{ progressMap[formation.id].total }} Leçons</small>
                                                <small class="text-primary fw-bold">{{ progressMap[formation.id].percent }}%</small>
                                            </div>
                                            <div class="progress" style="height: 6px; border-radius: 10px; background-color: #f1f5f9;">
                                                <div class="progress-bar" role="progressbar" 
                                                     style="width: {{ progressMap[formation.id].percent }}%; background: linear-gradient(90deg, #7c3aed, #8b5cf6); border-radius: 10px;" 
                                                     aria-valuenow="{{ progressMap[formation.id].percent }}" aria-valuemin="0" aria-valuemax="100"></div>
                                            </div>
                                            
                                            {% if progressMap[formation.id].percent == 100 %}
                                                <a href="{{ path('app_master_certificate', {'id': formation.id}) }}" 
                                                   class="btn btn-sm w-100 mt-3 d-flex align-items-center justify-content-center gap-2"
                                                   style="background: linear-gradient(135deg, #059669, #10b981); color: white; border: none; border-radius: 10px; padding: 10px; font-weight: 700; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.25); transition: transform 0.2s;">
                                                    <i class="bi bi-award-fill fs-5 text-warning"></i>
                                                    Master Certificate
                                                </a>
                                            {% endif %}
                                        </div>
                                    {% endif %}

                                    <p class="card-text formation-card-text flex-grow-1 mb-2">
                                        {{ formation.description ? formation.description|slice(0, 120) ~ '...' : 'Pas de description' }}
                                    </p>

                                    {% if formation.id not in purchasedIds %}
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="fw-bold fs-5 text-dark me-2">{{ formation.prix|format_currency }}</span>
                                            {% if formation.prix %}
                                                <span class="text-muted text-decoration-line-through small">{{ (formation.prix * 1.4)|format_currency }}</span>
                                            {% endif %}
                                        </div>
                                    {% else %}
                                        <!-- Real Rating Interactive Stars -->
                                        <div class="d-flex align-items-center mb-3 rating-stars-container" data-id="{{ formation.id }}">
                                            <span class="small text-muted me-2">Votre note :</span>
                                            {% for i in 1..5 %}
                                                <i class="bi bi-star p-1 cursor-pointer star-rate" data-score="{{ i }}" style="cursor: pointer; color: #fbbf24; font-size: 1.2rem;"></i>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                    
                                    <div class="formation-card-footer d-flex gap-2 flex-wrap mt-auto">
                                        {% if formation.id not in purchasedIds %}
                                            <button type="button" class="btn btn-sm formation-outline-btn fw-bold px-3" data-bs-toggle="modal" data-bs-target="#purchaseModal{{ formation.id }}">
                                                Acheter
                                            </button>
                                        {% endif %}
                                        <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn btn-sm formation-main-btn flex-grow-1">
                                            Voir formation
                                        </a>

                                        {% if progressMap[formation.id] is defined and progressMap[formation.id].isCompleted %}
                                            <a href="{{ path('app_my_certificates') }}" class="btn btn-sm btn-outline-success border-2 fw-bold w-100 mt-2" style="border-radius: 12px;">
                                                <i class="bi bi-award me-1"></i> Voir mes certificats
                                            </a>
                                        {% endif %}
                                        <button type="button" class="btn btn-sm btn-light quick-view-btn text-primary border" 
                                            style="border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);"
                                            data-title="{{ formation.titre|escape('html_attr') }}"
                                            data-desc="{{ formation.description|default('Pas de description')|escape('html_attr') }}"
                                            data-level="{{ formation.niveau }}"
                                            data-img="{{ formation.imageUrl ? asset('uploads/formations/' ~ formation.imageUrl) : asset('assets/images/courses/4by3/16.jpg') }}"
                                            data-category="{{ formation.categorie }}"
                                            data-price="{{ formation.prix|format_currency }}"
                                            data-fakeprice="{{ formation.prix ? (formation.prix * 1.4)|format_currency : '' }}"
                                            data-rating="{{ formation.rating|default(0)|number_format(1) }}"
                                            data-reviews="{{ formation.ratingCount|default(0)|number_format(0, '', ' ') }}"
                                            onclick="openQuickView(this)">
                                            <i class="bi bi-eye fw-bold"></i>
                                        </button>
                                    </div>
                                </div>

                            </div>
                        </div>

                        <!-- Purchase Modal for Formation {{ formation.id }} -->
                        <div class="modal fade" id="purchaseModal{{ formation.id }}" tabindex="-1" aria-labelledby="purchaseModalLabel{{ formation.id }}" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered modal-lg">
                                <div class="modal-content border-0 overflow-hidden" style="border-radius: 20px; box-shadow: 0 25px 50px -12px rgba(124, 58, 237, 0.25);">
                                    <div class="modal-header border-bottom-0 pb-0 pt-4 px-4">
                                        <h5 class="modal-title fw-bold" id="purchaseModalLabel{{ formation.id }}" style="color: #4c1d95;">Confirmation d'inscription</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                                    </div>
                                    <div class="modal-body p-4">
                                        <div class="row g-4">
                                            <div class="col-md-6">
                                                <div class="d-flex align-items-center mb-4">
                                                    <div class="icon-md bg-primary bg-opacity-10 text-primary rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                                        <i class="fas fa-user-circle fs-4"></i>
                                                    </div>
                                                    <div>
                                                        <label class="small text-muted d-block">Identité de l'apprenant</label>
                                                        <span class="fw-bold text-dark">{{ app.user ? app.user.username : 'Utilisateur Connecté' }}</span>
                                                    </div>
                                                </div>

                                                <h6 class="fw-bold mb-3 text-dark">Détails de la formation</h6>
                                                <div class="p-3 rounded-4 mb-4" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                                                    <h5 class="h6 fw-bold mb-2">{{ formation.titre }}</h5>
                                                    <p class="small text-muted mb-0">
                                                        {{ formation.description|slice(0, 150) }}{% if formation.description|length > 150 %}...{% endif %}
                                                    </p>
                                                </div>

                                                <div class="bg-primary bg-opacity-10 p-3 rounded-4 mb-3">
                                                    <p class="mb-2 fw-semibold text-primary small"><i class="fas fa-check-circle me-1"></i> Bénéfices inclus :</p>
                                                    <ul class="list-unstyled small mb-0 text-dark">
                                                        <li class="mb-1">✅ Accès illimité à toutes les leçons</li>
                                                        <li class="mb-1">✅ Quiz d'évaluation et certification</li>
                                                        <li>✅ Support et ressources pédagogiques</li>
                                                    </ul>
                                                </div>
                                            </div>

                                            <div class="col-md-6">
                                                <div class="p-4 rounded-4 h-100" style="background: #faf5ff; border: 1px solid #ede9fe;">
                                                    <label class="small fw-bold mb-3 d-block" style="color: #6d28d9;">
                                                        <i class="fas fa-list-ul me-1"></i> Programme ({{ formation.lessons|length }} Leçons)
                                                    </label>
                                                    <div class="lesson-preview-list" style="max-height: 250px; overflow-y: auto; padding-right: 5px;">
                                                        {% for lesson in formation.lessons %}
                                                            <div class="d-flex align-items-center mb-2 p-2 rounded-3 bg-white border border-light transition-all hover-shadow-sm">
                                                                <div class="small fw-bold text-primary me-2">{{ loop.index }}.</div>
                                                                <div class="small text-dark text-truncate">{{ lesson.titre }}</div>
                                                            </div>
                                                        {% else %}
                                                            <div class="text-muted small">Aucune leçon disponible.</div>
                                                        {% endfor %}
                                                    </div>

                                                    <form action="{{ path('app_formation_inscription', {'id': formation.id}) }}" method="post" id="purchaseFormList{{ formation.id }}" class="mt-4">
                                                        <div class="mb-4 text-center">
                                                            <label class="form-label small fw-bold text-muted d-block">Total à payer</label>
                                                            <div class="display-6 fw-bold text-dark">{{ formation.prix|format_currency }}</div>
                                                        </div>
                                                        <div class="mb-3">
                                                            <label class="form-label small fw-bold text-muted">Mode de paiement sécurisé</label>
                                                            <div class="d-flex gap-2">
                                                                <div class="flex-fill border rounded-3 p-2 text-center bg-white">
                                                                    <i class="fab fa-cc-visa text-primary fa-lg"></i>
                                                                </div>
                                                                <div class="flex-fill border rounded-3 p-2 text-center bg-white">
                                                                    <i class="fab fa-cc-mastercard text-danger fa-lg"></i>
                                                                </div>
                                                                <div class="flex-fill border rounded-3 p-2 text-center bg-white">
                                                                    <i class="fab fa-paypal text-info fa-lg"></i>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="d-grid mt-4">
                                                            <button type="submit" class="btn btn-primary py-3 fw-bold shadow-lg" style="border-radius: 14px; background: linear-gradient(135deg, #7c3aed, #8b5cf6); border: none; transition: transform 0.2s;">
                                                                Débloquer l'accès maintenant
                                                            </button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    {% endfor %}
                    </div>

                    <div class="d-flex justify-content-center mt-5 pagination-container">
                        {{ knp_pagination_render(formations) }}
                    </div>
                </div><!-- end #main-formations-wrapper -->
                
                <div id="infinite-scroll-trigger" class="text-center mt-4 mb-4" style="display: none;">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Chargement...</span>
                        </div>
                    </div>
                {% else %}
                    <div class="alert alert-info">
                        Aucune formation trouvée.
                    </div>
                {% endif %}
            </div>
        </div>
    </section>

    <!-- Unified Quick View Modal -->
    <div class="modal fade" id="quickViewModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 overflow-hidden" style="border-radius: 20px; box-shadow: 0 20px 40px rgba(0,0,0,0.2);">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3 z-3 bg-white" data-bs-dismiss="modal" aria-label="Close" style="border-radius: 50%; opacity: 0.9; box-shadow: 0 2px 5px rgba(0,0,0,0.1); padding: 10px;"></button>
                <div class="row g-0">
                    <div class="col-md-5 position-relative">
                        <img src="" id="qv-img" class="img-fluid h-100 object-fit-cover" alt="Formation Image" style="min-height: 300px; width: 100%;">
                        <div class="position-absolute bottom-0 start-0 w-100 p-3" style="background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);">
                            <span class="badge bg-warning text-dark fw-bold" id="qv-level"></span>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="modal-body p-4 p-md-5 d-flex flex-column h-100">
                            <div class="d-flex align-items-center mb-2 gap-2" id="qv-category-container">
                                <!-- Categories injected here -->
                            </div>
                            
                            <h4 class="fw-bold text-dark mb-2" id="qv-title"></h4>
                            
                            <div class="d-flex align-items-center mb-3">
                                <span class="text-warning fw-bold me-1"><i class="bi bi-star-fill"></i> <span id="qv-rating"></span></span>
                                <span class="text-muted small">(<span id="qv-reviews"></span> avis)</span>
                            </div>
                            
                            <div class="bg-light rounded p-3 mb-3">
                                <div class="d-flex align-items-baseline">
                                    <h3 class="fw-bold mb-0 text-primary me-2" id="qv-price"></h3>
                                    <span class="text-muted text-decoration-line-through small fw-bold" id="qv-fakeprice"></span>
                                </div>
                            </div>
                            
                            <div class="mb-4 flex-grow-1">
                                <h6 class="fw-bold text-dark">À propos de cette formation</h6>
                                <p class="text-muted small mb-0" id="qv-desc" style="line-height: 1.6;"></p>
                            </div>
                            
                            <button type="button" class="btn btn-primary w-100 py-2 fw-bold" data-bs-dismiss="modal" style="border-radius: 12px;">
                                Fermer l'aperçu
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

