{% extends 'base.html.twig' %}

{% block title %}FINORA - Formations{% endblock %}

{% block breadcrumb %}Catalogue des Formations{% endblock %}

{% block body %}
            <div class="row align-items-center g-4 purple-section p-4 p-lg-5 rounded-4 overflow-hidden hero-finora">
                <div class="col-lg-6">
                    <span class="badge bg-primary bg-opacity-10 text-primary mb-3">Bienvenue sur FINORA</span>
                    <h1 class="display-5 mb-3 finora-title">Explorez les formations FINORA</h1>
                    <p class="mb-4">
                        Découvrez des formations en finance, investissement, trading et analyse des marchés.
                        Recherchez, filtrez et trouvez rapidement le contenu qui correspond à votre niveau.
                    </p>
                    <div class="mb-4">
                        {% include 'home/_badges.html.twig' %}
                    </div>

                    <form method="get" action="{{ path('app_formations') }}" class="border rounded p-2 mb-4 bg-white" id="hero-search-form">
                        <div class="input-group">
                            <input
                                type="text"
                                name="titre"
                                id="voice-search-input"
                                class="form-control border-0 me-1"
                                placeholder="Trouver une formation"
                                value="{{ titre }}"
                            >
                            <button type="button" id="voice-btn" class="btn btn-warning">
                                🎤
                            </button>
                            <button class="btn btn-primary rounded" type="submit">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                        <div id="voice-status" class="small text-muted mt-2"></div>
                    </form>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <div class="icon-lg fs-4 text-primary bg-primary bg-opacity-10 rounded">
                                        <i class="bi bi-book-half"></i>
                                    </div>
                                    <div class="ms-3">
                                        <div class="d-flex">
                                            <h4 class="fw-bold mb-0">{{ formations.getTotalItemCount }}</h4>
                                            <span class="h4 mb-0">+</span>
                                        </div>
                                        <div>Formations disponibles</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <div class="icon-lg fs-4 text-primary bg-primary bg-opacity-10 rounded">
                                        <i class="fas fa-layer-group"></i>
                                    </div>
                                    <div class="ms-3">
                                        <div class="d-flex">
                                            <h4 class="fw-bold mb-0">{{ categories|length }}</h4>
                                        </div>
                                        <div>Catégories</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6 text-center">
                    <img src="{{ asset('assets/images/element/06.png') }}" class="img-fluid" style="max-height: 380px;" alt="hero image">
                </div>
            </div>
        </div>
    </section>

    <section class="py-5">
        <div class="container">

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}

            <div id="main-formations-wrapper" style="transition: opacity 0.3s ease;">

            <!-- =======================
            Bestseller Carousel START -->
            {% if bestsellers|length > 0 %}
            <div class="row mb-5">
                <div class="col-12">
                    <div id="bestsellerCarousel" class="carousel slide carousel-fade shadow-lg" data-bs-ride="carousel" style="border-radius: 25px; overflow: hidden;">
                        <div class="carousel-indicators">
                            {% for best in bestsellers %}
                                <button type="button" data-bs-target="#bestsellerCarousel" data-bs-slide-to="{{ loop.index0 }}" class="{{ loop.first ? 'active' : '' }}" aria-current="{{ loop.first ? 'true' : '' }}"></button>
                            {% endfor %}
                        </div>
                        <div class="carousel-inner">
                            {% for best in bestsellers %}
                                <div class="carousel-item {{ loop.first ? 'active' : '' }}" data-bs-interval="5000">
                                    <div class="position-relative h-400px h-md-500px bg-dark">
                                        {% if best.imageUrl %}
                                            <img src="{{ asset('uploads/formations/' ~ best.imageUrl) }}" class="d-block w-100 h-100 transition-all" style="object-fit: cover; opacity: 0.6; filter: brightness(0.7);" alt="{{ best.titre }}">
                                        {% else %}
                                            <img src="{{ asset('assets/images/courses/4by3/16.jpg') }}" class="d-block w-100 h-100 transition-all" style="object-fit: cover; opacity: 0.6; filter: brightness(0.7);" alt="{{ best.titre }}">
                                        {% endif %}
                                        
                                        <div class="carousel-caption d-none d-md-block text-start" style="left: 10%; bottom: 15%; max-width: 600px;">
                                            <span class="badge bg-warning text-dark mb-3 px-3 py-2 fw-bold" style="border-radius: 50px;">
                                                <i class="bi bi-fire me-1"></i> BESTSELLER #{{ loop.index }}
                                            </span>
                                            <h2 class="display-4 fw-bold text-white mb-3" style="text-shadow: 0 2px 10px rgba(0,0,0,0.5);">{{ best.titre }}</h2>
                                            <p class="fs-5 text-white-50 mb-4">{{ best.description|slice(0, 150) }}...</p>
                                            <div class="d-flex gap-3 align-items-center">
                                                <a href="{{ path('app_formation_show', {'id': best.id}) }}" class="btn btn-primary btn-lg px-5 py-3 fw-bold rounded-pill" style="background: linear-gradient(135deg, #7c3aed, #a855f7); border: none;">Explorer</a>
                                                <div class="d-flex align-items-center">
                                                    <div class="text-warning fs-5 me-2">
                                                        {% set stars = best.rating|round(0, 'floor') %}
                                                        {% for i in 1..5 %}
                                                            <i class="bi {{ i <= stars ? 'bi-star-fill' : 'bi-star' }}"></i>
                                                        {% endfor %}
                                                    </div>
                                                    <span class="text-white fw-bold">{{ best.rating|number_format(1) }} ({{ best.purchasedBy|length }} inscrits)</span>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Big Price on Right Middle -->
                                        <div class="position-absolute d-none d-lg-flex align-items-center justify-content-center" 
                                             style="right: 8%; top: 50%; transform: translateY(-50%); z-index: 10;">
                                            <div class="price-bubble-premium p-4 text-center" 
                                                 style="background: rgba(255,255,255,0.1); backdrop-filter: blur(15px); border: 1px solid rgba(255,255,255,0.2); border-radius: 30px; box-shadow: 0 25px 50px rgba(0,0,0,0.3); min-width: 240px;">
                                                <div class="small text-white-50 text-uppercase fw-bold mb-1" style="letter-spacing: 2px;">Investissez sur vous</div>
                                                <div class="display-3 fw-bold text-white mb-0" style="text-shadow: 0 4px 20px rgba(124, 58, 237, 0.4);">
                                                    {{ best.prix|format_currency }}
                                                </div>
                                                {% if best.prix %}
                                                    <div class="text-white-50 text-decoration-line-through small">{{ (best.prix * 1.4)|format_currency }}</div>
                                                {% endif %}
                                                <div class="badge bg-primary mt-3 px-3 py-1 rounded-pill small">Meilleur Prix</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#bestsellerCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon p-3 bg-dark bg-opacity-25 rounded-circle" aria-hidden="true"></span>
                            <span class="visually-hidden">Précédent</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#bestsellerCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon p-3 bg-dark bg-opacity-25 rounded-circle" aria-hidden="true"></span>
                            <span class="visually-hidden">Suivant</span>
                        </button>
                    </div>
                </div>
            </div>
            {% endif %}

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="mb-0 finora-title">Catégories populaires</h4>
                </div>
                
                <div class="category-wrapper">
                    <div class="d-flex flex-wrap gap-2" id="category-list">
                        <a href="{{ path('app_formations') }}"
                           class="btn btn-sm cat-pill {{ (categorie == '' and not mesFormations) ? 'btn-primary' : 'btn-outline-primary' }}">
                            Toutes
                        </a>

                        {% if app.user %}
                            <a href="{{ path('app_formations', {'mes_formations': 1}) }}"
                               class="btn btn-sm cat-pill {{ mesFormations ? 'btn-primary' : 'btn-outline-primary' }}"
                               style="border-color: #7c3aed; color: {{ mesFormations ? '#fff' : '#7c3aed' }}; background: {{ mesFormations ? '#7c3aed' : 'transparent' }};">
                                <i class="bi bi-journal-bookmark-fill me-1"></i> Mes Formations
                            </a>
                        {% endif %}

                        {% for cat in categories %}
                            <a href="{{ path('app_formations', {'categorie': cat}) }}"
                               class="btn btn-sm cat-pill category-item {{ categorie == cat ? 'btn-primary' : 'btn-outline-primary' }}"
                               {% if loop.index > 5 %}style="display: none;"{% endif %}>
                                {{ cat }}
                            </a>
                        {% endfor %}
                        
                        {% if categories|length > 5 %}
                            <button class="btn btn-sm btn-link text-primary p-0 ms-2" id="toggle-categories-btn">
                                <i class="bi bi-chevron-down"></i> Voir plus
                            </button>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- Currency Switcher START -->
            <div class="d-flex justify-content-end mb-4 px-2">
                <div class="currency-switcher-premium d-flex align-items-center gap-2 p-1" style="background: rgba(255,255,255,0.7); backdrop-filter: blur(10px); border-radius: 50px; border: 1px solid rgba(124, 58, 237, 0.2); box-shadow: 0 8px 32px rgba(31, 38, 135, 0.07);">
                    <div class="switcher-icon ms-2 me-1 text-primary">
                        <i class="bi bi-cash-stack fs-6"></i>
                    </div>
                    {% set currentCurr = app.session.get('app_currency', 'TND') %}
                    <div class="d-flex gap-1" id="currency-switcher-list">
                        {% for curr in ['TND', 'USD', 'EUR'] %}
                            <a href="{{ path('app_switch_currency', {'currency': curr}) }}" 
                               class="btn btn-xs curr-pill rounded-pill px-4 py-2 fw-bold transition-all {{ currentCurr == curr ? 'active-curr' : 'text-muted' }}"
                               style="font-size: 0.75rem; border: none; letter-spacing: 0.5px; transition: all 0.3s ease;">
                                {{ curr }}
                            </a>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <style>
                .active-curr {
                    background: linear-gradient(135deg, #7c3aed, #a855f7) !important;
                    color: white !important;
                    box-shadow: 0 4px 15px rgba(124, 58, 237, 0.3) !important;
                }
                .curr-pill:hover:not(.active-curr) {
                    background: rgba(124, 58, 237, 0.05);
                    color: #7c3aed !important;
                }
                .currency-switcher-premium {
                    transform: translateY(0);
                    transition: all 0.3s ease;
                }
                .currency-switcher-premium:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 12px 40px rgba(31, 38, 135, 0.12) !important;
                }
            </style>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <form method="get" action="{{ path('app_formations') }}" id="fo-formation-filter-form">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <input
                                    type="text"
                                    name="titre"
                                    id="fo-titre-search"
                                    class="form-control"
                                    placeholder="Rechercher par titre"
                                    value="{{ titre }}"
                                >
                            </div>

                            <div class="col-md-2">
                                <select name="categorie" class="form-select">
                                    <option value="">Toutes catégories</option>
                                    {% for cat in categories %}
                                        <option value="{{ cat }}" {{ categorie == cat ? 'selected' : '' }}>
                                            {{ cat }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="col-md-2">
                                <select name="niveau" class="form-select">
                                    <option value="">Tous niveaux</option>
                                    <option value="Débutant" {{ niveau == 'Débutant' ? 'selected' : '' }}>Débutant</option>
                                    <option value="Intermédiaire" {{ niveau == 'Intermédiaire' ? 'selected' : '' }}>Intermédiaire</option>
                                    <option value="Avancé" {{ niveau == 'Avancé' ? 'selected' : '' }}>Avancé</option>
                                </select>
                            </div>

                            <div class="col-md-2">
                                <select name="tri" class="form-select">
                                    <option value="id" {{ tri == 'id' ? 'selected' : '' }}>Trier par ID</option>
                                    <option value="titre" {{ tri == 'titre' ? 'selected' : '' }}>Titre</option>
                                    <option value="categorie" {{ tri == 'categorie' ? 'selected' : '' }}>Catégorie</option>
                                    <option value="niveau" {{ tri == 'niveau' ? 'selected' : '' }}>Niveau</option>
                                </select>
                            </div>

                            <div class="col-md-1">
                                <select name="ordre" class="form-select">
                                    <option value="asc" {{ ordre == 'asc' ? 'selected' : '' }}>ASC</option>
                                    <option value="desc" {{ ordre == 'desc' ? 'selected' : '' }}>DESC</option>
                                </select>
                            </div>

                            <div class="col-md-2 d-flex gap-2">
                                <button type="submit" class="btn btn-primary w-100">Filtrer</button>
                                <a href="{{ path('app_formations') }}" class="btn btn-outline-secondary w-100">Reset</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div id="results-container" style="transition: opacity 0.2s ease;">
                {% include 'home/_formations_grid.html.twig' %}
            </div>

            <div id="infinite-scroll-trigger" class="text-center mt-4 mb-4" style="display: none;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Chargement...</span>
                </div>
            </div>
            </div>
        </div>
    </section>

    <!-- Unified Quick View Modal -->
    <div class="modal fade" id="quickViewModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 overflow-hidden" style="border-radius: 20px; box-shadow: 0 20px 40px rgba(0,0,0,0.2);">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3 z-3 bg-white" data-bs-dismiss="modal" aria-label="Close" style="border-radius: 50%; opacity: 0.9; box-shadow: 0 2px 5px rgba(0,0,0,0.1); padding: 10px;"></button>
                <div class="row g-0">
                    <div class="col-md-5 position-relative">
                        <img src="" id="qv-img" class="img-fluid h-100 object-fit-cover" alt="Formation Image" style="min-height: 300px; width: 100%;">
                        <div class="position-absolute bottom-0 start-0 w-100 p-3" style="background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);">
                            <span class="badge bg-warning text-dark fw-bold" id="qv-level"></span>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="modal-body p-4 p-md-5 d-flex flex-column h-100">
                            <div class="d-flex align-items-center mb-2 gap-2" id="qv-category-container">
                                <!-- Categories injected here -->
                            </div>
                            
                            <h4 class="fw-bold text-dark mb-2" id="qv-title"></h4>
                            
                            <div class="d-flex align-items-center mb-3">
                                <span class="text-warning fw-bold me-1"><i class="bi bi-star-fill"></i> <span id="qv-rating"></span></span>
                                <span class="text-muted small">(<span id="qv-reviews"></span> avis)</span>
                            </div>
                            
                            <div class="bg-light rounded p-3 mb-3">
                                <div class="d-flex align-items-baseline">
                                    <h3 class="fw-bold mb-0 text-primary me-2" id="qv-price"></h3>
                                    <span class="text-muted text-decoration-line-through small fw-bold" id="qv-fakeprice"></span>
                                </div>
                            </div>
                            
                            <div class="mb-4 flex-grow-1">
                                <h6 class="fw-bold text-dark">À propos de cette formation</h6>
                                <p class="text-muted small mb-0" id="qv-desc" style="line-height: 1.6;"></p>
                            </div>
                            
                            <button type="button" class="btn btn-primary w-100 py-2 fw-bold" data-bs-dismiss="modal" style="border-radius: 12px;">
                                Fermer l'aperçu
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div id="ajax-loader-overlay" class="position-fixed top-0 start-0 w-100 h-100 d-none flex-column align-items-center justify-content-center" style="z-index: 9999; background: rgba(255,255,255,0.7); backdrop-filter: blur(4px);">
        <div class="spinner-grow text-primary" style="width: 3rem; height: 3rem;" role="status text-center"></div>
        <div class="mt-2 fw-bold text-primary">Chargement...</div>
    </div>
</main>

<style>
.hero-finora {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.08), rgba(167, 139, 250, 0.12));
    border: 1px solid rgba(124, 58, 237, 0.08);
}

.formation-card {
    border-radius: 22px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(109, 40, 217, 0.08);
    transition: transform 0.28s ease, box-shadow 0.28s ease;
    border: 1px solid rgba(124, 58, 237, 0.08);
}

.formation-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 18px 40px rgba(109, 40, 217, 0.16);
}

.formation-card-top {
    position: relative;
    height: 230px;
    overflow: hidden;
    background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 50%, #c4b5fd 100%);
}

.formation-card-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
}

.formation-card:hover .formation-card-media {
    transform: scale(1.05);
}

.formation-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(46, 16, 101, 0.55) 0%, rgba(46, 16, 101, 0.12) 45%, rgba(255,255,255,0) 100%);
    pointer-events: none;
}

.formation-card-badges {
    position: absolute;
    inset: auto 16px 16px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    z-index: 2;
}

.formation-level-badge {
    background: rgba(255, 255, 255, 0.95);
    color: #6d28d9;
    padding: 7px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 800;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
}

.formation-rating-badge {
    background: rgba(255, 255, 255, 0.95);
    color: #1f1147;
    padding: 7px 12px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 800;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
}

.formation-card-title {
    color: #1f1147;
    font-weight: 800;
    margin-bottom: 12px;
    line-height: 1.35;
}

.formation-card-text {
    color: #6b7280;
    line-height: 1.75;
    min-height: 85px;
}

.purple-chip {
    background: #f3e8ff;
    color: #6d28d9;
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    border: 1px solid rgba(124, 58, 237, 0.12);
}

.formation-card-footer {
    padding-top: 4px;
}

.formation-main-btn {
    background: linear-gradient(135deg, #7c3aed 0%, #8b5cf6 100%);
    color: #ffffff;
    border: none;
    border-radius: 12px;
    padding: 9px 14px;
    font-weight: 700;
    box-shadow: 0 8px 18px rgba(124, 58, 237, 0.22);
}

.formation-main-btn:hover {
    color: #ffffff;
    background: linear-gradient(135deg, #6d28d9 0%, #7c3aed 100%);
}

.formation-outline-btn {
    border-radius: 12px;
    padding: 9px 14px;
    font-weight: 700;
    border: 1px solid rgba(124, 58, 237, 0.24);
    color: #6d28d9;
    background: #faf5ff;
}

.formation-outline-btn:hover {
    background: #f3e8ff;
    color: #5b21b6;
    border-color: rgba(124, 58, 237, 0.35);
}

/* Category Pills */
.cat-pill {
    border-radius: 99px;
    padding: 8px 18px;
    font-weight: 600;
    font-size: 14px;
    border: 1px solid rgba(124, 58, 237, 0.2);
    transition: all 0.2s ease;
}

.cat-pill.btn-outline-primary {
    background: white;
    color: #5b21b6;
}

.cat-pill.btn-outline-primary:hover {
    background: rgba(124, 58, 237, 0.08);
    transform: translateY(-2px);
    border-color: rgba(124, 58, 237, 0.4);
}

.cat-pill.btn-primary {
    background: linear-gradient(135deg, #7c3aed 0%, #8b5cf6 100%);
    border: none;
    box-shadow: 0 4px 12px rgba(124, 58, 237, 0.25);
}

#toggle-categories-btn {
    border: 1px dashed rgba(124, 58, 237, 0.3);
    background: #fdfcff;
}
    #toggle-categories-btn:hover {
        background: #f3e8ff;
        color: #6d28d9 !important;
    }

    /* Modal Upgrades */
    .hover-shadow-sm:hover {
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        transform: translateX(3px);
    }
    .transition-all {
        transition: all 0.2s ease;
    }
    .lesson-preview-list::-webkit-scrollbar {
        width: 4px;
    }
    .lesson-preview-list::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 10px;
    }
    .lesson-preview-list::-webkit-scrollbar-thumb {
        background: #ddd6fe;
        border-radius: 10px;
    }
    .lesson-preview-list::-webkit-scrollbar-thumb:hover {
        background: #c4b5fd;
    }
    .icon-md {
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // --- Elements ---
    const filterForm = document.getElementById('fo-formation-filter-form');
    const heroForm = document.getElementById('hero-search-form');
    const filterSearchInput = document.getElementById('fo-titre-search');
    const heroSearchInput = document.getElementById('voice-search-input');
    const resultsContainer = document.getElementById('results-container') || document.getElementById('main-formations-wrapper');
    const mainWrapper = document.getElementById('main-formations-wrapper');
    const loaderOverlay = document.getElementById('ajax-loader-overlay');
    
    let ajaxController = null;
    let searchTimeout = null;

    // --- Core AJAX Fetch ---
    async function fetchFilteredResults(url) {
        if (ajaxController) ajaxController.abort();
        ajaxController = new AbortController();

        if (mainWrapper) mainWrapper.style.opacity = '0.5';
        if (loaderOverlay) {
            loaderOverlay.classList.remove('d-none');
            loaderOverlay.classList.add('d-flex');
        }
        
        window.history.pushState({}, '', url);

        try {
            const res = await fetch(url, { 
                signal: ajaxController.signal,
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
             });
            const html = await res.text();
            
            if (resultsContainer) {
                // Determine if we are replacing main Wrapper or just results container
                if(resultsContainer.id === 'main-formations-wrapper') {
                     // Need to extract the inner HTML or similar if replacing the wrapper itself
                     // Assuming backend returns only the partial
                     resultsContainer.innerHTML = html;
                } else {
                     resultsContainer.innerHTML = html;
                }

                // Re-init non-delegated components
                initInfiniteScroll();
                initBestsellerCarousel();
                initCategoryToggle();
            }
        } catch (err) {
            if (err.name === 'AbortError') return;
            console.error('AJAX Error:', err);
        } finally {
            if (mainWrapper) mainWrapper.style.opacity = '1';
            if (loaderOverlay) {
                loaderOverlay.classList.remove('d-flex');
                loaderOverlay.classList.add('d-none');
            }
        }
    }

    // --- Search Synchronization & Triggers ---
    function triggerUnifiedSearch(sourceForm) {
        if (!sourceForm) return;

        // Synchronize search inputs across forms
        if (sourceForm === heroForm && filterSearchInput && heroSearchInput) {
            filterSearchInput.value = heroSearchInput.value;
        } else if (sourceForm === filterForm && heroSearchInput && filterSearchInput) {
            heroSearchInput.value = filterSearchInput.value;
        }

        // Use filterForm as primary data source for all filters if available
        const activeForm = filterForm || sourceForm;
        const formData = new FormData(activeForm);
        const params = new URLSearchParams(formData);
        const action = activeForm.getAttribute('action') || window.location.pathname;
        
        // Strip out existing query params from action if any
        const baseUrl = action.split('?')[0];
        fetchFilteredResults(baseUrl + '?' + params.toString());
    }

    // Dynamic Search (Debounced typing)
    document.addEventListener('input', function(e) {
        const form = e.target.closest('#fo-formation-filter-form, #hero-search-form');
        if (form && e.target.tagName === 'INPUT') {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => triggerUnifiedSearch(form), 400); 
        }
    });

    // Form Submit (Manual click or Enter)
    document.addEventListener('submit', function(e) {
        const form = e.target.closest('#fo-formation-filter-form, #hero-search-form');
        if (form) {
            e.preventDefault();
            triggerUnifiedSearch(form);
        }
    });

    // Filter Change (Selects/Checkbox/Radio)
    document.addEventListener('change', function(e) {
        const form = e.target.closest('#fo-formation-filter-form');
        if (form && (e.target.tagName === 'SELECT' || e.target.type === 'checkbox' || e.target.type === 'radio')) {
            triggerUnifiedSearch(form);
        }
    });

    // --- Global Click Action Delegation ---
    document.addEventListener('click', async function(e) {
        // 1. Wishlist Heart Toggle
        const wishlistBtn = e.target.closest('.wishlist-toggle-btn');
        if (wishlistBtn) {
            e.preventDefault();
            const id = wishlistBtn.dataset.id;
            const icon = wishlistBtn.querySelector('i');
            
            wishlistBtn.style.opacity = '0.5';
            try {
                const res = await fetch(`/wishlist/toggle/${id}`, { 
                    method: 'POST', 
                    headers: { 'X-Requested-With': 'XMLHttpRequest' } 
                });
                const data = await res.json();
                if (data.status === 'added') {
                    icon.className = 'bi bi-heart-fill text-danger fs-6';
                    wishlistBtn.title = 'Retirer des favoris';
                } else {
                    icon.className = 'bi bi-heart text-secondary fs-6';
                    wishlistBtn.title = 'Ajouter aux favoris';
                }
            } catch (err) { console.error('Wishlist error:', err); }
            wishlistBtn.style.opacity = '1';
            return;
        }

        // 2. Star Rating Component
        const star = e.target.closest('.star-rate');
        if (star) {
            const container = star.closest('.rating-stars-container');
            const id = container.dataset.id;
            const score = star.dataset.score;
            try {
                const res = await fetch(`/formations/${id}/rate/${score}`, { 
                    method: 'POST', 
                    headers: { 'X-Requested-With': 'XMLHttpRequest' } 
                });
                const data = await res.json();
                if (data.newRating) {
                    const val = document.getElementById(`rating-val-${id}`);
                    const count = document.getElementById(`rating-count-${id}`);
                    if (val) val.textContent = data.newRating;
                    if (count) count.textContent = data.newCount;
                    container.innerHTML = '<span class="text-success small fw-bold"><i class="bi bi-check-circle-fill"></i> Merci !</span>';
                }
            } catch (err) { console.error('Rating error:', err); }
            return;
        }

        // 3. Quick View Trigger
        const quickBtn = e.target.closest('.quick-view-btn');
        if (quickBtn) {
            window.openQuickView(quickBtn); 
            return;
        }

        // 4. Currency Switcher
        const currLink = e.target.closest('.curr-pill');
        if (currLink && currLink.tagName === 'A') {
            e.preventDefault();
            try {
                const res = await fetch(currLink.href, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                const data = await res.json();
                if (data.success) fetchFilteredResults(window.location.href);
            } catch (err) { window.location.href = currLink.href; }
            return;
        }

        // 5. Category Pills (Top section)
        const catLink = e.target.closest('.cat-pill');
        if (catLink && catLink.tagName === 'A' && !catLink.id) {
            e.preventDefault();
            fetchFilteredResults(catLink.href);
            return;
        }

        // 6. Pagination Links
        const pagLink = e.target.closest('.pagination a');
        if (pagLink) {
            e.preventDefault();
            fetchFilteredResults(pagLink.href);
            if (mainWrapper) window.scrollTo({ top: mainWrapper.offsetTop - 150, behavior: 'smooth' });
            return;
        }
    });

    // --- Rating Hover (Delegated) ---
    document.addEventListener('mouseover', e => {
        const star = e.target.closest('.star-rate');
        if (star) {
            const container = star.closest('.rating-stars-container');
            const score = parseInt(star.dataset.score);
            container.querySelectorAll('.star-rate').forEach(s => {
                s.classList.toggle('bi-star-fill', parseInt(s.dataset.score) <= score);
                s.classList.toggle('bi-star', parseInt(s.dataset.score) > score);
            });
        }
    });

    // --- Quick View Logic ---
    window.openQuickView = function(button) {
        const data = button.dataset;
        const qvTitle = document.getElementById('qv-title');
        if(!qvTitle) return; // Quick view modal doesn't exist on this page
        
        qvTitle.textContent = data.title;
        document.getElementById('qv-desc').textContent = data.desc;
        document.getElementById('qv-img').src = data.img;
        document.getElementById('qv-level').textContent = data.level;
        document.getElementById('qv-price').textContent = data.price;
        
        const qvFake = document.getElementById('qv-fakeprice');
        if (data.fakeprice) {
            qvFake.textContent = data.fakeprice;
            qvFake.style.display = 'inline';
        } else {
            qvFake.style.display = 'none';
        }
        
        document.getElementById('qv-rating').textContent = data.rating;
        document.getElementById('qv-reviews').textContent = data.reviews;

        const catContainer = document.getElementById('qv-category-container');
        catContainer.innerHTML = '';
        if (data.category) {
            data.category.split(',').forEach(cat => {
                if (cat.trim()) {
                    const badge = document.createElement('span');
                    badge.className = 'badge bg-primary bg-opacity-10 text-primary border me-1';
                    badge.textContent = cat.trim();
                    catContainer.appendChild(badge);
                }
            });
        }

        const modalEl = document.getElementById('quickViewModal');
        if (modalEl && typeof bootstrap !== 'undefined') {
            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
            modal.show();
        }
    };

    // --- Optimized Initialize Functions ---
    let scrollObserver = null;
    function initInfiniteScroll() {
        const gridRow = document.getElementById('formations-grid-row');
        const scrollTrigger = document.getElementById('infinite-scroll-trigger');
        const pagContainer = document.querySelector('.pagination-container');
        
        if (scrollObserver) scrollObserver.disconnect();
        if (!gridRow || !scrollTrigger || !pagContainer) return;

        const getNextUrl = () => {
            const nextLink = document.querySelector('.pagination-container .page-link[rel="next"]');
            return nextLink ? nextLink.href : null;
        };

        if (getNextUrl()) {
            pagContainer.style.display = 'none';
            scrollTrigger.style.display = 'block';
        } else {
            pagContainer.style.display = 'none';
            scrollTrigger.style.display = 'none';
            return;
        }

        let isFetching = false;
        scrollObserver = new IntersectionObserver(async (entries) => {
            if (entries[0].isIntersecting && !isFetching) {
                const nextUrl = getNextUrl();
                if (nextUrl) {
                    isFetching = true;
                    try {
                        const res = await fetch(nextUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                        const html = await res.text();
                        const doc = new DOMParser().parseFromString(html, "text/html");
                        
                        const newCards = doc.querySelectorAll('#formations-grid-row > div');
                        const newPag = doc.querySelector('.pagination-container');
                        
                        newCards.forEach(card => gridRow.appendChild(card));
                        if (newPag) pagContainer.innerHTML = newPag.innerHTML;
                        
                        if (!getNextUrl()) {
                            scrollTrigger.style.display = 'none';
                            scrollObserver.disconnect();
                        }
                    } catch (err) { console.error('Scroll error:', err); }
                    finally { isFetching = false; }
                }
            }
        }, { rootMargin: "0px 0px 500px 0px" });

        scrollObserver.observe(scrollTrigger);
    }

    function initCategoryToggle() {
        const toggleBtn = document.getElementById('toggle-categories-btn');
        if (toggleBtn) {
            let expanded = false;
            // remove prev listeners by replacing clone
            const newBtn = toggleBtn.cloneNode(true);
            toggleBtn.parentNode.replaceChild(newBtn, toggleBtn);
            
            newBtn.onclick = function() {
                expanded = !expanded;
                document.querySelectorAll('.category-item').forEach((item, index) => {
                    if (index > 4) item.style.display = expanded ? 'inline-block' : 'none';
                });
                this.innerHTML = expanded ? '<i class="bi bi-chevron-up"></i> Voir moins' : '<i class="bi bi-chevron-down"></i> Voir plus';
            };
        }
    }

    function initBestsellerCarousel() {
        const carouselEl = document.querySelector('#bestsellerCarousel');
        if (carouselEl && typeof bootstrap !== 'undefined') {
            new bootstrap.Carousel(carouselEl, { interval: 5000, ride: 'carousel' });
        }
    }

    // --- Voice Search ---
    const voiceBtn = document.getElementById('voice-btn');
    if (voiceBtn && heroSearchInput) {
        let mediaRecorder = null;
        let audioChunks = [];
        const voiceStatus = document.getElementById('voice-status');
        
        voiceBtn.onclick = async () => {
            if (mediaRecorder && mediaRecorder.state === 'recording') {
                mediaRecorder.stop();
                voiceBtn.innerText = '🎤';
                return;
            }
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                mediaRecorder = new MediaRecorder(stream);
                audioChunks = [];
                mediaRecorder.ondataavailable = e => audioChunks.push(e.data);
                mediaRecorder.onstop = async () => {
                    const blob = new Blob(audioChunks, { type: 'audio/webm' });
                    const response = await fetch('{{ path('api_stt') }}', { method: 'POST', body: blob });
                    const data = await response.json();
                    if (data.success && data.text) {
                        heroSearchInput.value = data.text;
                        if (voiceStatus) voiceStatus.textContent = 'Reconnu : ' + data.text;
                        triggerUnifiedSearch(heroForm);
                    }
                    stream.getTracks().forEach(t => t.stop());
                };
                mediaRecorder.start();
                voiceBtn.innerText = '⏹';
                if(voiceStatus) voiceStatus.textContent = 'Écoute en cours...';
            } catch (err) { console.error('Voice error:', err); }
        };
    }

    // --- Initial Run ---
    initCategoryToggle();
    initInfiniteScroll();
    initBestsellerCarousel();
});
</script>
{% endblock %}
