{% extends 'base.html.twig' %}

{% block title %}FINORA - Formations{% endblock %}

{% block body %}
<header class="navbar-light navbar-sticky">
    <nav class="navbar navbar-expand-xl z-index-9">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}">
                <img class="light-mode-item navbar-brand-item" src="{{ asset('assets/images/logo.svg') }}" alt="logo">
                <img class="dark-mode-item navbar-brand-item" src="{{ asset('assets/images/logo-light.svg') }}" alt="logo">
            </a>

            <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-animation">
                    <span></span>
                    <span></span>
                    <span></span>
                </span>
            </button>

            <div class="navbar-collapse collapse" id="navbarCollapse">
                <ul class="navbar-nav navbar-nav-scroll ms-auto">
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}">Accueil</a></li>
                    <li class="nav-item"><a class="nav-link active" href="{{ path('app_formations') }}">Formations</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_lessons') }}">Lessons</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('admin_dashboard') }}">Dashboard</a></li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<main>
    <section class="pt-5 pb-0">
        <div class="container">
            <div class="row align-items-center g-4 purple-section p-4 p-lg-5">
                <div class="col-lg-6">
                    <span class="badge bg-primary bg-opacity-10 text-primary mb-3">Bienvenue sur FINORA</span>
                    <h1 class="display-5 mb-3 finora-title">Explorez les formations FINORA</h1>
                    <p class="mb-4">
                        Découvrez des formations en finance, investissement, trading et analyse des marchés.
                        Recherchez, filtrez et trouvez rapidement le contenu qui correspond à votre niveau.
                    </p>

                    <form method="get" action="{{ path('app_formations') }}" class="border rounded p-2 mb-4 bg-white" id="hero-search-form">
                        <div class="input-group">
                            <input
                                type="text"
                                name="titre"
                                class="form-control border-0 me-1"
                                placeholder="Trouver une formation"
                                value="{{ titre }}"
                            >
                            <button class="btn btn-primary rounded" type="submit">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </form>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <div class="icon-lg fs-4 text-primary bg-primary bg-opacity-10 rounded">
                                        <i class="bi bi-book-half"></i>
                                    </div>
                                    <div class="ms-3">
                                        <div class="d-flex">
                                            <h4 class="fw-bold mb-0">{{ formations.getTotalItemCount }}</h4>
                                            <span class="h4 mb-0">+</span>
                                        </div>
                                        <div>Formations disponibles</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <div class="icon-lg fs-4 text-primary bg-primary bg-opacity-10 rounded">
                                        <i class="fas fa-layer-group"></i>
                                    </div>
                                    <div class="ms-3">
                                        <div class="d-flex">
                                            <h4 class="fw-bold mb-0">{{ categories|length }}</h4>
                                        </div>
                                        <div>Catégories</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6 text-center">
                    <img src="{{ asset('assets/images/element/06.png') }}" class="img-fluid" style="max-height: 380px;" alt="hero image">
                </div>
            </div>
        </div>
    </section>

    <section class="py-5">
        <div class="container">

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}

            <div class="mb-4">
                <h4 class="mb-3 finora-title">Catégories populaires</h4>
                <div class="d-flex flex-wrap gap-2">
                    <a href="{{ path('app_formations') }}"
                       class="btn btn-sm {{ categorie == '' ? 'btn-primary' : 'btn-outline-primary' }}">
                        Toutes
                    </a>

                    {% for cat in categories %}
                        <a href="{{ path('app_formations', {'categorie': cat}) }}"
                           class="btn btn-sm {{ categorie == cat ? 'btn-primary' : 'btn-outline-primary' }}">
                            {{ cat }}
                        </a>
                    {% endfor %}
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <form method="get" action="{{ path('app_formations') }}" id="fo-formation-filter-form">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <input
                                    type="text"
                                    name="titre"
                                    id="fo-titre-search"
                                    class="form-control"
                                    placeholder="Rechercher par titre"
                                    value="{{ titre }}"
                                >
                            </div>

                            <div class="col-md-2">
                                <select name="categorie" class="form-select">
                                    <option value="">Toutes catégories</option>
                                    {% for cat in categories %}
                                        <option value="{{ cat }}" {{ categorie == cat ? 'selected' : '' }}>
                                            {{ cat }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="col-md-2">
                                <select name="niveau" class="form-select">
                                    <option value="">Tous niveaux</option>
                                    <option value="Débutant" {{ niveau == 'Débutant' ? 'selected' : '' }}>Débutant</option>
                                    <option value="Intermédiaire" {{ niveau == 'Intermédiaire' ? 'selected' : '' }}>Intermédiaire</option>
                                    <option value="Avancé" {{ niveau == 'Avancé' ? 'selected' : '' }}>Avancé</option>
                                </select>
                            </div>

                            <div class="col-md-2">
                                <select name="tri" class="form-select">
                                    <option value="id" {{ tri == 'id' ? 'selected' : '' }}>Trier par ID</option>
                                    <option value="titre" {{ tri == 'titre' ? 'selected' : '' }}>Titre</option>
                                    <option value="categorie" {{ tri == 'categorie' ? 'selected' : '' }}>Catégorie</option>
                                    <option value="niveau" {{ tri == 'niveau' ? 'selected' : '' }}>Niveau</option>
                                </select>
                            </div>

                            <div class="col-md-1">
                                <select name="ordre" class="form-select">
                                    <option value="asc" {{ ordre == 'asc' ? 'selected' : '' }}>ASC</option>
                                    <option value="desc" {{ ordre == 'desc' ? 'selected' : '' }}>DESC</option>
                                </select>
                            </div>

                            <div class="col-md-2 d-flex gap-2">
                                <button type="submit" class="btn btn-primary w-100">Filtrer</button>
                                <a href="{{ path('app_formations') }}" class="btn btn-outline-secondary w-100">Reset</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            {% if formations|length > 0 %}
                <div class="row g-4">
                    {% for formation in formations %}
                        <div class="col-md-6 col-xl-4">
                            <div class="card border-0 shadow-sm h-100 overflow-hidden">
                                <div class="position-relative">
                                    {% if formation.imageUrl %}
                                        <img src="{{ asset('uploads/formations/' ~ formation.imageUrl) }}" class="card-img-top" alt="{{ formation.titre }}" style="height: 220px; object-fit: cover;">
                                    {% else %}
                                        <img src="{{ asset('assets/images/courses/4by3/16.jpg') }}" class="card-img-top" alt="{{ formation.titre }}" style="height: 220px; object-fit: cover;">
                                    {% endif %}
                                </div>

                                <div class="card-body">
                                    <div class="d-flex flex-wrap gap-2 mb-3">
                                        <span class="badge bg-primary bg-opacity-10 text-primary">{{ formation.niveau }}</span>

                                        {% for tag in formation.categorie ? formation.categorie|split(',') : [] %}
                                            {% if tag|trim != '' %}
                                                <span class="purple-chip">{{ tag|trim }}</span>
                                            {% endif %}
                                        {% endfor %}

                                        {% if formation.isPublished %}
                                            <span class="badge bg-success bg-opacity-10 text-success">Publié</span>
                                        {% else %}
                                            <span class="badge bg-warning bg-opacity-10 text-warning">Non publié</span>
                                        {% endif %}
                                    </div>

                                    <h5 class="card-title">{{ formation.titre }}</h5>
                                    <p class="card-text">
                                        {{ formation.description ? formation.description|slice(0, 120) ~ '...' : 'Pas de description' }}
                                    </p>

                                    <div class="d-flex gap-2 flex-wrap mt-3">
                                        <a href="{{ path('app_formation_inscription', {'id': formation.id}) }}" class="btn btn-sm btn-outline-primary">
                                            S'inscrire
                                        </a>
                                        <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn btn-sm btn-primary">
                                            Voir formation
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                <div class="d-flex justify-content-center mt-5">
                    {{ knp_pagination_render(formations) }}
                </div>
            {% else %}
                <div class="alert alert-info">
                    Aucune formation trouvée.
                </div>
            {% endif %}
        </div>
    </section>
</main>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('fo-formation-filter-form');
    const titreInput = document.getElementById('fo-titre-search');

    let timeout = null;

    if (titreInput) {
        titreInput.addEventListener('keyup', function () {
            clearTimeout(timeout);
            timeout = setTimeout(() => {
                form.submit();
            }, 500);
        });
    }

    document.querySelectorAll('#fo-formation-filter-form select').forEach(select => {
        select.addEventListener('change', function () {
            form.submit();
        });
    });
});
</script>
{% endblock %}