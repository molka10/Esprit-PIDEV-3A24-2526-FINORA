<script>
// Quick View functionality
function openQuickView(button) {
    const title = button.getAttribute('data-title');
    const desc = button.getAttribute('data-desc');
    const img = button.getAttribute('data-img');
    const level = button.getAttribute('data-level');
    const categories = button.getAttribute('data-category');
    const price = button.getAttribute('data-price');
    const fakePrice = button.getAttribute('data-fakeprice');
    const rating = button.getAttribute('data-rating');
    const reviews = button.getAttribute('data-reviews');

    document.getElementById('qv-title').textContent = title;
    document.getElementById('qv-desc').textContent = desc;
    document.getElementById('qv-img').src = img;
    document.getElementById('qv-level').textContent = level;
    document.getElementById('qv-price').textContent = price;
    
    const fakePriceEl = document.getElementById('qv-fakeprice');
    if (fakePrice) {
        fakePriceEl.textContent = fakePrice;
        fakePriceEl.style.display = 'inline';
    } else {
        fakePriceEl.style.display = 'none';
    }
    
    document.getElementById('qv-rating').textContent = rating;
    document.getElementById('qv-reviews').textContent = reviews;

    const catContainer = document.getElementById('qv-category-container');
    catContainer.innerHTML = '';
    if (categories) {
        categories.split(',').forEach(cat => {
            if (cat.trim() !== '') {
                const badge = document.createElement('span');
                badge.className = 'badge bg-primary bg-opacity-10 text-primary border';
                badge.textContent = cat.trim();
                catContainer.appendChild(badge);
            }
        });
    }

    const modalEl = document.getElementById('quickViewModal');
    let modal = bootstrap.Modal.getInstance(modalEl);
    if (!modal) modal = new bootstrap.Modal(modalEl);
    modal.show();
}

    // Wishlist Toggle logic
    document.addEventListener('click', async function(e) {
        const btn = e.target.closest('.wishlist-toggle-btn');
        if (!btn) return;

        e.preventDefault();
        e.stopPropagation();

        const id = btn.getAttribute('data-id');
        const icon = btn.querySelector('i');

        try {
            btn.style.opacity = '0.5';
            btn.disabled = true;

            const response = await fetch(`/wishlist/toggle/${id}`, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });

            const data = await response.json();

            if (data.status === 'added') {
                icon.classList.remove('bi-heart', 'text-secondary');
                icon.classList.add('bi-heart-fill', 'text-danger');
                btn.title = 'Retirer des favoris';
            } else {
                icon.classList.remove('bi-heart-fill', 'text-danger');
                icon.classList.add('bi-heart', 'text-secondary');
                btn.title = 'Ajouter aux favoris';
            }
        } catch (err) {
            console.error('Wishlist error:', err);
        } finally {
            btn.style.opacity = '1';
            btn.disabled = false;
        }
    });

document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('fo-formation-filter-form');
    const heroForm = document.getElementById('hero-search-form');
    const titreInput = document.getElementById('fo-titre-search');
    const voiceBtn = document.getElementById('voice-btn');
    const voiceSearchInput = document.getElementById('voice-search-input');
    const voiceStatus = document.getElementById('voice-status');

    let timeout = null;
    let mediaRecorder = null;
    let audioChunks = [];

    // AJAX Search logic
    function setupAjaxForm(f) {
        if (!f) return;
        f.addEventListener('submit', async function (e) {
            e.preventDefault();
            const container = document.getElementById('results-container');
            const url = new URL(f.action || window.location.href);
            const formData = new FormData(f);
            const params = new URLSearchParams();
            for (const [key, value] of formData.entries()) {
                if (value) params.append(key, value);
            }
            url.search = params.toString();

            // Update URL
            window.history.pushState({}, '', url);

            if (container) container.style.opacity = '0.5';
            try {
                const res = await fetch(url.toString(), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const html = await res.text();
                const doc = new DOMParser().parseFromString(html, "text/html");
                const newContainer = doc.getElementById('results-container');
                if (container && newContainer) {
                    container.innerHTML = newContainer.innerHTML;
                    
                    // Reinitialize infinite scroll for the newly injected elements
                    initInfiniteScroll();
                }
            } catch (err) {
                console.error('AJAX search error:', err);
                // Fallback to normal submit
                f.submit();
            } finally {
                if (container) container.style.opacity = '1';
            }
        });
    }

    setupAjaxForm(form);
    setupAjaxForm(heroForm);

    // Infinite Scroll Implementation
    let globalObserver = null;

    function initInfiniteScroll() {
        const gridRow = document.getElementById('formations-grid-row');
        const scrollTrigger = document.getElementById('infinite-scroll-trigger');
        const paginationContainer = document.querySelector('.pagination-container');
        
        // Clean up old observer if it exists
        if (globalObserver) {
            globalObserver.disconnect();
            globalObserver = null;
        }

        if (gridRow && scrollTrigger && paginationContainer) {
            
            // Extract the "next" page URL natively from the KnpPaginator generated HTML
            const getNextUrl = () => {
                const navLinks = Array.from(document.querySelectorAll('.pagination-container .page-link'));
                const nextLink = navLinks.find(el => el.getAttribute('rel') === 'next');
                return nextLink ? nextLink.href : null; // Handles Knp pagination correctly
            };

            const nextUrl = getNextUrl();
            
            if (nextUrl) {
                // If there's a next page, hide normal pagination and show our loader trigger
                paginationContainer.style.display = 'none';
                scrollTrigger.style.display = 'block';
            } else {
                paginationContainer.style.display = 'none'; // hide pagination anyway for clean UX
                scrollTrigger.style.display = 'none';
                return; // Nothing to load
            }

            let isFetching = false;

            globalObserver = new IntersectionObserver(async (entries) => {
                if (entries[0].isIntersecting && !isFetching) {
                    const currentNextUrl = getNextUrl();
                    
                    if (currentNextUrl) {
                        isFetching = true;
                        try {
                            const res = await fetch(currentNextUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                            const html = await res.text();
                            const doc = new DOMParser().parseFromString(html, "text/html");
                            
                            // Extract just the new cards and KnpPagination box
                            const newCards = doc.querySelectorAll('#formations-grid-row > div');
                            const newPagination = doc.querySelector('.pagination-container');
                            
                            if (newCards.length > 0) {
                                newCards.forEach(card => gridRow.appendChild(card));
                            }
                            
                            if (newPagination) {
                                paginationContainer.innerHTML = newPagination.innerHTML;
                            }
                            
                            // Check if there are no more pages
                            if (!getNextUrl()) {
                                scrollTrigger.style.display = 'none';
                                globalObserver.disconnect();
                            }
                        } catch (err) {
                            console.error('Infinite scroll error:', err);
                        } finally {
                            isFetching = false;
                        }
                    } else {
                        scrollTrigger.style.display = 'none';
                        globalObserver.disconnect();
                    }
                }
            }, { rootMargin: "0px 0px 500px 0px" });

            globalObserver.observe(scrollTrigger);
        }
    }

    // Call on load
    initInfiniteScroll();

    if (titreInput) {
        titreInput.addEventListener('input', function () {
            clearTimeout(timeout);
            timeout = setTimeout(() => {
                if (form) form.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));
            }, 400);
        });
    }

    if (voiceSearchInput && heroForm) {
        voiceSearchInput.addEventListener('input', function () {
            clearTimeout(timeout);
            timeout = setTimeout(() => {
                if (heroForm) heroForm.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));
            }, 400);
        });
    }

    // --- GLOBAL EVENT DELEGATION FOR SEAMLESS BROWSING ---
    document.addEventListener('click', function(e) {
        // 1. Premium Currency Switcher
        const currLink = e.target.closest('.curr-pill');
        if (currLink && currLink.tagName === 'A') {
            e.preventDefault();
            const url = currLink.href;
            fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(res => res.json())
                .then(data => {
                    if (data.success) fetchFilteredResults(window.location.href);
                });
            return;
        }

        // 2. Category Pills
        const catLink = e.target.closest('.cat-pill');
        if (catLink && catLink.tagName === 'A') {
            e.preventDefault();
            fetchFilteredResults(catLink.href);
            return;
        }

        // 3. Pagination
        const pagLink = e.target.closest('.pagination a');
        if (pagLink) {
            e.preventDefault();
            fetchFilteredResults(pagLink.href);
            const wrapEl = document.getElementById('main-formations-wrapper');
            if (wrapEl) window.scrollTo({ top: wrapEl.offsetTop - 150, behavior: 'smooth' });
            return;
        }
    });

    // 4. Global Search & Filters
    document.addEventListener('submit', function(e) {
        const filterForm = e.target.closest('#fo-formation-filter-form') || e.target.closest('#hero-search-form');
        if (filterForm) {
            e.preventDefault();
            const formData = new FormData(filterForm);
            const params = new URLSearchParams(formData);
            fetchFilteredResults(filterForm.action + '?' + params.toString());
        }
    });

    document.addEventListener('change', function(e) {
        const select = e.target.closest('#fo-formation-filter-form select');
        if (select) {
            const f = select.closest('form');
            if (f) {
                const formData = new FormData(f);
                const params = new URLSearchParams(formData);
                fetchFilteredResults(f.action + '?' + params.toString());
            }
        }
    });

    // --- UTILITIES ---
    async function fetchFilteredResults(url) {
        const wrapper = document.getElementById('main-formations-wrapper');
        if (wrapper) wrapper.style.opacity = '0.5';
        window.history.pushState({}, '', url);

        try {
            const res = await fetch(url);
            const html = await res.text();
            const doc = new DOMParser().parseFromString(html, "text/html");
            
            const newWrapper = doc.getElementById('main-formations-wrapper');
            const currentWrapper = document.getElementById('main-formations-wrapper');
            if (currentWrapper && newWrapper) {
                currentWrapper.innerHTML = newWrapper.innerHTML;
            }
            
            if (typeof initInfiniteScroll === 'function') initInfiniteScroll();
            initBestsellerCarousel();
            initCategoryToggle();
        } catch (err) {
            console.error('AJAX Error:', err);
            window.location.href = url;
        } finally {
            if (wrapper) wrapper.style.opacity = '1';
        }
    }

    function initCategoryToggle() {
        const toggleBtn = document.getElementById('toggle-categories-btn');
        if (toggleBtn) {
            let expanded = false;
            // Remove old listener if any (though innerHTML handles this usually)
            toggleBtn.onclick = function() {
                expanded = !expanded;
                const items = document.querySelectorAll('.category-item');
                items.forEach((item, index) => {
                    if (index > 4) { // keep first 5 visible
                        item.style.display = expanded ? 'inline-block' : 'none';
                    }
                });
                this.innerHTML = expanded 
                    ? '<i class="bi bi-chevron-up"></i> Voir moins'
                    : '<i class="bi bi-chevron-down"></i> Voir plus';
            };
        }
    }

    function initBestsellerCarousel() {
        const carouselEl = document.querySelector('#bestsellerCarousel');
        if (carouselEl && typeof bootstrap !== 'undefined') {
            new bootstrap.Carousel(carouselEl, {
                interval: 5000,
                ride: 'carousel'
            });
        }
    }

    initCategoryToggle(); // Initial call

    if (voiceBtn && voiceSearchInput) {
        voiceBtn.addEventListener('click', async () => {
            try {
                if (mediaRecorder && mediaRecorder.state === 'recording') {
                    mediaRecorder.stop();
                    voiceBtn.innerText = '🎤';
                    if (voiceStatus) {
                        voiceStatus.textContent = 'Analyse en cours...';
                    }
                    return;
                }

                if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                    if (voiceStatus) {
                        voiceStatus.textContent = 'Le microphone n’est pas supporté sur ce navigateur.';
                    }
                    return;
                }

                if (!window.MediaRecorder) {
                    if (voiceStatus) {
                        voiceStatus.textContent = 'MediaRecorder n’est pas disponible sur ce navigateur.';
                    }
                    return;
                }

                const stream = await navigator.mediaDevices.getUserMedia({ audio: true });

                let mimeType = 'audio/webm';
                if (MediaRecorder.isTypeSupported('audio/webm;codecs=opus')) {
                    mimeType = 'audio/webm;codecs=opus';
                } else if (MediaRecorder.isTypeSupported('audio/webm')) {
                    mimeType = 'audio/webm';
                } else if (MediaRecorder.isTypeSupported('audio/mp4')) {
                    mimeType = 'audio/mp4';
                }

                mediaRecorder = new MediaRecorder(stream, { mimeType });
                audioChunks = [];

                mediaRecorder.ondataavailable = event => {
                    if (event.data && event.data.size > 0) {
                        audioChunks.push(event.data);
                    }
                };

                mediaRecorder.onstop = async () => {
                    try {
                        const blob = new Blob(audioChunks, { type: mimeType });

                        if (blob.size === 0) {
                            if (voiceStatus) {
                                voiceStatus.textContent = 'Aucun son détecté.';
                            }
                            return;
                        }

                        const response = await fetch('{{ path('api_stt') }}', {
                            method: 'POST',
                            headers: {
                                'Content-Type': mimeType,
                                'Accept': 'application/json'
                            },
                            body: blob
                        });

                        const rawText = await response.text();
                        let data = null;

                        try {
                            data = JSON.parse(rawText);
                        } catch (jsonError) {
                            if (voiceStatus) {
                                voiceStatus.textContent = 'Réponse serveur invalide: ' + rawText.substring(0, 120);
                            }
                            return;
                        }

                        if (data.success && data.text) {
                            voiceSearchInput.value = data.text;

                            const filterSearch = document.getElementById('fo-titre-search');
                            if (filterSearch) {
                                filterSearch.value = data.text;
                            }

                            if (voiceStatus) {
                                voiceStatus.textContent = 'Texte reconnu : ' + data.text;
                            }

                            document.getElementById('hero-search-form').submit();
                        } else {
                            if (voiceStatus) {
                                voiceStatus.textContent = data.error
                                    ? 'Erreur serveur: ' + data.error
                                    : 'Aucun texte reconnu.';
                            }
                        }
                    } catch (error) {
                        console.error('Erreur STT:', error);
                        if (voiceStatus) {
                            voiceStatus.textContent = error.message
                                ? 'Erreur: ' + error.message
                                : 'Erreur lors de la transcription.';
                        }
                    } finally {
                        voiceBtn.innerText = '🎤';
                        stream.getTracks().forEach(track => track.stop());
                    }
                };

                mediaRecorder.start();
                voiceBtn.innerText = '⏹';
                if (voiceStatus) {
                    voiceStatus.textContent = 'Enregistrement... Parlez maintenant.';
                }

                setTimeout(() => {
                    if (mediaRecorder && mediaRecorder.state === 'recording') {
                        mediaRecorder.stop();
                    }
                }, 6000);

            } catch (error) {
                console.error('Erreur micro:', error);
                if (voiceStatus) {
                    voiceStatus.textContent = error.message
                        ? 'Erreur micro: ' + error.message
                        : 'Impossible d’accéder au microphone.';
                }
                voiceBtn.innerText = '🎤';
            }
        });
    }
    // --- Star Rating Logic ---
    document.addEventListener('mouseover', function(e) {
        if (e.target.classList.contains('star-rate')) {
            const container = e.target.closest('.rating-stars-container');
            const score = parseInt(e.target.dataset.score);
            const stars = container.querySelectorAll('.star-rate');
            stars.forEach(s => {
                const sScore = parseInt(s.dataset.score);
                if (sScore <= score) {
                    s.classList.replace('bi-star', 'bi-star-fill');
                } else {
                    s.classList.replace('bi-star-fill', 'bi-star');
                }
            });
        }
    });

    document.addEventListener('mouseleave', function(e) {
        if (e.target.classList && e.target.classList.contains('rating-stars-container')) {
            const stars = e.target.querySelectorAll('.star-rate');
            stars.forEach(s => {
                s.classList.replace('bi-star-fill', 'bi-star');
            });
        }
    }, true);

    document.addEventListener('click', async function(e) {
        if (e.target.classList.contains('star-rate')) {
            const container = e.target.closest('.rating-stars-container');
            const formationId = container.dataset.id;
            const score = e.target.dataset.score;
            
            try {
                const response = await fetch(`/formations/${formationId}/rate/${score}`, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const data = await response.json();
                
                if (data.newRating) {
                    // Update the badge in UI
                    const valSpan = document.getElementById(`rating-val-${formationId}`);
                    const countSpan = document.getElementById(`rating-count-${formationId}`);
                    if (valSpan) valSpan.textContent = data.newRating;
                    if (countSpan) countSpan.textContent = data.newCount;
                    
                    // Show success
                    container.innerHTML = '<span class="text-success small animated bounceIn"><i class="bi bi-check-circle-fill me-1"></i> Merci pour votre note !</span>';
                }
            } catch (err) {
                console.error('Rating error:', err);
            }
        }
    });
});
</script>
{% endblock %}
