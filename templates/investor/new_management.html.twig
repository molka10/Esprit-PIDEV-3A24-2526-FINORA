{% extends 'base.html.twig' %}

{% block title %}Investir dans {{ investment.name }} - FINORA{% endblock %}

{% block body %}
<section class="py-5 bg-light">
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm p-4 p-md-5" style="border-radius: 20px;">
                    <div class="text-center mb-5">
                        <h2 class="fw-bold">Confirmer votre investissement</h2>
                        <p class="text-muted">Projet : <span class="text-primary">{{ investment.name }}</span></p>
                    </div>

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                    
                    <div class="row g-4">
                        <div class="col-md-6">
                            {{ form_label(form.investmentType, "Type d'investissement", {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.investmentType, {'attr': {'class': 'form-select'}}) }}
                            {{ form_errors(form.investmentType) }}
                        </div>
                        
                        <div class="col-md-6">
                            {{ form_label(form.amountInvested, "Montant à investir (TND)", {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.amountInvested, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.amountInvested) }}
                        </div>
                        
                        <div class="col-12">
                            {{ form_label(form.ownershipPercentage, "Part souhaitée (%)", {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.ownershipPercentage, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.ownershipPercentage) }}
                            <small class="text-muted">Ce champ peut être indicatif si l'administration valide la part finale.</small>
                        </div>
                        
                        <div class="col-12 mt-5 text-center">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold">
                                <i class="bi bi-check-circle me-2"></i>Confirmer l'investissement
                            </button>
                            <div class="mt-3">
                                <a href="{{ path('app_investment_show', {id: investment.id}) }}" class="text-muted text-decoration-none small">
                                    <i class="bi bi-arrow-left me-1"></i>Annuler
                                </a>
                            </div>
                        </div>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
