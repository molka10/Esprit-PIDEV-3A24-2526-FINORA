{% extends app.request.query.get('role') == 'admin' ? 'admin_base.html.twig' : 'base.html.twig' %}

{% block title %}{{ categorie.nom }}{% endblock %}

{% block body %}

<div class="py-3 mb-4" style="background: linear-gradient(135deg, #1a1a2e, #16213e); border-radius: 10px;">
    <div class="container text-white text-center py-2">
        <h2 class="font-weight-bold"><i class="fas fa-tag"></i> {{ categorie.nom }}</h2>
        <span class="badge bg-warning text-dark">{{ categorie.appelOffres|length }} appel(s) d'offre</span>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header" style="background:#1a1a2e; color:white;">
                <h5 class="mb-0"><i class="fas fa-file-contract"></i> Appels d'Offre liés</h5>
            </div>
            <div class="card-body p-0">
                {% if categorie.appelOffres|length > 0 %}
                <table class="table table-hover mb-0">
                    <thead class="thead-dark">
                        <tr>
                            <th>Titre</th>
                            <th>Type</th>
                            <th>Statut</th>
                            <th>Date Limite</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for appel in categorie.appelOffres %}
                        <tr>
                            <td><strong>{{ appel.titre }}</strong></td>
                            <td><span class="badge bg-info text-dark">{{ appel.type }}</span></td>
                            <td>
                                {% if appel.statut == 'published' %}
                                    <span class="badge bg-success text-white">Publié</span>
                                {% elseif appel.statut == 'draft' %}
                                    <span class="badge bg-secondary text-white">Brouillon</span>
                                {% else %}
                                    <span class="badge bg-danger text-white">Clôturé</span>
                                {% endif %}
                            </td>
                            <td>{{ appel.dateLimite ? appel.dateLimite|date('d/m/Y') : 'N/A' }}</td>
                            <td>
                                <a href="{{ path('app_appel_offre_show', {'id': appel.id, 'role': app.request.query.get('role')}) }}"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
                {% else %}
                    <div class="text-center text-muted py-4">
                        <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                        Aucun appel d'offre dans cette catégorie
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header" style="background:#1a1a2e; color:white;">
                <h5 class="mb-0"><i class="fas fa-cogs"></i> Actions</h5>
            </div>
            <div class="card-body">
                <a href="{{ path('app_categorie_edit', {'id': categorie.id, 'role': app.request.query.get('role')}) }}"
                   class="btn btn-warning btn-block mb-2">
                    <i class="fas fa-edit"></i> Modifier
                </a>
                <a href="{{ path('app_categorie_index', {'role': app.request.query.get('role')}) }}"
                   class="btn btn-secondary btn-block mb-2">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
                <hr>
                {{ include('categorie/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>

{% endblock %}