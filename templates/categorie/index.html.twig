{% extends app.request.query.get('role') == 'admin' ? 'admin_base.html.twig' : 'base.html.twig' %}

{% block title %}Catégories{% endblock %}

{% block body %}

{# HERO #}
<div class="py-4 mb-4" style="background: linear-gradient(135deg, #1a1a2e, #16213e); border-radius: 10px;">
    <div class="container text-center py-3">
        <h1 class="display-5 font-weight-bold" style="color: #ffffff !important;">
            <i class="fas fa-tags mr-2" style="color: #f0a500;"></i>Catégories
        </h1>
        <p class="lead" style="color: #d0d8e8 !important;">Gérez les catégories des appels d'offre</p>
        <a href="{{ path('app_categorie_new', {'role': app.request.query.get('role')}) }}" class="btn btn-warning btn-lg mt-2">
            <i class="fas fa-plus"></i> Nouvelle Catégorie
        </a>
    </div>
</div>

{# CARDS CATEGORIES #}
<div class="row">
    {% for categorie in categories %}
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header d-flex justify-content-between align-items-center" style="background:#1a1a2e;">
                <h5 class="mb-0 text-white">
                    <i class="fas fa-tag text-white"></i> {{ categorie.nom }}
                </h5>
                <span class="badge bg-warning text-dark">
                    {{ categorie.appelOffres|length }} offre(s)
                </span>
            </div>
            <div class="card-body">
                {% if categorie.appelOffres|length > 0 %}
                    <ul class="list-unstyled mb-0">
                        {% for appel in categorie.appelOffres|slice(0, 3) %}
                            <li class="mb-1">
                                <i class="fas fa-file-contract text-muted"></i>
                                <a href="{{ path('app_appel_offre_show', {'id': appel.id, 'role': app.request.query.get('role')}) }}">
                                    {{ appel.titre }}
                                </a>
                                {% if appel.statut == 'published' %}
                                    <span class="badge bg-success text-white float-right">Publié</span>
                                {% endif %}
                            </li>
                        {% endfor %}
                        {% if categorie.appelOffres|length > 3 %}
                            <li class="text-muted mt-1">
                                <small>+ {{ categorie.appelOffres|length - 3 }} autres...</small>
                            </li>
                        {% endif %}
                    </ul>
                {% else %}
                    <p class="text-muted text-center mb-0">
                        <i class="fas fa-inbox"></i> Aucun appel d'offre
                    </p>
                {% endif %}
            </div>
            <div class="card-footer bg-white d-flex justify-content-between">
                <a href="{{ path('app_categorie_show', {'id': categorie.id, 'role': app.request.query.get('role')}) }}"
                   class="btn btn-sm btn-outline-primary">
                    <i class="fas fa-eye"></i> Voir
                </a>
                <a href="{{ path('app_categorie_edit', {'id': categorie.id, 'role': app.request.query.get('role')}) }}"
                   class="btn btn-sm btn-outline-warning">
                    <i class="fas fa-edit"></i> Modifier
                </a>
            </div>
        </div>
    </div>
    {% else %}
        <div class="col-12">
            <div class="text-center text-muted py-5">
                <i class="fas fa-tags fa-3x mb-3 d-block"></i>
                <h5>Aucune catégorie pour le moment</h5>
                <a href="{{ path('app_categorie_new') }}" class="btn btn-warning mt-2">
                    <i class="fas fa-plus"></i> Créer une catégorie
                </a>
            </div>
        </div>
    {% endfor %}
</div>

{% endblock %}