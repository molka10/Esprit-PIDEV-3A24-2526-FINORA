<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.finora.controllers.LessonFormController"
      spacing="12" styleClass="card">

    <Label fx:id="lblTitle" text="Ajouter Lesson" styleClass="title"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints percentWidth="25"/>
            <ColumnConstraints percentWidth="75"/>
        </columnConstraints>

        <Label text="Formation:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cbFormation" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Titre:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtTitre" promptText="Titre lesson..." GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Contenu:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextArea fx:id="txtContenu" prefRowCount="4" promptText="Contenu..." GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <!-- ✅ NEW -->
        <Label text="Vidéo URL:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="txtVideoUrl"
                   promptText="YouTube / https://...  ou  MP4 direct (https://.../video.mp4)"
                   GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Ordre:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="txtOrdre" promptText="ex: 1" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Durée (min):" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="txtDuree" promptText="ex: 30" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
    </GridPane>

    <Label fx:id="lblError" text="" styleClass="error"/>

    <HBox spacing="10">
        <Button text="💾 Enregistrer" styleClass="btn-primary" onAction="#onSave"/>
        <Button text="Annuler" styleClass="btn-ghost" onAction="#onCancel"/>
    </HBox>

</VBox>