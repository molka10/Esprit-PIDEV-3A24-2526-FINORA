<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.crud.controllers.ActionController"
            stylesheets="@finora-light-theme.css"
            style="-fx-background-color: #f8f9fa;">

    <!-- ============================================ -->
    <!-- HEADER -->
    <!-- ============================================ -->
    <top>
        <VBox style="-fx-background-color: white; -fx-padding: 20 24; -fx-border-color: transparent transparent #e9ecef transparent; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="18">
                <Label text="📈 Gestion des Actions"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>

                <Region HBox.hgrow="ALWAYS"/>
                //<Button text="📊 Actualiser Prix"  />
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                <Button text="⬅ Retour"
                        onAction="#retourBourses"
                        style="-fx-background-color: #f3f4f6; -fx-text-fill: #4b5563; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
            </HBox>

            <Label text="Module FINORA - Actions par Bourse"
                   style="-fx-font-size: 13px; -fx-text-fill: #6b7280; -fx-padding: 8 0 0 0;"/>
        </VBox>
    </top>

    <!-- ============================================ -->
    <!-- CENTER -->
    <!-- ============================================ -->
    <center>
        <VBox spacing="18" style="-fx-padding: 24; -fx-background-color: #f8f9fa;">

            <!-- Barre de recherche -->
            <VBox spacing="12"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #e9ecef; -fx-border-radius: 12; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">

                <HBox spacing="12" alignment="CENTER_LEFT">

                    <!-- Sélecteur de bourse -->
                    <VBox spacing="6" HBox.hgrow="SOMETIMES">
                        <Label text="🏦 Bourse"
                               style="-fx-font-size: 12px; -fx-text-fill: #6b7280; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="cbBourse"
                                  promptText="Toutes les bourses"
                                  prefWidth="250"
                                  style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                    </VBox>

                    <!-- Recherche -->
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="🔍 Recherche"
                               style="-fx-font-size: 12px; -fx-text-fill: #6b7280; -fx-font-weight: bold;"/>
                        <TextField fx:id="searchField"
                                   promptText="Rechercher par symbole ou entreprise..."
                                   style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14; -fx-text-fill: #1f2937;"/>
                    </VBox>

                    <!-- Boutons -->
                    <VBox spacing="6">
                        <Label text=" " style="-fx-opacity: 0;"/>
                        <HBox spacing="10">
                            <Button text="🔍"
                                    onAction="#handleRechercher"
                                    style="-fx-background-color: #a855f7; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8; -fx-padding: 10 16; -fx-cursor: hand;"/>

                            <Button text="↻"
                                    onAction="#handleActualiser"
                                    style="-fx-background-color: #f3f4f6; -fx-text-fill: #4b5563; -fx-font-size: 14px; -fx-background-radius: 8; -fx-padding: 10 16; -fx-cursor: hand;"/>

                            <Button text="➕ Nouvelle Action"
                                    onAction="#ouvrirDialogAjout"
                                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                </HBox>
            </VBox>

            <!-- Compteur -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="lblTotal"
                       text="📊 Total : 0 action(s)"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
            </HBox>

            <!-- Liste actions -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" hbarPolicy="NEVER"
                        style="-fx-background-color: transparent;">
                <content>
                    <VBox fx:id="cardsContainer"
                          spacing="10"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 12; -fx-border-color: #e9ecef; -fx-border-radius: 12; -fx-border-width: 1;">
                        <!-- items générés dynamiquement -->
                    </VBox>
                </content>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
