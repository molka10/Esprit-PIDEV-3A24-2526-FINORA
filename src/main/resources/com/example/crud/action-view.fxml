<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.crud.controllers.ActionController"
            stylesheets="@finora-purple-theme.css">

    <!-- ============================================ -->
    <!-- HEADER -->
    <!-- ============================================ -->
    <top>
        <VBox styleClass="top-bar">
            <HBox alignment="CENTER_LEFT" spacing="18">
                <Label text="📈 Gestion des Actions" styleClass="top-title"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="⬅ Retour"
                        onAction="#retourBourses"
                        styleClass="btn btn-back"/>
            </HBox>

            <Label text="Module FINORA - Actions par Bourse" styleClass="top-subtitle"/>
        </VBox>
    </top>

    <!-- ============================================ -->
    <!-- CENTER -->
    <!-- ============================================ -->
    <center>
        <VBox spacing="18" style="-fx-padding: 24;">

            <!-- Barre de recherche -->
            <VBox spacing="12" styleClass="glass" style="-fx-padding: 18;">

                <HBox spacing="12" alignment="CENTER_LEFT">

                    <!-- Sélecteur de bourse -->
                    <VBox spacing="6" HBox.hgrow="SOMETIMES">
                        <Label text="🏦 Bourse" styleClass="label-muted"/>
                        <ComboBox fx:id="cbBourse"
                                  promptText="Toutes les bourses"
                                  prefWidth="250"/>
                    </VBox>

                    <!-- Recherche -->
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="🔍 Recherche" styleClass="label-muted"/>
                        <TextField fx:id="searchField"
                                   promptText="Rechercher par symbole ou entreprise..."/>
                    </VBox>

                    <!-- Boutons -->
                    <VBox spacing="6">
                        <Label text=" " style="-fx-opacity: 0;"/>
                        <HBox spacing="10">
                            <Button text="🔍"
                                    onAction="#handleRechercher"
                                    styleClass="btn btn-search"/>

                            <Button text="↻"
                                    onAction="#handleActualiser"
                                    styleClass="btn btn-refresh"/>

                            <Button text="➕ Nouvelle Action"
                                    onAction="#ouvrirDialogAjout"
                                    styleClass="btn btn-add"/>
                        </HBox>
                    </VBox>

                </HBox>
            </VBox>

            <!-- Compteur -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="lblTotal"
                       text="📊 Total : 0 action(s)"
                       styleClass="label-strong"/>
            </HBox>

            <!-- Liste actions -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" hbarPolicy="NEVER">
                <content>
                    <VBox fx:id="cardsContainer"
                          spacing="10"
                          styleClass="glass"
                          style="-fx-padding: 12;">
                        <!-- items générés dynamiquement -->
                    </VBox>
                </content>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
