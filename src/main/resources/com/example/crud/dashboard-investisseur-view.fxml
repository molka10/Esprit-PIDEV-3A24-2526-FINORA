<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<BorderPane prefHeight="850.0" prefWidth="1400.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.crud.controllers.DashboardInvestisseurController"
            style="-fx-background-color: #0f1117;">

    <!-- ============================================ -->
    <!-- LEFT SIDEBAR -->
    <!-- ============================================ -->
    <left>
        <VBox spacing="8"
              style="-fx-background-color: #1a1d27; -fx-pref-width: 90; -fx-padding: 20 10;">

            <!-- Logo -->
            <VBox alignment="CENTER" style="-fx-padding: 0 0 20 0;">
                <Label text="F" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #00d4aa; -fx-background-color: #00d4aa22; -fx-background-radius: 12; -fx-padding: 10 14;"/>
            </VBox>

            <!-- Nav items -->
            <Button fx:id="btnDashboard" text="⊞" onAction="#navDashboard"
                    style="-fx-background-color: #00d4aa22; -fx-text-fill: #00d4aa; -fx-font-size: 20px; -fx-background-radius: 10; -fx-cursor: hand; -fx-pref-width: 60; -fx-pref-height: 50;"/>
            <Label text="Dashboard" style="-fx-font-size: 9px; -fx-text-fill: #00d4aa; -fx-padding: -4 0 8 0;" alignment="CENTER"/>

            <Button text="📈" style="-fx-background-color: transparent; -fx-text-fill: #6b7280; -fx-font-size: 20px; -fx-background-radius: 10; -fx-cursor: hand; -fx-pref-width: 60; -fx-pref-height: 50;"/>
            <Label text="Ordres" style="-fx-font-size: 9px; -fx-text-fill: #6b7280; -fx-padding: -4 0 8 0;" alignment="CENTER"/>

            <Button text="📜" onAction="#ouvrirHistorique" style="-fx-background-color: transparent; -fx-text-fill: #6b7280; -fx-font-size: 20px; -fx-background-radius: 10; -fx-cursor: hand; -fx-pref-width: 60; -fx-pref-height: 50;"/>
            <Label text="Historique" style="-fx-font-size: 9px; -fx-text-fill: #6b7280; -fx-padding: -4 0 8 0;" alignment="CENTER"/>

            <Button text="📰" style="-fx-background-color: transparent; -fx-text-fill: #6b7280; -fx-font-size: 20px; -fx-background-radius: 10; -fx-cursor: hand; -fx-pref-width: 60; -fx-pref-height: 50;"/>
            <Label text="News" style="-fx-font-size: 9px; -fx-text-fill: #6b7280; -fx-padding: -4 0 8 0;" alignment="CENTER"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- User Avatar -->
            <VBox alignment="CENTER" spacing="4">
                <Label text="👤" style="-fx-font-size: 24px;"/>
                <Label fx:id="lblSidebarUser" text="Investisseur" style="-fx-font-size: 9px; -fx-text-fill: #9ca3af; -fx-wrap-text: true;" alignment="CENTER"/>
                <Label fx:id="lblSidebarId" text="ID: 1" style="-fx-font-size: 9px; -fx-text-fill: #6b7280; -fx-background-color: #ffffff11; -fx-background-radius: 4; -fx-padding: 2 6;"/>
            </VBox>
        </VBox>
    </left>

    <!-- ============================================ -->
    <!-- CENTER - MAIN CONTENT -->
    <!-- ============================================ -->
    <center>
        <VBox spacing="0" style="-fx-background-color: #0f1117;">

            <!-- TOP HEADER BAR -->
            <HBox alignment="CENTER_LEFT" spacing="20"
                  style="-fx-background-color: #1a1d27; -fx-padding: 16 24; -fx-border-color: transparent transparent #ffffff11 transparent; -fx-border-width: 0 0 1 0;">

                <VBox>
                    <Label text="Bourse — Desktop Dashboard"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label fx:id="lblDateTime" text="Lundi, 17 Février 2026"
                           style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Search -->
                <HBox spacing="8" alignment="CENTER"
                      style="-fx-background-color: #ffffff0d; -fx-background-radius: 10; -fx-padding: 8 16; -fx-border-color: #ffffff11; -fx-border-radius: 10; -fx-border-width: 1;">
                    <Label text="🔍" style="-fx-font-size: 14px; -fx-text-fill: #6b7280;"/>
                    <TextField fx:id="searchField"
                               promptText="Rechercher un symbole..."
                               style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #6b7280; -fx-font-size: 13px; -fx-pref-width: 200; -fx-border-color: transparent;"/>
                </HBox>

                <Button text="↻ Actualiser" onAction="#handleActualiser"
                        style="-fx-background-color: #00d4aa; -fx-text-fill: #0f1117; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 20; -fx-cursor: hand;"/>
            </HBox>

            <!-- MAIN CONTENT SCROLL -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: #0f1117;">
                <VBox spacing="20" style="-fx-padding: 20; -fx-background-color: #0f1117;">

                    <!-- ======================== -->
                    <!-- ROW 1: STAT CARDS -->
                    <!-- ======================== -->
                    <HBox spacing="16">

                        <!-- Portfolio Card -->
                        <VBox spacing="6" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #1a1d27; -fx-background-radius: 14; -fx-padding: 20; -fx-border-color: #ffffff11; -fx-border-radius: 14; -fx-border-width: 1;">
                            <Label text="Portfolio" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                            <Label fx:id="lblPortfolio" text="\$24,000"
                                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label fx:id="lblPortfolioChange" text="▲ +2.4% aujourd'hui"
                                   style="-fx-font-size: 12px; -fx-text-fill: #00d4aa;"/>
                        </VBox>

                        <!-- S&P 500 Card -->
                        <VBox spacing="6" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #1a1d27; -fx-background-radius: 14; -fx-padding: 20; -fx-border-color: #ffffff11; -fx-border-radius: 14; -fx-border-width: 1;">
                            <Label text="S&amp;P 500" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                            <Label text="4,980"
                                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="▼ -2.18%   ▲ +0.93%"
                                   style="-fx-font-size: 12px; -fx-text-fill: #ef4444;"/>
                        </VBox>

                        <!-- EUR/USD Card -->
                        <VBox spacing="6" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #1a1d27; -fx-background-radius: 14; -fx-padding: 20; -fx-border-color: #ffffff11; -fx-border-radius: 14; -fx-border-width: 1;">
                            <Label text="EUR/USD" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                            <Label text="1.0872"
                                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="▲ +0.08%   ▲ +0.30%"
                                   style="-fx-font-size: 12px; -fx-text-fill: #00d4aa;"/>
                        </VBox>

                        <!-- Actions Card -->
                        <VBox spacing="6" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #1a1d27; -fx-background-radius: 14; -fx-padding: 20; -fx-border-color: #ffffff11; -fx-border-radius: 14; -fx-border-width: 1;">
                            <Label text="Mes Actions" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                            <Label fx:id="lblMesActions" text="0 actions"
                                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label fx:id="lblWatchlistCount" text="⭐ 0 en watchlist"
                                   style="-fx-font-size: 12px; -fx-text-fill: #f59e0b;"/>
                        </VBox>

                    </HBox>

                    <!-- ======================== -->
                    <!-- ROW 2: CHART + WATCHLIST + NEWS -->
                    <!-- ======================== -->
                    <HBox spacing="16">

                        <!-- CHART SECTION -->
                        <VBox spacing="16" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #1a1d27; -fx-background-radius: 14; -fx-padding: 20; -fx-border-color: #ffffff11; -fx-border-radius: 14; -fx-border-width: 1;">

                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="Graphique" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Lun" style="-fx-background-color: #00d4aa22; -fx-text-fill: #00d4aa; -fx-background-radius: 6; -fx-font-size: 11px; -fx-padding: 4 10; -fx-cursor: hand;"/>
                                <Button text="Mois" style="-fx-background-color: transparent; -fx-text-fill: #6b7280; -fx-background-radius: 6; -fx-font-size: 11px; -fx-padding: 4 10; -fx-cursor: hand;"/>
                                <Button text="An" style="-fx-background-color: transparent; -fx-text-fill: #6b7280; -fx-background-radius: 6; -fx-font-size: 11px; -fx-padding: 4 10; -fx-cursor: hand;"/>
                            </HBox>

                            <!-- Chart Area -->
                            <LineChart fx:id="lineChart"
                                       VBox.vgrow="ALWAYS"
                                       prefHeight="220"
                                       style="-fx-background-color: transparent;"
                                       animated="false">
                                <xAxis>
                                    <CategoryAxis label="" tickLabelFill="gray" tickLabelsVisible="true"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis tickLabelFill="gray" tickLabelsVisible="true"/>
                                </yAxis>
                            </LineChart>

                            <!-- Actions Acheter/Vendre -->
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Button fx:id="btnAcheter" text="🟢 Acheter" onAction="#ouvrirDialogAcheter"
                                        style="-fx-background-color: #00d4aa; -fx-text-fill: #0f1117; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12 30; -fx-cursor: hand;"/>
                                <Button fx:id="btnVendre" text="🔴 Vendre" onAction="#ouvrirDialogVendre"
                                        style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12 30; -fx-cursor: hand;"/>
                                <Button text="⭐ Watchlist" onAction="#ouvrirDialogWatchlist"
                                        style="-fx-background-color: #f59e0b22; -fx-text-fill: #f59e0b; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand; -fx-border-color: #f59e0b44; -fx-border-radius: 10; -fx-border-width: 1;"/>
                                <Button text="📜 Historique" onAction="#ouvrirHistorique"
                                        style="-fx-background-color: #6366f122; -fx-text-fill: #6366f1; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand; -fx-border-color: #6366f144; -fx-border-radius: 10; -fx-border-width: 1;"/>
                            </HBox>
                        </VBox>

                        <!-- WATCHLIST -->
                        <VBox spacing="12"
                              style="-fx-background-color: #1a1d27; -fx-background-radius: 14; -fx-padding: 20; -fx-pref-width: 260; -fx-border-color: #ffffff11; -fx-border-radius: 14; -fx-border-width: 1;">

                            <HBox alignment="CENTER_LEFT">
                                <Label text="Watchlist" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Hyperlink text="Voir tout" style="-fx-text-fill: #00d4aa; -fx-font-size: 12px;"/>
                            </HBox>

                            <HBox spacing="8" style="-fx-background-color: #0f111788; -fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #ffffff11; -fx-border-radius: 8; -fx-border-width: 1;">
                                <TextField fx:id="searchWatchlist" promptText="Chercher..."
                                           style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #6b7280; -fx-font-size: 12px; -fx-border-color: transparent;" HBox.hgrow="ALWAYS"/>
                                <Button text="+" style="-fx-background-color: #00d4aa; -fx-text-fill: #0f1117; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 2 8;"/>
                            </HBox>

                            <ScrollPane fitToWidth="true" prefHeight="280"
                                        style="-fx-background-color: transparent; -fx-background: transparent;">
                                <VBox fx:id="watchlistContainer" spacing="8">
                                    <!-- Watchlist items générés dynamiquement -->
                                </VBox>
                            </ScrollPane>
                        </VBox>

                        <!-- NEWS -->
                        <VBox spacing="12"
                              style="-fx-background-color: #1a1d27; -fx-background-radius: 14; -fx-padding: 20; -fx-pref-width: 260; -fx-border-color: #ffffff11; -fx-border-radius: 14; -fx-border-width: 1;">

                            <HBox alignment="CENTER_LEFT">
                                <Label text="News" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Hyperlink text="Voir tout" style="-fx-text-fill: #00d4aa; -fx-font-size: 12px;"/>
                            </HBox>

                            <ScrollPane fitToWidth="true" prefHeight="340"
                                        style="-fx-background-color: transparent; -fx-background: transparent;">
                                <VBox fx:id="newsContainer" spacing="12">
                                    <!-- News items générés dynamiquement -->
                                </VBox>
                            </ScrollPane>
                        </VBox>

                    </HBox>

                    <!-- ======================== -->
                    <!-- ROW 3: MARCHÉ / ACTIONS TABLE -->
                    <!-- ======================== -->
                    <VBox spacing="16"
                          style="-fx-background-color: #1a1d27; -fx-background-radius: 14; -fx-padding: 20; -fx-border-color: #ffffff11; -fx-border-radius: 14; -fx-border-width: 1;">

                        <HBox alignment="CENTER_LEFT">
                            <Label text="Marché — Actions" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <ComboBox fx:id="cbFiltreMarche" promptText="Toutes les bourses"
                                      style="-fx-background-color: #ffffff0d; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 12px;"/>
                        </HBox>

                        <!-- TABLE HEADER -->
                        <HBox style="-fx-background-color: #0f111799; -fx-background-radius: 8; -fx-padding: 10 16;">
                            <Label text="Symbole" style="-fx-text-fill: #6b7280; -fx-font-size: 12px; -fx-font-weight: bold; -fx-pref-width: 120;"/>
                            <Label text="Nom" style="-fx-text-fill: #6b7280; -fx-font-size: 12px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
                            <Label text="Prix" style="-fx-text-fill: #6b7280; -fx-font-size: 12px; -fx-font-weight: bold; -fx-pref-width: 100;" alignment="CENTER_RIGHT"/>
                            <Label text="Variation" style="-fx-text-fill: #6b7280; -fx-font-size: 12px; -fx-font-weight: bold; -fx-pref-width: 100;" alignment="CENTER_RIGHT"/>
                            <Label text="Volume" style="-fx-text-fill: #6b7280; -fx-font-size: 12px; -fx-font-weight: bold; -fx-pref-width: 100;" alignment="CENTER_RIGHT"/>
                            <Label text="Action" style="-fx-text-fill: #6b7280; -fx-font-size: 12px; -fx-font-weight: bold; -fx-pref-width: 80;" alignment="CENTER"/>
                        </HBox>

                        <!-- TABLE ROWS -->
                        <ScrollPane fitToWidth="true" prefHeight="250"
                                    style="-fx-background-color: transparent; -fx-background: transparent;"
                                    hbarPolicy="NEVER">
                            <VBox fx:id="marcheContainer" spacing="4">
                                <!-- Rows générées dynamiquement -->
                            </VBox>
                        </ScrollPane>

                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>
