<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.crud.controllers.BourseController"
            style="-fx-background-color: #f5f7fa;">

    <!-- ============================================ -->
    <!-- HEADER / TOPBAR -->
    <!-- ============================================ -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #6366f1, #8b5cf6); -fx-padding: 24;">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label text="📊 FINORA - Gestion des Bourses"
                       style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="⬅ Retour"
                        onAction="#retourProfil"
                        style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
            </HBox>

            <Label text="Module FINORA - Marchés Financiers Internationaux"
                   style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 14px; -fx-padding: 8 0 0 0;"/>
        </VBox>
    </top>

    <!-- ============================================ -->
    <!-- LEFT SIDEBAR - FORMULAIRE -->
    <!-- ============================================ -->
    <left>
        <ScrollPane fitToHeight="true"
                    style="-fx-background-color: white; -fx-background: white;"
                    hbarPolicy="NEVER">
            <VBox spacing="16"
                  style="-fx-background-color: white; -fx-padding: 24; -fx-pref-width: 320;">

                <!-- Titre du formulaire -->
                <VBox spacing="6">
                    <Label text="📝 Formulaire Bourse"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                    <Separator style="-fx-background-color: #e5e7eb;"/>
                </VBox>

                <!-- Champ Nom -->
                <VBox spacing="6">
                    <Label text="Nom de la Bourse *"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <TextField fx:id="tfNom"
                               promptText="Ex: NYSE, Euronext, NASDAQ"
                               style="-fx-background-color: #f9fafb; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-padding: 10; -fx-font-size: 13px;"/>
                </VBox>

                <!-- Champ Pays -->
                <VBox spacing="6">
                    <Label text="Pays *"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <ComboBox fx:id="cbPays"
                              promptText="Sélectionner un pays"
                              maxWidth="Infinity"
                              style="-fx-background-color: #f9fafb; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-font-size: 13px;"/>
                </VBox>

                <!-- Champ Devise -->
                <VBox spacing="6">
                    <Label text="Devise *"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <ComboBox fx:id="cbDevise"
                              promptText="Sélectionner une devise"
                              maxWidth="Infinity"
                              style="-fx-background-color: #f9fafb; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-font-size: 13px;"/>
                </VBox>

                <!-- Champ Statut -->
                <VBox spacing="6">
                    <Label text="Statut *"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <ComboBox fx:id="cbStatut"
                              promptText="Sélectionner un statut"
                              maxWidth="Infinity"
                              style="-fx-background-color: #f9fafb; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-font-size: 13px;"/>
                </VBox>

                <!-- Séparateur -->
                <Separator style="-fx-background-color: #e5e7eb; -fx-padding: 8 0;"/>

                <!-- Boutons d'action -->
                <VBox spacing="10">

                    <!-- Bouton Ajouter -->
                    <Button text="✚ Ajouter"
                            onAction="#ajouterBourse"
                            maxWidth="Infinity"
                            style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12; -fx-cursor: hand;">
                        <font>
                            <Font name="System Bold" size="14"/>
                        </font>
                    </Button>

                    <!-- Bouton Modifier -->
                    <Button text="✏️ Modifier"
                            onAction="#modifierBourse"
                            maxWidth="Infinity"
                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12; -fx-cursor: hand;">
                        <font>
                            <Font name="System Bold" size="14"/>
                        </font>
                    </Button>

                    <!-- Bouton Supprimer -->
                    <Button text="🗑️ Supprimer"
                            onAction="#supprimerBourse"
                            maxWidth="Infinity"
                            style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12; -fx-cursor: hand;">
                        <font>
                            <Font name="System Bold" size="14"/>
                        </font>
                    </Button>

                    <!-- Bouton Vider -->
                    <Button text="↻ Vider le formulaire"
                            onAction="#viderFormulaire"
                            maxWidth="Infinity"
                            style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10; -fx-cursor: hand;">
                        <font>
                            <Font name="System Bold" size="13"/>
                        </font>
                    </Button>

                </VBox>

                <!-- Note d'information -->
                <VBox spacing="8"
                      style="-fx-background-color: #eff6ff; -fx-background-radius: 10; -fx-padding: 12; -fx-border-color: #3b82f6; -fx-border-radius: 10; -fx-border-width: 1;">
                    <Label text="ℹ️ Information"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1e40af;"/>
                    <Label text="Sélectionnez une carte pour la modifier ou la supprimer."
                           wrapText="true"
                           style="-fx-font-size: 11px; -fx-text-fill: #3b82f6;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </left>

    <!-- ============================================ -->
    <!-- CENTER - LISTE DES BOURSES -->
    <!-- ============================================ -->
    <center>
        <VBox spacing="20" style="-fx-padding: 24; -fx-background-color: #f5f7fa;">

            <!-- Barre de recherche et filtres -->
            <VBox spacing="12"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">

                <Label text="🔍 Recherche et Filtres"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>

                <HBox spacing="12" alignment="CENTER_LEFT">

                    <!-- Champ de recherche -->
                    <TextField fx:id="searchField"
                               promptText="Rechercher par nom ou pays..."
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: #f9fafb; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;"/>

                    <!-- Bouton Rechercher -->
                    <Button text="🔍 Rechercher"
                            onAction="#handleRechercher"
                            style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>

                    <!-- Bouton Actualiser -->
                    <Button text="↻ Actualiser"
                            onAction="#handleActualiser"
                            style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>

                </HBox>
            </VBox>

            <!-- Compteur total -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="lblTotal"
                       text="📊 Total : 0 bourse(s)"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
            </HBox>

            <!-- Container des cartes -->
            <ScrollPane fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;"
                        hbarPolicy="NEVER">
                <content>
                    <FlowPane fx:id="cardsContainer"
                              hgap="20"
                              vgap="20"
                              prefWrapLength="850"
                              style="-fx-background-color: transparent;">
                        <padding>
                            <Insets top="10" right="10" bottom="10" left="10"/>
                        </padding>
                    </FlowPane>
                </content>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
