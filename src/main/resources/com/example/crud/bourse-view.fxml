<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.crud.controllers.BourseController"
            style="-fx-background-color: #ffffff;">

    <!-- ===== LEFT SIDEBAR ===== -->
    <left>
        <VBox spacing="10"
              style="-fx-background-color: #f8f9fa; -fx-padding: 20 10; -fx-pref-width: 200; -fx-border-color: transparent #e9ecef transparent transparent; -fx-border-width: 0 1 0 0;">
            <Label text="FINORA"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #a855f7;"/>
            <Label text="Admin"
                   style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>

            <Button text="📊 Dashboard"
                    onAction="#retourProfil"
                    style="-fx-background-color: transparent; -fx-text-fill: #6b7280; -fx-alignment: CENTER_LEFT; -fx-padding: 10 14; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button text="🏛 Bourses"
                    style="-fx-background-color: #f3e8ff; -fx-text-fill: #a855f7; -fx-alignment: CENTER_LEFT; -fx-padding: 10 14; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;"/>
            <Button text="📈 Actions"
                    onAction="#retourProfil"
                    style="-fx-background-color: transparent; -fx-text-fill: #6b7280; -fx-alignment: CENTER_LEFT; -fx-padding: 10 14; -fx-background-radius: 8; -fx-cursor: hand;"/>

            <Pane VBox.vgrow="ALWAYS"/>

            <Label fx:id="lblTotal"
                   text="Total : 0 bourse(s)"
                   style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
        </VBox>
    </left>

    <!-- ===== TOP BAR ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="14"
              style="-fx-background-color: white; -fx-padding: 20 24; -fx-border-color: transparent transparent #e9ecef transparent; -fx-border-width: 0 0 1 0;">
            <VBox spacing="2">
                <Label text="Gestion des Bourses"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                <Label text="Marchés Financiers Internationaux"
                       style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
            </VBox>

            <Pane HBox.hgrow="ALWAYS"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <TextField fx:id="searchField"
                           promptText="Rechercher un nom ou un pays..."
                           style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14; -fx-pref-width: 250; -fx-text-fill: #1f2937;"/>

                <Button text="Actualiser"
                        onAction="#handleActualiser"
                        style="-fx-background-color: #f3f4f6; -fx-text-fill: #4b5563; -fx-font-size: 13px; -fx-background-radius: 8; -fx-padding: 10 18; -fx-cursor: hand;"/>
                <Button text="+ Nouvelle"
                        onAction="#ouvrirDialogAjout"
                        style="-fx-background-color: #a855f7; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                <Button text="Retour"
                        onAction="#retourProfil"
                        style="-fx-background-color: transparent; -fx-text-fill: #6b7280; -fx-font-size: 13px; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1; -fx-padding: 10 18; -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <!-- ===== CENTER CONTENT ===== -->
    <center>
        <VBox spacing="14" style="-fx-padding: 24; -fx-background-color: #f8f9fa;">

            <!-- Cards zone -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" hbarPolicy="NEVER"
                        style="-fx-background-color: transparent;">
                <content>
                    <FlowPane fx:id="cardsContainer"
                              hgap="14"
                              vgap="14"
                              prefWrapLength="900"
                              style="-fx-background-color: transparent;">
                        <padding>
                            <Insets top="4" right="4" bottom="4" left="4"/>
                        </padding>
                    </FlowPane>
                </content>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
