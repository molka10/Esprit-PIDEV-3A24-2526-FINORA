<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.crud.controllers.BourseController"
            stylesheets="@theme-user.css">

    <!-- TOPBAR -->
    <top>
        <VBox styleClass="topbar" spacing="6">
            <Label text="📊 FINORA - Gestion des Bourses" styleClass="top-title"/>
            <Label text="Module FINORA - Marchés Financiers Internationaux" styleClass="top-sub"/>
        </VBox>
    </top>

    <!-- LEFT SIDEBAR (FORM) -->
    <left>
        <VBox styleClass="sidebar" spacing="12">

            <Label text="📝 Formulaire Bourse" styleClass="card-title"/>
            <Separator opacity="0.4"/>

            <Label text="ID (modifier/supprimer)" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: 800;"/>
            <TextField fx:id="tfId" promptText="ID" />

            <Label text="Nom *" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: 800;"/>
            <TextField fx:id="tfNom" promptText="Ex: NYSE, Euronext" />

            <Label text="Pays *" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: 800;"/>
            <ComboBox fx:id="cbPays" promptText="Sélectionner un pays" />

            <Label text="Devise *" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: 800;"/>
            <ComboBox fx:id="cbDevise" promptText="Sélectionner" />

            <Label text="Statut *" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: 800;"/>
            <ComboBox fx:id="cbStatut" promptText="Sélectionner" />

            <Separator opacity="0.4"/>

            <Button text="✚ Ajouter" onAction="#ajouterBourse" styleClass="btn-success" maxWidth="1.7976931348623157E308"/>
            <Button text="✎ Modifier" onAction="#modifierBourse" styleClass="btn-primary" maxWidth="1.7976931348623157E308"/>
            <Button text="🗑 Supprimer" onAction="#supprimerBourse" styleClass="btn-danger" maxWidth="1.7976931348623157E308"/>
            <Button text="↻ Vider" onAction="#viderFormulaire" styleClass="btn-gray" maxWidth="1.7976931348623157E308"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="⬅ Retour" onAction="#retourProfil" styleClass="btn-outline" maxWidth="1.7976931348623157E308"/>

        </VBox>
    </left>

    <!-- CENTER CONTENT -->
    <center>
        <StackPane styleClass="content-wrap">
            <VBox styleClass="content" spacing="14" prefWidth="740">

                <!-- Search bar -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" promptText="Rechercher..." HBox.hgrow="ALWAYS"/>
                    <Button text="Rechercher" onAction="#handleRechercher" styleClass="btn-primary"/>
                    <Button text="Actualiser" onAction="#handleActualiser" styleClass="btn-gray"/>
                </HBox>

                <Label fx:id="lblTotal" text="📋 Total : 0 bourse(s)" styleClass="total"/>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <content>
                        <FlowPane fx:id="cardsContainer" hgap="16" vgap="16" prefWrapLength="700">
                            <padding>
                                <Insets top="8" right="8" bottom="8" left="8"/>
                            </padding>
                        </FlowPane>
                    </content>
                </ScrollPane>

            </VBox>
        </StackPane>
    </center>

</BorderPane>
