<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="750.0" prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.crud.controllers.Historiquecontroller"
            style="-fx-background-color: #0f1117;">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #1a1d27; -fx-padding: 20 24; -fx-border-color: transparent transparent #ffffff11 transparent; -fx-border-width: 0 0 1 0;">
            <Label text="📜 Historique des Transactions"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="⬅ Retour" onAction="#retourDashboard"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 24; -fx-background-color: #0f1117;">

            <!-- STATS CARDS -->
            <HBox spacing="16">

                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #1a1d27; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #ffffff11; -fx-border-radius: 12; -fx-border-width: 1;">
                    <Label text="Total Investi"
                           style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="lblTotalInvesti" text="0.00 TND"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #00d4aa;"/>
                </VBox>

                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #1a1d27; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #ffffff11; -fx-border-radius: 12; -fx-border-width: 1;">
                    <Label text="Total Vendu"
                           style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="lblTotalVendu" text="0.00 TND"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
                </VBox>

                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #1a1d27; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #ffffff11; -fx-border-radius: 12; -fx-border-width: 1;">
                    <Label text="Commissions Payées"
                           style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="lblCommissions" text="0.00 TND"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                </VBox>

                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #1a1d27; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #ffffff11; -fx-border-radius: 12; -fx-border-width: 1;">
                    <Label text="Nb. Transactions"
                           style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="lblNbTransactions" text="0"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                </VBox>

            </HBox>

            <!-- FILTRES -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: #1a1d27; -fx-background-radius: 12; -fx-padding: 16; -fx-border-color: #ffffff11; -fx-border-radius: 12; -fx-border-width: 1;">

                <Label text="Filtrer :" style="-fx-font-size: 13px; -fx-text-fill: #9ca3af;"/>

                <ToggleButton fx:id="btnTous" text="Tous" selected="true" onAction="#filtrerTous"
                              style="-fx-background-color: #00d4aa; -fx-text-fill: #0f1117; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 18; -fx-cursor: hand;"/>
                <ToggleButton fx:id="btnAchats" text="Achats" onAction="#filtrerAchats"
                              style="-fx-background-color: #ffffff11; -fx-text-fill: #9ca3af; -fx-background-radius: 8; -fx-padding: 8 18; -fx-cursor: hand;"/>
                <ToggleButton fx:id="btnVentes" text="Ventes" onAction="#filtrerVentes"
                              style="-fx-background-color: #ffffff11; -fx-text-fill: #9ca3af; -fx-background-radius: 8; -fx-padding: 8 18; -fx-cursor: hand;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <TextField fx:id="searchField" promptText="Rechercher par symbole..."
                           style="-fx-background-color: #0f1117; -fx-text-fill: white; -fx-prompt-text-fill: #4b5563; -fx-background-radius: 8; -fx-padding: 8 14; -fx-font-size: 13px; -fx-border-color: #ffffff11; -fx-border-radius: 8; -fx-border-width: 1; -fx-pref-width: 220;"/>

                <Button text="↻ Actualiser" onAction="#handleActualiser"
                        style="-fx-background-color: #374151; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
            </HBox>

            <!-- TABLE HEADER -->
            <VBox spacing="0" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: #1a1d27; -fx-background-radius: 12; -fx-border-color: #ffffff11; -fx-border-radius: 12; -fx-border-width: 1;">

                <!-- En-tête colonnes -->
                <HBox style="-fx-background-color: #0f111799; -fx-background-radius: 12 12 0 0; -fx-padding: 12 20;">
                    <Label text="Type"      style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 90;"/>
                    <Label text="Symbole"   style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 100;"/>
                    <Label text="Entreprise" style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
                    <Label text="Quantité"  style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 90;" alignment="CENTER_RIGHT"/>
                    <Label text="Prix Unit." style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 110;" alignment="CENTER_RIGHT"/>
                    <Label text="Montant"   style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 120;" alignment="CENTER_RIGHT"/>
                    <Label text="Commission" style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 110;" alignment="CENTER_RIGHT"/>
                    <Label text="Date"      style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 160;" alignment="CENTER_RIGHT"/>
                </HBox>

                <!-- Lignes dynamiques -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-background: transparent;"
                            hbarPolicy="NEVER">
                    <VBox fx:id="listeContainer" spacing="0"/>
                </ScrollPane>

            </VBox>

        </VBox>
    </center>

</BorderPane>
