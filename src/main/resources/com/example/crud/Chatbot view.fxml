<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.crud.controllers.Chatbotcontroller"
            style="-fx-background-color: #0f1117;">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #1a1d27; -fx-padding: 20 24; -fx-border-color: transparent transparent #ffffff11 transparent; -fx-border-width: 0 0 1 0;">
            <Label text="🤖 Conseiller Financier IA"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🔄 Nouvelle Conversation" onAction="#nouvelleConversation"
                    style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
            <Button text="⬅ Retour" onAction="#retourDashboard"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox style="-fx-background-color: #0f1117;">

            <!-- ZONE DE CONVERSATION -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;"
                        hbarPolicy="NEVER"
                        fx:id="scrollPane">
                <VBox fx:id="chatContainer" spacing="16" style="-fx-padding: 24;">
                    <!-- Messages ajoutés dynamiquement -->

                    <!-- Message d'accueil initial -->
                    <VBox spacing="8" alignment="CENTER_LEFT" maxWidth="600">
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="🤖" style="-fx-font-size: 24px;"/>
                            <VBox spacing="4">
                                <Label text="Assistant FINORA" style="-fx-font-size: 12px; -fx-text-fill: #6b7280; -fx-font-weight: bold;"/>
                                <VBox style="-fx-background-color: #1a1d27; -fx-background-radius: 12; -fx-padding: 16; -fx-border-color: #6366f144; -fx-border-radius: 12; -fx-border-width: 1;">
                                    <Label text="Bonjour ! 👋" wrapText="true"
                                           style="-fx-font-size: 14px; -fx-text-fill: white; -fx-font-weight: bold;"/>
                                    <Label text="Je suis votre conseiller financier IA. Je peux vous aider à :" wrapText="true"
                                           style="-fx-font-size: 13px; -fx-text-fill: #d1d5db; -fx-padding: 8 0 0 0;"/>
                                    <VBox spacing="6" style="-fx-padding: 8 0 0 0;">
                                        <Label text="• Analyser des actions" style="-fx-font-size: 12px; -fx-text-fill: #9ca3af;"/>
                                        <Label text="• Comprendre les marchés" style="-fx-font-size: 12px; -fx-text-fill: #9ca3af;"/>
                                        <Label text="• Gérer votre portefeuille" style="-fx-font-size: 12px; -fx-text-fill: #9ca3af;"/>
                                        <Label text="• Expliquer les concepts financiers" style="-fx-font-size: 12px; -fx-text-fill: #9ca3af;"/>
                                    </VBox>
                                    <Label text="Comment puis-je vous aider aujourd'hui ?" wrapText="true"
                                           style="-fx-font-size: 13px; -fx-text-fill: #d1d5db; -fx-padding: 12 0 0 0; -fx-font-weight: bold;"/>
                                </VBox>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- ZONE DE SAISIE -->
            <VBox style="-fx-background-color: #1a1d27; -fx-padding: 20 24; -fx-border-color: #ffffff11 transparent transparent transparent; -fx-border-width: 1 0 0 0;">

                <!-- Suggestions rapides -->
                <HBox spacing="8" style="-fx-padding: 0 0 12 0;">
                    <Label text="💡 Suggestions :" style="-fx-font-size: 11px; -fx-text-fill: #6b7280;"/>
                    <Button text="Qu'est-ce qu'une action ?" onAction="#envoyerSuggestion"
                            style="-fx-background-color: #ffffff11; -fx-text-fill: #9ca3af; -fx-font-size: 11px; -fx-background-radius: 20; -fx-padding: 4 12; -fx-cursor: hand;"/>
                    <Button text="Comment analyser un titre ?" onAction="#envoyerSuggestion"
                            style="-fx-background-color: #ffffff11; -fx-text-fill: #9ca3af; -fx-font-size: 11px; -fx-background-radius: 20; -fx-padding: 4 12; -fx-cursor: hand;"/>
                    <Button text="Diversifier mon portefeuille" onAction="#envoyerSuggestion"
                            style="-fx-background-color: #ffffff11; -fx-text-fill: #9ca3af; -fx-font-size: 11px; -fx-background-radius: 20; -fx-padding: 4 12; -fx-cursor: hand;"/>
                </HBox>

                <HBox spacing="12" alignment="CENTER">
                    <TextArea fx:id="inputField"
                              promptText="Posez votre question ici..."
                              wrapText="true"
                              prefRowCount="2"
                              HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #0f1117; -fx-text-fill: white; -fx-prompt-text-fill: #6b7280; -fx-background-radius: 12; -fx-padding: 12; -fx-font-size: 14px; -fx-border-color: #ffffff11; -fx-border-radius: 12; -fx-border-width: 1;"/>

                    <Button fx:id="btnEnvoyer" text="Envoyer" onAction="#envoyerMessage"
                            style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 32; -fx-cursor: hand; -fx-min-height: 56;"/>
                </HBox>

                <!-- Indicateur de chargement -->
                <HBox fx:id="loadingIndicator" spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 12 0 0 0;" visible="false" managed="false">
                    <ProgressIndicator prefWidth="20" prefHeight="20"/>
                    <Label text="Claude réfléchit..." style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                </HBox>

            </VBox>
        </VBox>
    </center>

</BorderPane>
