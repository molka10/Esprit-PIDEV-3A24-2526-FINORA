<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720.0" prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.crud.controllers.Dashboardadmincontroller"
            stylesheets="@admin-dark.css">

    <!-- TOP BAR -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="14">
            <Label fx:id="lblBienvenue" text="👨‍💼 Bienvenue, Administrateur !" styleClass="top-title"/>
            <Pane HBox.hgrow="ALWAYS"/>

            <Label fx:id="lblDateHeure" text="📅 --/--/---- - ⏰ --:--:--" styleClass="chip"/>
            <Button text="Déconnexion" styleClass="btn-logout" onAction="#deconnexion"/>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar">
            <Label text="Administration" styleClass="side-title"/>

            <Button text="🏛  Gérer Bourses" styleClass="side-btn primary" onAction="#gererBourses"/>
            <Button text="📈  Gérer Actions" styleClass="side-btn primary" onAction="#gererActions"/>

            <Separator style="-fx-opacity: 0.35;"/>

            <Label text="Logs Système" styleClass="side-title"/>

            <VBox styleClass="card" VBox.vgrow="ALWAYS">
                <ListView fx:id="logsListView" styleClass="logs"/>
            </VBox>
        </VBox>
    </left>

    <!-- CENTER CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll" pannable="true">
            <VBox spacing="14" styleClass="content-wrap">

                <!-- KPI Row -->
                <HBox spacing="14">
                    <VBox styleClass="card kpi" HBox.hgrow="ALWAYS">
                        <Label text="Total Bourses" styleClass="card-sub"/>
                        <Label fx:id="lblTotalBourses" text="0" styleClass="kpi-value"/>
                    </VBox>

                    <VBox styleClass="card kpi" HBox.hgrow="ALWAYS">
                        <Label text="Total Actions" styleClass="card-sub"/>
                        <Label fx:id="lblTotalActions" text="0" styleClass="kpi-value"/>
                    </VBox>

                    <VBox styleClass="card kpi" HBox.hgrow="ALWAYS">
                        <Label text="Pays Couverts" styleClass="card-sub"/>
                        <Label fx:id="lblBoursesPays" text="0" styleClass="kpi-value"/>
                    </VBox>

                    <VBox styleClass="card kpi" HBox.hgrow="ALWAYS">
                        <Label text="Secteurs" styleClass="card-sub"/>
                        <Label fx:id="lblSecteurs" text="0" styleClass="kpi-value"/>
                    </VBox>
                </HBox>

                <!-- Charts row -->
                <HBox spacing="14">
                    <VBox styleClass="card" HBox.hgrow="ALWAYS">
                        <Label text="🌍 Bourses par Pays" styleClass="card-title"/>
                        <VBox fx:id="chartPaysContainer" spacing="8"/>
                    </VBox>

                    <VBox styleClass="card" HBox.hgrow="ALWAYS">
                        <Label text="💰 Bourses par Devise" styleClass="card-title"/>
                        <VBox fx:id="chartDevisesContainer" spacing="8"/>
                    </VBox>
                </HBox>
                <Button text="💰 Commission"
                        onAction="#ouvrirCommission"
                        styleClass="btn-primary"/>

                <!-- Bar chart -->
                <VBox styleClass="card">
                    <Label text="🏷️ Actions par Secteur" styleClass="card-title"/>
                    <VBox fx:id="chartSecteursContainer" spacing="8"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
