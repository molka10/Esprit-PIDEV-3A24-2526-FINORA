<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.crud.controllers.UtilisateurStaticController"
            stylesheets="@finora-light-theme.css"
            style="-fx-background-color: #f8f9fa;">

    <top>
        <VBox spacing="6"
              style="-fx-background-color: white; -fx-padding: 30 24; -fx-border-color: transparent transparent #e9ecef transparent; -fx-border-width: 0 0 1 0;">
            <Label text="👤 Sélection du Profil"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #a855f7;"/>
            <Label text="Entreprise / Investisseur / Admin"
                   style="-fx-font-size: 14px; -fx-text-fill: rgb(168,85,247);"/>
        </VBox>
    </top>

    <center>
        <StackPane style="-fx-background-color: #f8f9fa;">
            <VBox alignment="CENTER"
                  spacing="22"
                  prefWidth="900"
                  prefHeight="520">

                <HBox spacing="18" alignment="CENTER">

                    <VBox fx:id="cardEntreprise"
                          prefWidth="260"
                          alignment="CENTER"
                          spacing="8"
                          onMouseClicked="#choisirEntreprise"
                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 40 20; -fx-border-color: #b86ffd; -fx-border-radius: 16; -fx-border-width: 2; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgb(168,85,247), 12, 0, 0, 4);">
                        <Label text="🏢"
                               style="-fx-font-size: 48px;"/>
                        <Label text="Entreprise"
                               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #b86ffd;"/>
                        <Label text="Gestion et suivi des opérations"
                               style="-fx-font-size: 13px; -fx-text-fill: rgba(168,85,247,0.38); -fx-wrap-text: true; -fx-text-alignment: center;"/>
                    </VBox>

                    <VBox fx:id="cardInvestisseur"
                          prefWidth="260"
                          alignment="CENTER"
                          spacing="8"
                          onMouseClicked="#choisirInvestisseur"
                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 40 20; -fx-border-color: rgba(168,85,247,0.38); -fx-border-radius: 16; -fx-border-width: 2; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgb(168,85,247), 12, 0, 0, 4);">
                        <Label text="💼"
                               style="-fx-font-size: 48px;"/>
                        <Label text="Investisseur"
                               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: rgb(168,85,247);"/>
                        <Label text="Portefeuille, achats et ventes"
                               style="-fx-font-size: 13px; -fx-text-fill: rgba(168,85,247,0.38); -fx-wrap-text: true; -fx-text-alignment: center;"/>
                    </VBox>

                    <VBox fx:id="cardAdmin"
                          prefWidth="260"
                          alignment="CENTER"
                          spacing="8"
                          onMouseClicked="#choisirAdmin"
                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 40 20; -fx-border-color: #e9ecef; -fx-border-radius: 16; -fx-border-width: 2; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgb(184,111,253), 12, 0, 0, 4);">
                        <Label text="🛡"
                               style="-fx-font-size: 48px;"/>
                        <Label text="Admin"
                               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #a855f7;"/>
                        <Label text="Contrôle et paramétrage du système"
                               style="-fx-font-size: 13px; -fx-text-fill: rgba(168,85,247,0.38); -fx-wrap-text: true; -fx-text-alignment: center;"/>
                    </VBox>

                </HBox>

                <Label fx:id="lblInfo"
                       text="Choisis un profil pour continuer"
                       style="-fx-font-size: 14px; -fx-text-fill: #a855f7; -fx-font-weight: bold;"/>

            </VBox>
        </StackPane>
    </center>

</BorderPane>
