<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="800.0" prefWidth="1400.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.crud.controllers.Supervisioncontroller"
            style="-fx-background-color: #0f1117;">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #1a1d27; -fx-padding: 20 24; -fx-border-color: transparent transparent #ffffff11 transparent; -fx-border-width: 0 0 1 0;">
            <Label text="🔍 Supervision des Transactions"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="📊 Export Excel" onAction="#exporterExcel"
                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
            <Button text="⬅ Retour" onAction="#retourDashboard"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 24; -fx-background-color: #0f1117;">

            <!-- STATS GLOBALES -->
            <HBox spacing="16">

                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #1a1d27; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #ffffff11; -fx-border-radius: 12; -fx-border-width: 1;">
                    <Label text="Volume Total Traité"
                           style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="lblVolumeTotal" text="0.00 TND"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #00d4aa;"/>
                </VBox>

                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #1a1d27; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #ffffff11; -fx-border-radius: 12; -fx-border-width: 1;">
                    <Label text="Commissions Générées"
                           style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="lblCommissionsTotal" text="0.00 TND"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                </VBox>

                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #1a1d27; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #ffffff11; -fx-border-radius: 12; -fx-border-width: 1;">
                    <Label text="Transactions Totales"
                           style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="lblNbTransactions" text="0"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                </VBox>

                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #1a1d27; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #ffffff11; -fx-border-radius: 12; -fx-border-width: 1;">
                    <Label text="Transactions Suspectes"
                           style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="lblTransactionsSuspectes" text="0"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
                    <Label text="⚠️ Montant > 50,000"
                           style="-fx-font-size: 10px; -fx-text-fill: #9ca3af;"/>
                </VBox>

            </HBox>

            <!-- FILTRES AVANCÉS -->
            <VBox spacing="12"
                  style="-fx-background-color: #1a1d27; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #ffffff11; -fx-border-radius: 12; -fx-border-width: 1;">

                <Label text="🔎 Filtres Avancés"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                <HBox spacing="12" alignment="CENTER_LEFT">

                    <!-- Type -->
                    <VBox spacing="6">
                        <Label text="Type" style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                        <ComboBox fx:id="cbFiltreType" promptText="Tous"
                                  style="-fx-background-color: #0f1117; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 12px; -fx-pref-width: 140;"/>
                    </VBox>

                    <!-- Symbole -->
                    <VBox spacing="6" HBox.hgrow="SOMETIMES">
                        <Label text="Action" style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                        <ComboBox fx:id="cbFiltreAction" promptText="Toutes"
                                  style="-fx-background-color: #0f1117; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 12px; -fx-pref-width: 180;"/>
                    </VBox>

                    <!-- Montant Min -->
                    <VBox spacing="6">
                        <Label text="Montant Min" style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                        <TextField fx:id="tfMontantMin" promptText="0"
                                   style="-fx-background-color: #0f1117; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 12px; -fx-pref-width: 120;"/>
                    </VBox>

                    <!-- Montant Max -->
                    <VBox spacing="6">
                        <Label text="Montant Max" style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                        <TextField fx:id="tfMontantMax" promptText="∞"
                                   style="-fx-background-color: #0f1117; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 12px; -fx-pref-width: 120;"/>
                    </VBox>

                    <!-- Date Début -->
                    <VBox spacing="6">
                        <Label text="Date Début" style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                        <DatePicker fx:id="dpDateDebut"
                                    style="-fx-background-color: #0f1117; -fx-background-radius: 8; -fx-pref-width: 150;"/>
                    </VBox>

                    <!-- Date Fin -->
                    <VBox spacing="6">
                        <Label text="Date Fin" style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                        <DatePicker fx:id="dpDateFin"
                                    style="-fx-background-color: #0f1117; -fx-background-radius: 8; -fx-pref-width: 150;"/>
                    </VBox>

                    <!-- Boutons -->
                    <VBox spacing="6">
                        <Label text=" " style="-fx-font-size: 11px;"/>
                        <HBox spacing="8">
                            <Button text="Appliquer" onAction="#appliquerFiltres"
                                    style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
                            <Button text="Réinitialiser" onAction="#reinitialiserFiltres"
                                    style="-fx-background-color: #374151; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                </HBox>
            </VBox>

            <!-- TABLEAU TRANSACTIONS -->
            <VBox spacing="0" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: #1a1d27; -fx-background-radius: 12; -fx-border-color: #ffffff11; -fx-border-radius: 12; -fx-border-width: 1;">

                <HBox alignment="CENTER_LEFT" style="-fx-padding: 20; -fx-border-color: transparent transparent #ffffff11 transparent; -fx-border-width: 0 0 1 0;">
                    <Label text="📋 Liste des Transactions"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblResultatsFiltres" text="Affichage : 0 transaction(s)"
                           style="-fx-font-size: 12px; -fx-text-fill: #9ca3af;"/>
                </HBox>

                <!-- Header colonnes -->
                <HBox style="-fx-background-color: #0f111799; -fx-padding: 12 20;">
                    <Label text="ID"        style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 60;"/>
                    <Label text="Type"      style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 90;"/>
                    <Label text="Action"    style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 120;"/>
                    <Label text="Quantité"  style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 90;" alignment="CENTER_RIGHT"/>
                    <Label text="Prix Unit." style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 100;" alignment="CENTER_RIGHT"/>
                    <Label text="Montant"   style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 120;" alignment="CENTER_RIGHT"/>
                    <Label text="Commission" style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 100;" alignment="CENTER_RIGHT"/>
                    <Label text="Date"      style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 140;" alignment="CENTER_RIGHT"/>
                    <Label text="Alerte"    style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 80;" alignment="CENTER"/>
                </HBox>

                <!-- Lignes -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-background: transparent;"
                            hbarPolicy="NEVER">
                    <VBox fx:id="listeContainer" spacing="0"/>
                </ScrollPane>

            </VBox>

        </VBox>
    </center>

</BorderPane>
