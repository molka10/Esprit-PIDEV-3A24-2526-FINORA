<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #ecf0f1;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.crud.controllers.TradingController">

    <!-- HEADER -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #2c3e50, #34495e); -fx-padding: 25;" spacing="10">
            <Label text="💼 FINORA - Marché"
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font size="28.0"/></font>
            </Label>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label fx:id="lblRole" text="Profil : ?"
                       style="-fx-text-fill:#bdc3c7; -fx-font-size: 14px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="⬅ Retour" onAction="#retourProfil"
                        style="-fx-background-color:#16a085; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;"/>
            </HBox>
        </VBox>
    </top>

    <!-- LEFT : BUY/SELL PANEL -->
    <left>
        <VBox prefWidth="350" spacing="12"
              style="-fx-background-color: white; -fx-padding: 25; -fx-border-color: #dfe6e9; -fx-border-width: 0 1 0 0;">

            <Label text="🧾 Trading"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
            <Separator />

            <Label text="Bourse sélectionnée :" style="-fx-font-weight:bold; -fx-text-fill:#34495e;"/>
            <Label fx:id="lblBourseSelected" text="Aucune"
                   style="-fx-text-fill:#2c3e50; -fx-font-size:14px;"/>

            <Label text="Action sélectionnée :" style="-fx-font-weight:bold; -fx-text-fill:#34495e;"/>
            <Label fx:id="lblActionSelected" text="Aucune"
                   style="-fx-text-fill:#2c3e50; -fx-font-size:14px;"/>

            <Separator />

            <TextField fx:id="tfQuantiteTrade" promptText="Quantité" style="-fx-pref-height:35px;"/>

            <HBox spacing="10">
                <Button text="🟢 Acheter" onAction="#acheter"
                        prefWidth="145" prefHeight="40"
                        style="-fx-background-color:#27ae60; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;"/>
                <Button text="🔴 Vendre" onAction="#vendre"
                        prefWidth="145" prefHeight="40"
                        style="-fx-background-color:#e74c3c; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;"/>
            </HBox>

            <Separator />

            <Label text="💡 Cliquez une bourse puis une action"
                   style="-fx-text-fill:#7f8c8d; -fx-background-color:#f8f9fa; -fx-padding:10; -fx-background-radius:8;"
                   wrapText="true"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Label fx:id="lblMsg" text=""
                   style="-fx-text-fill:#2c3e50; -fx-font-weight:bold;"/>
        </VBox>
    </left>

    <!-- CENTER : LISTS -->
    <center>
        <VBox spacing="16" style="-fx-padding: 30;">

            <!-- Search -->
            <HBox alignment="CENTER_LEFT" spacing="15"
                  style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
                <Label text="🔍" style="-fx-font-size: 20px;" />
                <TextField fx:id="searchField" promptText="Rechercher action (symbole/entreprise)..." HBox.hgrow="ALWAYS"
                           style="-fx-pref-height:35px;"/>
                <Button text="Rechercher" onAction="#rechercher"
                        style="-fx-background-color:#34495e; -fx-text-fill:white; -fx-font-weight:bold; -fx-pref-height:35px;"/>
                <Button text="↻ Actualiser" onAction="#actualiser"
                        style="-fx-background-color:#16a085; -fx-text-fill:white; -fx-font-weight:bold; -fx-pref-height:35px;"/>
            </HBox>

            <HBox spacing="20">
                <!-- Bourses -->
                <VBox spacing="10" prefWidth="360">
                    <Label text="🏦 Bourses" style="-fx-font-weight:bold; -fx-font-size:16px; -fx-text-fill:#2c3e50;"/>
                    <ScrollPane fitToWidth="true" prefHeight="520"
                                style="-fx-background-color: transparent; -fx-border-color: transparent;">
                        <content>
                            <FlowPane fx:id="boursesContainer" hgap="12" vgap="12" prefWrapLength="340"
                                      style="-fx-padding: 10;" />
                        </content>
                    </ScrollPane>
                </VBox>

                <!-- Actions -->
                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblActionsTitle" text="📈 Actions (toutes)"
                           style="-fx-font-weight:bold; -fx-font-size:16px; -fx-text-fill:#2c3e50;"/>
                    <ScrollPane fitToWidth="true" prefHeight="520"
                                style="-fx-background-color: transparent; -fx-border-color: transparent;">
                        <content>
                            <FlowPane fx:id="actionsContainer" hgap="12" vgap="12" prefWrapLength="650"
                                      style="-fx-padding: 10;" />
                        </content>
                    </ScrollPane>
                </VBox>
            </HBox>

        </VBox>
    </center>

</BorderPane>
