<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<BorderPane prefHeight="750.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.crud.controllers.PredictionController"
            style="-fx-background-color: #0f1117;">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #1a1d27; -fx-padding: 20 24; -fx-border-color: transparent transparent #ffffff11 transparent; -fx-border-width: 0 0 1 0;">
            <Label text="🎯 Prédiction de Prix IA"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="⬅ Retour" onAction="#retourDashboard"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="20" style="-fx-padding: 24; -fx-background-color: #0f1117;">

                <!-- SÉLECTION ACTION -->
                <VBox spacing="12"
                      style="-fx-background-color: #1a1d27; -fx-background-radius: 14; -fx-padding: 20; -fx-border-color: #ffffff11; -fx-border-radius: 14; -fx-border-width: 1;">

                    <Label text="Sélectionner une Action"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <ComboBox fx:id="cbAction" promptText="Choisir une action..."
                                  HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: #0f1117; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 14px; -fx-pref-width: 400;"/>

                        <Button fx:id="btnAnalyser" text="🎯 Analyser" onAction="#analyserAction"
                                style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12 30; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <!-- RÉSULTATS -->
                <VBox fx:id="resultsContainer" spacing="16" visible="false" managed="false">

                    <!-- INFO ACTION + GRAPHIQUE -->
                    <HBox spacing="16">

                        <!-- Info Action -->
                        <VBox spacing="12"
                              style="-fx-background-color: #1a1d27; -fx-background-radius: 14; -fx-padding: 20; -fx-pref-width: 350; -fx-border-color: #ffffff11; -fx-border-radius: 14; -fx-border-width: 1;">

                            <Label text="📊 Information" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                            <VBox spacing="8">
                                <HBox spacing="8">
                                    <Label text="Action :" style="-fx-font-size: 12px; -fx-text-fill: #6b7280; -fx-pref-width: 100;"/>
                                    <Label fx:id="lblActionNom" text="-" style="-fx-font-size: 12px; -fx-text-fill: white; -fx-font-weight: bold;"/>
                                </HBox>
                                <HBox spacing="8">
                                    <Label text="Secteur :" style="-fx-font-size: 12px; -fx-text-fill: #6b7280; -fx-pref-width: 100;"/>
                                    <Label fx:id="lblSecteur" text="-" style="-fx-font-size: 12px; -fx-text-fill: white;"/>
                                </HBox>
                                <HBox spacing="8">
                                    <Label text="Prix actuel :" style="-fx-font-size: 12px; -fx-text-fill: #6b7280; -fx-pref-width: 100;"/>
                                    <Label fx:id="lblPrixActuel" text="-" style="-fx-font-size: 14px; -fx-text-fill: #00d4aa; -fx-font-weight: bold;"/>
                                </HBox>
                            </VBox>

                            <Separator/>

                            <Label text="🎯 Prédictions IA" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                            <VBox spacing="8">
                                <HBox spacing="8">
                                    <Label text="Tendance :" style="-fx-font-size: 12px; -fx-text-fill: #6b7280; -fx-pref-width: 100;"/>
                                    <Label fx:id="lblTendance" text="-" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                                </HBox>
                                <HBox spacing="8">
                                    <Label text="7 jours :" style="-fx-font-size: 12px; -fx-text-fill: #6b7280; -fx-pref-width: 100;"/>
                                    <Label fx:id="lblPred7j" text="-" style="-fx-font-size: 12px; -fx-text-fill: white; -fx-font-weight: bold;"/>
                                </HBox>
                                <HBox spacing="8">
                                    <Label text="30 jours :" style="-fx-font-size: 12px; -fx-text-fill: #6b7280; -fx-pref-width: 100;"/>
                                    <Label fx:id="lblPred30j" text="-" style="-fx-font-size: 12px; -fx-text-fill: white; -fx-font-weight: bold;"/>
                                </HBox>
                                <HBox spacing="8">
                                    <Label text="Confiance :" style="-fx-font-size: 12px; -fx-text-fill: #6b7280; -fx-pref-width: 100;"/>
                                    <ProgressBar fx:id="progressConfiance" prefWidth="150" prefHeight="20"/>
                                    <Label fx:id="lblConfiance" text="0%" style="-fx-font-size: 11px; -fx-text-fill: #6b7280;"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <!-- Graphique Historique + Prédictions -->
                        <VBox spacing="12" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #1a1d27; -fx-background-radius: 14; -fx-padding: 20; -fx-border-color: #ffffff11; -fx-border-radius: 14; -fx-border-width: 1;">

                            <Label text="📈 Historique 30j + Prédictions" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                            <LineChart fx:id="lineChart" prefHeight="280" animated="false"
                                       style="-fx-background-color: transparent;">
                                <xAxis><CategoryAxis label="" tickLabelFill="gray"/></xAxis>
                                <yAxis><NumberAxis label="" tickLabelFill="gray"/></yAxis>
                            </LineChart>
                        </VBox>

                    </HBox>

                    <!-- SCÉNARIOS -->
                    <HBox spacing="16">

                        <VBox spacing="8" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #10b98122; -fx-background-radius: 12; -fx-padding: 16; -fx-border-color: #10b98144; -fx-border-radius: 12; -fx-border-width: 1;">
                            <Label text="📈 Scénario Optimiste" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                            <Label fx:id="lblScenarioOpt" text="-" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                        </VBox>

                        <VBox spacing="8" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #f59e0b22; -fx-background-radius: 12; -fx-padding: 16; -fx-border-color: #f59e0b44; -fx-border-radius: 12; -fx-border-width: 1;">
                            <Label text="⚖️ Scénario Réaliste" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                            <Label fx:id="lblScenarioReal" text="-" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                        </VBox>

                        <VBox spacing="8" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #ef444422; -fx-background-radius: 12; -fx-padding: 16; -fx-border-color: #ef444444; -fx-border-radius: 12; -fx-border-width: 1;">
                            <Label text="📉 Scénario Pessimiste" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
                            <Label fx:id="lblScenarioPess" text="-" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
                        </VBox>

                    </HBox>

                    <!-- ANALYSE DÉTAILLÉE -->
                    <VBox spacing="12"
                          style="-fx-background-color: #1a1d27; -fx-background-radius: 14; -fx-padding: 20; -fx-border-color: #ffffff11; -fx-border-radius: 14; -fx-border-width: 1;">

                        <Label text="🧠 Analyse de Claude" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                        <TextArea fx:id="txtAnalyse" editable="false" wrapText="true" prefHeight="200"
                                  style="-fx-background-color: #0f1117; -fx-text-fill: #d1d5db; -fx-background-radius: 8; -fx-font-size: 13px; -fx-control-inner-background: #0f1117;"/>
                    </VBox>

                    <!-- AVERTISSEMENT -->
                    <HBox spacing="12" alignment="CENTER_LEFT"
                          style="-fx-background-color: #f59e0b22; -fx-background-radius: 10; -fx-padding: 16; -fx-border-color: #f59e0b44; -fx-border-radius: 10; -fx-border-width: 1;">
                        <Label text="⚠️" style="-fx-font-size: 20px;"/>
                        <Label text="Cette prédiction est générée par IA et ne constitue pas un conseil financier. Les marchés sont imprévisibles. Investissez prudemment."
                               wrapText="true"
                               style="-fx-font-size: 12px; -fx-text-fill: #f59e0b;"/>
                    </HBox>

                </VBox>

                <!-- LOADING INDICATOR -->
                <VBox fx:id="loadingContainer" spacing="16" alignment="CENTER" visible="false" managed="false"
                      style="-fx-background-color: #1a1d27; -fx-background-radius: 14; -fx-padding: 60; -fx-border-color: #ffffff11; -fx-border-radius: 14; -fx-border-width: 1;">
                    <ProgressIndicator prefWidth="60" prefHeight="60"/>
                    <Label text="Claude analyse l'action..." style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Cela peut prendre 5-10 secondes" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
