<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.Line?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.finora.controllers.LoginController"
            stylesheets="@theme.css" styleClass="root-bg">

    <children>
        <VBox alignment="CENTER" spacing="12"
              AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

            <VBox maxWidth="420" spacing="12" styleClass="card">
                <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

                <Label text="Connexion" styleClass="h2"/>

                <TextField fx:id="emailField" promptText="Email" styleClass="field"/>
                <PasswordField fx:id="passwordField" promptText="Mot de passe" styleClass="field"/>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <ImageView fx:id="captchaImage" fitWidth="220" fitHeight="60" preserveRatio="false"/>
                    <Button text="↻" onAction="#refreshCaptcha" styleClass="btn-ghost"/>
                </HBox>

                <TextField fx:id="captchaField" promptText="Entrez le code CAPTCHA"/>

                <Button text="Se connecter" onAction="#handleLogin" styleClass="btn-primary" maxWidth="Infinity"/>

                <!-- ── Separator ── -->
                <HBox alignment="CENTER" spacing="8">
                    <Line startX="0" endX="60" style="-fx-stroke: #CBD5E0;"/>
                    <Label text="ou" style="-fx-text-fill: #9CA3AF; -fx-font-size: 12;"/>
                    <Line startX="0" endX="60" style="-fx-stroke: #CBD5E0;"/>
                </HBox>

                <!-- ── Google Login Button ── -->
                <Button onAction="#handleGoogleLogin" maxWidth="Infinity"
                        style="-fx-background-color: white; -fx-border-color: #DADCE0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-border-width: 1.5; -fx-cursor: hand; -fx-padding: 10 16 10 16;">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER">
                            <!-- Google G SVG-like label using unicode -->
                            <Label text="G" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #4285F4;"/>
                            <Label text="Continuer avec Google" style="-fx-font-size: 14; -fx-text-fill: #3C4043; -fx-font-weight: bold;"/>
                        </HBox>
                    </graphic>
                </Button>

                <!-- ── Face ID Login Button ── -->
                <Button onAction="#handleFaceIdLogin" maxWidth="Infinity" styleClass="btn-secondary"
                        style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-cursor: hand;">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER">
                            <Label text="👤" style="-fx-font-size: 18; -fx-text-fill: white;"/>
                            <Label text="Connexion Face ID" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        </HBox>
                    </graphic>
                </Button>

                <Button text="Créer un compte" onAction="#goToSignup" styleClass="btn-ghost" maxWidth="Infinity"/>
                <Hyperlink text="Mot de passe oublié ?" onAction="#goForgotPassword" styleClass="link"/>

                <Label fx:id="statusLabel" text="" wrapText="true" styleClass="muted"/>
            </VBox>

        </VBox>
    </children>
</AnchorPane>
