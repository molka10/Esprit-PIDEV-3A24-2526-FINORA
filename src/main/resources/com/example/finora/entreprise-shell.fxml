<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.finora.controllers.EntrepriseShellController">

    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="10">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <children>
                <Label text="Finora • Enterprise Portal" styleClass="topbar-title"/>
                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="btnTheme" text="☀️ Light" onAction="#toggleTheme" styleClass="ghost-btn"/>
                <Button text="Déconnexion" onAction="#logout" styleClass="ghost-btn"/>
            </children>
        </HBox>
    </top>

    <left>
        <VBox spacing="10" styleClass="sidebar" prefWidth="220">
            <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>

            <children>
                <Label text="Business Menu" styleClass="h2"/>

                <Button text="Portefeuille (Pro)" onAction="#goPortefeuille" styleClass="nav-btn" maxWidth="Infinity"/>
                <Button text="Bourse (Commission)" onAction="#goBourse" styleClass="nav-btn" maxWidth="Infinity"/>
                <Button text="Bourse (Dashboard)" onAction="#goBourseDashboard" styleClass="nav-btn" maxWidth="Infinity"/>
                <Button text="Offres" onAction="#goEntrepriseHome" styleClass="nav-btn" maxWidth="Infinity"/>
                <Button text="Statistiques" onAction="#goStats" styleClass="nav-btn" maxWidth="Infinity"/>

                <Separator/>
                <Button text="Mon Profil" onAction="#goProfile" styleClass="nav-btn" maxWidth="Infinity"/>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- USER INFO SIDEBAR -->
                <VBox alignment="CENTER" spacing="5" style="-fx-padding: 10 0 0 0;">
                    <StackPane styleClass="avatar" prefWidth="40" prefHeight="40">
                        <Label fx:id="sidebarAvatarText" text="E" styleClass="avatar-text"/>
                    </StackPane>
                    <Label fx:id="sidebarNameLabel" text="Enterprise" styleClass="profile-name" style="-fx-font-size: 12px;"/>
                    <Label fx:id="sidebarIdLabel" text="ID: 0" style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-background-color: #f3f4f6; -fx-background-radius: 4; -fx-padding: 2 6;"/>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
        </StackPane>
    </center>

</BorderPane>
