<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    Dashboard User — content only (loaded inside user-shell.fxml's center StackPane)
    The shell already provides the top bar and left nav.
-->
<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.finora.controllers.DashboardUserController"
            stylesheets="@theme.css" styleClass="scroll-pane-clean" fitToHeight="false">

    <VBox spacing="20" styleClass="content-area">
        <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>

        <!-- ── Titre + Date ── -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="Tableau de Bord" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblDateTime" text="" styleClass="datetime-label"/>
        </HBox>

        <!-- ── Welcome Card ── -->
        <VBox styleClass="card-elevated" spacing="10">
            <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>
            <Label text="👋 Bienvenue sur FINORA" styleClass="h2"/>
            <Label text="Plateforme de gestion financière et boursière" styleClass="text-secondary"/>
            <Separator><VBox.margin><Insets top="10" bottom="10"/></VBox.margin></Separator>
            <Label fx:id="lblWelcomeMessage" text="Accédez à vos outils financiers ci-dessous" styleClass="text-muted"/>
        </VBox>

        <!-- ── Section title : Statistiques ── -->
        <Label text="📈 Statistiques Rapides" styleClass="section-title">
            <VBox.margin><Insets top="10"/></VBox.margin>
        </Label>

        <GridPane hgap="15" vgap="15">
            <!-- Stat 1 -->
            <VBox styleClass="stat-card-primary" GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="8">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <Label text="💰 Transactions" styleClass="stat-label"/>
                <Label fx:id="lblTotalTransactions" text="0" styleClass="stat-value"/>
                <Label text="Total effectuées" styleClass="stat-sublabel"/>
            </VBox>
            <!-- Stat 2 -->
            <VBox styleClass="stat-card-success" GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="8">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <Label text="📊 Portefeuille" styleClass="stat-label"/>
                <Label fx:id="lblPortfolioValue" text="0.00 TND" styleClass="stat-value"/>
                <Label text="Valeur totale" styleClass="stat-sublabel"/>
            </VBox>
            <!-- Stat 3 -->
            <VBox styleClass="stat-card-warning" GridPane.columnIndex="2" GridPane.rowIndex="0" spacing="8">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <Label text="🎯 Actions" styleClass="stat-label"/>
                <Label fx:id="lblTotalActions" text="0" styleClass="stat-value"/>
                <Label text="En portefeuille" styleClass="stat-sublabel"/>
            </VBox>
            <!-- Stat 4 -->
            <VBox styleClass="stat-card-info" GridPane.columnIndex="3" GridPane.rowIndex="0" spacing="8">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <Label text="💳 Commissions" styleClass="stat-label"/>
                <Label fx:id="lblTotalCommissions" text="0.00 TND" styleClass="stat-value"/>
                <Label text="Frais totaux" styleClass="stat-sublabel"/>
            </VBox>
            <columnConstraints>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
            </columnConstraints>
        </GridPane>

        <!-- ── Section title : Modules ── -->
        <Label text="🚀 Accès Rapide aux Modules" styleClass="section-title">
            <VBox.margin><Insets top="20"/></VBox.margin>
        </Label>

        <GridPane hgap="15" vgap="15">
            <!-- Module 1 - Bourse -->
            <VBox styleClass="module-card" GridPane.columnIndex="0" GridPane.rowIndex="0"
                  spacing="15" alignment="CENTER" onMouseClicked="#goBourse" style="-fx-cursor: hand;">
                <padding><Insets top="30" right="20" bottom="30" left="20"/></padding>
                <StackPane styleClass="module-icon-primary">
                    <Label text="📊" style="-fx-font-size: 36px;"/>
                </StackPane>
                <Label text="Gestion Bourse" styleClass="module-title"/>
                <Label text="Gérer les bourses, actions et transactions boursières"
                       styleClass="module-description" wrapText="true" alignment="CENTER"/>
                <Button text="Ouvrir le module →" onAction="#goBourse"
                        styleClass="btn-primary" prefWidth="180">
                    <VBox.margin><Insets top="10"/></VBox.margin>
                </Button>
            </VBox>

            <!-- Module 2 - Portefeuille -->
            <VBox styleClass="module-card" GridPane.columnIndex="1" GridPane.rowIndex="0"
                  spacing="15" alignment="CENTER" onMouseClicked="#openPortefeuille" style="-fx-cursor: hand;">
                <padding><Insets top="30" right="20" bottom="30" left="20"/></padding>
                <StackPane styleClass="module-icon-success">
                    <Label text="💼" style="-fx-font-size: 36px;"/>
                </StackPane>
                <Label text="Mon Portefeuille" styleClass="module-title"/>
                <Label text="Consulter mes actions, suivre mes investissements"
                       styleClass="module-description" wrapText="true" alignment="CENTER"/>
                <Button text="Voir mon portefeuille →" onAction="#openPortefeuille"
                        styleClass="btn-success" prefWidth="180">
                    <VBox.margin><Insets top="10"/></VBox.margin>
                </Button>
            </VBox>

            <!-- Module 3 - Appels d'Offre -->
            <VBox styleClass="module-card" GridPane.columnIndex="2" GridPane.rowIndex="0"
                  spacing="15" alignment="CENTER" onMouseClicked="#openAppelOffre" style="-fx-cursor: hand;">
                <padding><Insets top="30" right="20" bottom="30" left="20"/></padding>
                <StackPane styleClass="module-icon-warning">
                    <Label text="📋" style="-fx-font-size: 36px;"/>
                </StackPane>
                <Label text="Appels d'Offre" styleClass="module-title"/>
                <Label text="Consulter et répondre aux appels d'offre publiés"
                       styleClass="module-description" wrapText="true" alignment="CENTER"/>
                <Button text="Parcourir →" onAction="#openAppelOffre"
                        styleClass="btn-warning" prefWidth="180">
                    <VBox.margin><Insets top="10"/></VBox.margin>
                </Button>
            </VBox>

            <!-- Module 4 - Formation -->
            <VBox styleClass="module-card" GridPane.columnIndex="0" GridPane.rowIndex="1"
                  spacing="15" alignment="CENTER" onMouseClicked="#openFormation" style="-fx-cursor: hand;">
                <padding><Insets top="30" right="20" bottom="30" left="20"/></padding>
                <StackPane styleClass="module-icon-info">
                    <Label text="🎓" style="-fx-font-size: 36px;"/>
                </StackPane>
                <Label text="Formation" styleClass="module-title"/>
                <Label text="Formations et cours en ligne"
                       styleClass="module-description" wrapText="true" alignment="CENTER"/>
                <Button text="Accéder →" onAction="#openFormation"
                        styleClass="btn-info" prefWidth="180">
                    <VBox.margin><Insets top="10"/></VBox.margin>
                </Button>
            </VBox>

            <!-- Module 5 - Wallet -->
            <VBox styleClass="module-card" GridPane.columnIndex="1" GridPane.rowIndex="1"
                  spacing="15" alignment="CENTER" onMouseClicked="#openWallet" style="-fx-cursor: hand;">
                <padding><Insets top="30" right="20" bottom="30" left="20"/></padding>
                <StackPane styleClass="module-icon-success">
                    <Label text="💰" style="-fx-font-size: 36px;"/>
                </StackPane>
                <Label text="Wallet" styleClass="module-title"/>
                <Label text="Gestion de vos finances personnelles"
                       styleClass="module-description" wrapText="true" alignment="CENTER"/>
                <Button text="Ouvrir →" onAction="#openWallet"
                        styleClass="btn-success" prefWidth="180">
                    <VBox.margin><Insets top="10"/></VBox.margin>
                </Button>
            </VBox>

            <!-- Module 6 - Investissement -->
            <VBox styleClass="module-card" GridPane.columnIndex="2" GridPane.rowIndex="1"
                  spacing="15" alignment="CENTER" onMouseClicked="#openInvestment" style="-fx-cursor: hand;">
                <padding><Insets top="30" right="20" bottom="30" left="20"/></padding>
                <StackPane styleClass="module-icon-warning">
                    <Label text="🏘️" style="-fx-font-size: 36px;"/>
                </StackPane>
                <Label text="Investissement" styleClass="module-title"/>
                <Label text="Gérer vos investissements immobiliers"
                       styleClass="module-description" wrapText="true" alignment="CENTER"/>
                <Button text="Consulter →" onAction="#openInvestment"
                        styleClass="btn-warning" prefWidth="180">
                    <VBox.margin><Insets top="10"/></VBox.margin>
                </Button>
            </VBox>

            <columnConstraints>
                <ColumnConstraints percentWidth="33.33"/>
                <ColumnConstraints percentWidth="33.33"/>
                <ColumnConstraints percentWidth="33.33"/>
            </columnConstraints>
        </GridPane>

        <!-- ── Activité Récente ── -->
        <Label text="🕐 Activité Récente" styleClass="section-title">
            <VBox.margin><Insets top="20"/></VBox.margin>
        </Label>

        <VBox styleClass="card-elevated" spacing="10">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="📅 Dernières Actions" styleClass="h3"/>
            </HBox>
            <Separator/>
            <VBox fx:id="vboxRecentActivity" spacing="10">
                <HBox spacing="15" alignment="CENTER_LEFT" styleClass="activity-item">
                    <Label text="✓" styleClass="activity-icon-success"/>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Connexion réussie" styleClass="activity-title"/>
                        <Label fx:id="lblLoginTime" text="Aujourd'hui" styleClass="activity-time"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>

        <!-- ── Footer ── -->
        <HBox alignment="CENTER" spacing="20" styleClass="footer-info">
            <VBox.margin><Insets top="20" bottom="10"/></VBox.margin>
            <Label text="🛡️ Plateforme sécurisée" styleClass="footer-text"/>
            <Label text="•" styleClass="footer-separator"/>
            <Label text="📞 Support 24/7" styleClass="footer-text"/>
            <Label text="•" styleClass="footer-separator"/>
            <Label text="© 2026 FINORA" styleClass="footer-text"/>
        </HBox>

    </VBox>
</ScrollPane>
