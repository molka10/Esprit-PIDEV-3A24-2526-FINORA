<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.finora_user.controllers.SignupController"
            stylesheets="@theme.css" styleClass="root-bg">

    <children>
        <VBox alignment="CENTER" spacing="12"
              AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

            <VBox maxWidth="420" spacing="12" styleClass="card">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label text="Créer un compte" styleClass="h2"/>

                <TextField fx:id="usernameField" promptText="Username" styleClass="field"/>
                <TextField fx:id="emailField" promptText="Email" styleClass="field"/>
                <PasswordField fx:id="passwordField" promptText="Mot de passe" styleClass="field"/>

                <ComboBox fx:id="roleCombo" promptText="Role" styleClass="field"/>

                <Button text="S'inscrire" onAction="#handleSignup" styleClass="btn-primary" maxWidth="Infinity"/>
                <Button text="Retour login" onAction="#goToLogin" styleClass="btn-ghost" maxWidth="Infinity"/>

                <Label fx:id="statusLabel" text="" wrapText="true" styleClass="muted"/>
            </VBox>

        </VBox>
    </children>
</AnchorPane>
