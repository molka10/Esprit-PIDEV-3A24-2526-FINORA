<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.finora_user.controllers.ProfileController"
      spacing="14"
      styleClass="root-bg">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <VBox styleClass="card" spacing="12">
        <padding>
            <Insets top="18" right="18" bottom="18" left="18"/>
        </padding>

        <children>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="avatar avatar-lg">
                    <Label fx:id="avatarText" text="AA" styleClass="avatar-text avatar-text-lg"/>
                </StackPane>

                <VBox spacing="3">
                    <Label fx:id="fullNameLabel" text="Profil" styleClass="h2"/>
                    <Label fx:id="emailLabel" text="email@finora.com" styleClass="muted"/>
                </VBox>
            </HBox>

            <Separator/>

            <GridPane hgap="12" vgap="12">
                <columnConstraints>
                    <ColumnConstraints percentWidth="30"/>
                    <ColumnConstraints percentWidth="70"/>
                </columnConstraints>

                <Label text="Username" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="usernameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Téléphone" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="phoneField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Adresse" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="addressField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Date de naissance" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <DatePicker fx:id="dobPicker" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            </GridPane>

            <HBox spacing="10">
                <Button text="Enregistrer" onAction="#handleSave" styleClass="btn-primary"/>
                <Label fx:id="statusLabel" text="" styleClass="muted"/>
            </HBox>
        </children>
    </VBox>

</VBox>
