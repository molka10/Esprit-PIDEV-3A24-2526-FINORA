<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gestionwallet.controllers.EntrepriseController"
            prefWidth="1366"
            prefHeight="768"
            stylesheets="@dashboard.css">




    <!-- CENTER WITH SCROLL -->
    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="transparent-scroll">


            <content>

                <VBox spacing="30"
                      style="-fx-padding:30; -fx-background-color:#f4f4f8;">
                    <Label text="ENTREPRISE"
                           style="-fx-font-size:26;
                  -fx-font-weight:bold;
                  -fx-text-fill:#6a0dad;"/>
                    <Button
                            text="Retour"
                            fx:id="backButton"
                            onAction="#goBack"
                            prefWidth="120.0"
                            prefHeight="35.0"
                            style="-fx-background-color:#6a0dad; -fx-text-fill:white; -fx-background-radius:10;" />

                    <ComboBox fx:id="currencyBox"
                              prefWidth="100"
                              onAction="#changeCurrency"/>
                    <!-- STAT CARDS -->
                    <HBox spacing="30" alignment="CENTER">
                        <VBox spacing="5"
                              style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:15; -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.1), 15,0,0,3);">

                            <Label text="Balance" styleClass="stat-title"/>
                            <Label fx:id="balanceLabel"
                                   text="0 DT"
                                   styleClass="stat-value"/>
                        </VBox>

                        <VBox spacing="5"
                              style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:15; -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.1), 15,0,0,3);">

                            <Label text="Total Income" styleClass="stat-title"/>
                            <Label fx:id="totalIncomeLabel"
                                   text="0 DT"
                                   styleClass="income-value"/>
                        </VBox>

                        <VBox spacing="5"
                              style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:15; -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.1), 15,0,0,3);">

                            <Label text="Total Outcome" styleClass="stat-title"/>
                            <Label fx:id="totalOutcomeLabel"
                                   text="0 DT"
                                   styleClass="outcome-value"/>
                        </VBox>
                        <VBox spacing="5" alignment="CENTER"
                              style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:15; -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.1), 10,0,0,3);">

                            <Label text="Total Transactions" style="-fx-text-fill:gray;"/>

                            <Label fx:id="totalTransactionsLabel"
                                   text="0"
                                   style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#6a0dad;"/>
                        </VBox>

                        <Button text="Historique"
                                style="-fx-background-color:#8e44ad; -fx-text-fill:white; -fx-background-radius:10;"
                                onAction="#openHistorique"/>

                        <Button text="Exporter PDF"
                                onAction="#exportPDF"
                                style="-fx-background-color:#2ecc71; -fx-text-fill:white; -fx-background-radius:10;"/>

                        <Button text="Export Excel"
                                onAction="#exportExcel"
                                style="-fx-background-color:#35da7b; -fx-text-fill:white; -fx-background-radius:10;"/>
                    </HBox>
                    <Label fx:id="averageLabel"
                           style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#6a0dad;"/>


                    <!-- CHARTS -->
                    <HBox spacing="40" alignment="CENTER">

                        <!-- OUTCOME -->
                        <VBox spacing="10" alignment="CENTER">
                            <Label text="Outcome" styleClass="section-title-outcome"/>
                            <Button text="Ajouter Outcome"
                                    onAction="#openAddOutcome"
                                    styleClass="btn-danger"/>

                            <LineChart fx:id="outcomeChart" prefWidth="450" prefHeight="300">
                                <xAxis>
                                    <CategoryAxis label="Categorie"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis label="Montant"/>
                                </yAxis>
                            </LineChart>
                        </VBox>

                        <!-- INCOME -->
                        <VBox spacing="10" alignment="CENTER">
                            <Label text="Income" styleClass="section-title-income"/>
                            <Button text="Ajouter Income"
                                    onAction="#openAddIncome"
                                    styleClass="btn-success"/>

                            <LineChart fx:id="incomeChart" prefWidth="450" prefHeight="300">
                                <xAxis>
                                    <CategoryAxis label="Categorie"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis label="Montant"/>
                                </yAxis>
                            </LineChart>
                        </VBox>

                    </HBox>

                    <HBox spacing="40" alignment="TOP_CENTER">

                        <!-- PIE + MOYENNE -->
                        <VBox spacing="20" alignment="CENTER">

                            <PieChart fx:id="pieChart"
                                      prefWidth="350"
                                      prefHeight="300"/>


                        </VBox>

                        <!-- MONTHLY CARDS -->
                        <FlowPane fx:id="monthlyContainer"
                                  hgap="20"
                                  vgap="20"
                                  prefWrapLength="400"
                                  prefWidth="450"
                                  style="-fx-padding:20;"/>

                    </HBox>
                    <VBox spacing="15"
                          alignment="TOP_LEFT"
                          prefWidth="500"
                          prefHeight="300"
                          style="
          -fx-background-color:white;
          -fx-padding:20;
          -fx-background-radius:20;
          -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,3);
      ">

                        <Label text="Wishlist "
                               style="
               -fx-font-size:18;
               -fx-font-weight:bold;
               -fx-text-fill:#6a0dad;
           "/>

                        <HBox spacing="10">
                            <TextField fx:id="itemField"
                                       promptText="Nom produit..."
                                       prefWidth="180"
                                       style="-fx-background-radius:15;"/>

                            <TextField fx:id="priceField"
                                       promptText="Montant DT"
                                       prefWidth="120"
                                       style="-fx-background-radius:15;"/>

                            <Button text="Ajouter"
                                    onAction="#addWishlistItem"
                                    style="
                    -fx-background-color:#6a0dad;
                    -fx-text-fill:white;
                    -fx-background-radius:20;
                    -fx-padding:5 15;
                "/>
                        </HBox>

                        <ListView fx:id="wishlistView"
                                  prefHeight="180"
                                  style="-fx-background-radius:15;"/>

                    </VBox>

                </VBox>


            </content>
        </ScrollPane>
    </center>

</BorderPane>