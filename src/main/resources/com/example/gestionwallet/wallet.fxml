<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gestionwallet.controllers.WalletController"
            prefWidth="1200"
            prefHeight="700"
            stylesheets="@dashboard.css">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox prefWidth="220"
              spacing="30"
              style="-fx-background-color: linear-gradient(to bottom, #8e44ad, #6a0dad); -fx-padding:30;">

            <Label text="💳 Wallet"
                   style="-fx-text-fill:white; -fx-font-size:22; -fx-font-weight:bold;"/>

            <Button text="🏠 Dashboard"
                    style="-fx-background-color:white; -fx-text-fill:#6a0dad; -fx-background-radius:10;"/>

            <Button text="Admin"
                    style="-fx-background-color:#e8e3f8; -fx-text-fill:#6a0dad; -fx-background-radius:10;"
                    onAction="#openAdminPage"/>

        </VBox>
    </left>

    <!-- CENTER WITH SCROLL -->
    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="transparent-scroll">

            <content>
                <VBox spacing="30"
                      style="-fx-padding:30; -fx-background-color:#f4f4f8;">

                    <!-- STAT CARDS -->
                    <HBox spacing="30" alignment="CENTER">
                        <VBox spacing="5"
                              style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:15; -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.1), 15,0,0,3);">

                            <Label text="Balance" styleClass="stat-title"/>
                            <Label fx:id="balanceLabel"
                                   text="0 DT"
                                   styleClass="stat-value"/>
                        </VBox>

                        <VBox spacing="5"
                              style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:15; -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.1), 15,0,0,3);">

                            <Label text="Total Income" styleClass="stat-title"/>
                            <Label fx:id="totalIncomeLabel"
                                   text="0 DT"
                                   styleClass="income-value"/>
                        </VBox>

                        <VBox spacing="5"
                              style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:15; -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.1), 15,0,0,3);">

                            <Label text="Total Outcome" styleClass="stat-title"/>
                            <Label fx:id="totalOutcomeLabel"
                                   text="0 DT"
                                   styleClass="outcome-value"/>
                        </VBox>

                        <Button text="Historique"
                                style="-fx-background-color:#8e44ad; -fx-text-fill:white; -fx-background-radius:10;"
                                onAction="#openHistorique"/>

                        <Button text="Exporter PDF"
                                onAction="#exportPDF"
                                style="-fx-background-color:#2ecc71; -fx-text-fill:white; -fx-background-radius:10;"/>
                    </HBox>

                    <!-- CHARTS -->
                    <HBox spacing="40" alignment="CENTER">

                        <!-- OUTCOME -->
                        <VBox spacing="10" alignment="CENTER">
                            <Label text="Outcome" styleClass="section-title-outcome"/>
                            <Button text="Ajouter Outcome"
                                    onAction="#openAddOutcome"
                                    styleClass="btn-danger"/>

                            <LineChart fx:id="outcomeChart" prefWidth="450" prefHeight="300">
                                <xAxis>
                                    <CategoryAxis label="Categorie"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis label="Montant"/>
                                </yAxis>
                            </LineChart>
                        </VBox>

                        <!-- INCOME -->
                        <VBox spacing="10" alignment="CENTER">
                            <Label text="Income" styleClass="section-title-income"/>
                            <Button text="Ajouter Income"
                                    onAction="#openAddIncome"
                                    styleClass="btn-success"/>

                            <LineChart fx:id="incomeChart" prefWidth="450" prefHeight="300">
                                <xAxis>
                                    <CategoryAxis label="Categorie"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis label="Montant"/>
                                </yAxis>
                            </LineChart>
                        </VBox>

                    </HBox>

                    <!-- PIE + STATS -->
                    <VBox spacing="20" alignment="CENTER">

                        <PieChart fx:id="pieChart"
                                  prefWidth="350"
                                  prefHeight="300"/>

                        <Label fx:id="averageLabel"
                               style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#6a0dad;"/>

                    </VBox>

                    <!-- MONTHLY CARDS -->
                    <FlowPane fx:id="monthlyContainer"
                              hgap="20"
                              vgap="20"
                              prefWrapLength="1000"
                              style="-fx-padding:20;"/>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>