<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.project_pi.controllers.CandidatureController"

            styleClass="root">

    <top>
        <HBox spacing="12" styleClass="topbar">
            <padding>
                <Insets top="14" right="18" bottom="14" left="18"/>
            </padding>

            <VBox spacing="2">
                <Label text="Gestion des Candidatures" styleClass="title"/>
                <Label text="Afficher, ajouter, modifier, supprimer des candidatures" styleClass="subtitle"/>
            </VBox>

            <Pane HBox.hgrow="ALWAYS"/>

            <TextField fx:id="searchField" promptText="Rechercher par nom / email..." styleClass="search"/>
            <Button text="Nouveau" styleClass="primary-btn" onAction="#onNew"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="12" styleClass="content">
            <padding>
                <Insets top="16" right="18" bottom="18" left="18"/>
            </padding>

            <VBox spacing="10" styleClass="card">
                <HBox spacing="10">
                    <Label text="Liste des candidatures" styleClass="section-title"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="Actualiser" styleClass="ghost-btn" onAction="#onRefresh"/>
                    <Button text="Modifier" styleClass="ghost-btn" onAction="#onEdit"/>
                    <Button text="Supprimer" styleClass="danger-btn" onAction="#onDelete"/>
                </HBox>

                <HBox spacing="10">
                    <Label text="Filtrer par AppelOffre ID:" styleClass="muted"/>
                    <TextField fx:id="appelOffreIdFilterField" promptText="ex: 1" prefWidth="140"/>
                    <Button text="Appliquer" styleClass="ghost-btn" onAction="#onApplyFilter"/>
                    <Button text="Reset" styleClass="ghost-btn" onAction="#onResetFilter"/>
                </HBox>

                <TableView fx:id="table" styleClass="table">
                    <columns>
                        <TableColumn fx:id="colAppelOffreId" text="AppelOffre ID" prefWidth="110"/>
                        <TableColumn fx:id="colNom" text="Nom" prefWidth="180"/>
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="220"/>
                        <TableColumn fx:id="colMontant" text="Montant" prefWidth="120"/>
                        <TableColumn fx:id="colStatut" text="Statut" prefWidth="120"/>
                        <TableColumn fx:id="colCreatedAt" text="Créé le" prefWidth="130"/>
                    </columns>
                </TableView>

                <Label text="Astuce: l’appel_offre_id doit exister ."
                       styleClass="muted"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>
