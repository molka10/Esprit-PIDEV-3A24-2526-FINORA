<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.finora.controllers.LessonViewController"
            styleClass="screen">

    <top>
        <VBox styleClass="card" spacing="14">

            <!-- Row 1: eyebrow + back button -->
            <HBox alignment="CENTER_LEFT" spacing="0">
                <Label fx:id="lblEyebrow"
                       text="FORMATION"
                       styleClass="viewer-eyebrow"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="← Retour"
                        styleClass="btn-ghost"
                        onAction="#onBack"/>
            </HBox>

            <!-- Row 2: big lesson title -->
            <Label fx:id="lblTitre"
                   text="Titre de la leçon"
                   styleClass="viewer-title"
                   wrapText="true"
                   maxWidth="820"/>

            <!-- Row 3: order + duration -->
            <Label fx:id="lblMeta"
                   text="Ordre  •  Durée"
                   styleClass="viewer-meta"/>

            <!-- Row 4: progress + navigation -->
            <HBox alignment="CENTER_LEFT" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Progression"
                           styleClass="viewer-progress-label"/>
                    <ProgressBar fx:id="progressBar"
                                 prefWidth="260"
                                 prefHeight="6"
                                 styleClass="viewer-progress-bar"/>
                    <Label fx:id="lblProgress"
                           text="0%"
                           styleClass="viewer-progress-label"/>
                </HBox>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Label fx:id="lblIndex"
                           text="01 / 01"
                           styleClass="viewer-index-pill"/>
                    <Button fx:id="btnPrev"
                            text="◀ Précédent"
                            styleClass="btn-nav-prev"
                            onAction="#onPrev"/>
                    <Button fx:id="btnNext"
                            text="Suivant ▶"
                            styleClass="btn-nav-next"
                            onAction="#onNext"/>
                </HBox>

            </HBox>

        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll">
            <content>
                <VBox spacing="16">
                    <padding>
                        <Insets top="28" right="36" bottom="36" left="36"/>
                    </padding>

                    <Label text="CONTENU DE LA LEÇON"
                           styleClass="viewer-section-label"/>

                    <TextArea fx:id="txtContenu"
                              editable="false"
                              wrapText="true"
                              prefRowCount="22"
                              styleClass="viewer-content"/>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>