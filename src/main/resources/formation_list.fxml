<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.finora.controllers.FormationListController">

    <top>
        <VBox spacing="8" styleClass="card">
            <Label text="Gestion Formations" styleClass="title"/>
            <Label fx:id="lblInfo" text="" styleClass="subtitle"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="14" styleClass="screen">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
                <TextField fx:id="txtSearch"
                           promptText="Rechercher (titre / catégorie / niveau)..."
                           onKeyReleased="#onSearch"
                           prefWidth="320"/>

                <ComboBox fx:id="cbSort"
                          prefWidth="220"
                          onAction="#onSort"/>

                <Button fx:id="btnAdd" text="➕ Ajouter" styleClass="btn-primary" onAction="#onAdd"/>
                <Button fx:id="btnEdit" text="✏ Modifier" styleClass="btn-ghost" onAction="#onEdit"/>
                <Button fx:id="btnDelete" text="🗑 Supprimer" styleClass="btn-danger" onAction="#onDelete"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="btnLessons" text="📚 Lessons" styleClass="btn-ghost" onAction="#goLessons"/>
                <Button fx:id="btnRole" text="🔁 Changer espace" styleClass="btn-ghost" onAction="#goRoleChoice"/>
            </HBox>

            <ScrollPane fitToWidth="true" styleClass="scroll">
                <content>
                    <VBox fx:id="cardsContainer" spacing="12" styleClass="cards"/>
                </content>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>