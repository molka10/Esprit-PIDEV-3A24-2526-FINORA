<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.finora.controllers.InvestmentManagementFormController"
            stylesheets="@../styles/style.css">

    <center>
        <VBox spacing="10" styleClass="form-box">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>

            <Label fx:id="titleLabel" text="Add Investment Management" styleClass="title"/>

            <GridPane hgap="12" vgap="5">
                <columnConstraints>
                    <ColumnConstraints percentWidth="32"/>
                    <ColumnConstraints percentWidth="68"/>
                </columnConstraints>

                <!-- Investment -->
                <Label text="Investment (FK):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ComboBox fx:id="investmentCombo" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Label fx:id="investmentErrorLabel" textFill="red" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <!-- Type -->
                <Label text="Investment Type:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="typeField" promptText="ex: LONG_TERM" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                <Label fx:id="typeErrorLabel" textFill="red" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <!-- Amount -->
                <Label text="Amount Invested:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="amountField" promptText="ex: 5000.00" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                <Label fx:id="amountErrorLabel" textFill="red" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                <!-- Ownership % -->
                <Label text="Ownership %:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <TextField fx:id="percentField" promptText="0 - 100" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                <Label fx:id="percentErrorLabel" textFill="red" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

                <!-- Start Date -->
                <Label text="Start Date:" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                <DatePicker fx:id="startDatePicker" GridPane.rowIndex="8" GridPane.columnIndex="1"/>
                <Label fx:id="startDateErrorLabel" textFill="red" GridPane.rowIndex="9" GridPane.columnIndex="1"/>

                <!-- Status -->
                <Label text="Status:" GridPane.rowIndex="10" GridPane.columnIndex="0"/>
                <ComboBox fx:id="statusCombo" GridPane.rowIndex="10" GridPane.columnIndex="1"/>
                <Label fx:id="statusErrorLabel" textFill="#800807" GridPane.rowIndex="11" GridPane.columnIndex="1"/>
            </GridPane>

            <HBox spacing="10">
                <Button text="Save" onAction="#onSave" styleClass="btn-primary"/>
                <Button text="Cancel" onAction="#onCancel" styleClass="btn-secondary"/>
            </HBox>

        </VBox>
    </center>
</BorderPane>