<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.finora.controllers.InvestmentFormController"
            stylesheets="@../styles/style.css"
            styleClass="screen">

    <center>
        <VBox spacing="18" alignment="TOP_CENTER">

            <!-- CARD CONTAINER -->
            <VBox spacing="16" styleClass="form-box">
                <padding>
                    <Insets top="28" right="28" bottom="28" left="28"/>
                </padding>

                <!-- Title -->
                <Label fx:id="titleLabel"
                       text="Add New Investment"
                       styleClass="title"/>

                <Label text="Fill the information below to create a new investment"
                       styleClass="subtitle"/>

                <!-- FORM GRID -->
                <GridPane hgap="14" vgap="14">

                    <columnConstraints>
                        <ColumnConstraints percentWidth="30"/>
                        <ColumnConstraints percentWidth="70"/>
                    </columnConstraints>

                    <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="nameField"
                               promptText="ex: Land Project"
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Category:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="categoryField"
                               promptText="ex: Real Estate"
                               GridPane.rowIndex="1"
                               GridPane.columnIndex="1"/>

                    <Label text="Location:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="locationField"
                               promptText="ex: Tunis"
                               GridPane.rowIndex="2"
                               GridPane.columnIndex="1"/>

                    <Label text="Estimated Value:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextField fx:id="valueField"
                               promptText="ex: 15000.50"
                               GridPane.rowIndex="3"
                               GridPane.columnIndex="1"/>

                    <Label text="Risk Level:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="riskCombo"
                              GridPane.rowIndex="4"
                              GridPane.columnIndex="1"/>

                    <Label text="Image URL:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <TextField fx:id="imageField"
                               promptText="https://..."
                               GridPane.rowIndex="5"
                               GridPane.columnIndex="1"/>

                    <Label text="Description:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                    <TextArea fx:id="descArea"
                              promptText="Short description..."
                              prefRowCount="3"
                              GridPane.rowIndex="6"
                              GridPane.columnIndex="1"/>
                </GridPane>

                <!-- ERROR -->
                <Label fx:id="errorLabel"
                       text=""
                       styleClass="error-text"/>

                <!-- BUTTONS -->
                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text=" Save Investment"
                            onAction="#onSave"
                            styleClass="btn-primary"/>

                    <Button text="Cancel"
                            onAction="#onCancel"
                            styleClass="btn-secondary"/>
                </HBox>

            </VBox>

        </VBox>
    </center>
</BorderPane>