<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.finora.controllers.InvestmentCardsController"
            stylesheets="@../styles/style.css">

    <!-- ================= HEADER ================= -->
    <top>
        <VBox spacing="16" style="-fx-padding: 30 30 20 30;">

            <HBox alignment="CENTER_LEFT" spacing="20">

                <VBox spacing="4">
                    <Label text="Investment Portfolio" styleClass="title"/>
                    <Label text="Manage and monitor your investments efficiently"
                           styleClass="subtitle"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <ToggleButton text="🌙 Dark Mode"
                              onAction="#toggleDarkMode"
                              styleClass="btn-ghost"/>
            </HBox>

            <!-- ===== DASHBOARD KPI ===== -->

            <HBox spacing="20">

                <VBox styleClass="kpi-card">
                    <Label text="Total Portfolio Value"
                           styleClass="kpi-title"/>
                    <Label fx:id="totalValueLabel"
                           styleClass="kpi-value"/>
                </VBox>

                <VBox styleClass="kpi-card">
                    <Label text="Total Investments"
                           styleClass="kpi-title"/>
                    <Label fx:id="totalCountLabel"
                           styleClass="kpi-value"/>
                </VBox>

            </HBox>

        </VBox>
    </top>

    <!-- ================= MAIN CONTENT ================= -->
    <center>
        <VBox spacing="20" style="-fx-padding: 0 30 30 30;">

            <!-- ===== TOOLBAR ===== -->
            <HBox spacing="12" alignment="CENTER_LEFT">

                <Button text="Add Investment"
                        onAction="#onAdd"
                        styleClass="btn-primary"/>

                <Button text="Refresh"
                        onAction="#onRefresh"
                        styleClass="btn-ghost"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Management"
                        onAction="#goToManagement"
                        styleClass="btn-ghost"/>

            </HBox>

            <!-- ===== SEARCH BAR ===== -->
            <HBox spacing="16" alignment="CENTER_LEFT">

                <HBox alignment="CENTER_LEFT"
                      spacing="8"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-padding: 8 16 8 16;
                             -fx-effect: dropshadow(gaussian, rgba(109,40,217,0.08), 12, 0.2, 0, 4);"
                      HBox.hgrow="ALWAYS">

                    <Label text="🔍"
                           style="-fx-font-size: 16;
                                  -fx-text-fill: #8B5CF6;"/>

                    <TextField fx:id="searchField"
                               promptText="Search investments by name..."
                               style="-fx-background-color: transparent;
                                      -fx-border-width: 0;"
                               HBox.hgrow="ALWAYS"
                               prefHeight="36"/>

                </HBox>

                <Button text="Search"
                        onAction="#onSearch"
                        styleClass="btn-primary"/>

                <Button text="Clear"
                        onAction="#onClearSearch"
                        styleClass="btn-ghost"/>

                <ComboBox fx:id="riskFilter"
                          prefWidth="150"
                          prefHeight="36"
                          promptText="Filter Risk"
                          onAction="#onFilterRisk"
                          style="-fx-background-radius: 14;"/>

            </HBox>

            <!-- ===== CARDS AREA ===== -->
            <ScrollPane fitToWidth="true"
                        style="-fx-background-color: transparent;">

                <content>
                    <FlowPane fx:id="cardsPane"
                              hgap="20"
                              vgap="20"
                              prefWrapLength="1200"
                              style="-fx-background-color: transparent;">

                        <padding>
                            <Insets top="20" right="10"
                                    bottom="20" left="10"/>
                        </padding>

                    </FlowPane>
                </content>

            </ScrollPane>

        </VBox>
    </center>

</BorderPane>