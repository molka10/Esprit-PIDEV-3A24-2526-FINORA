<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.finora.controllers.InvestmentCardsController"
            stylesheets="@../styles/style.css"
            styleClass="screen">

    <!-- ================= HEADER ================= -->
    <top>
        <VBox spacing="8" styleClass="card">
            <padding>
                <Insets top="20" right="24" bottom="20" left="24"/>
            </padding>

            <Label text="Investment Portfolio"
                   styleClass="title"/>

            <Label text="Manage and monitor your investments efficiently"
                   styleClass="subtitle"/>
        </VBox>
    </top>

    <!-- ================= CONTENT ================= -->
    <center>
        <VBox spacing="16" styleClass="screen">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>

            <!-- ===== TOOLBAR ===== -->
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="toolbar">
                <Button text=" Add"
                        onAction="#onAdd"
                        styleClass="btn-primary"/>
                <Button text=" Refresh"
                        onAction="#onRefresh"
                        styleClass="btn-ghost"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text=" Management"
                        onAction="#goToManagement"
                        styleClass="btn-ghost"/>
            </HBox>

            <!-- ===== SEARCH + CARDS AREA ===== -->
            <ScrollPane fitToWidth="true" styleClass="card">
                <content>
                    <VBox spacing="12">
                        <!-- Search bar -->
                        <!-- ===== SEARCH BAR ===== -->
                        <!-- ===== SEARCH BAR PROFESSIONNELLE ===== -->
                        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10 0 10 0;">

                            <!-- Barre de recherche avec icône -->
                            <HBox alignment="CENTER_LEFT" spacing="6"
                                  style="-fx-background-color: #f5f5f5; -fx-background-radius: 12; -fx-padding: 6 12 6 12;"
                                  HBox.hgrow="ALWAYS">

                                <!-- Icône Loupe -->
                                <Label text="🔍" style="-fx-font-size: 16; -fx-text-fill: #888888;"/>

                                <!-- Champ texte -->
                                <TextField fx:id="searchField"
                                           promptText="Search investments by name..."
                                           style="-fx-background-color: transparent; -fx-border-width: 0; -fx-padding: 4 0 4 0;"
                                           HBox.hgrow="ALWAYS"/>
                            </HBox>

                            <!-- Boutons Search et Clear -->
                            <Button text="Search" onAction="#onSearch" styleClass="btn-primary" minWidth="80"/>
                            <Button text="Clear" onAction="#onClearSearch" styleClass="btn-secondary" minWidth="80"/>
                        </HBox>

                        <!-- Cards -->
                        <FlowPane fx:id="cardsPane"
                                  hgap="16"
                                  vgap="16"
                                  prefWrapLength="1100"
                                  styleClass="cards-zone">
                            <padding>
                                <Insets top="18" right="18" bottom="18" left="18"/>
                            </padding>
                        </FlowPane>
                    </VBox>
                </content>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>