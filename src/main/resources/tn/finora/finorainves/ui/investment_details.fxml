<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.finora.controllers.InvestmentDetailsController"
      spacing="15"
      style="-fx-background-color: #F4F4F9; -fx-padding: 20;">

    <!-- Back Button -->
    <HBox spacing="10">
        <Button fx:id="backBtn" text="← Back" onAction="#onBack"
                style="-fx-background-color: #8A2BE2; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 5 15; -fx-background-radius: 10;"/>
    </HBox>

    <!-- Image + Infos -->
    <HBox spacing="20" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 0);">
        <ImageView fx:id="imageView" fitWidth="200" fitHeight="120" preserveRatio="true"/>
        <VBox spacing="8">
            <Label fx:id="nameLabel" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #4B0082;"/>
            <Label fx:id="categoryLabel" style="-fx-font-size: 14; -fx-text-fill: #555555;"/>
            <Label fx:id="valueLabel" style="-fx-font-size: 14; -fx-text-fill: #333333;"/>
            <Label fx:id="riskLabel" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
            <Label fx:id="descriptionLabel" wrapText="true" style="-fx-font-size: 13; -fx-text-fill: #666666;"/>
            <Label fx:id="predictionLabel" wrapText="true" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #8A2BE2;"/>
        </VBox>
    </HBox>

    <!-- Graphique historique -->
    <LineChart fx:id="valueChart" title="Historical Values" prefHeight="250"
               style="-fx-background-color: white; -fx-border-radius: 10; -fx-background-radius: 10;">
        <xAxis>
            <CategoryAxis label="Month"/>
        </xAxis>
        <yAxis>
            <NumberAxis label="Value"/>
        </yAxis>
    </LineChart>

</VBox>