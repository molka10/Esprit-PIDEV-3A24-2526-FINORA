<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.finora.controllers.LessonListController">

    <top>
        <VBox spacing="0" styleClass="card">
            <Label text="Gestion Lessons" styleClass="title"/>
            <Label text="Gestion des leçons associées aux formations" styleClass="subtitle"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="14" styleClass="screen">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <!-- Toolbar -->
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="toolbar">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Formation:" styleClass="subtitle"/>
                    <ComboBox fx:id="cbFormation"
                              prefWidth="200"
                              promptText="Toutes les formations"
                              onAction="#onFilter"/>
                    <TextField fx:id="txtSearch"
                               prefWidth="220"
                               promptText="Rechercher..."
                               onKeyReleased="#onSearch"/>
                    <ComboBox fx:id="cbSort"
                              prefWidth="180"
                              onAction="#onSort"/>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="➕ Ajouter"    styleClass="btn-primary" onAction="#onAdd"/>
                    <Button text="✏ Modifier"   styleClass="btn-ghost"   onAction="#onEdit"/>
                    <Button text="🗑 Supprimer"  styleClass="btn-danger"  onAction="#onDelete"/>
                    <Button text="⬅ Formations" styleClass="btn-ghost"   onAction="#goFormations"/>
                </HBox>
            </HBox>

            <!-- ✅ FlowPane grid for square cards -->
            <ScrollPane fitToWidth="true" styleClass="scroll" VBox.vgrow="ALWAYS">
                <content>
                    <FlowPane fx:id="cardsBox"
                              hgap="18"
                              vgap="18"
                              styleClass="cards">
                        <padding>
                            <Insets top="8" right="8" bottom="8" left="8"/>
                        </padding>
                    </FlowPane>
                </content>
            </ScrollPane>

            <Label fx:id="lblInfo" text="" styleClass="subtitle"/>
        </VBox>
    </center>

</BorderPane>