<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.finora.controllers.LessonListController">

    <top>
        <VBox spacing="8" styleClass="card">
            <Label text="Gestion Lessons" styleClass="title"/>
            <Label text="Gestion des leçons associées aux formations" styleClass="subtitle"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="14" styleClass="screen">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <!-- Toolbar -->
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="toolbar">

                <!-- LEFT SIDE -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Formation:" styleClass="subtitle"/>

                    <ComboBox fx:id="cbFormation"
                              prefWidth="220"
                              minWidth="180"
                              promptText="Toutes les formations"
                              onAction="#onFilter"/>

                    <TextField fx:id="txtSearch"
                               prefWidth="220"
                               minWidth="180"
                               promptText="Rechercher..."
                               onKeyReleased="#onSearch"/>

                    <ComboBox fx:id="cbSort"
                              prefWidth="180"
                              minWidth="150"
                              onAction="#onSort"/>
                </HBox>

                <!-- PUSH BUTTONS TO RIGHT -->
                <Region HBox.hgrow="ALWAYS"/>

                <!-- RIGHT SIDE BUTTONS -->
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="➕ Ajouter"
                            minWidth="110"
                            styleClass="btn-primary"
                            onAction="#onAdd"/>

                    <Button text="✏ Modifier"
                            minWidth="110"
                            styleClass="btn-ghost"
                            onAction="#onEdit"/>

                    <Button text="🗑 Supprimer"
                            minWidth="110"
                            styleClass="btn-danger"
                            onAction="#onDelete"/>

                    <Button text="⬅ Formations"
                            minWidth="130"
                            styleClass="btn-ghost"
                            onAction="#goFormations"/>
                </HBox>

            </HBox>


            <!-- Cards -->
            <ScrollPane fitToWidth="true" styleClass="scroll">
                <content>
                    <VBox fx:id="cardsBox" spacing="14" styleClass="cards"/>
                </content>
            </ScrollPane>

            <Label fx:id="lblInfo" text="" styleClass="subtitle"/>
        </VBox>
    </center>

</BorderPane>
