<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.finora.controllers.QuizTakeController"
            styleClass="screen">

    <!-- ================= TOP ================= -->
    <top>
        <VBox spacing="12" styleClass="card">
            <padding>
                <Insets top="16" right="18" bottom="16" left="18"/>
            </padding>

            <HBox alignment="CENTER_LEFT">
                <Label text="Quiz" styleClass="title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnClose"
                        text="✖ Fermer"
                        styleClass="btn-ghost"
                        onAction="#onClose"/>
            </HBox>

            <Label fx:id="lblStatus"
                   text="..."
                   styleClass="subtitle"/>

            <Label fx:id="lblProgress"
                   text="Question 1/5"
                   style="-fx-font-weight: bold; -fx-text-fill: #7C3AED;"/>
        </VBox>
    </top>

    <!-- ================= CENTER ================= -->
    <center>
        <VBox spacing="20" alignment="CENTER">
            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>

            <!-- Question -->
            <Label fx:id="lblQuestion"
                   wrapText="true"
                   style="-fx-font-size: 16px; -fx-font-weight: 800; -fx-text-fill: #1E0A3C;"/>

            <!-- Options -->
            <VBox spacing="12" alignment="CENTER_LEFT">
                <RadioButton fx:id="rb1"/>
                <RadioButton fx:id="rb2"/>
                <RadioButton fx:id="rb3"/>
                <RadioButton fx:id="rb4"/>
            </VBox>

            <!-- Navigation -->
            <HBox spacing="20" alignment="CENTER">
                <Button fx:id="btnPrevious"
                        text="⬅ Previous"
                        onAction="#onPrevious"/>

                <Button fx:id="btnNext"
                        text="Next ➡"
                        styleClass="btn-primary"
                        onAction="#onNext"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>