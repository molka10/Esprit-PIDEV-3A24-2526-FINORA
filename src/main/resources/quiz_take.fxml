<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.finora.controllers.QuizTakeController"
            styleClass="screen">

    <!-- ================= HEADER ================= -->
    <top>
        <VBox spacing="10" styleClass="card">
            <padding>
                <Insets top="20" right="25" bottom="20" left="25"/>
            </padding>

            <HBox alignment="CENTER_LEFT">
                <Label text="📝 Quiz Evaluation" styleClass="title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnClose"
                        text="✖"
                        styleClass="btn-ghost"
                        onAction="#onClose"/>
            </HBox>

            <Label fx:id="lblStatus" styleClass="subtitle"/>

            <!-- Progress Bar -->
            <ProgressBar fx:id="progressBar"
                         prefWidth="600"
                         progress="0.0"/>

            <Label fx:id="lblProgress"
                   style="-fx-font-weight: bold; -fx-text-fill: #7C3AED;"/>
        </VBox>
    </top>

    <!-- ================= BODY ================= -->
    <center>
        <VBox spacing="30" alignment="TOP_CENTER">
            <padding>
                <Insets top="40" right="80" bottom="40" left="80"/>
            </padding>

            <!-- Question Card -->
            <VBox spacing="20" styleClass="quiz-card">
                <padding>
                    <Insets top="30" right="30" bottom="30" left="30"/>
                </padding>

                <Label fx:id="lblQuestion"
                       wrapText="true"
                       styleClass="quiz-question"/>

                <!-- Options -->
                <VBox spacing="15">
                    <RadioButton fx:id="rb1" styleClass="quiz-option"/>
                    <RadioButton fx:id="rb2" styleClass="quiz-option"/>
                    <RadioButton fx:id="rb3" styleClass="quiz-option"/>
                    <RadioButton fx:id="rb4" styleClass="quiz-option"/>
                </VBox>
            </VBox>

            <!-- Navigation -->
            <HBox spacing="40" alignment="CENTER">
                <Button fx:id="btnPrevious"
                        text="⬅ Previous"
                        styleClass="btn-ghost"
                        onAction="#onPrevious"/>

                <Button fx:id="btnNext"
                        text="Next ➡"
                        styleClass="btn-primary"
                        onAction="#onNext"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>