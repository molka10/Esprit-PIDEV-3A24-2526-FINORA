<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.finora.controllers.QuizTakeController"
            styleClass="screen">

    <top>
        <VBox spacing="10" styleClass="card">
            <padding>
                <Insets top="20" right="25" bottom="20" left="25"/>
            </padding>

            <HBox alignment="CENTER_LEFT">
                <Label text="📝 Quiz Evaluation" styleClass="title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnClose"
                        text="✖"
                        onAction="#onClose"/>
            </HBox>

            <Label fx:id="lblStatus"/>
            <Label fx:id="lblProgress"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color:transparent;">
            <VBox spacing="30" alignment="TOP_CENTER">
                <padding>
                    <Insets top="40" right="80" bottom="40" left="80"/>
                </padding>

                <Label fx:id="lblQuestion"
                       wrapText="true"
                       maxWidth="700"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                <VBox spacing="15">
                    <RadioButton fx:id="rb1"/>
                    <RadioButton fx:id="rb2"/>
                    <RadioButton fx:id="rb3"/>
                    <RadioButton fx:id="rb4"/>
                </VBox>

                <HBox spacing="40" alignment="CENTER">
                    <Button fx:id="btnPrevious"
                            text="⬅ Previous"
                            onAction="#onPrevious"/>

                    <Button fx:id="btnNext"
                            text="Next ➡"
                            onAction="#onNext"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>