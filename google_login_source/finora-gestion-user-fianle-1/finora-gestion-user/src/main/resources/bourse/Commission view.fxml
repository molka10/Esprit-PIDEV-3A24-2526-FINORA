<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.finora.controllers.bourse.Commissioncontroller"
            style="-fx-background-color: #f8f9fa;">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #ffffff; -fx-padding: 20 24; -fx-border-color: transparent transparent #e9ecef transparent; -fx-border-width: 0 0 1 0;">
            <Label text="💰 Gestion des Commissions"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="➕ Nouvelle Commission" onAction="#ouvrirDialogAjout"
                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
            <Button text="⬅ Retour" onAction="#retourDashboard"
                    style="-fx-background-color: #a855f7; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
            <Button text="🔍 Supervision" onAction="#ouvrirSupervision"
                    style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 24; -fx-background-color: #f8f9fa;">

            <!-- STATS CARDS -->
            <HBox spacing="16">

                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #e9ecef; -fx-border-radius: 12; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                    <Label text="Taux Actuel"
                           style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="lblTauxActuel" text="0.5%"
                           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                </VBox>

                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #e9ecef; -fx-border-radius: 12; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                    <Label text="Revenus Totaux"
                           style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="lblRevenusTotaux" text="0.00 TND"
                           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                </VBox>

                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #e9ecef; -fx-border-radius: 12; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                    <Label text="Revenus ce Mois"
                           style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="lblRevenusMois" text="0.00 TND"
                           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #a855f7;"/>
                </VBox>

            </HBox>

            <!-- LISTE DES COMMISSIONS -->
            <VBox spacing="0" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-border-color: #e9ecef; -fx-border-radius: 12; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">

                <HBox alignment="CENTER_LEFT" style="-fx-padding: 20; -fx-border-color: transparent transparent #e9ecef transparent; -fx-border-width: 0 0 1 0;">
                    <Label text="📋 Configurations de commission"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="↻ Actualiser" onAction="#handleActualiser"
                            style="-fx-background-color: #f3f4f6; -fx-text-fill: #4b5563; -fx-font-size: 12px; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
                </HBox>

                <!-- En-têtes colonnes -->
                <HBox style="-fx-background-color: #f8f9fa; -fx-padding: 12 20;">
                    <Label text="Nom"           style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 250;"/>
                    <Label text="Type"          style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 150;"/>
                    <Label text="Taux (%)"      style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 100;" alignment="CENTER_RIGHT"/>
                    <Label text="Statut"        style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 120;" alignment="CENTER"/>
                    <Label text="Dernière Modif" style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
                    <Label text="Actions"       style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 200;" alignment="CENTER"/>
                </HBox>

                <!-- Lignes dynamiques -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent;"
                            hbarPolicy="NEVER">
                    <VBox fx:id="listeContainer" spacing="0"/>
                </ScrollPane>

            </VBox>

        </VBox>
    </center>

</BorderPane>
