<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.finora.controllers.CenterMapController"
            style="-fx-background-color: linear-gradient(to bottom right, #ede9fe, #f5f3ff);">

    <!-- ================= TOP BAR ================= -->
    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="16" right="20" bottom="12" left="20"/>
            </padding>

            <!-- Glass Header -->
            <HBox spacing="15"
                  alignment="CENTER_LEFT"
                  style="
                        -fx-padding: 14 18;
                        -fx-background-color: rgba(255,255,255,0.70);
                        -fx-background-radius: 18;
                        -fx-border-radius: 18;
                        -fx-border-color: rgba(124,58,237,0.18);
                        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 20, 0.3, 0, 8);
                  ">

                <Label text="📍 FINORA Training Center Finder"
                       style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #1E0A3C;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Search Box -->
                <HBox spacing="8"
                      alignment="CENTER_LEFT"
                      style="
                            -fx-padding: 6 10;
                            -fx-background-color: rgba(255,255,255,0.90);
                            -fx-background-radius: 999;
                            -fx-border-radius: 999;
                            -fx-border-color: rgba(124,58,237,0.25);
                      ">

                    <TextField fx:id="txtCity"
                               promptText="Enter your city (ex: Tunis)"
                               style="
                                    -fx-background-color: transparent;
                                    -fx-border-color: transparent;
                                    -fx-font-size: 13px;
                                    -fx-padding: 8 12;
                                    -fx-prompt-text-fill: #8B7BB5;
                               "/>

                    <Button text="Find"
                            onAction="#onFind"
                            style="
                                -fx-background-color: #7C3AED;
                                -fx-text-fill: white;
                                -fx-font-weight: 800;
                                -fx-background-radius: 999;
                                -fx-padding: 8 16;
                                -fx-cursor: hand;
                            "/>
                </HBox>

                <!-- ✅ ADD CENTER BUTTON -->
                <Button text="➕ Add Center"
                        onAction="#onAddCenter"
                        style="
                            -fx-background-color: #F59E0B;
                            -fx-text-fill: white;
                            -fx-font-weight: 800;
                            -fx-background-radius: 999;
                            -fx-padding: 8 16;
                            -fx-cursor: hand;
                        "/>

                <!-- Use my location -->
                <Button text="📍 Use my location"
                        onAction="#onUseMyLocation"
                        style="
                            -fx-background-color: rgba(124,58,237,0.10);
                            -fx-text-fill: #1E0A3C;
                            -fx-font-weight: 800;
                            -fx-background-radius: 999;
                            -fx-padding: 8 14;
                            -fx-cursor: hand;
                        "/>

                <!-- Close Button -->
                <Button text="✖"
                        onAction="#onClose"
                        style="
                            -fx-background-color: rgba(0,0,0,0.06);
                            -fx-text-fill: #1E0A3C;
                            -fx-font-weight: 900;
                            -fx-background-radius: 12;
                            -fx-padding: 8 12;
                            -fx-cursor: hand;
                        "/>
            </HBox>

            <Label text="Type your city and FINORA will highlight the closest training office."
                   style="-fx-text-fill:#6B5A8A; -fx-font-size:12px;"/>
        </VBox>
    </top>

    <!-- ================= MAP ================= -->
    <center>
        <StackPane>
            <padding>
                <Insets top="8" right="20" bottom="20" left="20"/>
            </padding>

            <StackPane style="
                -fx-background-color: rgba(255,255,255,0.60);
                -fx-background-radius: 20;
                -fx-border-radius: 20;
                -fx-border-color: rgba(124,58,237,0.20);
                -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 25, 0.3, 0, 8);
            ">
                <WebView fx:id="webView"/>
            </StackPane>
        </StackPane>
    </center>

</BorderPane>