<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.finora.controllers.ForgotPasswordController"
      spacing="14"
      styleClass="root-bg"
      stylesheets="@theme.css">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <VBox styleClass="card" spacing="12">
        <padding>
            <Insets top="18" right="18" bottom="18" left="18"/>
        </padding>

        <children>
            <Label text="Mot de passe oublié" styleClass="h2"/>

            <Label text="Email"/>
            <TextField fx:id="emailField" promptText="ex: user@mail.com"/>

            <Button text="Envoyer le code SMS" onAction="#handleSendOtp" styleClass="btn-primary"/>

            <Separator/>

            <Label text="Code reçu (SMS)"/>
            <TextField fx:id="otpField" promptText="6 chiffres"/>

            <Label text="Nouveau mot de passe"/>
            <PasswordField fx:id="newPasswordField" promptText="min 8 caractères"/>

            <Label text="Confirmer"/>
            <PasswordField fx:id="confirmPasswordField"/>

            <HBox spacing="10">
                <Button text="Réinitialiser" onAction="#handleReset" styleClass="btn-secondary"/>
                <Button text="Retour" onAction="#handleBack" styleClass="btn-ghost"/>
            </HBox>

            <Label fx:id="statusLabel" text="" wrapText="true"/>
        </children>
    </VBox>
</VBox>